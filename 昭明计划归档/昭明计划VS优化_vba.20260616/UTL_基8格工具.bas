'========================================================================================
'操作：移至尾部
'========================================================================================
'========================================================================================
Sub PSOP格整理调程_移至at尾部()
    '====================================================================================
    '验明正身
    '====================================================================================
    If PSOP格整理质程_是否适用首列(ActiveSheet.Name) = False Then
        MsgBox "NP", Title:="工表整理"
        Exit Sub
    End If
    '====================================================================================
    'SOP
    '====================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Call PSOP格整理质程_移至尾部(ActiveSheet)
    'MsgBox "移至尾部：" & PSOP格整理质程_移至尾部(ActiveSheet)
    ActiveSheet.Cells(65536, 1).End(xlUp).Select
    '------------------------------------------------------------------------------------
    UTL宏工具_END
    '====================================================================================
End Sub
Private Function PSOP格整理质程_移至尾部(WS As Worksheet) As Integer
    '====================================================================================
    '变量声明
    '====================================================================================
    Dim 末行 As Integer
    末行 = PBASE格程工具_表参末行指定(WS, 1)
    '------------------------------------------------------------------------------------
    '遍历进行复制
    '------------------------------------------------------------------------------------
    Dim 总数 As Integer
    总数 = 0
    Dim 行号遍历 As Integer
    For 行号遍历 = 2 To 末行
        If Not Intersect(WS.Rows(行号遍历), Selection) Is Nothing Then
            总数 = 总数 + 1
            'WS.Rows(行号遍历).Copy WS.Cells(末行 + 总数, 1)
            WS.Cells(末行 + 总数, 1) = WS.Cells(行号遍历, 1)
            WS.Cells(末行 + 总数, 2) = WS.Cells(行号遍历, 2)
        End If
    Next
    '------------------------------------------------------------------------------------
    '遍历进行删除
    '------------------------------------------------------------------------------------
    For 行号遍历 = 末行 To 2 Step -1
        If Not Intersect(WS.Rows(行号遍历), Selection) Is Nothing Then
            WS.Rows(行号遍历).Delete
        End If
    Next
    '====================================================================================
    PSOP格整理质程_移至尾部 = 总数
End Function






