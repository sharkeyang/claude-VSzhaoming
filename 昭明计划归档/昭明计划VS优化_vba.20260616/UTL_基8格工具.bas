    '====================================================================================
End Sub
'========================================================================================
'========================================================================================
'操作：将本页中重复的进行标注
'========================================================================================
'========================================================================================
Sub PSOP格整理调程_删除重复()
    '====================================================================================
    '验明正身
    '====================================================================================
    If PSOP格整理质程_是否适用首列(ActiveSheet.Name) = False Then
        MsgBox "NP", Title:="工表整理"
        Exit Sub
    End If
    '====================================================================================
    'SOP
    '====================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    MsgBox "重复共计：" & PSOP格整理质程_检查重复(ActiveSheet, 是否删除:=True)
    '------------------------------------------------------------------------------------
    UTL宏工具_END
    '====================================================================================
End Sub
Private Function PSOP格整理质程_检查重复(WS As Worksheet, Optional 是否删除 As Boolean = False) As Integer
'========================================================================================
    Dim 末行 As Integer
    末行 = PBASE格程工具_表参末行指定(WS, 1)
    '====================================================================================
    '变量声明
    '====================================================================================
    Dim 集合全部 As New Dictionary
    Dim 集合重复 As New Dictionary
    Dim 集合重复首次 As New Dictionary
    Dim 集合重复删除 As New Dictionary
    Dim CIDL As String
    Dim CIDCL As Range
    '====================================================================================
    '选择重复出现过的对象
    '====================================================================================
    On Error Resume Next
    Dim K As Integer
    For K = 2 To 末行
        '--------------------------------------------------------------------------------
        Set CIDCL = WS.Cells(K, 位qt代码)
        '--------------------------------------------------------------------------------
        If UBCID是代码(CIDCL.Value) = True Then
            CIDL = CIDCL.Value
            
            If 集合全部.Exists(CIDL) Then
                集合重复.Add Item:=CIDL, Key:=CIDL
            Else
                集合全部.Add Item:=CIDL, Key:=CIDL
            End If
        End If
        '--------------------------------------------------------------------------------
    Next
    On Error GoTo 0
    '====================================================================================
    '分别标注重复出现过的对象
    '====================================================================================
    For K = 2 To 末行
        '--------------------------------------------------------------------------------
        Set CIDCL = WS.Cells(K, 位qt代码)
        CIDL = CIDCL.Value
        '--------------------------------------------------------------------------------
        If 集合重复.Exists(CIDL) Then
            If 集合重复首次.Exists(CIDL) Then
                CIDCL.Interior.Color = 常色十红
                集合重复删除.Add Item:=K, Key:=K
            Else
                CIDCL.Font.Color = 常色十红
                集合重复首次.Add Item:=CIDL, Key:=CIDL
            End If
        End If
        '--------------------------------------------------------------------------------
    Next
    '====================================================================================
    '删除重复出现过的对象
    '====================================================================================
    If 是否删除 = True Then
    For K = 末行 To 2 Step -1
        '--------------------------------------------------------------------------------
        If 集合重复删除.Exists(K) Then
            WS.Rows(K).Delete
        End If
        '--------------------------------------------------------------------------------
    Next
    End If
'========================================================================================
'返回
'========================================================================================
    PSOP格整理质程_检查重复 = 集合重复.Count
    '====================================================================================
    集合全部.RemoveAll
    Set 集合全部 = Nothing
    集合重复.RemoveAll
    Set 集合重复 = Nothing
    集合重复首次.RemoveAll
    Set 集合重复首次 = Nothing
    集合重复删除.RemoveAll
    Set 集合重复删除 = Nothing
'========================================================================================
End Function






'========================================================================================
'========================================================================================
'操作：删除选定区域中的空行
'========================================================================================
'========================================================================================
Sub PSOP格整理调程_删除空行()
    '====================================================================================
    '验明正身
    '====================================================================================
    If PSOP格整理质程_是否适用首列(ActiveSheet.Name) = False Then
        MsgBox "NP", Title:="工表整理"
        Exit Sub
    End If
    '====================================================================================
    'SOP
    '====================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Call PSOP格整理质程_删除空行(ActiveSheet)
    '------------------------------------------------------------------------------------
    UTL宏工具_END
    '====================================================================================
End Sub
Function PSOP格整理质程_删除空行(WS As Worksheet, Optional 是否全页 As Boolean = False) As Integer
    '====================================================================================
    '变量声明
    '====================================================================================
    Dim CIDL As String
    Dim 总数 As Integer
    '------------------------------------------------------------------------------------
    '遍历文件获取详细信息
    '------------------------------------------------------------------------------------
    总数 = 0
    Dim 行号遍历 As Integer
    If 是否全页 = False Then
        For 行号遍历 = PBASE格程工具_表参末行指定(WS, 1) To 2 Step -1
            If Not Intersect(WS.Rows(行号遍历), Selection) Is Nothing Then
                CIDL = WS.Cells(行号遍历, 位qt代码).Value
                If UBCID是代码(CIDL) = False Then                  '针对代码
                    WS.Rows(行号遍历).Delete
                    总数 = 总数 + 1
                End If
            End If
        Next
    Else
        Dim 归类始元 As Range
        Set 归类始元 = WS.Columns(1).Find(What:="备选")
        Dim 归类始行 As Integer
        If 归类始元 Is Nothing Then
            归类始行 = 2
        Else
            归类始行 = 归类始元.Row + 1
        End If
        Set 归类始元 = Nothing
        
        For 行号遍历 = PBASE格程工具_表参末行指定(WS, 1) To 归类始行 Step -1
            CIDL = WS.Cells(行号遍历, 位qt代码).Value
            If UBCID是代码(CIDL) = False Then                  '针对代码
                WS.Rows(行号遍历).Delete
                总数 = 总数 + 1
            End If
        Next
    End If
'========================================================================================
    PSOP格整理质程_删除空行 = 总数
End Function




