Function PSOP格整理质程_是否适用首列(工表名 As String) As Boolean
        If Left(工表名, 1) = 常簿缀选自 _
        Or Left(工表名, 1) = 常簿缀选日 _
        Or Left(工表名, 1) = 常簿缀市板 _
        Then
            PSOP格整理质程_是否适用首列 = True
        Else
            PSOP格整理质程_是否适用首列 = False
        End If
End Function
Function PSOP格整理质程_是否适用池类(工表名 As String) As Boolean
        If 工表名 = 常池名今 _
        Or 工表名 = 常池名金 _
        Or 工表名 = 常池名银 _
        Or 工表名 = 常池名铜 _
        Or 工表名 = 常池名黑 _
        Then
            PSOP格整理质程_是否适用池类 = True
        Else
            PSOP格整理质程_是否适用池类 = False
        End If
End Function
