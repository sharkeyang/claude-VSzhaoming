Private Function PSOP格整理正程_移至区域(区签 As String, Optional 区域备注 As String) As Integer
    '====================================================================================
    '验明正身
    '====================================================================================
    If PSOP格整理质程_是否适用首列(ActiveSheet.Name) = False Then
        MsgBox "NP", Title:="工表整理"
        Exit Function
    End If
    '====================================================================================
    'SOP
    '====================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Dim 总数 As Integer
    总数 = PSOP格整理质程_移至区域(ActiveSheet, 区签, 区域备注:=区域备注)
    '------------------------------------------------------------------------------------
    UTL宏工具_END
    '====================================================================================
    PSOP格整理正程_移至区域 = 总数
End Function
Private Function PSOP格整理质程_移至区域(WS As Worksheet, 区签 As String, Optional 区域备注 As String) As Integer
    '====================================================================================
    '变量声明
    '====================================================================================
    Dim 末行 As Integer
    末行 = PBASE格程工具_表参末行指定(WS, 1)
    '------------------------------------------------------------------------------------
    '确定目标位置的存在性
    '------------------------------------------------------------------------------------
    Dim 区域单元 As Range
    Set 区域单元 = WS.Columns(1).Find(What:=区签)
    If 区域单元 Is Nothing Then
        MsgBox 区签 & "   区域不存在"
        Exit Function
    End If
    '------------------------------------------------------------------------------------
    '遍历：将所选单元移动至尾部
    '------------------------------------------------------------------------------------
    Dim 总数 As Integer
    总数 = PSOP格整理质程_移至尾部(ActiveSheet)
    '------------------------------------------------------------------------------------
    '遍历：移动至区域
    '------------------------------------------------------------------------------------
    Dim 区域行偏 As Integer
    区域行偏 = WS.Columns(1).Find(What:=区签).Row + 1
    
    Dim 计数移动 As Integer
    For 计数移动 = 1 To 总数
        'WS.Rows(末行).Cut
        WS.Rows(区域行偏).Insert Shift:=xlDown
        WS.Cells(区域行偏, 位qt代码) = WS.Cells(末行 + 1, 1)
        WS.Cells(区域行偏, 位qt代称) = WS.Cells(末行 + 1, 2)
        WS.Cells(区域行偏, 位谕列终全部 + 1) = 区域备注
        WS.Rows(末行 + 1).Delete
    Next
    '====================================================================================
    PSOP格整理质程_移至区域 = 总数
End Function
