Sub PSOP格整理调程_移至本区域顶部()
    Dim WS As Worksheet
    Set WS = ActiveSheet
    Dim 本行 As Integer
    本行 = Selection.Row
    '------------------------------------------------------------------------------------
    '移动
    '------------------------------------------------------------------------------------
    Dim 上沿 As Integer
    Dim 行号遍历 As Integer
    For 行号遍历 = 本行 To 2 Step -1
        If UBCID是代码(WS.Cells(行号遍历, 位qt代码)) Then
            上沿 = 行号遍历
        Else
            Exit For
        End If
    Next 行号遍历
    '------------------------------------------------------------------------------------
    '移动
    '------------------------------------------------------------------------------------
    WS.Rows(上沿).Insert Shift:=xlDown
    WS.Cells(上沿, 1) = WS.Cells(本行 + 1, 1)
    WS.Cells(上沿, 2) = WS.Cells(本行 + 1, 2)
    WS.Rows(本行 + 1).Delete
    '------------------------------------------------------------------------------------
    Selection.ClearOutline
    Set WS = Nothing
End Sub








