Private Function 区域UNQT格程( _
      WS As Worksheet _
    , Optional 首列 As Integer = 1 _
    , Optional 基色底 As Long = 常色主绿 _
    , Optional 基色调 As Double = 0.8 _
    , Optional 标行 As Integer = 1 _
    ) As Integer
'========================================================================================
'列格式
'========================================================================================
    WS.Columns(首列).Columns(位列天组代码).NumberFormatLocal = 全设格式of代码
    WS.Columns(首列).Columns(位列天组今涨).NumberFormatLocal = 全设格式of一位
    WS.Columns(首列).Columns(位列天组振幅).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组量比).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组换手).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组今收).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组前收).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组今开).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组流市).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组总市).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组今额).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组市净).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组市盈).NumberFormatLocal = 全设格式of零位
    WS.Columns(首列).Columns(位列天组时间).NumberFormatLocal = 全设格式of零位
    '------------------------------------------------------------------------------------
    WS.Cells(标行, 首列).Resize(1, 位列天组维度).EntireColumn.ColumnWidth = 4
    
    WS.Columns(首列).Columns(位列天组代码).ColumnWidth = 9
    WS.Columns(首列).Columns(位列天组代称).ColumnWidth = 10
    WS.Columns(首列).Columns(位列天组代称).HorizontalAlignment = xlRight
    WS.Columns(首列).Columns(位列天组今涨).ColumnWidth = 6
    WS.Columns(首列).Columns(位列天组今收).ColumnWidth = 4
    WS.Columns(首列).Columns(位列天组振幅).ColumnWidth = 3.5
    WS.Columns(首列).Columns(位列天组量比).ColumnWidth = 3.5
    WS.Columns(首列).Columns(位列天组换手).ColumnWidth = 3.5
    WS.Columns(首列).Columns(位列天组今额).ColumnWidth = 4
    WS.Columns(首列).Columns(位列天组市盈).ColumnWidth = 4
    WS.Columns(首列).Columns(位列天组市净).ColumnWidth = 4
    '------------------------------------------------------------------------------------
    WS.Cells(标行, 首列).Resize(1, 位列天组维度).EntireColumn.Hidden = True
    
    WS.Columns(首列).Columns(位列天组代称).Hidden = False
    WS.Columns(首列).Columns(位列天组今涨).Hidden = False
    WS.Columns(首列).Columns(位列天组振幅).Hidden = False
    WS.Columns(首列).Columns(位列天组量比).Hidden = False
    WS.Columns(首列).Columns(位列天组换手).Hidden = False
    
    
'    WS.Columns(首列).Columns(位列天组代码).Hidden = True
'    WS.Columns(首列).Columns(位列天组前收).Hidden = True
'    WS.Columns(首列).Columns(位列天组今收).Hidden = True
