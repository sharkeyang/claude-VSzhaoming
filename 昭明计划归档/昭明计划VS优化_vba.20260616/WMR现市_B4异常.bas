        , 去典 As Dictionary _
        , 异常位列 As Integer _
        , Optional 异常排序 As XlSortOrder = xlDescending _
        ) As Integer
'========================================================================================
'判断是否存在异常
'========================================================================================
    '------------------------------------------------------------------------------------
    '陈列计数
    '------------------------------------------------------------------------------------
    Dim 去数 As Integer
    去数 = 去典.Count
    
    If 去数 = 0 Then
        查程异常 = 去行
        Exit Function
    End If
'========================================================================================
'输出：标题
'========================================================================================
    With 去表.Cells(去行, 去列)
        .Cells(1, 位qt代称).Value = 异常类型
        .Cells(1, 位qt代称).Font.ColorIndex = 6
        .Cells(1, 位qt代称).Font.Bold = True
        .Cells(1, 位qt今涨幅).NumberFormatLocal = 全设格式of零位
        If 去列 = 1 Then
            .Cells(1, 位qt行益).Value = 去数
        Else
            .Cells(1, 位qt今涨幅).Value = 去数
            .Cells(1, 位qt今涨幅).Font.ColorIndex = 6
        End If
    End With
    去表.Columns(去列 - 1 + 异常位列).Hidden = False
'========================================================================================
'输出：具体数据
'========================================================================================
    Dim 天组定位 As Integer
    Dim X As Integer
    Dim Y As Integer
    With 去表.Cells(去行, 去列).Offset(1, 0)
            '============================================================================
            '遍历
            '============================================================================
            For X = 1 To 去数
                '------------------------------------------------------------------------
                '数值输出
                '------------------------------------------------------------------------
                天组定位 = 去典.Items(X - 1)
                For Y = LBound(天组, 2) To UBound(天组, 2)
                    .Cells(X, Y) = 天组(天组定位, Y)
                Next Y
                '------------------------------------------------------------------------
                '格式化
                '------------------------------------------------------------------------
                .Cells(X, 1).Resize(1, 位列天组维度).Interior.ColorIndex = 15
        
                .Cells(X, 位列天组代码).Font.Color = 常色主绿
                .Cells(X, 位列天组代码).Interior.Color = 常色主绿
                .Cells(X, 位列天组代称).Interior.Color = 常色主绿
                .Cells(X, 异常位列).Interior.Color = 常色十青
                .Cells(X, 异常位列).Interior.ColorIndex = 33
                '------------------------------------------------------------------------
            Next X
            '============================================================================
            '排序
            '============================================================================
            .Resize(去数, 位列天组维度).Sort key1:=.Cells(1, 异常位列), order1:=异常排序, Header:=xlNo
            '============================================================================
    End With
'========================================================================================
'返回值
'========================================================================================
    查程异常 = 去行 + 去数 + 1
'========================================================================================
End Function



