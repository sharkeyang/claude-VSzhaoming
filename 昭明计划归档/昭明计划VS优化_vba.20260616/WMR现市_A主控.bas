'========================================================================================
'========================================================================================
'市场概览:本工作簿汇总
'========================================================================================
'========================================================================================
Function 现市总程汇总子程( _
          MB As Workbook _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 是否全局 As Boolean = False _
        , Optional 是否中股 As Boolean = False _
        , Optional 是否海外 As Boolean = False _
        ) As String
'----------------------------------------------------------------------------------------
    TT = Timer
    Dim MSG As String
'----------------------------------------------------------------------------------------
'外部市场
'----------------------------------------------------------------------------------------
    If 是否海外 Then
        MSG = MSG & 现市子程_市场美股(MB, 是否排序)
        MSG = MSG & 现市子程_市场港股(MB, 是否排序)
    End If
'----------------------------------------------------------------------------------------
'中股概览
'----------------------------------------------------------------------------------------
    If 是否中股 Then
        Dim 天组 As Variant
        Dim 天典 As New Dictionary
        MSG = MSG & 市调预程引擎初始(天组, 天典)
        If 天典.Count <= 0 Then
            'MSG = MSG & 现市子程_中股指基(MB)   '不依赖于【天组】
            'MSG = MSG & 现市子程_中股精分行业益盟(MB, 是否排序:=是否排序, 天组:=天组, 天典:=天典)
            'MSG = MSG & 现市子程_中股精分概念益盟(MB, 是否排序:=是否排序, 天组:=天组, 天典:=天典)
            
            MSG = MSG & 现市子程_中股异常(MB, 天组:=天组, 天典:=天典)
            Call 市调预程引擎销毁(天组, 天典)
        End If
    End If
'----------------------------------------------------------------------------------------
'全局
'----------------------------------------------------------------------------------------
    If 是否全局 Then
        MSG = MSG & 现市子程_全局监视(MB, 是否排序)
        MSG = MSG & 现市子程_全局全球(MB)
    End If
'----------------------------------------------------------------------------------------
    现市总程汇总子程 = MSG & ">>市场概览耗时：" & CInt(Timer - TT)
End Function






'20260612改：外簿分支 历码核 改用 历研统码基程_展日码总；添加 TT 全部耗时
Function 现市总程汇总正程( _
          Optional 是否外簿 As Boolean = False _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 是否全局 As Boolean = False _
        , Optional 是否中股 As Boolean = False _
        , Optional 是否海外 As Boolean = False _
        ) As String
'----------------------------------------------------------------------------------------
    UTL宏工具_BEGIN
    Dim TT As Single: TT = Timer
'========================================================================================
'准备
'========================================================================================
    Dim MB As Workbook
    If 是否外簿 = True Then
        Set MB = Workbooks.Add
    Else
        Set MB = ThisWorkbook
    End If
'========================================================================================
'输出：现市
'========================================================================================
    Dim MSG As String
    MSG = 现市总程汇总子程(MB:=MB, 是否排序:=是否排序, 是否全局:=是否全局, 是否中股:=是否中股, 是否海外:=是否海外)
    MSG = MSG & vbCrLf
    '------------------------------------------------------------------------------------
    If UTL判断工表存在("G", MB) Then MB.Sheets("G").Move Before:=MB.Sheets(1)
    If UTL判断工表存在("W", MB) Then MB.Sheets("W").Move after:=MB.Sheets(1)
    If UTL判断工表存在("G", MB) Then MB.Sheets("G").Activate
'========================================================================================
'输出：照明决策
'========================================================================================
If 是否外簿 = True Then
    '====================================================================================
    '输出：昭明决策
    '====================================================================================
    MSG = MSG & vbCrLf
    MSG = MSG & IQQQ展擎主前调正程(实结类型:="sSCC", 是否外簿:=True, 是否剔黑:=False, 是否筛决策:=True, 参of筛决策剔池:=False, 参of筛决策详表:=True, 是否筛市类:=True, 是否筛频谱:=True, 出章模式:="月护", 出节模式:="周层", WB:=MB)
    '====================================================================================
End If
'========================================================================================
'输出：历码核
'========================================================================================
If 是否外簿 = True Then
    '====================================================================================
    '输出：历码核
    '====================================================================================
    Dim 表名统码 As String
    表名统码 = "轮"
    MSG = MSG & vbCrLf
    MSG = MSG & 历研统码基程_展日码总(常期类为日, 表名统码, WB:=MB)
    MB.Sheets(表名统码).Activate
    '====================================================================================
End If
'========================================================================================
'保存：外部存档
'========================================================================================
    '------------------------------------------------------------------------------------
    '获取腾讯实时行情的最后日期
    '------------------------------------------------------------------------------------
    Dim sdate As Date
    Dim qdate As Date
    Dim qtime As Date
    sdate = STBASE取据引擎查时戳由腾实("sh000001")
    qdate = DateValue(sdate)
    qtime = TimeValue(sdate)
    '------------------------------------------------------------------------------------
    '文件名称
    '------------------------------------------------------------------------------------
    Dim 工簿简称 As String
    Dim 工簿路径 As String
    工簿简称 = "MMMM" & Format$(qdate, "YYYYMMDD")
    工簿路径 = ThisWorkbook.Path & "\" & 工簿简称 & ".xlsx"
    '------------------------------------------------------------------------------------
    '进行保存
    '------------------------------------------------------------------------------------
    If MB.Name <> ThisWorkbook.Name Then
        MSG = MSG & vbCrLf & PBASE格程工具_表操保存外簿(MB, 工簿简称) & vbCrLf
        'MB.Close
        MB.Activate
    End If
'========================================================================================
'结束
'========================================================================================
    Set MB = Nothing
    'ThisWorkbook.Save
    '------------------------------------------------------------------------------------
    UTL宏工具_END
    '------------------------------------------------------------------------------------
    MSG = MSG & ">>全部耗时：" & CInt(Timer - TT) & vbCrLf
    MSG = "市场概览：" & vbCrLf & MSG
    Debug.Print MSG
    MsgBox MSG, vbOKOnly, "市场概览"
    '------------------------------------------------------------------------------------
    现市总程汇总正程 = MSG
End Function
