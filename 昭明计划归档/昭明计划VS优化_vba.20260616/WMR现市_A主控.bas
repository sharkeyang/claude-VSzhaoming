Function 现市子程_中股精分行业益盟(MB As Workbook, Optional 是否排序 As XlSortOrder = xlDescending, Optional 天组 As Variant, Optional 天典 As Dictionary) As String
    TT = Timer
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Dim 表名 As String
    表名 = "行益"
    Dim MS As Worksheet
    Call PBASE格程工具_表操工表新增(MS, 表名, WB:=MB)
    MS.Cells.Font.Name = "宋体"
    MS.Cells.Font.Size = 9
    MS.Tab.ColorIndex = 49
    MS.Cells.Interior.ColorIndex = 35
    '------------------------------------------------------------------------------------
    Call 现市基程_族行业益盟(MS, 是否排序:=是否排序, 天组:=天组, 天典:=天典)
    Set MS = Nothing
    UTL宏工具_END
    现市子程_中股精分行业益盟 = "【A股行业益盟】耗时：" & CInt(Timer - TT) & vbCrLf
End Function
Function 现市子程_中股精分概念益盟(MB As Workbook, Optional 是否排序 As XlSortOrder = xlDescending, Optional 天组 As Variant, Optional 天典 As Dictionary) As String
    TT = Timer
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Dim 表名 As String
    表名 = "概念"
    Dim MS As Worksheet
    Call PBASE格程工具_表操工表新增(MS, 表名, WB:=MB)
    MS.Cells.Font.Name = "宋体"
    MS.Cells.Font.Size = 9
    MS.Tab.ColorIndex = 49
    MS.Cells.Interior.ColorIndex = 35
    '------------------------------------------------------------------------------------
    Call 现市基程_族概念益盟(MS, 是否排序:=是否排序, 天组:=天组, 天典:=天典)
    MS.Columns("D").ColumnWidth = 25
    Set MS = Nothing
    UTL宏工具_END
    现市子程_中股精分概念益盟 = "【A股概念益盟】耗时：" & CInt(Timer - TT) & vbCrLf
End Function
