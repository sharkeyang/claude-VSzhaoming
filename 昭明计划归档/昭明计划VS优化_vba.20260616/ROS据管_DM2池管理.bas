'========================================================================================
'========================================================================================
'这个sub的核心任务就是：寻找符合题材风口且顺应行业走势的龙头股
'========================================================================================
'========================================================================================
Function STBASE池管理_索引基程( _
      Optional ByVal 实结类型 As String = "cCCC" _
    , Optional ByVal 是否索引池金 As Boolean = False _
    , Optional ByVal 是否索引池银 As Boolean = False _
    , Optional ByVal 是否索引池铜 As Boolean = False _
    , Optional ByVal 是否索引池黑 As Boolean = False _
    , Optional ByVal 是否索引池今 As Boolean = False _
    ) As String
'========================================================================================
'验证文件存在
'========================================================================================
'========================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Dim TT As Long
    TT = Timer
    Dim TTT As Long
    Dim MSG As String
'========================================================================================
'准备：谕组
'========================================================================================
    Dim 计数全息 As Integer
    Dim 谕组 As Variant
    计数全息 = IQQQ跨码据擎_数程生成全息(谕组, 常花中股, 实结类型:=实结类型)
    If 计数全息 = 0 Then
        UTL宏工具_END
        Exit Function
'========================================================================================
'交叉校验五池关系：【池今】与其他池无排斥关系
'作用：去除本池重复
'作用：去除池间重复
'========================================================================================
    Dim 典集池金 As New Dictionary
    Dim 典集池银 As New Dictionary
    Dim 典集池铜 As New Dictionary
    Dim 典集池黑 As New Dictionary
    Dim 典集池今 As New Dictionary
    Dim 典码输出 As New Dictionary
    '------------------------------------------------------------------------------------
    Dim CIDL As String
    Dim X As Integer
    For X = LBound(谕组, 1) To UBound(谕组, 1)
        CIDL = 谕组(X, 1)
        If 谕组(X, 位qt在池) = 常池名金 Then
            If 典集池金.Exists(CIDL) = False Then 典集池金.Add Item:=X, Key:=CIDL
            If 典码输出.Exists(CIDL) = False And 是否索引池金 = True Then 典码输出.Add Item:=X, Key:=CIDL
        ElseIf 谕组(X, 位qt在池) = 常池名银 Then
            If 典集池银.Exists(CIDL) = False Then 典集池银.Add Item:=X, Key:=CIDL
            If 典码输出.Exists(CIDL) = False And 是否索引池银 = True Then 典码输出.Add Item:=X, Key:=CIDL
        ElseIf 谕组(X, 位qt在池) = 常池名铜 Then
            If 典集池铜.Exists(CIDL) = False Then 典集池铜.Add Item:=X, Key:=CIDL
            If 典码输出.Exists(CIDL) = False And 是否索引池铜 = True Then 典码输出.Add Item:=X, Key:=CIDL
        ElseIf 谕组(X, 位qt在池) = 常池名黑 Then
            If 典集池黑.Exists(CIDL) = False Then 典集池黑.Add Item:=X, Key:=CIDL
            If 典码输出.Exists(CIDL) = False And 是否索引池黑 = True Then 典码输出.Add Item:=X, Key:=CIDL
        End If
        If 谕组(X, 位qt今池) <> "" Then
            If 典集池今.Exists(CIDL) = False Then 典集池今.Add Item:=X, Key:=CIDL
            If 典码输出.Exists(CIDL) = False And 是否索引池今 = True Then 典码输出.Add Item:=X, Key:=CIDL
        End If
    Next
'========================================================================================
'整理信息：行业
'注意：每页自上向下搜索从而保证输出自左向右变差
'========================================================================================
    Dim 典集行业 As New Dictionary
    Dim 值行业 As String
    '------------------------------------------------------------------------------------
    '设置全局信息：行业大类
    '------------------------------------------------------------------------------------
    Dim 典集行业大类 As New Dictionary
    Call STBASE池管理_设置必选行业(典集行业大类)
    '------------------------------------------------------------------------------------
    '整理信息：行业
    '补充信息：港股、未分类
    '------------------------------------------------------------------------------------
    For I = 1 To 典码输出.Count
        CIDL = 典码输出.Keys(I - 1)
        X = 典码输出.Items(I - 1)
        值行业 = 谕组(X, 位qt行益)
        If UBCID是港股票(CIDL) = True Then
            值行业 = "港股"
        ElseIf Len(值行业) = 0 Then
            值行业 = "未分类"
        End If
        If 典集行业.Exists(CIDL) = False Then
            典集行业.Add Item:=值行业, Key:=CIDL
        End If
        If 典集行业大类.Exists(值行业) = False Then
            典集行业大类.Add Item:="未分类", Key:=值行业
        End If
    Next
    '----------------------------------------------------------
    Dim 典集行业索引 As New Dictionary
    For I = 1 To 典集行业大类.Count
        典集行业索引.Add Item:=I, Key:=典集行业大类.Keys(I - 1)
    Next
'========================================================================================
'进行列表
'========================================================================================
    '------------------------------------------------------------------------------------
    '建立页
    '------------------------------------------------------------------------------------
    Dim WSTO As Worksheet
    Call PBASE格程工具_表操工表新增(WSTO, 常簿缀选日 & "ZZZ", 基色底:=常色四蓝)
    With WSTO
        .Cells.Interior.Color = 常色主黑
        .Columns(1).Font.Color = 常色主白
        .Columns(2).Font.Color = 常色主白
    End With
    '------------------------------------------------------------------------------------
    '输出纵向索引
    '------------------------------------------------------------------------------------
    Dim 标类宽数 As Integer
    标类宽数 = 2
    Dim 目行输出 As Integer, 目列输出 As Integer
    For I = 1 To 典集行业大类.Count
        目行输出 = 1 + (I - 1) * 标类宽数
        With WSTO.Cells(目行输出, 1)
            .Cells(1, 1) = 典集行业大类.Items(I - 1)
            .Cells(1, 2) = 典集行业大类.Keys(I - 1)
        End With
    Next
    With WSTO
        .Cells.Font.Size = 11
        .Columns.ColumnWidth = 9
        With .Columns(1)
            .ColumnWidth = 8
            .Font.Bold = True
        End With
        With .Columns(2)
            .ColumnWidth = 12
            .Font.Bold = True
        End With
        .Cells(1, 1).Activate
    End With
    '------------------------------------------------------------------------------------
    '遍历输出
    '------------------------------------------------------------------------------------
    Dim 值周层三鳄 As String
    Dim 值注释 As String
    On Error Resume Next
    For I = 1 To 典码输出.Count
            '----------------------------------------------------------------------------
            CIDL = 典码输出.Keys(I - 1)
            定位谕组行号 = 典码输出.Items(I - 1)
            '----------------------------------------------------------------------------
            '定位输出位置
            值行业 = 典集行业(CIDL)
            目行输出 = 1 + (典集行业索引(值行业) - 1) * 标类宽数
            目列输出 = PBASE格程工具_表参末列指定(WSTO, 目行输出) + 1
            '进行输出
            With WSTO.Cells(目行输出, 目列输出)
                '------------------------------------------------------
                .Cells(2, 1) = CIDL
                .Cells(1, 1) = 谕组(定位谕组行号, 位qt代称)
                '设置背景色
                值周层三鳄 = 谕组(定位谕组行号, 位谕of周层三鳄)
                值势局色度 = STBASE结算工具_衍生色度按鳄鱼(值周层三鳄)
                .Cells(1, 1).Interior.Color = 值势局色度
                '------------------------------------------------------
                '设置字体
                If 典集池金.Exists(CIDL) = True Then
                    值池名 = "金"
                    .Font.Size = 11
                    设定scheme = 10        '蓝色
                ElseIf 典集池银.Exists(CIDL) = True Then
                    值池名 = "银"
                    .Font.Size = 10
                    设定scheme = 50        '嫩绿色
                ElseIf 典集池铜.Exists(CIDL) = True Then
                    值池名 = "非"
                    .Font.Size = 9
                    设定scheme = 57        '深绿色
                ElseIf 典集池今.Exists(CIDL) = True Then
                    值池名 = "今"
                    .Font.Size = 10
                    设定scheme = 34        '黄色
                ElseIf 典集池黑.Exists(CIDL) = True Then
                    值池名 = "黑"
                    .Font.Size = 8
                    设定scheme = 34        '黄色
                End If
                '------------------------------------------------------
                '设置注释
                '值注释 = 谕组(定位谕组行号, 位谕of周道乾坤) _
                        & vbCrLf & "池  " & 值池名
                值注释 = vbCrLf & "池  " & 值池名
                With .Cells(1, 1)
                        .Comment.Delete
                        .AddComment
                        .Comment.Visible = False
                        .Comment.Shape.Width = 320
                        .Comment.Shape.Height = 120
                        .Comment.Shape.TextFrame.Characters.Font.Size = 10
                        .Comment.Shape.TextFrame.Characters.Font.Name = "宋体"
                        .Comment.Shape.Fill.Solid
                        .Comment.Text Text:=值注释
                        .Comment.Shape.Fill.ForeColor.SchemeColor = 设定scheme
                End With
                '------------------------------------------------------
            End With
            '----------------------------------------------------------------------------
    Next
    On Error GoTo 0
    Set 典集行业 = Nothing
    Set 典集池名 = Nothing
    Set 典集行号 = Nothing
'========================================================================================
'格式化
'========================================================================================
    '------------------------------------------------------------------------------------
    '隐藏空行
    '------------------------------------------------------------------------------------
    'WSTO.Rows.Hidden = True
    For I = 1 To 典集行业大类.Count
        目行输出 = 1 + (I - 1) * 标类宽数
        With WSTO.Rows(目行输出)
            .Hidden = IIf(Len(.Cells(1, 3)) = 0, True, False)
            .Rows(2).Hidden = True
        End With
    Next
    '------------------------------------------------------------------------------------
    '总结
    '------------------------------------------------------------------------------------
    目行输出 = 1 + (典集行业大类.Count) * 标类宽数
    With WSTO.Cells(目行输出, 1)
        当行 = 1
        .Cells(当行, 1) = "池今" & 常池名今
        .Cells(当行, 2) = 典集池今.Count
        当行 = 当行 + 1
        .Cells(当行, 1) = "池黑" & 常池名黑
        .Cells(当行, 2) = 典集池黑.Count
        当行 = 当行 + 1
        .Cells(当行, 1) = "池白汇总"
        .Cells(当行, 2) = 典集池金.Count + 典集池银.Count + 典集池铜.Count
        当行 = 当行 + 1
        .Cells(当行, 1) = "池金" & 常池名金
        .Cells(当行, 2) = 典集池金.Count
        当行 = 当行 + 1
        .Cells(当行, 1) = "池银" & 常池名银
        .Cells(当行, 2) = 典集池银.Count
        当行 = 当行 + 1
        .Cells(当行, 1) = "池铜" & 常池名铜
        .Cells(当行, 2) = 典集池铜.Count
    End With
    '------------------------------------------------------------------------------------
    '首列合并
    '------------------------------------------------------------------------------------
    Dim 值前类别 As String
    Dim 行始合并 As Integer
    Dim 行终合并 As Integer
    Dim 列待合并 As Integer
    '---------------------------------------------------------------
    '合并：第一列
    列待合并 = 1
    值前类别 = WSTO.Cells(1, 列待合并)
    行始合并 = 1
    For I = 2 To 目行输出
        If WSTO.Cells(I, 列待合并) <> "" Then
            If WSTO.Cells(I, 列待合并) <> 值前类别 Then
                行终合并 = I - 1
                With WSTO.Cells(行始合并, 列待合并).Resize(行终合并 - 行始合并 + 1, 1)
                    .ClearContents
                    .Merge
                    .Value = 值前类别
                    .VerticalAlignment = xlTop
                    .Interior.Color = 常色四靛
                    .Font.Color = 常色六灰
                End With
                With WSTO.Rows(I)
                        .Borders(xlEdgeTop).Color = 常色六灰
                        .Borders(xlEdgeTop).Weight = xlThin
                End With
                值前类别 = WSTO.Cells(I, 列待合并)
                行始合并 = I
            Else
            End If
        End If
    Next
    '---------------------------------------------------------------
    '合并：第二列
    列待合并 = 2
    值前类别 = WSTO.Cells(1, 列待合并)
    行始合并 = 1
    For I = 2 To 目行输出
        If WSTO.Cells(I, 列待合并) <> "" Then
            If WSTO.Cells(I, 列待合并) <> 值前类别 Then
                行终合并 = I - 1
                With WSTO.Cells(行始合并, 列待合并).Resize(行终合并 - 行始合并 + 1, 1)
                    .ClearContents
                    .Merge
                    .Value = 值前类别
                    .VerticalAlignment = xlTop
                    .Interior.Color = 常色四靛
                    .Font.Color = 常色四灰
                End With
                值前类别 = WSTO.Cells(I, 列待合并)
                行始合并 = I
            Else
            End If
        End If
    Next
'========================================================================================
'展示
'========================================================================================
    Dim WB As Workbook
    Set WB = ThisWorkbook
    Dim 表名 As String
    '------------------------------------------------------------------------------------
    '在池
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & 常池名黑
    MSG = MSG & vbCrLf
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:="月护", 出节模式:="周层", 典码输出:=典集池黑, 是否建表:=True, 章色:=常色八青, 章签:="池黑")
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & 常池名铜
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:="月护", 出节模式:="周层", 典码输出:=典集池铜, 是否建表:=True, 章色:=常色八青, 章签:="池铜")
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & 常池名银
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:="月护", 出节模式:="周层", 典码输出:=典集池银, 是否建表:=True, 章色:=常色八青, 章签:="池银")
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & 常池名金
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:="月护", 出节模式:="周层", 典码输出:=典集池金, 是否建表:=True, 章色:=常色八青, 章签:="池金")
    '------------------------------------------------------------------------------------
    '特殊处理：区分池外/在池
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & 常池名今
'    MSG = MSG & vbCrLf & IQQQ展擎筛程至B1书按池(WB, 表名, 谕组, 典集池今, 是否建表:=True, 章色:=常色二青, 章签:="今池")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:="月护", 出节模式:="周层", 典码输出:=典集池今, 是否建表:=True, 章色:=常色二青, 章签:="池今")
'========================================================================================
'返回
'========================================================================================
    UTL宏工具_END
    '------------------------------------------------------------------------------------
    MSG = MSG & "池索引全部耗时：" & CInt(Timer - TT)
    STBASE池管理_索引基程 = MSG
    Debug.Print MSG
'========================================================================================
End Function



Function STBASE池管理_设置必选行业(典集行业分类 As Dictionary)
    典集行业分类.RemoveAll
'========================================================================================
'设置基本行业分类
'每周进行调整：名单、顺序
'========================================================================================
    With 典集行业分类
        '---------------------------------------
        .Add Item:="必须", Key:="港股"
        .Add Item:="必须", Key:="未分类"
'----------------------------------------------------------------------------------------
'上升趋势
'----------------------------------------------------------------------------------------
        '---------------------------------------
        '类别：TMT
        .Add Item:="TMT行业", Key:="通信设备"
        .Add Item:="TMT行业", Key:="通信服务"
        .Add Item:="TMT行业", Key:="IT设备"
        .Add Item:="TMT行业", Key:="电子设备"
        .Add Item:="TMT行业", Key:="软件服务"
        .Add Item:="TMT行业", Key:="电子元器件"
        .Add Item:="TMT行业", Key:="通用设备"
        .Add Item:="TMT行业", Key:="专用设备"
        '---------------------------------------
        '类别：军工
        .Add Item:="军工制造", Key:="航天国防"
        .Add Item:="军工制造", Key:="船舶制造"
        .Add Item:="军工制造", Key:="仪器仪表"
        .Add Item:="军工制造", Key:="机床设备"
        '---------------------------------------
        '类别：汽车相关
        .Add Item:="汽车制造", Key:="汽车制造"
        .Add Item:="汽车制造", Key:="汽车服务"
        .Add Item:="汽车制造", Key:="电机"
        .Add Item:="汽车制造", Key:="汽车零部件"
        '---------------------------------------
        '类别：碳中和
        .Add Item:="电力", Key:="电力"
        .Add Item:="电力", Key:="电气智能化设备"
        .Add Item:="电力", Key:="高低压设备"
        .Add Item:="电力", Key:="电源设备"
        '---------------------------------------
        '类别：原材料
        .Add Item:="原材料", Key:="化学制品"
        .Add Item:="原材料", Key:="化学原料"
        .Add Item:="原材料", Key:="金属制品"
        .Add Item:="原材料", Key:="新材料"
        .Add Item:="原材料", Key:="玻璃制造"
        .Add Item:="原材料", Key:="塑料"
        .Add Item:="原材料", Key:="造纸"
        '---------------------------------------
        '类别：人口刺激
        .Add Item:="文化娱乐", Key:="互联网传媒"
        .Add Item:="文化娱乐", Key:="文化传媒"
        .Add Item:="文化娱乐", Key:="营销传播"
        .Add Item:="文化娱乐", Key:="包装印刷"
        '---------------------------------------
        '类别：交运类
        .Add Item:="交运", Key:="航空运输"
        .Add Item:="交运", Key:="高速公路"
        .Add Item:="交运", Key:="港口"
        .Add Item:="交运", Key:="水上运输"
        .Add Item:="交运", Key:="公共交通"
        .Add Item:="交运", Key:="铁路运输"
        .Add Item:="交运", Key:="仓储物流"
        .Add Item:="交运", Key:="其他交运设备"
        '---------------------------------------
        .Add Item:="关税", Key:="纺织"
        .Add Item:="关税", Key:="服装"
        .Add Item:="关税", Key:="轻工产品"
        .Add Item:="关税", Key:="化纤"
        .Add Item:="关税", Key:="贸易"
'----------------------------------------------------------------------------------------
'震荡
'----------------------------------------------------------------------------------------
        '---------------------------------------
