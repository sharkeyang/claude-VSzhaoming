'========================================================================================
'========================================================================================
'TS：导入文件 由指定文件位置
'可接受文件类型包括：益盟到处文件/本程序导出文件
'========================================================================================
'========================================================================================
Public Function STBASE池管理_表导入基程由指定文件(表名输出 As String, FILEOPEN As String) As Integer
'========================================================================================
'验证文件是否存在
'========================================================================================
    If UTL判断文件存在(FILEOPEN) = False Then Exit Function
'========================================================================================
'导入数组
'========================================================================================
    'Application.DisplayAlerts = False
    '-------------------------------
    Dim 所在区域 As Range
    Dim 位列TS代码 As Integer
    Dim 位元TS代码 As Range
    '-------------------------------
    Dim WBTS As Workbook
    Set WBTS = GetObject(FILEOPEN)
    Dim ARRTS  As Variant
    With WBTS.ActiveSheet
            Set 所在区域 = .Cells(1, 1).CurrentRegion
            ARRTS = 所在区域
            
            Set 位元TS代码 = 所在区域.Rows(1).Find(What:="代码")
            If 位元TS代码 Is Nothing Then
                Set 位元TS代码 = 所在区域.Rows(1).Find(What:="CID")
            End If
            If 位元TS代码 Is Nothing Then
                MsgBox "错误：代码列未找到"
                Exit Function
            Else
                位列TS代码 = 位元TS代码.Column
            End If
            Set 位元TS代码 = Nothing
            Set 所在区域 = Nothing
    End With
    WBTS.Close False
    Set WBTS = Nothing
    '-------------------------------
    'Application.DisplayAlerts = True
'========================================================================================
'常花中股：导入股票列表
'========================================================================================
    Dim 工表持仓 As Worksheet
    Call PBASE格程工具_表操工表新增(工表持仓, 表名输出, WB:=ThisWorkbook, 基色底:=常色主靛)
'========================================================================================
'常花中股：导入股票列表
'========================================================================================
    Dim sdate As String
    Dim CIDV As Variant
    '====================================================================================
    '导入
    '====================================================================================
    Dim 计数导入 As Integer
    Dim 主列行号 As Integer
    Dim 遍历序号 As Integer
    计数导入 = 0
    主列行号 = 1
    For 遍历序号 = LBound(ARRTS, 1) + 1 To UBound(ARRTS, 1)
        '--------------------------------------------------------------------------------
        '处理代码
        '--------------------------------------------------------------------------------
        CIDV = ARRTS(遍历序号, 位列TS代码)
        计数导入 = 计数导入 + 1
        主列行号 = 主列行号 + 1
        工表持仓.Cells(主列行号, 1) = UBCID规制代码(CIDV)
        '--------------------------------------------------------------------------------
        Debug.Print "益盟股票池导入>>>"; 遍历序号
        '--------------------------------------------------------------------------------
    Next
    Erase ARRTS
'========================================================================================
'更新
'========================================================================================
    UTL宏工具_BEGIN
    Call IQQQ展擎瓜页引擎基程(工表持仓, "更新排否", 实结类型:="sSCC", 基色底:=常色指金)
    Set 工表持仓 = Nothing
    UTL宏工具_END
'========================================================================================
    STBASE池管理_表导入基程由指定文件 = 计数导入
End Function
