Function STBASE池管理甄别调程_查看股性分布正程(典码称 As Dictionary, Optional ByVal 章色 As Long = 常色八黄)
    '------------------------------------------------------------------------------------
    '制作谕组
    '------------------------------------------------------------------------------------
    Dim 谕组 As Variant
    计数全息 = IQQQ跨码据擎_数程生成全息(谕组, 常花中股, 采样典码:=典码称, 实结类型:="cCCC")
    '------------------------------------------------------------------------------------
    '制作典码位
    '------------------------------------------------------------------------------------
    Dim 典码位 As New Dictionary
    Dim 码数 As Integer
    码数 = UTL数据转换_集典码2典码位(典码位, 谕组, 典码称)
    '------------------------------------------------------------------------------------
