Function UGSOP拣选引擎花册归集子程( _
          ByVal 设置值 As String _
        , Optional ByVal 设置列 As Integer = 位列花天在池 _
        ) As Integer
'========================================================================================
    UTL宏工具_BEGIN
'========================================================================================
'归集
'========================================================================================
    Dim WSIN As Worksheet
    Set WSIN = ActiveSheet
    '因为引用了ActiveSheet，所以必须放到下面建页的前面
    Dim 当前表名 As String
    当前表名 = WSIN.Name
    '------------------------------------------------------------------------------------
    Dim 集合归集代码 As New Dictionary
    Dim 计数归集 As Integer
    计数归集 = UGSOP拣选质程_归集代码从通用(集合归集代码, WSIN)
    Set WSIN = Nothing
'========================================================================================
'花册设置
'========================================================================================
    '====================================================================================
    '验证文件存在
    '====================================================================================
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then
        Debug.Print 常花中股 & "不存在"
        UTL宏工具_END
        Exit Function
    End If
    '====================================================================================
    '输入
    '====================================================================================
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽主道)
    '====================================================================================
    '设置：信息
    '====================================================================================
    For X = LBound(组花册, 1) To UBound(组花册, 1)
                        '----------------------------------------------------------------
                        CIDL = 组花册(X, 位列花天CIDL)
                        If UBCID是代码(CIDL) = True Then
                            If 集合归集代码.Exists(CIDL) = True Then
                                If 设置值 = 常池名金 Then
                                    组花册(X, 设置列) = 设置值
                                Else
                                    组花册(X, 设置列) = 设置值
                                End If
                            End If
                        End If
                        '----------------------------------------------------------------
    Next
    '====================================================================================
    '输出：花册
    '====================================================================================
    Call UTL数据转换_集ARR2WS(组花册, WS花册, 始行:=2, 始列:=1)
    Erase 组花册
    Set WS花册 = Nothing
'========================================================================================
'返回
'========================================================================================
    UTL宏工具_END
    UGSOP拣选引擎花册归集子程 = MSG
End Function






