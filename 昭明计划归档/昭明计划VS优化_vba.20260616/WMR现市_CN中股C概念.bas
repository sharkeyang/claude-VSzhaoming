Function 现市基程_族概念益盟( _
          MS As Worksheet _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 始行 As Integer = 3 _
        , Optional 始列 As Integer = 3 _
        , Optional 天组 As Variant _
        , Optional 天典 As Dictionary _
        ) As Boolean
    '=============================================================================================================================
    '前置检查
    '=============================================================================================================================
    If 天典 Is Nothing Or 天典.Count = 0 Then
        现市基程_族概念益盟 = False
        Exit Function
    End If
    '=============================================================================================================================
    '页面格式设置
    '=============================================================================================================================
    MS.Cells.Font.Size = 10
    MS.Cells.Font.Color = 常色三灰
    MS.Columns.ColumnWidth = 2
    '-----------------------------------------------------------------------------------------------------------------------------
    '行格式
    MS.Cells(始行 + 1, 始行 + 1) = "芥蓝"
    MS.Rows(始行).Font.Bold = True
    MS.Rows(始行).HorizontalAlignment = xlLeft
    With MS.Rows(始行 + 1)
        .RowHeight = 40
        .VerticalAlignment = xlTop
        .WrapText = True
        .Orientation = 0
    End With
    MS.Rows(始行 + 1).Font.Bold = True
    '-----------------------------------------------------------------------------------------------------------------------------
    '列格式
    MS.Columns(始行 + 1).HorizontalAlignment = xlRight
    MS.Columns(始行 + 1).Font.Bold = True
    MS.Columns(始行 + 1).ColumnWidth = 12
    MS.Columns(始行 + 2).ColumnWidth = 6
    MS.Columns(始行 + 3).ColumnWidth = 5
    '=============================================================================================================================
    '分程调用列表：族概念益盟
    '=============================================================================================================================
    Dim 当列 As Integer
    当列 = 始行 + 5
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_最新概念类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_电子芯片类(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_人工智能族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_电子消费类(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_新能源族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_碳中和族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_高端制造类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_新材料类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_医药生物类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_农业类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族概念益盟_偏门族类(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    '当列 = 现市分程_族概念益盟_略_公司概念族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    '当列 = 现市分程_族概念益盟_略_过于宽泛类(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    '当列 = 现市分程_族概念益盟_略_指数类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    '当列 = 现市分程_族概念益盟_略_股东类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    '当列 = 现市分程_族概念益盟_略_区域族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    '当列 = 现市分程_族概念益盟_略_过时族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '=============================================================================================================================
    '页面格式设置
    '=============================================================================================================================
    If 是否排序 = xlAscending Or 是否排序 = xlDescending Then
        With MS.Cells(始行 + 1, 始行 + 1)
            .Resize(.Offset(65536, 0).End(xlUp).Row, 3).Sort _
            key1:=.Offset(0, 1), order1:=是否排序, Header:=xlYes
        End With
    End If
    '-----------------------------------------------------------------------------------------------------------------------------
    MS.Activate
    Call PBASE格程工具_表冻结锁定(MS, 始行 + 1, 始行 + 3)
    '=============================================================================================================================
End Function
