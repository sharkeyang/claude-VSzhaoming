Sub 历研统时调程涨停()
'========================================================================================
'制作字典
'========================================================================================
    '------------------------------------------------------------------------------------
    '读取花册
    '------------------------------------------------------------------------------------
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then Exit Sub
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽主道)
    '------------------------------------------------------------------------------------
    '制作字典
    '------------------------------------------------------------------------------------
    Dim 典码花册 As New Dictionary
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
        CIDL = 组花册(X, 位列花天CIDL)
        代称 = 组花册(X, 位列花天代称)
        If UBCID是中股票(CIDL) = True Then
            典码花册.Add Key:=CIDL, Item:=代称
        End If
'        If 典码花册.Count > 500 Then Exit For
        Debug.Print X, CIDL
    Next
    Stop
'========================================================================================
'输出
'========================================================================================
    Dim 表名输出 As String
    表名输出 = "..ZT"
    Dim 是否输出分表 As Boolean
    Dim 是否输出涨停 As Boolean
    是否输出分表 = False
    是否输出涨停 = True
    Call 历研统时引擎1主程(表名输出, 典码花册, 基色底:=常色主绿, 是否输出分表:=是否输出分表, 是否输出涨停:=是否输出涨停, 是否更新源TR:=True)
'========================================================================================
End Sub


Sub 历研统时调程涨停由中间表()
