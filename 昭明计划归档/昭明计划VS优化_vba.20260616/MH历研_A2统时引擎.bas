'========================================================================================
'========================================================================================
Function 历研统时引擎1主程( _
          表名输出 As String _
        , 典码称 As Dictionary _
        , Optional ByVal 指定期类 As String = 常期类为日 _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限历短 _
        , Optional ByVal 是否更新源TR As Boolean = False _
        , Optional ByVal 始行 As Integer = 1 _
        , Optional ByVal 始列 As Integer = 1 _
        , Optional ByVal 是否输出分表 As Boolean = False _
        , Optional ByVal 是否输出涨停 As Boolean = False _
        , Optional 基色底 As Long = 常色四青 _
        )
    '====================================================================================
    '生成数据
    '====================================================================================
    Dim 组历统时 As Variant
    Call 历研统时引擎2数程(组历统时, 典码称, 指定期类, 指定结期上限:=指定结期上限, 指定结期下限:=指定结期下限, 是否更新源TR:=是否更新源TR)
    '====================================================================================
    '测试：输出全部
    '====================================================================================
    Dim WSTO As Worksheet
    Call PBASE格程工具_表操工表新增(WSTO, 表名输出, 基色底:=基色底)
    WSTO.Cells.Font.Size = 9
    Call PBASE格程工具_表冻结锁定(WSTO, 1, 2)
    Call 历研统时引擎5格程按列(WSTO, 始列:=1) '注20230730：一定要将格式化放在输出前面，否则会导致【位统时列结期】格式不正确。
    Call UTL数据转换_集ARR2WS(组历统时, WSTO, 2, 1)
    '====================================================================================
    '筛选
    '====================================================================================
    If 是否输出分表 = True Then
        Call 历研统时引擎3统程分布(表名输出, 组历统时)
    End If
    If 是否输出涨停 = True Then
        Call 历研统时引擎3统程涨停(表名输出, 组历统时)
    End If
    '====================================================================================
End Function
Function 历研统时引擎2数程( _
          组历统时 As Variant _
        , 典码称 As Dictionary _
        , Optional 指定期类 As String = 常期类为日 _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限历短 _
        , Optional ByVal 是否更新源TR As Boolean = False _
        )
    '====================================================================================
    If 典码称 Is Nothing Then Exit Function
    If 典码称.Count = 0 Then Exit Function
    '====================================================================================
    '准备数据
    '====================================================================================
    Dim 矩历码期值 As Variant
    Call 历研数据引擎_基础数据准备(矩历码期值, 典码称, 指定期类, 指定结期上限:=指定结期上限, 指定结期下限:=指定结期下限, 是否更新源TR:=是否更新源TR)
    '====================================================================================
    Dim CIDL As String
    Dim 值幅涨 As Double, 值幅高 As Double, 值幅低 As Double
    Dim 值幅下限 As Double, 值幅上限 As Double
    '------------------------------------------------------------------------------------
    ReDim 组历统时(1 To UBound(矩历码期值, 1), 位统时列总始 To 位统时列总终) As Variant
    '====================================================================================
    '批量查询腾实（逐股HTTP → 一次批量，复用 UBHTTP腾实_查回典批量）
    '====================================================================================
    Dim 代码串 As String
    Dim vKeyQ As Variant
    For Each vKeyQ In 典码称.Keys
        代码串 = 代码串 & vKeyQ & ","
    Next
    Dim 典腾实 As Dictionary
    If Len(代码串) > 1 Then
        Set 典腾实 = UBHTTP腾实_查回典批量(Left(代码串, Len(代码串) - 1))
    Else
        Set 典腾实 = New Dictionary
    End If
    '====================================================================================
    '统计数据
    '====================================================================================
    Dim X As Integer, Y As Integer
    For X = 1 To UBound(矩历码期值, 1) '按码
    CIDL = 矩历码期值(X, 位矩历二维下限, 位矩历三维价收)    '从-1获取CIDL
    值代称 = 矩历码期值(X, 位矩历二维下限, 位矩历三维幅涨)     '从1获取代称
    If UBCID是代码(CIDL) = True Then
            '============================================================================
            '基本信息
            '============================================================================
            组历统时(X, 位统时列CIDL) = CIDL
            组历统时(X, 位统时列代称) = 矩历码期值(X, 位矩历二维下限, 位矩历三维幅涨)
            组历统时(X, 位统时列结期) = 矩历码期值(位矩历一维下限, 1, 位矩历三维幅涨)
            组历统时(X, 位统时列今幅涨) = 矩历码期值(X, 1, 位矩历三维幅涨)
            组历统时(X, 位统时列今幅高) = 矩历码期值(X, 1, 位矩历三维幅高)
            组历统时(X, 位统时列今幅低) = 矩历码期值(X, 1, 位矩历三维幅低)
            If VBA.IsNumeric(矩历码期值(X, 1, 1)) = False Then 组历统时(X, 位统时列停牌) = "S"
            '============================================================================
            '确定 幅度限度
            '============================================================================
            If UBCID是中股票(CIDL) Then
                    值幅下限 = 1.5
                    值幅上限 = 3
            ElseIf UBCID是中股指(CIDL) Or UBCID是中股基(CIDL) Then
                    值幅下限 = 1
                    值幅上限 = 2
            End If
            '============================================================================
            '查询腾实获取信息（批量HTTP，字典取值）
            '============================================================================
            If 典腾实.Exists(CIDL) Then
                Dim aRESP As Variant
                aRESP = 典腾实(CIDL)
                组历统时(X, 位统时列交额) = Round(aRESP(位序腾实交额) / 10000, 2)
                If Len(aRESP(位序腾实总市)) > 0 Then 组历统时(X, 位统时列市值) = Round(aRESP(位序腾实总市), 1)
            End If
            '============================================================================
            '正向遍历统计：短期指标
            '待完成替换：放入神谕生成/放入OS结算
            '============================================================================
            For Y = UBound(矩历码期值, 2) To 1 Step -1   '按日
            If VBA.IsNumeric(矩历码期值(X, Y, 位矩历三维幅涨)) = True Then
                        '================================================================
                        '统计幅
                        '================================================================
                        值幅涨 = 矩历码期值(X, Y, 位矩历三维幅涨)
                        值幅高 = 矩历码期值(X, Y, 位矩历三维幅高)
                        值幅低 = 矩历码期值(X, Y, 位矩历三维幅低)
                        '----------------------------------------------------------------
                        '统计：累时 【已放入OS】
                        '----------------------------------------------------------------
                        组历统时(X, 位统时列BTHR9) = STBASE结算工具_衍生交叉天数(组历统时(X, 位统时列BTHR9), 值幅高, 9)
                        组历统时(X, 位统时列BTHR3) = STBASE结算工具_衍生交叉天数(组历统时(X, 位统时列BTHR3), 值幅高, 3)
                        组历统时(X, 位统时列BTHR1) = STBASE结算工具_衍生交叉天数(组历统时(X, 位统时列BTHR1), 值幅高, 1.5)
                        组历统时(X, 位统时列BTHR0) = STBASE结算工具_衍生交叉天数(组历统时(X, 位统时列BTHR0), 值幅高, 0)
                        '----------------------------------------------------------------
                        '统计：停五符 【已放入神谕】
                        '----------------------------------------------------------------
                        If Y = 1 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 1000000000 * IIf(值幅高 > 9, 1, 0)
                        If Y = 1 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 100000000 * IIf(值幅涨 > 9, 1, 0)
                        If Y = 2 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 10000000 * IIf(值幅高 > 9, 1, 0)
                        If Y = 2 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 1000000 * IIf(值幅涨 > 9, 1, 0)
                        If Y = 3 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 100000 * IIf(值幅高 > 9, 1, 0)
                        If Y = 3 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 10000 * IIf(值幅涨 > 9, 1, 0)
                        If Y = 4 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 1000 * IIf(值幅高 > 9, 1, 0)
                        If Y = 4 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 100 * IIf(值幅涨 > 9, 1, 0)
                        If Y = 5 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 10 * IIf(值幅高 > 9, 1, 0)
                        If Y = 5 Then 组历统时(X, 位统时列停五符) = 组历统时(X, 位统时列停五符) + 1 * IIf(值幅涨 > 9, 1, 0)
                        '----------------------------------------------------------------
                        '统计：各区间属性
                        '----------------------------------------------------------------
                        If Y <= 10 Then
                            组历统时(X, 位统时列十停数涨) = 组历统时(X, 位统时列十停数涨) + IIf(值幅涨 > 9, 1, 0)
                            组历统时(X, 位统时列十停数高) = 组历统时(X, 位统时列十停数高) + IIf(值幅高 > 9, 1, 0)
                            组历统时(X, 位统时列十停数跌) = 组历统时(X, 位统时列十停数跌) + IIf(值幅涨 < -9, 1, 0)
                            组历统时(X, 位统时列十停数低) = 组历统时(X, 位统时列十停数低) + IIf(值幅低 < -9, 1, 0)
                            组历统时(X, 位统时列十均幅涨) = 组历统时(X, 位统时列十均幅涨) + 值幅涨
                            组历统时(X, 位统时列十均幅高) = 组历统时(X, 位统时列十均幅高) + 值幅高
                            组历统时(X, 位统时列十均幅低) = 组历统时(X, 位统时列十均幅低) + 值幅低
                            组历统时(X, 位统时列十高小比) = 组历统时(X, 位统时列十高小比) + IIf(值幅高 < 值幅下限, 1, 0)
                            组历统时(X, 位统时列十重心正比) = 组历统时(X, 位统时列十重心正比) + IIf(值幅高 + 值幅低 >= 0, 1, 0)
                            组历统时(X, 位统时列十计数) = 组历统时(X, 位统时列十计数) + 1
                        End If
                        '================================================================
            End If
            Next
            If 组历统时(X, 位统时列十计数) > 0 Then
                    组历统时(X, 位统时列十均幅涨) = Round(组历统时(X, 位统时列十均幅涨) / 组历统时(X, 位统时列十计数), 1)
                    组历统时(X, 位统时列十均幅高) = Round(组历统时(X, 位统时列十均幅高) / 组历统时(X, 位统时列十计数), 1)
                    组历统时(X, 位统时列十均幅低) = Round(组历统时(X, 位统时列十均幅低) / 组历统时(X, 位统时列十计数), 1)
                    组历统时(X, 位统时列十高小比) = Round(组历统时(X, 位统时列十高小比) / 组历统时(X, 位统时列十计数), 2)
                    组历统时(X, 位统时列十重心正比) = Round(组历统时(X, 位统时列十重心正比) / 组历统时(X, 位统时列十计数), 2)
            End If
            '============================================================================
            '逆向遍历统计：中长期指标
            '============================================================================
            For Y = 1 To UBound(矩历码期值, 2)  '按日
            If VBA.IsNumeric(矩历码期值(X, Y, 位矩历三维幅涨)) = True Then
                        '================================================================
                        '统计幅
                        '================================================================
                        值幅涨 = 矩历码期值(X, Y, 位矩历三维幅涨)
                        值幅高 = 矩历码期值(X, Y, 位矩历三维幅高)
                        值幅低 = 矩历码期值(X, Y, 位矩历三维幅低)
                        '----------------------------------------------------------------
                        '统计：各区间属性 中期/长期
                        '----------------------------------------------------------------
                        If Y <= 30 Then
                            组历统时(X, 位统时列仨停数涨) = 组历统时(X, 位统时列仨停数涨) + IIf(值幅涨 > 9, 1, 0)
                            组历统时(X, 位统时列仨停数高) = 组历统时(X, 位统时列仨停数高) + IIf(值幅高 > 9, 1, 0)
                            组历统时(X, 位统时列仨停数跌) = 组历统时(X, 位统时列仨停数跌) + IIf(值幅涨 < -9, 1, 0)
                            组历统时(X, 位统时列仨停数低) = 组历统时(X, 位统时列仨停数低) + IIf(值幅低 < -9, 1, 0)
                            组历统时(X, 位统时列仨均幅涨) = 组历统时(X, 位统时列仨均幅涨) + 值幅涨
                            组历统时(X, 位统时列仨均幅高) = 组历统时(X, 位统时列仨均幅高) + 值幅高
                            组历统时(X, 位统时列仨均幅低) = 组历统时(X, 位统时列仨均幅低) + 值幅低
                            组历统时(X, 位统时列仨高小比) = 组历统时(X, 位统时列仨高小比) + IIf(值幅高 < 值幅下限, 1, 0)
                            组历统时(X, 位统时列仨重心正比) = 组历统时(X, 位统时列仨重心正比) + IIf(值幅高 + 值幅低 >= 0, 1, 0)
                            组历统时(X, 位统时列仨计数) = 组历统时(X, 位统时列仨计数) + 1
                            If 组历统时(X, 位统时列仨顶价) = 0 Then
                                组历统时(X, 位统时列仨顶价) = 矩历码期值(X, Y, 位矩历三维价高)
                                组历统时(X, 位统时列仨顶龄) = Y
                            ElseIf 矩历码期值(X, Y, 位矩历三维价高) > 组历统时(X, 位统时列仨顶价) Then
                                组历统时(X, 位统时列仨顶价) = 矩历码期值(X, Y, 位矩历三维价高)
                                组历统时(X, 位统时列仨顶龄) = Y
                            End If
                            If 组历统时(X, 位统时列仨底价) = 0 Then
                                组历统时(X, 位统时列仨底价) = 矩历码期值(X, Y, 位矩历三维价低)
                                组历统时(X, 位统时列仨底龄) = Y
                            ElseIf 矩历码期值(X, Y, 位矩历三维价低) < 组历统时(X, 位统时列仨底价) Then
                                组历统时(X, 位统时列仨底价) = 矩历码期值(X, Y, 位矩历三维价低)
                                组历统时(X, 位统时列仨底龄) = Y
                            End If
                        ElseIf Y <= 250 And Y > 30 Then
                            组历统时(X, 位统时列佰停数涨) = 组历统时(X, 位统时列佰停数涨) + IIf(值幅涨 > 9, 1, 0)
                            组历统时(X, 位统时列佰停数高) = 组历统时(X, 位统时列佰停数高) + IIf(值幅高 > 9, 1, 0)
                            组历统时(X, 位统时列佰停数跌) = 组历统时(X, 位统时列佰停数跌) + IIf(值幅涨 < -9, 1, 0)
                            组历统时(X, 位统时列佰停数低) = 组历统时(X, 位统时列佰停数低) + IIf(值幅低 < -9, 1, 0)
                            组历统时(X, 位统时列佰均幅涨) = 组历统时(X, 位统时列佰均幅涨) + 值幅涨
                            组历统时(X, 位统时列佰均幅高) = 组历统时(X, 位统时列佰均幅高) + 值幅高
                            组历统时(X, 位统时列佰均幅低) = 组历统时(X, 位统时列佰均幅低) + 值幅低
                            组历统时(X, 位统时列佰高小比) = 组历统时(X, 位统时列佰高小比) + IIf(值幅高 < 值幅下限, 1, 0)
                            组历统时(X, 位统时列佰重心正比) = 组历统时(X, 位统时列佰重心正比) + IIf(值幅高 + 值幅低 >= 0, 1, 0)
                            组历统时(X, 位统时列佰计数) = 组历统时(X, 位统时列佰计数) + 1
                            If 组历统时(X, 位统时列佰顶价) = 0 Then
                                组历统时(X, 位统时列佰顶价) = 矩历码期值(X, Y, 位矩历三维价高)
                                组历统时(X, 位统时列佰顶龄) = Y
                            ElseIf 矩历码期值(X, Y, 位矩历三维价高) > 组历统时(X, 位统时列佰顶价) Then
                                组历统时(X, 位统时列佰顶价) = 矩历码期值(X, Y, 位矩历三维价高)
                                组历统时(X, 位统时列佰顶龄) = Y
                            End If
                            If 组历统时(X, 位统时列佰底价) = 0 Then
                                组历统时(X, 位统时列佰底价) = 矩历码期值(X, Y, 位矩历三维价低)
                                组历统时(X, 位统时列佰底龄) = Y
                            ElseIf 矩历码期值(X, Y, 位矩历三维价低) < 组历统时(X, 位统时列佰底价) Then
                                组历统时(X, 位统时列佰底价) = 矩历码期值(X, Y, 位矩历三维价低)
                                组历统时(X, 位统时列佰底龄) = Y
                            End If
                        End If
                        '================================================================
            End If
            Next
            '----------------------------------------------------------------------------
            If 组历统时(X, 位统时列仨计数) > 0 Then
                    组历统时(X, 位统时列仨均幅涨) = Round(组历统时(X, 位统时列仨均幅涨) / 组历统时(X, 位统时列仨计数), 2)
                    组历统时(X, 位统时列仨均幅高) = Round(组历统时(X, 位统时列仨均幅高) / 组历统时(X, 位统时列仨计数), 2)
                    组历统时(X, 位统时列仨均幅低) = Round(组历统时(X, 位统时列仨均幅低) / 组历统时(X, 位统时列仨计数), 2)
                    组历统时(X, 位统时列仨高小比) = Round(组历统时(X, 位统时列仨高小比) / 组历统时(X, 位统时列仨计数), 2)
                    组历统时(X, 位统时列仨重心正比) = Round(组历统时(X, 位统时列仨重心正比) / 组历统时(X, 位统时列仨计数), 2)
            End If
            If 组历统时(X, 位统时列佰计数) > 0 Then
                    组历统时(X, 位统时列佰均幅涨) = Round(组历统时(X, 位统时列佰均幅涨) / 组历统时(X, 位统时列佰计数), 2)
                    组历统时(X, 位统时列佰均幅高) = Round(组历统时(X, 位统时列佰均幅高) / 组历统时(X, 位统时列佰计数), 2)
                    组历统时(X, 位统时列佰均幅低) = Round(组历统时(X, 位统时列佰均幅低) / 组历统时(X, 位统时列佰计数), 2)
                    组历统时(X, 位统时列佰高小比) = Round(组历统时(X, 位统时列佰高小比) / 组历统时(X, 位统时列佰计数), 2)
                    组历统时(X, 位统时列佰重心正比) = Round(组历统时(X, 位统时列佰重心正比) / 组历统时(X, 位统时列佰计数), 2)
            End If
            If VBA.IsNumeric(矩历码期值(X, 1, 位矩历三维价收)) = True Then
                    组历统时(X, 位统时列仨顶幅) = Round(组历统时(X, 位统时列仨顶价) / 矩历码期值(X, 1, 位矩历三维价收) - 1, 2)
                    组历统时(X, 位统时列仨底幅) = Round(组历统时(X, 位统时列仨底价) / 矩历码期值(X, 1, 位矩历三维价收) - 1, 2)
                    组历统时(X, 位统时列佰顶幅) = Round(组历统时(X, 位统时列佰顶价) / 矩历码期值(X, 1, 位矩历三维价收) - 1, 2)
                    组历统时(X, 位统时列佰底幅) = Round(组历统时(X, 位统时列佰底价) / 矩历码期值(X, 1, 位矩历三维价收) - 1, 2)
            End If
            '============================================================================
            '衍生股性
            '============================================================================
                    If InStr(值代称, "ST") > 0 Or InStr(值代称, "退") > 0 Then
                            组历统时(X, 位统时列股性) = "0ST退"
                    ElseIf 组历统时(X, 位统时列停牌) = "S" Then
                            组历统时(X, 位统时列股性) = "0停"
                    ElseIf 组历统时(X, 位统时列佰计数) < 150 Then
                            组历统时(X, 位统时列股性) = "0新"
                    ElseIf 组历统时(X, 位统时列佰均幅高) < 1 Then
                            组历统时(X, 位统时列股性) = "0萎"
                    '-------------------------------------------------
                    '过滤均高幅：佰小 应分为三类
                    ElseIf 组历统时(X, 位统时列佰均幅高) < 值幅下限 Then
                        If 组历统时(X, 位统时列仨均幅高) < 值幅下限 Then
                            组历统时(X, 位统时列股性) = "11蔫"
                        ElseIf 组历统时(X, 位统时列仨均幅高) < 值幅上限 Then
                            组历统时(X, 位统时列股性) = "12变活"
                        Else
                            组历统时(X, 位统时列股性) = "13变活"
                        End If
                    '-------------------------------------------------
                    '过滤均高幅：佰中
                    ElseIf 组历统时(X, 位统时列佰均幅高) < 值幅上限 Then
                        If 组历统时(X, 位统时列仨均幅高) < 值幅下限 Then
                            组历统时(X, 位统时列股性) = "21变蔫"
                        ElseIf 组历统时(X, 位统时列仨均幅高) < 值幅上限 Then
                            组历统时(X, 位统时列股性) = "22中"
                        Else
                            组历统时(X, 位统时列股性) = "23变活"
                        End If
                    '-------------------------------------------------
                    '过滤均高幅：佰大 应分为三类
                    Else
                        If 组历统时(X, 位统时列仨均幅高) < 值幅下限 Then
                            组历统时(X, 位统时列股性) = "31变蔫"
                        ElseIf 组历统时(X, 位统时列仨均幅高) < 值幅上限 Then
                            组历统时(X, 位统时列股性) = "32变蔫"
                        Else
                            组历统时(X, 位统时列股性) = "33活"
                        End If
                    End If
            '============================================================================
    End If
    Next
    '====================================================================================
    '返回
    '====================================================================================
End Function




Function 历研统时引擎3统程分布(表名输出 As String, 组历统时 As Variant)
'========================================================================================
'定义
'========================================================================================
    Dim 值幅下限 As Double, 值幅上限 As Double
    '------------------------------------------------------------------------------------
    Dim 典跨时类22中十常 As New Dictionary
    Dim 典跨时类22中十低 As New Dictionary
    Dim 典跨时类23变活 As New Dictionary
    Dim 典跨时类22中 As New Dictionary
    Dim 典跨时类21变蔫 As New Dictionary
    Dim 典跨时类33活 As New Dictionary
    Dim 典跨时类32变蔫 As New Dictionary
    Dim 典跨时类31变蔫 As New Dictionary
    Dim 典跨时类13变活 As New Dictionary
    Dim 典跨时类12变活 As New Dictionary
    Dim 典跨时类11蔫 As New Dictionary
    Dim 典跨时类OST退 As New Dictionary
    Dim 典跨时类O停 As New Dictionary
    Dim 典跨时类O新 As New Dictionary
    Dim 典跨时类O萎 As New Dictionary
'========================================================================================
'筛选
'========================================================================================
    Dim X As Integer
    For X = 1 To UBound(组历统时, 1)  '按码
        CIDL = 组历统时(X, 位统时列CIDL)
        代称 = 组历统时(X, 位统时列代称)
        If UBCID是中股票(CIDL) Then
                '------------------------------------------------------------------------
                '设置波动上下限
                '------------------------------------------------------------------------
                If UBCID是中股票(CIDL) Then
                        值幅下限 = 1.5
                        值幅上限 = 3
                ElseIf UBCID是中股指(CIDL) Or UBCID是中股基(CIDL) Then
                        值幅下限 = 1
                        值幅上限 = 2
                End If
                '------------------------------------------------------------------------
                '注意20230730：以下赋值会覆盖原有程序，但是不需要改变。本程序属于试验性质，用于探索适当的参数，如果参数有调整，反过去修改数程就行了。
                '------------------------------------------------------------------------
                If 组历统时(X, 位统时列股性) = "0ST退" Then
                        典跨时类OST退.Add Item:=代称, Key:=CIDL
                ElseIf 组历统时(X, 位统时列股性) = "0停" Then
                        典跨时类O停.Add Item:=代称, Key:=CIDL
                ElseIf 组历统时(X, 位统时列股性) = "0新" Then
                        典跨时类O新.Add Item:=代称, Key:=CIDL
                ElseIf 组历统时(X, 位统时列股性) = "0萎" Then
                        典跨时类O萎.Add Item:=代称, Key:=CIDL
                '-------------------------------------------------
                '过滤均高幅：佰小 应分为三类
                ElseIf 组历统时(X, 位统时列佰均幅高) < 值幅下限 Then
                    If 组历统时(X, 位统时列仨均幅高) < 值幅下限 Then
                        组历统时(X, 位统时列股性) = "11蔫"
                        典跨时类11蔫.Add Item:=代称, Key:=CIDL
                    ElseIf 组历统时(X, 位统时列仨均幅高) < 值幅上限 Then
                        组历统时(X, 位统时列股性) = "12变活"
                        典跨时类12变活.Add Item:=代称, Key:=CIDL
                    Else
                        组历统时(X, 位统时列股性) = "13变活"
                        典跨时类13变活.Add Item:=代称, Key:=CIDL
                    End If
                '-------------------------------------------------
                '过滤均高幅：佰中
                ElseIf 组历统时(X, 位统时列佰均幅高) < 值幅上限 Then
                    If 组历统时(X, 位统时列仨均幅高) < 值幅下限 Then
                            组历统时(X, 位统时列股性) = "21变蔫"
                            典跨时类21变蔫.Add Item:=代称, Key:=CIDL
                    ElseIf 组历统时(X, 位统时列仨均幅高) < 值幅上限 Then
                            组历统时(X, 位统时列股性) = "22中"
                            典跨时类22中.Add Item:=代称, Key:=CIDL
                    Else
                            组历统时(X, 位统时列股性) = "23变活"
                            典跨时类23变活.Add Item:=代称, Key:=CIDL
                    End If
                '-------------------------------------------------
                '过滤均高幅：佰大 应分为三类
                Else
                    If 组历统时(X, 位统时列仨均幅高) < 值幅下限 Then
                        组历统时(X, 位统时列股性) = "31变蔫"
                        典跨时类31变蔫.Add Item:=代称, Key:=CIDL
                    ElseIf 组历统时(X, 位统时列仨均幅高) < 值幅上限 Then
                        组历统时(X, 位统时列股性) = "32变蔫"
                        典跨时类32变蔫.Add Item:=代称, Key:=CIDL
                    Else
                        组历统时(X, 位统时列股性) = "33活"
                        典跨时类33活.Add Item:=代称, Key:=CIDL
                    End If
                End If
        '                '-------------------------------------------------
        ''                If 组历统时(X, 位统时列十均幅高) <值幅下限 Then
        '                If 组历统时(X, 位统时列仨均幅高) + 组历统时(X, 位统时列仨均幅低) > 0 Then
        '                    '远期正常中期正常近期萎靡 冲高回落
        '                    典跨时类22中十低.Add Item:=代称, Key:=CIDL
        '                '过滤：佰均幅高(非小)仨均幅高(非小)
        '                Else
        '                        '远期正常中期正常近期正常
        '                    典跨时类22中十常.Add Item:=代称, Key:=CIDL
        '                End If
        '                '-------------------------------------------------
                '-------------------------------------------------
        End If
    Next
'========================================================================================
'输出
'========================================================================================
    '-------------------------------------------------
    Call 历研统时引擎4输程(".跨时0", 组历统时, 典跨时类O新, 节色:=常色二灰, 节签:="新股", 是否建表:=True)
    Call 历研统时引擎4输程(".跨时0", 组历统时, 典跨时类OST退, 节色:=常色二灰, 节签:="ST & 退市")
    Call 历研统时引擎4输程(".跨时0", 组历统时, 典跨时类O萎, 节色:=常色二灰, 节签:="长期萎靡")
    Call 历研统时引擎4输程(".跨时0", 组历统时, 典跨时类O停, 节色:=常色二灰, 节签:="停牌")
    '-------------------------------------------------
    Call 历研统时引擎4输程(".跨时32", 组历统时, 典跨时类32变蔫, 是否建表:=True, 节色:=常色八黄, 节签:="32变蔫  变得不活跃")
    Call 历研统时引擎4输程(".跨时31", 组历统时, 典跨时类31变蔫, 是否建表:=True, 节色:=常色八黄, 节签:="31变蔫  突然变得不活跃")
    Call 历研统时引擎4输程(".跨时21", 组历统时, 典跨时类21变蔫, 是否建表:=True, 节色:=常色八黄, 节签:="21变蔫  变得不活跃")
    Call 历研统时引擎4输程(".跨时11", 组历统时, 典跨时类11蔫, 是否建表:=True, 节色:=常色四灰, 节签:="11蔫  股性就是萎靡")
    '-------------------------------------------------
    Call 历研统时引擎4输程(".跨时33", 组历统时, 典跨时类33活, 是否建表:=True, 节色:=常色四靛, 节签:="33活  股性就是活跃")
    Call 历研统时引擎4输程(".跨时23", 组历统时, 典跨时类23变活, 是否建表:=True, 节色:=常色43绿, 节签:="23变活   ")
    Call 历研统时引擎4输程(".跨时13", 组历统时, 典跨时类13变活, 是否建表:=True, 节色:=常色43绿, 节签:="13变活  变得很活跃")
    Call 历研统时引擎4输程(".跨时12", 组历统时, 典跨时类12变活, 是否建表:=True, 节色:=常色43绿, 节签:="12变活  变得活跃")
    '-------------------------------------------------
    Call 历研统时引擎4输程(".跨时22", 组历统时, 典跨时类22中, 是否建表:=True, 节色:=常色六青, 节签:="22中  正常活跃 ")
'========================================================================================
End Function






