        .Cells(1, 位统时列佰均幅高) = "%m高" & vbCrLf & "佰"
        .Cells(1, 位统时列佰高小比) = "%高<下限"
        .Cells(1, 位统时列佰均幅低) = "%m低" & vbCrLf & "佰"
        .Cells(1, 位统时列佰重心正比) = "%心正" & vbCrLf & "佰"
