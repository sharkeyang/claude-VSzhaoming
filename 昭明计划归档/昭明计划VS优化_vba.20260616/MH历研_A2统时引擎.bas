Sub 测试中间_历研统时引擎3统程分布_分析股性2()
    Dim 表名输出 As String
    表名输出 = "..ZT"
    Dim WSTO As Worksheet
    Set WSTO = ThisWorkbook.Sheets(表名输出)
    Dim 组历统时 As Variant
    Call UTL数据转换_集WS2ARR(组历统时, WSTO, 2, 1)
'========================================================================================
'筛选
'========================================================================================
    Call 历研统时引擎3统程分布(表名输出, 组历统时)
'    Call 历研统时引擎3统程涨停(表名输出, 组历统时)
End Sub



'========================================================================================
'========================================================================================
'功能：按照【典码称输出】所含代码输出【组历统时】
'========================================================================================
'========================================================================================
Function 历研统时引擎4输程( _
          表名输出 As String _
        , 组历统时 As Variant _
        , 典码称输出 As Dictionary _
        , 节签 As String _
        , Optional 节色 As Long = 常色四靛 _
        , Optional 是否建表 As Boolean = False _
        , Optional 始列 As Integer = 1 _
        , Optional 基色底 As Long = 常色主绿 _
      )
'========================================================================================
'建立工表
'========================================================================================
    基色底 = IIf(InStr(表名输出, "停") > 0, 常色主绿, 常色四青)
    Dim WSTO As Worksheet
    If 是否建表 = True Or UTL判断工表存在(表名输出) = False Then
        Call PBASE格程工具_表操工表新增(WSTO, 表名输出, 基色底:=基色底)
        Call PBASE格程工具_表冻结锁定(WSTO, 1, 始列 + 位统时列代称 - 1)
        WSTO.Cells.Interior.Color = 常色主黑
        WSTO.Cells.Font.Size = 8
        Call 历研统时引擎5格程按列(WSTO, 始列:=始列)
    End If
    Set WSTO = ThisWorkbook.Sheets(表名输出)
'========================================================================================
'验证
'========================================================================================
    If VBA.IsEmpty(组历统时) Then Exit Function
    If 典码称输出.Count = 0 Then Exit Function
'========================================================================================
'输出数据
'========================================================================================
    Dim 典组历统时 As New Dictionary
    For X = LBound(组历统时, 1) To UBound(组历统时, 1)
        CIDL = 组历统时(X, 1)
        典组历统时.Add Item:=X, Key:=CIDL
    Next
    '------------------------------------------------------------------------------------
    ReDim 组输出(1 To 典码称输出.Count, LBound(组历统时, 2) To UBound(组历统时, 2)) As Variant
    '------------------------------------------------------------------------------------
    For X = 1 To 典码称输出.Count
        CIDL = 典码称输出.Keys(X - 1)
        定位组历统时 = 典组历统时(CIDL)
        For Y = LBound(组历统时, 2) To UBound(组历统时, 2)
            组输出(X, Y) = 组历统时(定位组历统时, Y)
        Next
    Next
'========================================================================================
'输出标签
'========================================================================================
    Dim 始行 As Integer
    始行 = PBASE格程工具_表参末行指定(WSTO, 始列) + 2
    '------------------------------------------------------------------------------------
    With WSTO.Rows(始行)
        .Cells(1, 始列) = 节签 & "  #" & 典码称输出.Count
        .Interior.Color = 节色
        .Font.Color = 常色主白
        .RowHeight = 50
        .Font.Size = 20
        .Font.Bold = True
    End With
    始行 = 始行 + 2
'========================================================================================
'格式化
'========================================================================================
    '------------------------------------------------------------------------------------
    '输出
    '------------------------------------------------------------------------------------
    Call UTL数据转换_集ARR2WS(组输出, WSTO, 始行, 始列)
    Set 典组历统时 = Nothing
    Dim 总行数 As Integer
    总行数 = UBound(组输出, 1) - LBound(组输出, 1) + 1
    '------------------------------------------------------------------------------------
    '格式化：
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Resize(总行数, 位统时列总终)
        .Font.Size = 9
        .Interior.ColorIndex = 37
    End With
    '纵列
    With WSTO.Cells(始行, 始列).Cells(1, 位统时列CIDL).Resize(总行数, 1)
        .Interior.Color = 常色四灰
        .Font.Color = 常色四灰
        .Font.TintAndShade = -0.1
        .Font.Size = 10
    End With
    With WSTO.Cells(始行, 始列).Cells(1, 位统时列代称).Resize(总行数, 1)
        .Interior.Color = 常色四灰
        .Font.Color = 常色主白
        .Font.Size = 10
    End With
    '------------------------------------------------------------------------------------
    '格式化：单元格
    '------------------------------------------------------------------------------------
    For X = 1 To 总行数
        目行 = 始行 + X - 1
        For Y = 位统时列波始 To 位统时列总终
            目列 = 始列 + Y - 1
            With WSTO.Cells(目行, 目列)
                If .Value = 0 Then
                    .Font.Color = .Interior.Color
                    .Font.TintAndShade = -0.1
                End If
            End With
        Next
    Next
    '------------------------------------------------------------------------------------
    '格式化：排序
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Resize(总行数, 位统时列总终)
            .Sort key1:=.Cells(1, 位统时列十均幅高), order1:=xlDescending, _
                  key2:=.Cells(1, 位统时列仨均幅涨), order2:=xlDescending, _
                  Header:=xlNo
            .Sort key1:=.Cells(1, 位统时列停五符), order1:=xlDescending, _
                  key2:=.Cells(1, 位统时列十停数高), order2:=xlDescending, _
                  key3:=.Cells(1, 位统时列BTHR9), order3:=xlDescending, _
                  Header:=xlNo              '序：涨停时间>涨停次数>涨停倒数
    End With
    '------------------------------------------------------------------------------------
    '格式化：边框
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列)
        '--------------------------------------------------------------------------------
        .Cells(1, 位统时列十停数涨).Resize(总行数, 1).Interior.ColorIndex = 36
        .Cells(1, 位统时列十停数高).Resize(总行数, 1).Interior.ColorIndex = 36
        .Cells(1, 位统时列十停数跌).Resize(总行数, 1).Interior.ColorIndex = 35
        .Cells(1, 位统时列十停数低).Resize(总行数, 1).Interior.ColorIndex = 35
        .Cells(1, 位统时列仨停数涨).Resize(总行数, 1).Interior.ColorIndex = 36
        .Cells(1, 位统时列仨停数高).Resize(总行数, 1).Interior.ColorIndex = 36
        .Cells(1, 位统时列仨停数跌).Resize(总行数, 1).Interior.ColorIndex = 35
        .Cells(1, 位统时列仨停数低).Resize(总行数, 1).Interior.ColorIndex = 35
        .Cells(1, 位统时列佰停数涨).Resize(总行数, 1).Interior.ColorIndex = 36
        .Cells(1, 位统时列佰停数高).Resize(总行数, 1).Interior.ColorIndex = 36
        .Cells(1, 位统时列佰停数跌).Resize(总行数, 1).Interior.ColorIndex = 35
        .Cells(1, 位统时列佰停数低).Resize(总行数, 1).Interior.ColorIndex = 35
        '--------------------------------------------------------------------------------
        .Cells(1, 位统时列仨顶龄).Resize(总行数, 1).Interior.Color = 常色六灰
        .Cells(1, 位统时列仨顶价).Resize(总行数, 1).Interior.Color = 常色四灰
        .Cells(1, 位统时列仨顶幅).Resize(总行数, 1).Interior.Color = 常色八灰
        .Cells(1, 位统时列仨底龄).Resize(总行数, 1).Interior.Color = 常色六灰
        .Cells(1, 位统时列仨底价).Resize(总行数, 1).Interior.Color = 常色四灰
        .Cells(1, 位统时列仨底幅).Resize(总行数, 1).Interior.Color = 常色八灰
        .Cells(1, 位统时列佰顶龄).Resize(总行数, 1).Interior.Color = 常色六灰
        .Cells(1, 位统时列佰顶价).Resize(总行数, 1).Interior.Color = 常色四灰
        .Cells(1, 位统时列佰顶幅).Resize(总行数, 1).Interior.Color = 常色八灰
        .Cells(1, 位统时列佰底龄).Resize(总行数, 1).Interior.Color = 常色六灰
        .Cells(1, 位统时列佰底价).Resize(总行数, 1).Interior.Color = 常色四灰
        .Cells(1, 位统时列佰底幅).Resize(总行数, 1).Interior.Color = 常色八灰
        '--------------------------------------------------------------------------------
    End With
    '------------------------------------------------------------------------------------
    '格式化：边框
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Cells(1, 位统时列十始).Resize(总行数, 1).Borders(xlLeft)
       .Color = 常色主黑
       .Weight = xlThick
    End With
    With WSTO.Cells(始行, 始列).Cells(1, 位统时列仨始).Resize(总行数, 1).Borders(xlLeft)
       .Color = 常色主黑
       .Weight = xlThick
    End With
    With WSTO.Cells(始行, 始列).Cells(1, 位统时列佰始).Resize(总行数, 1).Borders(xlLeft)
       .Color = 常色主黑
       .Weight = xlThick
    End With
    With WSTO.Cells(始行, 始列).Cells(1, 位统时列股性).Resize(总行数, 1).Borders(xlLeft)
       .Color = 常色主黑
       .Weight = xlThick
    End With
        With WSTO.Cells(始行, 始列).Cells(1, 位统时列今幅低).Resize(总行数, 1).Borders(xlLeft)
           .Color = 常色主黑
           .Weight = xlThin
        End With
        With WSTO.Cells(始行, 始列).Cells(1, 位统时列停五符).Resize(总行数, 1).Borders(xlLeft)
           .Color = 常色主黑
           .Weight = xlThin
        End With
        With WSTO.Cells(始行, 始列).Cells(1, 位统时列停牌).Resize(总行数, 1).Borders(xlLeft)
           .Color = 常色主黑
           .Weight = xlThin
        End With
        With WSTO.Cells(始行, 始列).Cells(1, 位统时列停牌).Resize(总行数, 1).Borders(xlRight)
           .Color = 常色主黑
           .Weight = xlThin
        End With
'========================================================================================
End Function


