        .Cells(1, 位统时列佰停数高) = "#S高" & vbCrLf & "佰"
        .Cells(1, 位统时列佰停数跌) = "#S跌" & vbCrLf & "佰"
        .Cells(1, 位统时列佰停数低) = "#S低" & vbCrLf & "佰"
