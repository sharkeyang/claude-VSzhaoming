        .Columns(位统时列仨高小比).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列佰高小比).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列十重心正比).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列仨重心正比).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列佰重心正比).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列仨顶幅).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列仨底幅).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列佰顶幅).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列佰底幅).NumberFormatLocal = 全设格式of百分
        .Columns(位统时列交额).NumberFormatLocal = 全设格式of零位
        .Columns(位统时列市值).NumberFormatLocal = 全设格式of零位
        .Columns(位统时列今幅涨).NumberFormatLocal = "[黑色]0_);[红色](0)"
        .Columns(位统时列今幅高).NumberFormatLocal = "[黑色]0_);[红色](0)"
        .Columns(位统时列今幅低).NumberFormatLocal = "[黑色]0_);[红色](0)"
    End With
    '------------------------------------------------------------------------------------
    '格式化：首行
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Resize(1, 位统时列总终)
        .Font.Bold = True
        .Interior.Color = 基色底
        .Font.Color = 常色主黑
        .Font.Size = 8
    End With
    '------------------------------------------------------------------------------------
    '格式化：隐藏列
    '------------------------------------------------------------------------------------
    WSTO.Columns(始列).Columns(位统时列十计数).Hidden = True
    WSTO.Columns(始列).Columns(位统时列仨计数).Hidden = True
    WSTO.Columns(始列).Columns(位统时列佰计数).Hidden = True
    WSTO.Columns(始列).Columns(位统时列仨顶价).Hidden = True
    WSTO.Columns(始列).Columns(位统时列仨底价).Hidden = True
    WSTO.Columns(始列).Columns(位统时列佰顶价).Hidden = True
    WSTO.Columns(始列).Columns(位统时列佰底价).Hidden = True
    '====================================================================================
End Function
