        .Cells(1, 位统时列仨停数高) = "#S高" & vbCrLf & "仨"
        .Cells(1, 位统时列仨停数跌) = "#S跌" & vbCrLf & "仨"
        .Cells(1, 位统时列仨停数低) = "#S低" & vbCrLf & "仨"
        .Cells(1, 位统时列仨均幅涨) = "%m涨" & vbCrLf & "仨"
        .Cells(1, 位统时列仨均幅高) = "%m高" & vbCrLf & "仨"
        .Cells(1, 位统时列仨高小比) = "%高<下限"
        .Cells(1, 位统时列仨均幅低) = "%m低" & vbCrLf & "仨"
        .Cells(1, 位统时列仨重心正比) = "%心正" & vbCrLf & "仨"
        .Cells(1, 位统时列仨顶价) = "顶价" & vbCrLf & "仨"
        .Cells(1, 位统时列仨顶龄) = "顶龄" & vbCrLf & "仨"
        .Cells(1, 位统时列仨顶幅) = "顶幅" & vbCrLf & "仨"
