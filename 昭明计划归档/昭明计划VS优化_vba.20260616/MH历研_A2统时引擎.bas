    Set WSTO = ThisWorkbook.Sheets(表名输出)
    Dim 组历统时 As Variant
    Call UTL数据转换_集WS2ARR(组历统时, WSTO, 2, 1)
    '------------------------------------------------------------------------------------
    '筛选
    '------------------------------------------------------------------------------------
'    Call 历研统时引擎3统程分布(表名输出, 组历统时)
    Call 历研统时引擎3统程涨停(表名输出, 组历统时)
End Sub



'已转移至【IQQQ展擎筛程_筛程至表涨停】
Function 历研统时引擎3统程涨停(表名输出 As String, 组历统时 As Variant)
'========================================================================================
'定义
'========================================================================================
    Dim 典跨时类停高一佰小 As New Dictionary
    Dim 典跨时类停高二佰小 As New Dictionary
    Dim 典跨时类停高十佰小 As New Dictionary
    Dim 典跨时类停高一佰中 As New Dictionary
    Dim 典跨时类停高二佰中 As New Dictionary
    Dim 典跨时类停高十佰中 As New Dictionary
    Dim 典跨时类停高一佰大 As New Dictionary
    Dim 典跨时类停高二佰大 As New Dictionary
    Dim 典跨时类停高十佰大 As New Dictionary
    '------------------------------------------------------------------------------------
    Dim 典跨时类停高十类0 As New Dictionary
'========================================================================================
'筛选
'========================================================================================
    Dim X As Integer
    For X = 1 To UBound(组历统时, 1)  '按码
        CIDL = 组历统时(X, 位统时列CIDL)
        代称 = 组历统时(X, 位统时列代称)
        If UBCID是代码(CIDL) Then
                '------------------------------------------------------------------------
                '设置波动上下限
                '------------------------------------------------------------------------
                If UBCID是中股票(CIDL) Then
                        值幅下限 = 1.5
                        值幅上限 = 3
                ElseIf UBCID是中股指(CIDL) Or UBCID是中股基(CIDL) Then
                        值幅下限 = 1
                        值幅上限 = 2
                End If
                '------------------------------------------------------------------------
                If 组历统时(X, 位统时列股性) Like "0*" Then
                    If 组历统时(X, 位统时列十停数高) > 0 Then 典跨时类停高十类0.Add Item:=代称, Key:=CIDL
                '-------------------------------------------------
                '过滤均高幅：佰小 应分为三类
                ElseIf 组历统时(X, 位统时列佰均幅高) <= 值幅下限 Then
                    If 组历统时(X, 位统时列十停数高) > 0 Then 典跨时类停高十佰小.Add Item:=代称, Key:=CIDL
                '-------------------------------------------------
                '过滤均高幅：佰大 应分为三类
                ElseIf 组历统时(X, 位统时列佰均幅高) >= 值幅上限 Then
                    If 组历统时(X, 位统时列十停数高) > 0 Then 典跨时类停高十佰大.Add Item:=代称, Key:=CIDL
                '-------------------------------------------------
                '过滤均高幅：佰中
                Else
                    If 组历统时(X, 位统时列十停数高) > 0 Then 典跨时类停高十佰中.Add Item:=代称, Key:=CIDL
                End If
                '-------------------------------------------------
        End If
    Next
'========================================================================================
'输出：涨停
'========================================================================================
    '-------------------------------------------------
    Call 历研统时引擎4输程(".停0", 组历统时, 典跨时类停高十类0, 节色:=常色主绿, 节签:="高停十类0", 是否建表:=True)
    '-------------------------------------------------
    Call 历研统时引擎4输程(".停小", 组历统时, 典跨时类停高一佰小, 节色:=常色主绿, 节签:="高停一佰小", 是否建表:=True)
    Call 历研统时引擎4输程(".停小", 组历统时, 典跨时类停高二佰小, 节色:=常色主绿, 节签:="高停二佰小")
    Call 历研统时引擎4输程(".停小", 组历统时, 典跨时类停高十佰小, 节色:=常色主绿, 节签:="高停十佰小")
    '-------------------------------------------------
    Call 历研统时引擎4输程(".停中", 组历统时, 典跨时类停高一佰中, 节色:=常色六青, 节签:="高停一佰中", 是否建表:=True)
    Call 历研统时引擎4输程(".停中", 组历统时, 典跨时类停高二佰中, 节色:=常色六青, 节签:="高停二佰中")
    Call 历研统时引擎4输程(".停中", 组历统时, 典跨时类停高十佰中, 节色:=常色六青, 节签:="高停十佰中")
    '-------------------------------------------------
    Call 历研统时引擎4输程(".停大", 组历统时, 典跨时类停高一佰大, 节色:=常色四靛, 节签:="高停一佰大", 是否建表:=True)
    Call 历研统时引擎4输程(".停大", 组历统时, 典跨时类停高二佰大, 节色:=常色四靛, 节签:="高停二佰大")
    Call 历研统时引擎4输程(".停大", 组历统时, 典跨时类停高十佰大, 节色:=常色四靛, 节签:="高停十佰大")
'========================================================================================
End Function
