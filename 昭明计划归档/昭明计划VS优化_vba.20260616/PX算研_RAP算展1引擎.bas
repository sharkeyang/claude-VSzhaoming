'#####################################   按日墨汁   ######################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'名称：按日墨汁数程基程
'功能：对明细记录按照日期进行合并
'========================================================================================
'========================================================================================
Function STBASE罗盘数程_OS按日墨汁数程基程( _
          ARRLLL As Variant _
        , ARRLB As Variant _
        ) As Integer
'========================================================================================
'进行合并验证，排除空数组
'========================================================================================
    If VBA.IsEmpty(ARRLLL) _
    Or VBA.IsEmpty(ARRLB) _
    Then
        Exit Function
    End If
'========================================================================================
'扩展数组
'========================================================================================
    Dim 维二左值 As Integer
    维二左值 = UBound(ARRLLL, 2) - LBound(ARRLLL, 2) + 1
    Dim 维二右值 As Integer
    维二右值 = UBound(ARRLB, 2) - LBound(ARRLB, 2) + 1
    Dim 维二合值 As Integer
    维二合值 = 维二左值 + 维二右值
    '------------------------------------------------------------------------------------
    ReDim Preserve ARRLLL(LBound(ARRLLL, 1) To UBound(ARRLLL, 1), 1 To 维二合值) As Variant
'========================================================================================
'读取信息
'========================================================================================
    Dim 集合记录 As New Dictionary
    Dim sdate As String
    '------------------------------------------------------------------------------------
    '将日期信息导入集合
    '------------------------------------------------------------------------------------
    Dim Y As Integer
    For Y = LBound(ARRLB, 1) To UBound(ARRLB, 1)
        'sdate = Format$(ARRLB(Y, 位os结期), 全设格式of日期)
        sdate = Format$(ARRLB(Y, 位os临期), 全设格式of日期)
        集合记录.Add Item:=Y, Key:=sdate
    Next Y
'========================================================================================
'遍历合并
'========================================================================================
    Dim 行号定位 As Integer
    行号定位 = 1
    '------------------------------------------------------------------------------------
    Dim X As Integer
    For X = LBound(ARRLLL, 1) To UBound(ARRLLL, 1)
        '--------------------------------------------------------------------------------
        '获取主键
        '--------------------------------------------------------------------------------
        sdate = Format$(ARRLLL(X, 位os结期), 全设格式of日期)
        '--------------------------------------------------------------------------------
        '合并右信息并递延
        '--------------------------------------------------------------------------------
        If 集合记录.Exists(sdate) Then
            行号定位 = 集合记录(sdate)
        End If
        For Y = 1 To 维二右值
            ARRLLL(X, 维二左值 + Y) = ARRLB(行号定位, Y)
        Next Y
        '--------------------------------------------------------------------------------
        'Debug.Print "墨汁OS>>> "  & X & "__" & sdate
        '--------------------------------------------------------------------------------
    Next X
    '------------------------------------------------------------------------------------
    集合记录.RemoveAll
    Set 集合记录 = Nothing
'========================================================================================
'返回
'========================================================================================
    STBASE罗盘数程_OS按日墨汁数程基程 = UBound(ARRLLL, 1) - LBound(ARRLLL, 1) + 1
'========================================================================================
End Function
