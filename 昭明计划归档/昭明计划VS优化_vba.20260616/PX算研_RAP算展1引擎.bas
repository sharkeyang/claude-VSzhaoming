        , WS As Worksheet _
        , Optional 基色底 As Long = 常色研究 _
        , Optional 基列 As Integer = 1 _
        ) As Integer
'========================================================================================
'检查
'========================================================================================
    If VBA.IsEmpty(ARRLA) = True Then
        Exit Function
    End If
