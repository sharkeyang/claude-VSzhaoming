'########################################################################################
'##################################     算展格程     #####################################
'########################################################################################
'########################################################################################







'只看周类算法，但是同时展示月类和日类算法，看看算法什么时候会成功，什么时候会失败。与其他周期指标的关系是什么？
'========================================================================================
'========================================================================================
'格式化：乾类日
'========================================================================================
'========================================================================================
Function XL算展格程跨期( _
          ARRLLL As Variant _
        , WS As Worksheet _
        , Optional 被研期类 As String = 常期类为日 _
        , Optional 基色底 As Long = 常色研究 _
        , Optional 基列 As Integer = 1 _
        , Optional 基行 As Integer = 1 _
        ) As Integer
'========================================================================================
'检查
'========================================================================================
    If VBA.IsEmpty(ARRLLL) = True Then
        Exit Function
    End If
'========================================================================================
'格式化：全局设置
'========================================================================================
            '============================================================================
            '全局设置
            '============================================================================
            WS.Tab.Color = 基色底
            With WS.Cells
                .ClearFormats
                .Interior.ColorIndex = 56
                .Font.Name = "宋体"
                .Font.Size = 10
            End With
            '============================================================================
            '调整与冻结
            '注意：此步骤要放在其他过程前面
            '============================================================================
            WS.Rows.Hidden = False
            WS.Columns.Hidden = False
            Call PBASE格程工具_表冻结锁定(WS, 基列:=2)
'========================================================================================
'输出
'========================================================================================
    '------------------------------------------------------------------------------------
    '生成神谕
    '------------------------------------------------------------------------------------
    Dim 谕组 As Variant
    ReDim 谕组(LBound(ARRLLL, 1) To UBound(ARRLLL, 1), 1 To 位qt主宽) As Variant
    Call IQQQ跨码据擎_数程生成跨时神谕(谕组, ARRLLL, 基列:=1, 是否跨码:=False)
    '------------------------------------------------------------------------------------
'    Dim WSLX As Worksheet
'    Call PBASE格程工具_表操工表新增(WSLX, "KD2")
'    Call UTL数据转换_集ARR2WS(ARRLLL, WSLX, 2, 1)
'    Call IQQQ跨码展擎_按列OS区域(WSLX, 1)
'    Call IQQQ跨码展擎_按列OS区域(WSLX, 1 + 花宽单道)
'    Call IQQQ跨码展擎_按列OS区域(WSLX, 1 + 花宽单道 * 2)
'Stop
    '------------------------------------------------------------------------------------
    '控制索引
    '根据期类设置不同日期
    '------------------------------------------------------------------------------------
    Dim 基位日类  As Integer
    基位日类 = 0
    Dim 基位周类  As Integer
    基位周类 = 花宽单道
    Dim 基位月类  As Integer
    基位月类 = 花宽单道 * 2
    Dim 日类结日  As Date
    Dim 周类结日  As Date
    Dim 月类结日  As Date
    Dim 计数主键 As Integer
    计数主键 = 0
    Dim X As Integer
    For X = LBound(谕组, 1) To UBound(谕组, 1)
        日类结日 = ARRLLL(X, 基位日类 + 位os结期)
        周类结日 = ARRLLL(X, 基位周类 + 位os结期)
        月类结日 = ARRLLL(X, 基位月类 + 位os结期)
        谕组(X, 位谕展of主期) = 日类结日
        谕组(X, 位谕展of主七) = Weekday(日类结日, vbMonday)
        If 被研期类 = 常期类为日 Then
            谕组(X, 位谕展of主龄) = ARRLLL(X, 基位日类 + 位os基累龄)
            谕组(X, 位谕展of主涨) = 谕组(X, 位谕of日波BSPR)
            谕组(X, 位谕展of主键) = True
            计数主键 = 计数主键 + 1
        ElseIf 被研期类 = 常期类为周 Then
            谕组(X, 位谕展of主龄) = ARRLLL(X, 基位周类 + 位os基累龄)
            谕组(X, 位谕展of主涨) = 谕组(X, 位谕of周波今涨幅)
            If 周类结日 = 日类结日 Then
                谕组(X, 位谕展of主键) = True
                计数主键 = 计数主键 + 1
            End If
        ElseIf 被研期类 = 常期类为月 Then
            谕组(X, 位谕展of主龄) = ARRLLL(X, 基位月类 + 位os基累龄)
            谕组(X, 位谕展of主涨) = 谕组(X, 位谕of月波今涨幅)
            If 月类结日 = 日类结日 Then
                谕组(X, 位谕展of主键) = True
                计数主键 = 计数主键 + 1
            End If
        End If
    Next
    '------------------------------------------------------------------------------------
    '输出：神谕
    '------------------------------------------------------------------------------------
    WS.Cells(基行, 基列).Resize(1, 位谕列终全部).EntireColumn.ClearContents
    Call UTL数据转换_集ARR2WS(谕组, WS, 始行:=基行 + 1, 始列:=基列)
    '格式化
    Dim 列定位 As Integer
    列定位 = IQQQ跨码展擎_按列神谕区域(WS, 基列:=基列)
    Call IQQQ跨码展擎_按行汇总(WS, 是否跨码:=False)
    '------------------------------------------------------------------------------------
    '控制显示：只显示主键
    '------------------------------------------------------------------------------------
    For X = PBASE格程工具_表参末行指定(WS, 1) To 2 Step -1
        If WS.Cells(X, 位谕展of主键) <> True Then
            WS.Rows(X).Hidden = True
        End If
    Next
'========================================================================================
'格式化：
'========================================================================================
    '------------------------------------------------------------------------------------
    '格式化
    '------------------------------------------------------------------------------------
    With WS.Cells(1, 基列).Resize(1, 位qt主宽).EntireColumn
        .Font.ColorIndex = 2
        .Font.Size = 9
    End With
    '------------------------------------------------------------------------------------
    WS.Cells(1, 位谕展of主龄) = "龄"
    WS.Cells(1, 位谕展of主期) = "期"
    WS.Cells(1, 位谕展of主涨) = "涨"
    WS.Cells(1, 位谕展of主键) = "键"
    WS.Cells(1, 位谕展of主七) = "七"
    WS.Columns(基列).Columns(位谕展of主龄).HorizontalAlignment = xlLeft
    WS.Columns(基列).Columns(位谕展of主龄).Font.ColorIndex = 15
    'WS.Columns(基列).Columns(位谕展of主龄).Font.Bold = True
    WS.Columns(基列).Columns(位谕展of主期).HorizontalAlignment = xlLeft
    WS.Columns(基列).Columns(位谕展of主期).Font.ColorIndex = 15
    'WS.Columns(基列).Columns(位谕展of主期).Font.Bold = True
    WS.Columns(基列).Columns(位谕展of主期).NumberFormatLocal = 全设格式of日期
    WS.Columns(基列).Columns(位谕展of主涨).NumberFormatLocal = "[红色]0_);[绿色](0)"
    WS.Columns(基列).Columns(位谕展of主涨).Font.Bold = True
    WS.Columns(基列).Columns(位谕展of主七).Font.Color = 常色主黑
    WS.Columns(基列).Columns(位谕展of主键).Font.Color = 常色主黑
    '------------------------------------------------------------------------------------
    WS.Columns(基列).Columns(位谕展of主龄).ColumnWidth = 4
    WS.Columns(基列).Columns(位谕展of主期).ColumnWidth = 8
    WS.Columns(基列).Columns(位谕展of主键).ColumnWidth = 5
    WS.Columns(基列).Columns(位谕展of主涨).ColumnWidth = 5
    WS.Columns(基列).Columns(位谕展of主七).ColumnWidth = 2
    '------------------------------------------------------------------------------------
    WS.Cells(1, 基列).Resize(1, 位qt主宽).EntireColumn.Hidden = True
    WS.Columns(基列).Columns(位谕展of主龄).Hidden = False
    WS.Columns(基列).Columns(位谕展of主期).Hidden = False
'    WS.Columns(基列).Columns(位谕展of主键).Hidden = False
    WS.Columns(基列).Columns(位谕展of主涨).Hidden = False
    '------------------------------------------------------------------------------------
    '显隐：神谕
    '------------------------------------------------------------------------------------
    If 被研期类 = 常期类为日 Then
        WS.Columns(基列).Columns(位谕展of主七).Hidden = False
    ElseIf 被研期类 = 常期类为周 Then
    ElseIf 被研期类 = 常期类为月 Then
        WS.Columns(基列).Columns(位谕展of主七).Hidden = False
    End If
    If 被研期类 <> 常期类为日 Then  '对于非【日类】，隐藏临数据
        WS.Columns(基列).Columns(位谕of周波临涨幅).Hidden = True
        WS.Columns(基列).Columns(位谕of周波临高幅).Hidden = True
    End If
    WS.Columns(基列).Columns(位谕of日波BSPR).Hidden = False
'    WS.Columns(基列).Columns(位谕of月波临涨幅).Hidden = True
'    WS.Columns(基列).Columns(位谕of月波临高幅).Hidden = True
'    WS.Columns(基列).Columns(位谕of月波临低幅).Hidden = True
    WS.Cells(1, 1).Cells(1, 位谕始of族仓).Resize(1, 位谕终of族仓 - 位谕始of族仓 + 1).EntireColumn.Hidden = True
    WS.Columns(位谕of仓类).Hidden = False
    WS.Cells(1, 1).Cells(1, 位谕始of族日段).Resize(1, 位谕终of族日段 - 位谕始of族日段 + 1).EntireColumn.Hidden = True
'========================================================================================
'输出：原始数据
'========================================================================================
    Call UTL数据转换_集ARR2WS(ARRLLL, WS, 2, 列定位)
'========================================================================================
'格式化：原始数据
'========================================================================================
    Dim 基列一期 As Integer
    Dim 基列二期 As Integer
    Dim 基列三期 As Integer
    基列一期 = 列定位
    基列二期 = 列定位 + 花宽单道 * 1
