'        '================================================================================
'        '阶示 与 今涨 匹配度
'        '================================================================================
'        今涨 = WS.Cells(行号遍历, OS基列).Cells(1, 位os结幅PR0).Value
'
'        If 阶示 Like "I*" Or 阶示 Like "K*" Then
'            谱色 = 常色主靛
'            If 今涨 >= 0 Then
'                谱度 = 0
'            ElseIf 今涨 >= -10 Then
'                谱度 = 0.3
'            Else
'                谱度 = 0.6
'            End If
'        ElseIf 阶示 Like "V*" Or 阶示 Like "W*" Then
'            谱色 = 常色主绿
'            If 今涨 <= 0 Then
'                谱度 = 0
'            ElseIf 今涨 <= 10 Then
'                谱度 = 0.3
'            Else
'                谱度 = 0.6
'            End If
'        Else
'            谱色 = 常色十红
'            谱度 = 0
'        End If
'
'        谱列 = 幕数
'        With WS.Cells(行号遍历, 列定位).Cells(1, 谱列)
'            .Value = 阶示
'            .Interior.Color = 谱色
'            .Interior.TintAndShade = 谱度
'            .Font.Color = .Interior.Color
'        End With
        '--------------------------------------------------------------------------------
