'========================================================================================
'========================================================================================
'算展引擎批程：对选定的代码生成报告 LLL/LM/LW/LD
'========================================================================================
'========================================================================================
Function XL算展前调模板( _
          被研期类 As String _
        , Optional 被研数据 As String = "" _
        , Optional 被研算法 As String = "" _
        , Optional 是否外簿 As Boolean = True _
        , Optional 基色底 As Long = 常色研究 _
        ) As Integer
'========================================================================================
    TT = Timer
'========================================================================================
'获取代码列表
'========================================================================================
    Dim 典被研代码 As New Dictionary
    Dim 运行次数 As Integer
    运行次数 = UGSOP拣选引擎圈选(典被研代码)
    '------------------------------------------------------------------------------------
    If 运行次数 = 0 Then
        MsgBox "NP"
        Exit Function
    End If
'========================================================================================
'遍历调用
'========================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Dim 被研代码 As String
    Dim 被研代称 As String
    '------------------------------------------------------------------------------------
    Dim K As Integer
    For K = 1 To 运行次数
        '--------------------------------------------------------------------------------
        被研代码 = 典被研代码.Keys(K - 1)
        被研代称 = 典被研代码.Items(K - 1)
        Call XL算展引擎正程( _
                  被研代码:=被研代码 _
                , 被研期类:=被研期类 _
                , 被研算法:=被研算法 _
                , 是否外簿:=是否外簿 _
                , 基色底:=基色底 _
                )
        '--------------------------------------------------------------------------------
        MSG = MSG & "【" & K & "】" & 被研代码 & " " & 被研代称 & vbCrLf
        Debug.Print "AL算法展示批处理>> ", K, 被研代码, 被研代称
        '--------------------------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    典被研代码.RemoveAll
    Set 典被研代码 = Nothing
    '------------------------------------------------------------------------------------
    UTL宏工具_END
'========================================================================================
'返回
'========================================================================================
    ThisWorkbook.Save
    '------------------------------------------------------------------------------------
    MSG = "算法展示引擎批处理" _
         & vbCrLf & "运行用时：" & CInt(Timer - TT) _
         & vbCrLf & "运行次数：" & 运行次数 _
         & vbCrLf & "运行列表：" _
         & vbCrLf & MSG
    '------------------------------------------------------------------------------------
    Debug.Print MSG
    MsgBox MSG, vbOKOnly, Title:="算法展示批处理"
'========================================================================================
End Function
