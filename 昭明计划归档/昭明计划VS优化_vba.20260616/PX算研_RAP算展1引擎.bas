Function UG区域格程涨幅匹配( _
          WS As Worksheet _
        , 列定位 As Integer _
        , OS基列 As Integer _
        , Optional 是否清理 As Boolean = True _
        , Optional 行定位 As Integer = 1 _
        ) As Integer
'========================================================================================
'行数
'========================================================================================
    Dim 末行 As Integer
    末行 = WS.Cells(65536, OS基列).End(xlUp).Row
    If 末行 < 2 Then Exit Function
'========================================================================================
'列格式
'========================================================================================
    Dim 幕数 As Integer
    幕数 = 1
    '------------------------------------------------------------------------------------
    With WS.Cells(行定位, 列定位).Resize(1, 幕数).EntireColumn
        '--------------------------------------------------------------------------------
        If 是否清理 = True Then
            .Interior.Color = 常色主黑
            .ClearContents
        End If
        '--------------------------------------------------------------------------------
        .Font.Size = 5
        .ColumnWidth = 2
        .HorizontalAlignment = xlLeft
        .NumberFormatLocal = "0"
        '--------------------------------------------------------------------------------
    End With
'========================================================================================
'列内容
'========================================================================================
    Dim 谱列 As Integer
    Dim 谱色 As Long
    Dim 谱度 As Double
    Dim 阶示 As String
    Dim 今涨 As Double
    '------------------------------------------------------------------------------------
    Dim 行号遍历 As Integer
    For 行号遍历 = 行定位 + 1 To 末行
        '================================================================================
        '阶示图谱
        '================================================================================
        阶示 = WS.Cells(行号遍历, OS基列).Cells(1, 位os阶示).Value
        今涨 = WS.Cells(行号遍历, OS基列).Cells(1, 位os结幅PR0).Value
        '================================================================================
        '阶示 与 今涨 匹配度
        '================================================================================
        If 阶示 Like "I*" Or 阶示 Like "K*" Then
            If 今涨 >= 0 Then
                谱色 = 常色主白
                谱度 = 0
            Else
                谱色 = 常色主靛
                
                If 今涨 <= -5 Then
                    谱度 = 0
                Else
                    谱度 = (5 + 今涨) / 10
                End If
            End If
        ElseIf 阶示 Like "V*" Or 阶示 Like "W*" Then
            If 今涨 <= 0 Then
                谱色 = 常色主白
                谱度 = 0
            Else
                谱色 = 常色主绿
                If 今涨 >= 5 Then
                    谱度 = 0
                Else
                    谱度 = (5 - 今涨) / 10
                End If
            End If
        Else
            谱色 = 常色主黄
            谱度 = 0
        End If
        '================================================================================
        '输出
        '================================================================================
        谱列 = 幕数
        With WS.Cells(行号遍历, 列定位).Cells(1, 谱列)
            .Value = 阶示
            .Interior.Color = 谱色
            .Interior.TintAndShade = 谱度
            .Font.Color = .Interior.Color
        End With
        '--------------------------------------------------------------------------------
    Next 行号遍历
'========================================================================================
'首行
'========================================================================================
    With WS.Cells(行定位, 列定位).Resize(1, 幕数)
        .HorizontalAlignment = xlCenter
        .Interior.Color = 常色主黑
        .Font.ColorIndex = 2
        .Font.Bold = True
        .Font.Size = 10
        '--------------------------------------------------------------------------------
        .Cells(1, 1) = "匹"
        '--------------------------------------------------------------------------------
    End With
'========================================================================================
'边框
'========================================================================================
    With WS.Cells(行定位, 列定位)
        '--------------------------------------------------------------------------------
        With .Resize(1, 幕数).EntireColumn
            With .Borders(xlEdgeLeft)
                .LineStyle = xlContinuous
                .ColorIndex = 56
                .Weight = xlMedium
            End With
            With .Borders(xlEdgeRight)
                .LineStyle = xlContinuous
                .ColorIndex = 56
                .Weight = xlMedium
            End With
        End With
        '--------------------------------------------------------------------------------
    End With
'========================================================================================
'返回
'========================================================================================
    UG区域格程涨幅匹配 = 列定位 + 幕数
End Function
