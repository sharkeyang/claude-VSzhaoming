'========================================================================================
'========================================================================================
'功能：单界明细导入
'========================================================================================
'========================================================================================
Function XL算展数程单期( _
          ARRLLL As Variant _
        , 指定代码 As String _
        , 指定期类 As String _
        ) As Integer
'========================================================================================
'参数设置
'========================================================================================
    Dim 指定结日 As Date
    指定结日 = Date
'========================================================================================
'导入外部数据
'========================================================================================
    '------------------------------------------------------------------------------------
    '导入数据：日类
    '------------------------------------------------------------------------------------
    Dim ARRCSVD As Variant
    Dim 计数日类 As Integer
    计数日类 = STBASE取据引擎_工具取据由外库(ARRCSVD, 指定代码, 指定结期上限:=指定结日)
    If 计数日类 < 1 Then Exit Function
    '------------------------------------------------------------------------------------
    '转换数据：日类
    '------------------------------------------------------------------------------------
    Dim ARRDATAD As Variant
    计数日类 = STBASE取据引擎_工具结算数据转换(ARRCSVD, ARRDATAD, 常期类为日, 是否去重:=True)
    '------------------------------------------------------------------------------------
    '转换数据：周类
    '------------------------------------------------------------------------------------
    Dim ARRDATAW As Variant
    Dim 计数周类 As Integer
    计数周类 = STBASE取据引擎_工具结算数据转换(ARRCSVD, ARRDATAW, 常期类为周, 是否去重:=True)
'========================================================================================
'合并
'========================================================================================
    '------------------------------------------------------------------------------------
    '结算：日类
    '------------------------------------------------------------------------------------
    Dim ARROSD As Variant
    Call STBASE结算引擎_全点基组数程(ARROSD, ARRDATAD, 指定代码, 常期类为日)
    Erase ARRCSVD
    '------------------------------------------------------------------------------------
    '结算：周类
    '------------------------------------------------------------------------------------
    Dim ARROSW As Variant
    Call STBASE结算引擎_全点基组数程(ARROSW, ARRDATAW, 指定代码, 常期类为周)
    Erase ARRDATAW
    '------------------------------------------------------------------------------------
    '合并
    '------------------------------------------------------------------------------------
    If 指定期类 = 常期类为日 Then
        ARRLLL = ARROSD
        XL算展数程单期 = 计数日类
    ElseIf 指定期类 = 常期类为周 Then
        ARRLLL = ARROSW
        XL算展数程单期 = 计数周类
    End If
    Erase ARROSD
    Erase ARROSW
'========================================================================================
End Function



