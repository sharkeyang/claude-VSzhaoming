               谱度 = 0.5
               谱色 = 常色主绿
           Case "VY"
               谱列 = 4
               谱度 = 0.5
               谱色 = 常色主绿
           Case "VX"
               谱列 = 3
               谱度 = 0.5
               谱色 = 常色主绿
           Case "VW"
               谱列 = 2
               谱度 = 0.5
               谱色 = 常色主绿
           '----------
           Case Else
               谱列 = 1
               谱度 = 0
               谱色 = 常色十红
           '----------
        End Select
            
        With WS.Cells(行号遍历, 列定位).Cells(1, 谱列)
            .Value = 阶示
            .Interior.Color = 谱色
            .Interior.TintAndShade = 谱度
