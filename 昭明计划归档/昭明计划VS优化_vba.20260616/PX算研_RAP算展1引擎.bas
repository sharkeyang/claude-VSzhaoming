'========================================================================================
'========================================================================================
'格式化：重组
'========================================================================================
'========================================================================================
Function UG区域格程重组( _
          重输始列数组 As Variant _
        , 重输指标数组 As Variant _
        , WS As Worksheet _
        , 基列 As Integer _
        ) As Integer
'========================================================================================
'重组维度
'========================================================================================
    Dim 重维 As Integer
    重维 = UBound(重输始列数组) - LBound(重输始列数组) + 1
'========================================================================================
'重组信息
'========================================================================================
    Dim 重组信息偏离 As Integer
    Dim 重组信息宽度 As Double
    Dim 重组信息单元 As Range
    
    Dim 重组信息计数 As Integer
    重组信息计数 = 0
    Dim 遍历重组信息 As Integer
    For 遍历重组信息 = LBound(重输指标数组, 1) To UBound(重输指标数组, 1)
        '--------------------------------------------------------------------------------
        '重组输出
        '--------------------------------------------------------------------------------
        If Not VBA.IsMissing(重输指标数组(遍历重组信息)) Then
            重组信息计数 = 重组信息计数 + 1
            Set 重组信息单元 = WS.Cells(1, 基列 + (重组信息计数 - 1) * 重维)
            '----------------------------------------------------------------------------
            重组信息偏离 = 重输指标数组(遍历重组信息)(0)
            '排列顺序
            For I = LBound(重输始列数组) To UBound(重输始列数组)
                WS.Columns(重输始列数组(I)).Columns(重组信息偏离).Copy 重组信息单元.Offset(0, I)
            Next
            '----------------------------------------------------------------------------
            重组信息宽度 = 重输指标数组(遍历重组信息)(1)
            重组信息单元.Resize(1, 重维).EntireColumn.ColumnWidth = 重组信息宽度
            '----------------------------------------------------------------------------
            Set 重组信息单元 = Nothing
        '--------------------------------------------------------------------------------
        '分割边框
        '--------------------------------------------------------------------------------
        Else
            With WS.Cells(1, 基列).Cells(1, 重组信息计数 * 重维).EntireColumn.Borders(xlEdgeRight)
                .LineStyle = xlContinuous
                .Color = 常色二灰
                .Weight = xlThin
            End With
        End If
        '--------------------------------------------------------------------------------
    Next 遍历重组信息
'========================================================================================
'区域格式化
'========================================================================================
    With WS.Cells(1, 基列).Resize(1, 重组信息计数 * 重维).EntireColumn
        .Interior.Color = 常色六灰
        '--------------------------------------------------------------------------------
        '.Hidden = False
        '--------------------------------------------------------------------------------
        '.Borders(xlInsideVertical).LineStyle = xlNone
        '.Borders(xlInsideHorizontal).LineStyle = xlNone
        '.Borders(xlDiagonalDown).LineStyle = xlNone
        '.Borders(xlDiagonalUp).LineStyle = xlNone
        '.Borders(xlEdgeLeft).LineStyle = xlNone
        '.Borders(xlEdgeRight).LineStyle = xlNone
        '.Borders(xlEdgeTop).LineStyle = xlNone
        '.Borders(xlEdgeBottom).LineStyle = xlNone
        '--------------------------------------------------------------------------------
        With .Borders(xlEdgeLeft)
            .LineStyle = xlContinuous
            .Color = 常色主黑
            .Weight = xlMedium
        End With
        With .Borders(xlEdgeRight)
            .LineStyle = xlContinuous
            .Color = 常色主黑
            .Weight = xlMedium
        End With
        '--------------------------------------------------------------------------------
    End With
'========================================================================================
'返回
'========================================================================================
    UG区域格程重组 = 基列 + 重组信息计数 * 重维
'========================================================================================
End Function




















