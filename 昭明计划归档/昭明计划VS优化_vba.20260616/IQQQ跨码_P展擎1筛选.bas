Attribute VB_Name = "IQQQ跨码_P展擎1筛选"
Public Const 常列标签类别 = 位qt代码
Public Const 常列标签计数 = 位谕of日基月局          '位qt在池                '位qt行益
Public Const 常列标签注释 = 位谕of日层联动          '位qt在池        '注意：避免备隐藏





Function IQQQ展擎筛程至A1册按全数据( _
          ByRef WB As Workbook _
        , ByRef 谕组 As Variant _
        , Optional ByVal 参of筛决策剔池 As Boolean = True _
        , Optional ByVal 参of筛决策详表 As Boolean = False _
        , Optional ByVal 出章模式 As String = "" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'验证
'========================================================================================
    Dim 计数谕组 As Integer
    计数谕组 = UBound(谕组, 1) - LBound(谕组, 1) + 1
    If 计数谕组 = 0 Then Exit Function
'    '------------------------------------------------------------------------------------
'    '输出数组：测试
'    '------------------------------------------------------------------------------------
'    Dim WSYM As Worksheet
'    Call PBASE格程工具_表操工表新增(WSYM, "SSS", WB:=ThisWorkbook, 基色底:=常色十红)
'    Call UTL数据转换_集ARR2WS(谕组, WSYM)
'========================================================================================
'声明变量
'========================================================================================
    Dim 本程前缀 As String
    本程前缀 = 常簿缀选日 & "Y"
    '--------------------------------------------------
    Dim MSG As String
    Dim 表名 As String
    Dim CIDL As String
    Dim X  As Integer
    '--------------------------------------------------
    Dim 计码股萎变活 As Integer
    计码股萎变活 = 0
    Dim 计码股萎始终 As Integer
    计码股萎始终 = 0
    Dim 计码股Qb As Integer
    计码股Qb = 0
    Dim 计码股Q8 As Integer
    计码股Q8 = 0
    Dim 计码股Qo As Integer
    计码股Qo = 0
    Dim 计码池黑 As Integer
    计码池黑 = 0
    Dim 计码池内 As Integer
    计码池内 = 0
    Dim 计码池外 As Integer
    计码池外 = 0
    Dim 计码市指 As Integer
    计码市指 = 0
    Dim 计码市基 As Integer
    计码市基 = 0
    Dim 计码股总 As Integer
    计码股总 = 0
    '-----------------------------------------------
    Dim 计码股月尊比柱A As Integer
    计码股月尊比柱A = 0
    Dim 计码股月尊比柱B As Integer
    计码股月尊比柱B = 0
    Dim 计码股月尊比柱C As Integer
    计码股月尊比柱C = 0
    Dim 计码股月尊比柱D As Integer
    计码股月尊比柱D = 0
    '-----------------------------------------------
    Dim 计码股日DJEC之上甲 As Integer
    计码股日DJEC之上甲 = 0
    Dim 计码股日DJEC之上乙 As Integer
    计码股日DJEC之上乙 = 0
    '--------------------------------------------------
    '周层三鳄第二位分布
    Dim 计码三鳄金 As Integer
    计码三鳄金 = 0
    Dim 计码三鳄银 As Integer
    计码三鳄银 = 0
    Dim 计码三鳄嘘 As Integer
    计码三鳄嘘 = 0
    Dim 计码三鳄唏 As Integer
    计码三鳄唏 = 0
    Dim 计码三鳄屎 As Integer
    计码三鳄屎 = 0
    Dim 计码三鳄尿 As Integer
    计码三鳄尿 = 0
    '-----------------------------------------------
'========================================================================================
'定义典
'========================================================================================
    '------------------------------------------------------------------------------------
    '复盘
    '------------------------------------------------------------------------------------
    Dim 典统周复_幅高20 As New Dictionary
    Dim 典统周复_幅高10 As New Dictionary
    Dim 典统周复_幅涨负10 As New Dictionary
    Dim 典统周复_幅涨负20 As New Dictionary
    Dim 典统周复_幅高零 As New Dictionary
    '-----------------------------------------------------------
    Dim 典筛复日_停今甲 As New Dictionary
    Dim 典筛复日_停今乙 As New Dictionary
    Dim 典筛复日_停今丙 As New Dictionary
    Dim 典筛复日_停今丁 As New Dictionary
    Dim 典筛复日_幅涨4 As New Dictionary
    Dim 典筛复日_幅高4 As New Dictionary
    Dim 典筛复日_停十数3 As New Dictionary
    '------------------------------------------------------------------------------------
    '周复盘：区分仨内是否出现过涨停
    '------------------------------------------------------------------------------------
    Dim 典统周复_周单列屎尿嘘甲 As New Dictionary
    Dim 典统周复_周单列屎尿嘘乙 As New Dictionary
    Dim 典统周复_周单列被 As New Dictionary
    Dim 典统周复_周单列唏 As New Dictionary
    Dim 典统周复_周单列银 As New Dictionary
    Dim 典统周复_周单列警 As New Dictionary
    Dim 典统周复_周活龙猪 As New Dictionary
    Dim 典统周复_周活龙管 As New Dictionary
    Dim 典统周复_周活头震 As New Dictionary
    Dim 典统周复_周萎龙猪 As New Dictionary
    Dim 典统周复_周萎龙管 As New Dictionary
    Dim 典统周复_周萎头震 As New Dictionary
    '------------------------------------------------------------------------------------
    '周层
    '------------------------------------------------------------------------------------
    Dim 典集筛已在池持 As New Dictionary
    Dim 典集筛已在池今 As New Dictionary
    Dim 典集筛已在池白 As New Dictionary
    '---------------------------------------
    Dim 典集筛股性非 As New Dictionary
    Dim 典集筛股性微 As New Dictionary
    Dim 典集筛股性萎 As New Dictionary
    Dim 典集筛股性活 As New Dictionary
    '---------------------------------------
    Dim 典集市板Qe As New Dictionary
    Dim 典集市板Qe2 As New Dictionary
    Dim 典集市板ST As New Dictionary
    Dim 典集市板Qb As New Dictionary
    Dim 典集市板Q8 As New Dictionary
    '------------------------------------------------------------------------------------
    '【日机】
    '------------------------------------------------------------------------------------
    Dim 典筛日外月护屎尿嘘例外 As New Dictionary
    Dim 典筛日外月护M2e As New Dictionary
    Dim 典筛日外月护M3v As New Dictionary
    Dim 典筛日外月护余 As New Dictionary
    '---------------------------------------
    Dim 典筛日外月护A3 As New Dictionary
    Dim 典筛日外月护A1 As New Dictionary
    Dim 典筛日外月护A0 As New Dictionary
    Dim 典筛日外月护C6 As New Dictionary
    Dim 典筛日外月护C4 As New Dictionary
    Dim 典筛日外月护C0 As New Dictionary
    '---------------------------------------
    Dim 典筛日外A7低波_日高lt1 As New Dictionary
    Dim 典筛日外A7低波 As New Dictionary
    Dim 典筛日外A7败多 As New Dictionary
    '---------------------------------------
    Dim 典筛日外A7常_渡区再B As New Dictionary
    Dim 典筛日外A7常_渡区再C As New Dictionary
    Dim 典筛日外A7常_渡区再D As New Dictionary
    Dim 典筛日外月护C7初储 As New Dictionary
    Dim 典筛日外月护A7破 As New Dictionary
    '---------------------------------------
    Dim 典筛日外A7常_剔周丘幅80 As New Dictionary
    Dim 典筛日外A7常_汇震正〇 As New Dictionary
    Dim 典筛日外A7常_汇震WJA劫 As New Dictionary
    Dim 典筛日外A7常_汇头WJB劫 As New Dictionary
    '---------------------------------------
    Dim 典筛日外A7常_主区龙管根 As New Dictionary
    Dim 典筛日外A7常_主区龙管余 As New Dictionary
    Dim 典筛日外A7常_主区龙猪首 As New Dictionary
    Dim 典筛日外A7常_主区龙猪地型4 As New Dictionary
    Dim 典筛日外A7常_主区龙猪地型0 As New Dictionary
    Dim 典筛日外A7常_主区龙猪地型1 As New Dictionary
    Dim 典筛日外A7常_主区龙猪地型2 As New Dictionary
    Dim 典筛日外A7常_主区龙猪地型3 As New Dictionary
'========================================================================================
'筛选：微观 筛群周以日阶森为准绳
'========================================================================================
For X = LBound(谕组, 1) To UBound(谕组, 1)
CIDL = 谕组(X, 位qt代码)
If UBCID是代码(CIDL) = False Then
ElseIf 谕组(X, 位qt停牌) = "S" Then                 '提出停牌
ElseIf Len(谕组(X, 位谕of日波BSHR)) = 0 Then   '剔除无属性信息
Else
    '====================================================================================
    '单独列示：池
    '====================================================================================
            If 谕组(X, 位谕of仓持数) > 0 Then
                    典集筛已在池持.Add Item:=X, Key:=CIDL
            'ElseIf (谕组(X, 位qt在池) = 常池名金 Or 谕组(X, 位qt在池) = 常池名银 Or 谕组(X, 位qt在池) = 常池名铜) Then
            '        典集筛已在池白.Add Item:=X, Key:=CIDL
            '        计码池内 = 计码池内 + 1
            End If
            If 谕组(X, 位qt今池) <> "" Then
                    典集筛已在池今.Add Item:=X, Key:=CIDL
            End If
    '====================================================================================
    '统计全市场
    '====================================================================================
            '============================================================================
            '分布：全市场月尊分布
            '============================================================================
            If 谕组(X, 位qt市板) = 常市板指 Then
                    计码市指 = 计码市指 + 1
            ElseIf 谕组(X, 位qt市板) = 常市板基 Then
                    计码市基 = 计码市基 + 1
                    If 谕组(X, 位谕of日段佰均幅高) >= 0.4 Then      '过滤债类产品
                        典集市板Qe.Add Item:=X, Key:=CIDL
                    Else
                        典集市板Qe2.Add Item:=X, Key:=CIDL
                    End If
            ElseIf InStr(谕组(X, 位qt代称), "ST") > 0 Or InStr(谕组(X, 位qt代称), "退") > 0 Then
                        '剔除：ST/退市
                        计码股ST = 计码股ST + 1
                        典集市板ST.Add Item:=X, Key:=CIDL
            Else
                    '-----------------------------------------------
                    计码股总 = 计码股总 + 1
                    '-----------------------------------------------
                    '统计：按月
                    If 谕组(X, 位谕of月道尊比柱) = "A" Then
                        计码股月尊比柱A = 计码股月尊比柱A + 1
                    ElseIf Left(谕组(X, 位谕of月道尊比柱), 1) = "B" Then
                        计码股月尊比柱B = 计码股月尊比柱B + 1
                    ElseIf Left(谕组(X, 位谕of月道尊比柱), 1) = "C" Then
                        计码股月尊比柱C = 计码股月尊比柱C + 1
                    Else
                        计码股月尊比柱D = 计码股月尊比柱D + 1
                    End If
                    '-----------------------------------------------
                    '统计：按日规则
                    If 谕组(X, 位谕of日类BTZE) > 0 And 谕组(X, 位谕of日类BTZC) > 0 Then
                        计码股日DJEC之上甲 = 计码股日DJEC之上甲 + 1
                        If 谕组(X, 位谕of日类BTZB) > 0 Then
                            计码股日DJEC之上乙 = 计码股日DJEC之上乙 + 1
                        End If
                    End If
                    '-----------------------------------------------
                    '统计前置剔除
                    If 谕组(X, 位qt市板) = 常市板票Qb Then
                        计码股Qb = 计码股Qb + 1
                        典集市板Qb.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位qt市板) = 常市板票Q8 Then
                        计码股Q8 = 计码股Q8 + 1
                        典集市板Q8.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位qt市板) = 常市板票Qo Then
                        计码股Qo = 计码股Qo + 1
                    ElseIf 谕组(X, 位谕of日段股性) = "12变活" Or 谕组(X, 位谕of日段股性) = "13变活" Then
                        计码股萎变活 = 计码股萎变活 + 1
                    ElseIf 谕组(X, 位谕of日段股性) = "0萎" Or 谕组(X, 位谕of日段股性) = "11蔫" Then
                        计码股萎始终 = 计码股萎始终 + 1
                    End If
                    '-----------------------------------------------
                    '统计：周层三鳄第二位分布
                    Select Case Mid(谕组(X, 位谕of周层三鳄), 2, 1)
                    Case "金"
                        计码三鳄金 = 计码三鳄金 + 1
                    Case "银"
                        计码三鳄银 = 计码三鳄银 + 1
                    Case "嘘"
                        计码三鳄嘘 = 计码三鳄嘘 + 1
                    Case "唏"
                        计码三鳄唏 = 计码三鳄唏 + 1
                    Case "屎"
                        计码三鳄屎 = 计码三鳄屎 + 1
                    Case "尿"
                        计码三鳄尿 = 计码三鳄尿 + 1
                    End Select
                    '-----------------------------------------------
            End If
    '====================================================================================
    '机会筛选：根据各单独条件筛选，参数与筛选条件要根据所在时点进行调整（时者势也）。
    '====================================================================================
    IS是否筛选下周冲高 = False
    If 谕组(X, 位qt市板) = 常市板指 Then
    ElseIf 谕组(X, 位qt市板) = 常市板基 Then
    ElseIf InStr(谕组(X, 位qt代称), "ST") > 0 Or InStr(谕组(X, 位qt代称), "退") > 0 Then
    ElseIf 谕组(X, 位qt市板) = 常市板票Qb Then
    Else
            '============================================================================
            '复盘：用于复盘本周
            '============================================================================
                '------------------------------------------------------------------------
                '复盘周类：涨幅异常
                '------------------------------------------------------------------------
                If 谕组(X, 位谕of周波临高幅) >= 20 Then
                        典统周复_幅高20.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of周波临高幅) >= 10 Then
                        典统周复_幅高10.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of周波临涨幅) <= -20 Then
                        典统周复_幅涨负20.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of周波临涨幅) <= -10 Then
                        典统周复_幅涨负10.Add Item:=X, Key:=CIDL
                End If
                If 谕组(X, 位谕of周层猪操作) = "零高" Then               '操作：检查是否继续下探
                        典统周复_幅高零.Add Item:=X, Key:=CIDL
                End If
                '------------------------------------------------------------------------
                '复盘日类：涨幅异常
                '------------------------------------------------------------------------
                If 谕组(X, 位谕of日波龄BTPR9) >= 1 Then
                            If 谕组(X, 位谕of日波龄BTHR9) >= 3 Then
                                典筛复日_停今甲.Add Item:=X, Key:=CIDL
                            ElseIf 谕组(X, 位谕of日波龄BTHR9) >= 2 Then
                                典筛复日_停今乙.Add Item:=X, Key:=CIDL
                            ElseIf 谕组(X, 位谕of日波龄BTPR9) >= 1 Then
                                典筛复日_停今丙.Add Item:=X, Key:=CIDL
                            Else
                                典筛复日_停今丁.Add Item:=X, Key:=CIDL
                            End If
                Else
                            '------------------------------------------------------------
                            '非剔：剧烈波动
                            '------------------------------------------------------------
                            If 谕组(X, 位谕of日段十停数高) >= 3 Then
                                典筛复日_停十数3.Add Item:=X, Key:=CIDL
                            '------------------------------------------------------------
                            '非剔：用于单列本日较大波动。主要用于观察走势，总结能够预测大涨的规律，用于后续选股。
                            '------------------------------------------------------------
                            ElseIf 谕组(X, 位谕of日波BSPR) >= 4 Then
                                典筛复日_幅涨4.Add Item:=X, Key:=CIDL
                            ElseIf 谕组(X, 位谕of日波BSHR) >= 4 Then
                                典筛复日_幅高4.Add Item:=X, Key:=CIDL
                            End If
                            '------------------------------------------------------------
                End If
            '============================================================================
            '复盘：周机筛选
            '----------------------------------------------------------------------------
            '日类筛选：日机只在【根据周机能够预判下柱为冲高】的情况才适用。其他情况没有意义。
            '重新梳理筛选分类：
            '(1)先要把刚上破DJC、刚上破DJB的找出来。
            '(2)再把（顶，DJB）之间的找出来：对于DTZA≤2看是否入管；其余看顶型与柱排。
            '(3)最后看捡漏机会：是否存在下破DJA，下破DJB，并按周柱排列可以捡漏的机会。
            '============================================================================
                '------------------------------------------------------------------------
                '保证以下：是否过滤涨停
                '------------------------------------------------------------------------
                If 谕组(X, 位谕of日波龄BTPR9) >= 1 And InStr(出节模式, "日") > 0 Then
                    '注20260405：区分输出按日类与周类，是否剔除涨停。
                '------------------------------------------------------------------------
                '保证以下：月护符合
                '剔除/C7/C6/C4/C0
                '------------------------------------------------------------------------
                ElseIf InStr(谕组(X, 位谕of日层联动), "屎") > 0 _
                    Or InStr(谕组(X, 位谕of日层联动), "尿") > 0 _
                    Or InStr(谕组(X, 位谕of日层联动), "嘘") > 0 Then
                        If 谕组(X, 位谕of日类BTAB) > 0 Then
                            典统周复_周单列屎尿嘘甲.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日类BTZB) > 0 Then
                            典统周复_周单列屎尿嘘乙.Add Item:=X, Key:=CIDL
                        End If
                ElseIf InStr(谕组(X, 位谕of日层联动), "唏") > 0 Then
                            典统周复_周单列唏.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of日层联动), "银") > 0 Then
                            典统周复_周单列银.Add Item:=X, Key:=CIDL
                '------------------------------------------------------------------------
                '以下均为：金银。寻找DXAB转正。
                '根据“日层段”分类，分别筛选（警：丁戊 DXAB负交）（被：丙 下破DJB）
                '------------------------------------------------------------------------
                ElseIf InStr(谕组(X, 位谕of日层联动), "警") > 0 Then        '日层段：丁戊
                            典统周复_周单列警.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of日层联动), "被") > 0 Then        '日层段：丙
                            典统周复_周单列被.Add Item:=X, Key:=CIDL
                '------------------------------------------------------------------------
                '区分：仨内是否出现过涨停
                '------------------------------------------------------------------------
                Else
                    '--------------------------------------------------------------------
                    '分类：仨曾出现涨停
                    '--------------------------------------------------------------------
                    If 谕组(X, 位谕of日段仨停数高) >= 1 Then
                                If InStr(谕组(X, 位谕of周层波型), "龙猪") > 0 Then
                                    典统周复_周活龙猪.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of周层波型), "龙") > 0 Then
                                    典统周复_周活龙管.Add Item:=X, Key:=CIDL
                                Else
                                    典统周复_周活头震.Add Item:=X, Key:=CIDL
                                End If
                    '--------------------------------------------------------------------
                    '分类：其他
                    '--------------------------------------------------------------------
                    Else
                                If InStr(谕组(X, 位谕of周层波型), "龙猪") > 0 Then
                                    典统周复_周萎龙猪.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of周层波型), "龙管") > 0 Then
                                    典统周复_周萎龙管.Add Item:=X, Key:=CIDL
                                Else
                                    典统周复_周萎头震.Add Item:=X, Key:=CIDL
                                End If
                    End If
                    '--------------------------------------------------------------------
                End If
            '============================================================================
            '============================================================================
            '复盘：用于筛选“下周冲高”机会。
            '注20260110：不要/（低）波动太小/（败）失败太多/（暴）本周涨幅太大/（/X4/X0）下降趋势/顶部震荡
            '============================================================================
            '============================================================================
                    '--------------------------------------------------------------------
                    '过滤：今池
                    '作用20250309：重点关注并在后续筛选中剔除，提高甄别效率。所有分类按照最有后续希望上涨的种类进行分类和排序，从而避免选到今池后不给与充分重视。
                    '--------------------------------------------------------------------
                    If 谕组(X, 位qt今池) <> "" Then
                    '--------------------------------------------------------------------
                    '剔：特殊形态【特停】
                    '注20241023：剔除【涨停】所包含个股，避免重复包含。以下两个条件已经包含在【涨停】筛选之中。
                    '注20241023：此处选择过滤HR8而不是PR8，主要有两个原因，一个是观察冲高规律；另一个是提醒冲高后要及时止盈。
                    '注20260405：区分输出按日类与周类，是否剔除涨停。
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of日波龄BTPR9) >= 1 And InStr(出节模式, "日") > 0 Then
                            If 谕组(X, 位谕of日波龄BTHR9) >= 2 Then
                            ElseIf 谕组(X, 位谕of日波龄BTPR9) >= 1 Then
                            Else
                                IS是否筛选下周冲高 = True       '衔接：后续筛选下周冲高
                            End If
                    '--------------------------------------------------------------------
                    '过滤：                    '
                    '--------------------------------------------------------------------
                    Else
                            '衔接：后续筛选下周冲高
                            IS是否筛选下周冲高 = True
                    End If
            '============================================================================
            '【接力筛选】下柱冲高
            '============================================================================
            If IS是否筛选下周冲高 = True Then
                '------------------------------------------------------------------------
                '剔：不符合，不认为是机会
                '注20260110：要符合WXAB在日类的展开DXCD＞0，以及基本要求WJC在日类的展开DXZE＞0。
                '------------------------------------------------------------------------
                    '--------------------------------------------------------------------
                    '过滤破线：DJE
                    '--------------------------------------------------------------------
                    If (InStr(谕组(X, 位谕of周层三鳄), "屎") > 0 Or InStr(谕组(X, 位谕of周层三鳄), "尿") > 0 Or InStr(谕组(X, 位谕of周层三鳄), "嘘") > 0) _
                    And 谕组(X, 位谕of周类BTZB) > 0 Then
                                    典筛日外月护屎尿嘘例外.Add Item:=X, Key:=CIDL
                    '--------------------------------------------------------------------
                    '过滤破线：DJE
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of日类BTZE) < 0 Then
                    '--------------------------------------------------------------------
                    '过滤破线：DJD
                    '注20250120：将BTZE<0与BTZD<0统一为BTZD<0，作为这种方案，用于发现潜在的备选。
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of日类BTZD) < 0 Then
                '------------------------------------------------------------------------
                '过滤：按月阶
                '------------------------------------------------------------------------
                    '--------------------------------------------------------------------
                    '单列：潜在上升趋势
                    '注20261010：要将B1与B0分别，在底部会有多次震荡，B1的等级要比B0高很多。
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周道月势), "A3") > 0 Or 谕组(X, 位谕of周基月局) = "1e" Then
                                    '应属于主升，但存续时间非常短。故统一提取出来，作为潜在主升。
                                    典筛日外月护A3.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周道月势), "A1") > 0 Then
                                    典筛日外月护A1.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周道月势), "A0") > 0 Then
                                    典筛日外月护A0.Add Item:=X, Key:=CIDL
                    '--------------------------------------------------------------------
                    '单列：下降趋势中的反弹，没有参与的必要。
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周道月势), "C0") > 0 Then
                                    典筛日外月护C0.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周道月势), "C4") > 0 Then
                                    典筛日外月护C4.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周道月势), "C6") > 0 Then
                                    典筛日外月护C6.Add Item:=X, Key:=CIDL
                    '--------------------------------------------------------------------
                    '单列：非A7、非C7
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周道月势), "A7") = 0 And InStr(谕组(X, 位谕of周道月势), "C7") = 0 Then
                                If 谕组(X, 位谕of周基月局) = "2e" Then
                                    典筛日外月护M2e.Add Item:=X, Key:=CIDL
                                ElseIf 谕组(X, 位谕of周基月局) = "3v" Or 谕组(X, 位谕of周基月局) = "4v" Then
                                    典筛日外月护M3v.Add Item:=X, Key:=CIDL
                                Else
                                    典筛日外月护余.Add Item:=X, Key:=CIDL
                                End If
                    '--------------------------------------------------------------------
                    '单列：C7潜在顶部震荡。
                    '注20260320：此处将所有C7集中，因为WXBC劫仅有极少会成为“主升”，所以在此处集中。从而，即使是<低波><败多>，也不包含WXBC情况。
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周道月势), "C7") > 0 Then
                                    典筛日外月护C7初储.Add Item:=X, Key:=CIDL
                                    '注20260303：因存续时间较短，且已经区分地型，不再对（储初）区分是否为龙。
                    ElseIf InStr(谕组(X, 位谕of周层界), "破") > 0 Then
                                    典筛日外月护A7破.Add Item:=X, Key:=CIDL
                '------------------------------------------------------------------------
                '注：以下都是（月护为A7）
                '------------------------------------------------------------------------
                '单列：不适用于“下周冲高”。包含/（低）波动太小/（败）失败太多/（暴）本周涨幅太大。
                '------------------------------------------------------------------------
                    '--------------------------------------------------------------------
                    '剔除：低波（不活跃）
                    '孙类：周均高幅太小。没有操作空间，不适合日类操作。
                    '孙类：日均高幅太小。没有操作空间，不适合日类操作。
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of周波均高幅十) <= 3 Then
                                    典筛日外A7低波.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位谕of日段十均幅高) <= 1.2 Then
                                    '过滤日波动过小，没有操作意义。
                                    典筛日外A7低波_日高lt1.Add Item:=X, Key:=CIDL
                    '--------------------------------------------------------------------
                    '剔除：败多（用于过滤周波动较小的情况，除非有较明确走势，否则不应参与）
                    '剔除（单列只用于个别选择进入长期池，只在周末进行筛选不用于每日筛选）
                    '历史高幅：涉及股性，可能多次出现不冲高情况。
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of周波类) = "2败多" Then
                                    典筛日外A7败多.Add Item:=X, Key:=CIDL
                '------------------------------------------------------------------------
                '注：以下都是（月护为A7）（周波动率大于3%）
                '------------------------------------------------------------------------
                '单列：边角料
                '注20260110：所有WXBC劫已包含在(C7)之中。
                '------------------------------------------------------------------------
                    '--------------------------------------------------------------------
                    '剔除：偏离较大
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of周类BTZC) > 0 And 谕组(X, 位谕of周层盈丘幅) > 80 Then              '操作：检查是否继续上冲
                                典筛日外A7常_剔周丘幅80.Add Item:=X, Key:=CIDL
                    '--------------------------------------------------------------------
                    '单列：过渡期，为经历WJB劫后始终未触顶
                    '注20260303：因存续时间较短，且已经区分地型，不再对（再）区分是否为龙。
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周层波型), "再B") > 0 Then
                                典筛日外A7常_渡区再B.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周层波型), "再C") > 0 Then
                                典筛日外A7常_渡区再C.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周层波型), "再") > 0 Then
                                典筛日外A7常_渡区再D.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周层波型), "震负") > 0 Or InStr(谕组(X, 位谕of周层波型), "头") > 0 Then
                                典筛日外A7常_汇头WJB劫.Add Item:=X, Key:=CIDL   '包含：震负芽（/W3h/W3u）头负芽（/W2I/W2i）头正芽。包含虽经过WJB劫，但较长时间未触顶的情况。
                '------------------------------------------------------------------------
                '注：以下都是（月护为A7）（周波动率大于3%）(主)
                '------------------------------------------------------------------------
                    '--------------------------------------------------------------------
                    '单列：“头”肯定是前面经历了WJB劫。“震”肯定是前面经历了WXZA劫，或WXZB劫（W3h/W3u）。
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周层波型), "震正芽") > 0 Or InStr(谕组(X, 位谕of周层波型), "震正根") > 0 Then
                                典筛日外A7常_汇震WJA劫.Add Item:=X, Key:=CIDL   '包含：震正芽、震正根
                    '--------------------------------------------------------------------
                    '单列：离顶。代表很可能属于【震荡】。
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周层波型), "震") > 0 Then
                                典筛日外A7常_汇震正〇.Add Item:=X, Key:=CIDL
                                '注20250520：：可能属于地型杂，或“帐篷”。仍可能属于阶梯上升过程，仅优于WXZA劫。
                    ElseIf InStr(谕组(X, 位谕of周层波型), "龙管根") > 0 Then
                                典筛日外A7常_主区龙管根.Add Item:=X, Key:=CIDL
                    ElseIf InStr(谕组(X, 位谕of周层波型), "龙管") > 0 Then
                                典筛日外A7常_主区龙管余.Add Item:=X, Key:=CIDL
                    '--------------------------------------------------------------------
                    '单列：/存在WXZA劫（存在上冲动力）/合顶初（属于机会较多情况）。WXZA劫是很可能处于经过高点后的震荡，所以一定要把“蛀”放在“首”之前进行过滤。
                    '注20260520：不再对“首”进行过滤，将其放回各自地型考虑。实质上是，减少顶的重要性，增加地型的重要性。
                    '--------------------------------------------------------------------
                    'ElseIf InStr(谕组(X, 位谕of周层波型), "首") > 0 Then
                    '            典筛日外A7常_主区龙猪首.Add Item:=X, Key:=CIDL
                    '--------------------------------------------------------------------
                    '单列：地型（前四柱是否存在异常柱/跌连/跌吞）
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周层波型), "_4") > 0 Then
                                典筛日外A7常_主区龙猪地型4.Add Item:=X, Key:=CIDL
                    Else
                        If InStr(谕组(X, 位谕of周层波型), "_0") > 0 Then
                                典筛日外A7常_主区龙猪地型0.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层波型), "_1") > 0 Then
                                典筛日外A7常_主区龙猪地型1.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层波型), "_2") > 0 Then
                                典筛日外A7常_主区龙猪地型2.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层波型), "_3") > 0 Then
                                典筛日外A7常_主区龙猪地型3.Add Item:=X, Key:=CIDL
                        End If
                    End If
                '------------------------------------------------------------------------
            End If
            '============================================================================
    End If
    '====================================================================================
    '整体漏斗：周层
    '====================================================================================
            '============================================================================
            '主程序
            '============================================================================
            '----------------------------------------------------------------------------
            '剔除：池
            '注意20230101：仅排除（/池持/池黑/池金银非），非排斥性展示（/池今）
            '----------------------------------------------------------------------------
                    If 参of筛决策剔池 = True And 谕组(X, 位谕of仓持数) > 0 Then
                    ElseIf 参of筛决策剔池 = True And 谕组(X, 位qt在池) = 常池名黑 Then
                    'ElseIf 参of筛决策剔池 = True And (谕组(X, 位qt在池) = 常池名金 Or 谕组(X, 位qt在池) = 常池名银 Or 谕组(X, 位qt在池) = 常池名铜) Then
            '----------------------------------------------------------------------------
            '剔除：市类
            '注意20230101：由于池持也可能包含基金，所以此处仅用于剔除，统计计数放到外部逻辑。
            '注意20240221：已经移至[筛市类]
            '----------------------------------------------------------------------------
                    ElseIf 谕组(X, 位qt市板) = 常市板指 Then
                    ElseIf 谕组(X, 位qt市板) = 常市板基 Then
                    '注20240222：提取不在任何指数基金成分中的股票。现阶段ST退市风险太大，单独列示，不进行买卖操作。
                    ElseIf InStr(谕组(X, 位qt代称), "ST") > 0 Or InStr(谕组(X, 位qt代称), "退") > 0 Then
                    ElseIf 谕组(X, 位qt市板) = 常市板票Qb Then
            '----------------------------------------------------------------------------
            '筛选类别：【非】【新】【萎】【活】
            '【非】20240222：提取不在任何指数基金成分中的股票。现阶段ST退市风险太大，单独列示，不进行买卖操作。
            '【新】20220612：由于科创板与其他短时期上市的股票，无法用按周规律进行甄别，可以单独列示按日分析。
            '【萎】20230101：按照【日均高】过滤，而不要按照【周均高】。用于剔除低波动长期蓝筹股。
            '【活】
            '----------------------------------------------------------------------------
                    ElseIf 谕组(X, 位qt成分) = "N" Then
                            典集筛股性非.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位qt成分) = "It" Then
                            典集筛股性微.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位qt市板) = 常市板票Q8 Or 谕组(X, 位qt市板) = 常市板票Qo Then
                            典集筛股性活.Add Item:=X, Key:=CIDL
                    Else
                        If 谕组(X, 位谕of日段股性) = "12变活" Or 谕组(X, 位谕of日段股性) = "13变活" _
                        Or 谕组(X, 位谕of日段股性) = "0萎" Or 谕组(X, 位谕of日段股性) = "11蔫" Then
                            典集筛股性萎.Add Item:=X, Key:=CIDL
                        Else
                            典集筛股性活.Add Item:=X, Key:=CIDL
                        End If
                    End If
    '====================================================================================
End If
