                                Else
                                    典日正储初_DJC初乙.Add Item:=X, Key:=CIDL
                                End If
                        ElseIf 谕组(X, 位谕of日基日局) = "6w" Then
                                    典日正储初_DJC初6w.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日基日局) = "1v" Then
                                    典日正储初_DJC初1v.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日基日局) = "6v" Then
                                    典日正储初_DJC初6v.Add Item:=X, Key:=CIDL
