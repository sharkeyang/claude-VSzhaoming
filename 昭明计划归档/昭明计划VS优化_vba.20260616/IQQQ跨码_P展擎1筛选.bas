    Dim 典周层正主_汇头WJB劫 As New Dictionary
    Dim 典周层正主_破DJC As New Dictionary
    Dim 典周层正主_破DJB As New Dictionary
    Dim 典周层正主杂 As New Dictionary
    Dim 典周层正主根 As New Dictionary
    Dim 典周层正主栏 As New Dictionary
    Dim 典周层正主栅 As New Dictionary
    Dim 典周层正主枝贯 As New Dictionary
    Dim 典周层正主枝启 As New Dictionary
    Dim 典周层正主梯升a顶 As New Dictionary
    Dim 典周层正主梯升b〇 As New Dictionary
    Dim 典周层正主梯升余 As New Dictionary
    Dim 典周层正主梯交 As New Dictionary
    '-------------
    Dim 典周层正再_汇震WJA劫 As New Dictionary
    Dim 典周层正再_汇头WJB劫 As New Dictionary
    Dim 典周层正再杂 As New Dictionary
    Dim 典周层正再根 As New Dictionary
    Dim 典周层正再栏 As New Dictionary
    Dim 典周层正再栅 As New Dictionary
    Dim 典周层正再枝贯 As New Dictionary
    Dim 典周层正再枝启 As New Dictionary
    Dim 典周层正再梯升 As New Dictionary
    Dim 典周层正再梯升b〇 As New Dictionary
    Dim 典周层正再梯升余 As New Dictionary
    Dim 典周层正再梯交 As New Dictionary
    '-------------
    Dim 典周层正初_汇震WJA劫 As New Dictionary
    Dim 典周层正初_汇头WJB劫 As New Dictionary
    Dim 典周层正初杂 As New Dictionary
    Dim 典周层正初根 As New Dictionary
    Dim 典周层正初栏 As New Dictionary
    Dim 典周层正初栅 As New Dictionary
    Dim 典周层正初枝贯 As New Dictionary
    Dim 典周层正初枝启 As New Dictionary
    Dim 典周层正初梯升 As New Dictionary
    Dim 典周层正初梯交 As New Dictionary
    '-------------
    Dim 典周层正储梯 As New Dictionary
    Dim 典周层正储栏 As New Dictionary
    Dim 典周层正储栅 As New Dictionary
    Dim 典周层正储枝 As New Dictionary
    Dim 典周层正储根 As New Dictionary
    Dim 典周层正储杂 As New Dictionary
    '-------------
    Dim 典周层正破JB排跌 As New Dictionary
    Dim 典周层正破JB排人 As New Dictionary
    Dim 典周层正破JB排升 As New Dictionary
    '---------------------------------------------------
    Dim 典周层负主G触a As New Dictionary
    Dim 典周层负主G触b〇 As New Dictionary
    Dim 典周层负主G震〇 As New Dictionary
    Dim 典周层负主G震芽 As New Dictionary
    Dim 典周层负主G震篪 As New Dictionary
    Dim 典周层负初A触a As New Dictionary
    Dim 典周层负初A触b〇 As New Dictionary
    Dim 典周层负初A震〇 As New Dictionary
    Dim 典周层负初A震芽 As New Dictionary
    Dim 典周层负初A震篪 As New Dictionary
    '-------------
    Dim 典周层负A芽非头4b As New Dictionary
    Dim 典周层负A芽非头4v As New Dictionary
    Dim 典周层负A芽非头4w As New Dictionary
    '-------------
    Dim 典周层负B混 As New Dictionary
    Dim 典周层负C混 As New Dictionary
    Dim 典周层负D混 As New Dictionary
    '------------------------------------------------------------------------------------
    '【冲机】
    Dim 典周机触首 As New Dictionary
    Dim 典周机触升梯 As New Dictionary
    Dim 典周机触升尾跌孕 As New Dictionary
    Dim 典周机r雀升 As New Dictionary
    Dim 典周机特鼎 As New Dictionary
    Dim 典周机特踩 As New Dictionary
    Dim 典周机特升栅 As New Dictionary
    '------------------------------------------------------------------------------------
    '【周地型】
    Dim 典周地型_含4暂 As New Dictionary
    Dim 典周地型_含4蛀 As New Dictionary
    Dim 典周地型_含0 As New Dictionary
    Dim 典周地型_含1 As New Dictionary
    Dim 典周地型_含2 As New Dictionary
    Dim 典周地型_含3 As New Dictionary
    Dim 典周地型_余 As New Dictionary
    '------------------------------------------------------------------------------------
    '【周护型】
    Dim 典周护型_甲乙 As New Dictionary
    Dim 典周护型_丙 As New Dictionary
    Dim 典周护型_己 As New Dictionary
    Dim 典周护型_丁戊 As New Dictionary
'========================================================================================
'筛选：微观 以周为粒度进行柱类分析
'========================================================================================
    For Y = 1 To 典码输出.Count
        X = 典码输出.Items(Y - 1)
        CIDL = 谕组(X, 位qt代码)
        值月局 = 谕组(X, 位谕of周基月局)
        值周局 = 谕组(X, 位谕of周基周局)
'########################################################################################
        '================================================================================
        '按照【周护型】进行细分
        '================================================================================
        If 出节模式 = "周护" Then
            If UBCID是代码(CIDL) = False Then
            ElseIf 谕组(X, 位qt停牌) = "S" Then
                            典周废单停牌.Add Item:=X, Key:=CIDL
            Else
                '========================================================================
                If InStr(谕组(X, 位谕of周层护型), "甲") > 0 Or InStr(谕组(X, 位谕of周层护型), "乙") > 0 Then
                            典周护型_甲乙.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层护型), "丙") > 0 Then
                            典周护型_丙.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层护型), "己") > 0 Then
                            典周护型_己.Add Item:=X, Key:=CIDL
                Else
                            典周护型_丁戊.Add Item:=X, Key:=CIDL
                End If
                '========================================================================
            End If
        End If
        '================================================================================
'########################################################################################
        '================================================================================
        '按照【周地型】进行细分
        '================================================================================
        If 出节模式 = "周地" Then
            If UBCID是代码(CIDL) = False Then
            ElseIf 谕组(X, 位qt停牌) = "S" Then
                            典周废单停牌.Add Item:=X, Key:=CIDL
            Else
                '========================================================================
                If InStr(谕组(X, 位谕of周层波型), "_4暂") > 0 Then
                            典周地型_含4暂.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层波型), "_4蛀") > 0 Then
                            典周地型_含4蛀.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层波型), "_0") > 0 Then
                            典周地型_含0.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层波型), "_1") > 0 Then
                            典周地型_含1.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层波型), "_2") > 0 Then
                            典周地型_含2.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层波型), "_3") > 0 Then
                            典周地型_含3.Add Item:=X, Key:=CIDL
                Else
                            典周地型_余.Add Item:=X, Key:=CIDL
                End If
                '========================================================================
            End If
        End If
        '================================================================================
'########################################################################################
        '================================================================================
        '按照周层进行细分，核心是周横，周层只是附加。
        '================================================================================
        If 出节模式 = "周层" Then
        If UBCID是代码(CIDL) = False Then
        ElseIf 谕组(X, 位qt停牌) = "S" Then
                            典周废单停牌.Add Item:=X, Key:=CIDL
        '--------------------------------------------------------------------------------
        '【出全是否】不只输出DJC之上，而是按照周层范围进行筛选。如果需要仅保留DXZC>0，则利用日类进行筛选。
        '--------------------------------------------------------------------------------
        'ElseIf 出全是否 = False And 谕组(X, 位谕of日类BTZC) < 0 Then
                            '典废单错误.Add Item:=X, Key:=CIDL        '测试用
        '--------------------------------------------------------------------------------
        '单独列示：破
        '[破JB]仍然属于WXBC正，属于比较危险的中间状态，但未达到w4b空头开端。可以等待/w3h/w2I再入。
        '--------------------------------------------------------------------------------
        ElseIf 谕组(X, 位谕of周基周局) = "3w" Or 谕组(X, 位谕of周基周局) = "3v" Then
                        If InStr(谕组(X, 位谕of周层柱排), "跌.") > 0 Then
                                典周层正破JB排跌.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱排), "升.") > 0 Then
                                典周层正破JB排升.Add Item:=X, Key:=CIDL
                        Else
                                典周层正破JB排人.Add Item:=X, Key:=CIDL
                        End If
        '--------------------------------------------------------------------------------
        '单独列示：储
        '注：在WJA之上凡是逆趋势（跌孕/跌吞/跌连）都是机会，需要甄别。
        '不要把[根]与[WJA之上]区分开来，而应该按照是否触顶进行分类
        '--------------------------------------------------------------------------------
        ElseIf InStr(谕组(X, 位谕of周层界), "储") > 0 Then
                        If InStr(谕组(X, 位谕of周层柱型), "梯") > 0 Then
                                典周层正储梯.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "栏") > 0 Then
                                典周层正储栏.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "栅") > 0 Then
                                典周层正储栅.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "枝") > 0 Then
                                典周层正储枝.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "根") > 0 Then
                                典周层正储根.Add Item:=X, Key:=CIDL
                        Else
                                典周层正储杂.Add Item:=X, Key:=CIDL
                        End If
        '--------------------------------------------------------------------------------
        '正向：WJC之上
        '--------------------------------------------------------------------------------
        ElseIf 谕组(X, 位谕of周类BTZC) > 0 Then
                '------------------------------------------------------------------------
                '单独列示：再
                '------------------------------------------------------------------------
                If InStr(谕组(X, 位谕of周层界), "再") > 0 Then
                    If InStr(谕组(X, 位谕of周层波型), "龙") > 0 Then
                        '----------------------------------------------------------------
                        If InStr(谕组(X, 位谕of周层柱型), "根") > 0 Then
                                典周层正再根.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "杂") > 0 Then
                                典周层正再杂.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "枝") > 0 Then
                            If InStr(谕组(X, 位谕of周层柱型), "枝贯") > 0 Then
                                典周层正再枝贯.Add Item:=X, Key:=CIDL
                            Else
                                典周层正再枝启.Add Item:=X, Key:=CIDL
                            End If
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "栅") > 0 Then
                                典周层正再栅.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "梯") > 0 Then
                            '注20251002：先均线后顶型。体现【顶型】是【均线】的子集。
                            If InStr(谕组(X, 位谕of周层柱型), "梯交") > 0 Then
                                典周层正再梯交.Add Item:=X, Key:=CIDL
                            Else
                                典周层正再梯升.Add Item:=X, Key:=CIDL
                            End If
                        Else
                                典周层正再栏.Add Item:=X, Key:=CIDL
                        End If
                        '----------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周层波型), "震正") > 0 Then
                                典周层正再_汇震WJA劫.Add Item:=X, Key:=CIDL   '包含：震正芽、震正根
                    '以下为经历WJB劫后始终未触顶
                    Else
                                典周层正再_汇头WJB劫.Add Item:=X, Key:=CIDL   '包含：震负芽（/W3h/W3u）头负芽（/W2I/W2i）头正芽
                    End If
                '------------------------------------------------------------------------
                '单独列示：初
                '------------------------------------------------------------------------
                ElseIf InStr(谕组(X, 位谕of周层界), "初") > 0 Then
                    If InStr(谕组(X, 位谕of周层波型), "龙") > 0 Then
                        '----------------------------------------------------------------
                        If InStr(谕组(X, 位谕of周层柱型), "根") > 0 Then
                                典周层正初根.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "杂") > 0 Then
                                典周层正初杂.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "枝") > 0 Then
                            If InStr(谕组(X, 位谕of周层柱型), "枝贯") > 0 Then
                                典周层正初枝贯.Add Item:=X, Key:=CIDL
                            Else
                                典周层正初枝启.Add Item:=X, Key:=CIDL
                            End If
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "栅") > 0 Then
                                典周层正初栅.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "梯") > 0 Then
                            If InStr(谕组(X, 位谕of周层柱型), "梯交") > 0 Then
                                典周层正初梯交.Add Item:=X, Key:=CIDL
                            Else
                                典周层正初梯升.Add Item:=X, Key:=CIDL
                            End If
                        Else
                                典周层正初栏.Add Item:=X, Key:=CIDL
                        End If
                        '----------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周层波型), "震正") > 0 Then
                                典周层正初_汇震WJA劫.Add Item:=X, Key:=CIDL   '包含：震正芽、震正根
                    '以下为经历WJB劫后始终未触顶
                    Else
                                典周层正初_汇头WJB劫.Add Item:=X, Key:=CIDL   '包含：震负芽（/W3h/W3u）头负芽（/W2I/W2i）头正芽
                    End If
                '------------------------------------------------------------------------
                '单独列示：主
                '注20251011：【主】的周期不同于过渡期【储初再】。过渡期一般很短，且典型形态类似，要单独列示；而【主】可长可短，所以要对【主】进行更细致的分类。
                '       根据柱型分类，【根杂枝】均为与WJA相关，要把WXZA劫单独出来作为防止顶震的情况。
                '------------------------------------------------------------------------
                Else
                    If InStr(谕组(X, 位谕of周层波型), "龙") > 0 Then
                        '----------------------------------------------------------------
                        '【根杂枝】均为与WJA打交道，有下落如【杂根】，有围绕震荡如【枝】，要把他们与包含升连的主升情况分离。
                        '----------------------------------------------------------------
                        If InStr(谕组(X, 位谕of周层柱型), "根") > 0 Then
                                '为了突出【破WJA】不是趋势结束，应该将所有【破WJA】集中出来。包含：中C、中D、中E
                                典周层正主根.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "杂") > 0 Then
                                典周层正主杂.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "枝") > 0 Then
                            If InStr(谕组(X, 位谕of周层柱型), "枝贯") > 0 Then
                                典周层正主枝贯.Add Item:=X, Key:=CIDL
                            Else
                                典周层正主枝启.Add Item:=X, Key:=CIDL
                            End If
                        ElseIf InStr(谕组(X, 位谕of周层柱型), "栅") > 0 Then
                                典周层正主栅.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        '注20251011：日类下破均线DJC或DJB，只应包含主升情况中的预警，而不应对【根杂枝】等本就靠近DJC的情况进行警示。
                        '----------------------------------------------------------------
                        ElseIf 谕组(X, 位谕of日类BTZC) < 0 Then
                                典周层正主_破DJC.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日类BTZB) < 0 Then
                                典周层正主_破DJB.Add Item:=X, Key:=CIDL
                        Else
                            If InStr(谕组(X, 位谕of周层柱型), "梯") > 0 Then
                                If InStr(谕组(X, 位谕of周层柱型), "梯交") > 0 Then
                                        典周层正主梯交.Add Item:=X, Key:=CIDL
                                Else
                                    If InStr(谕组(X, 位谕of周层界), "a顶") > 0 Then
                                        典周层正主梯升a顶.Add Item:=X, Key:=CIDL
                                    ElseIf InStr(谕组(X, 位谕of周层界), "b〇") > 0 Then
                                        典周层正主梯升b〇.Add Item:=X, Key:=CIDL
                                    Else
                                        典周层正主梯升余.Add Item:=X, Key:=CIDL
                                    End If
                                End If
                            Else
                                    典周层正主栏.Add Item:=X, Key:=CIDL
                            End If
                        End If
                        '----------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of周层波型), "震正") > 0 Then
                                典周层正主_汇震WJA劫.Add Item:=X, Key:=CIDL   '包含：震正芽、震正根
                    '以下为经历WJB劫后始终未触顶
                    Else
                                典周层正主_汇头WJB劫.Add Item:=X, Key:=CIDL   '包含：震负芽（/W3h/W3u）头负芽（/W2I/W2i）头正芽
                    End If
                End If
        '--------------------------------------------------------------------------------
        '负向：WJC之下
        '--------------------------------------------------------------------------------
        Else
                '------------------------------------------------------------------------
                '单独列示：/BA劫/CA劫/BZ劫
                '------------------------------------------------------------------------
                If InStr(谕组(X, 位谕of周层类合), 常枚层类D) > 0 Then
                            典周层负D混.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层类合), 常枚层类C) > 0 Then
                            典周层负C混.Add Item:=X, Key:=CIDL
                ElseIf InStr(谕组(X, 位谕of周层类合), 常枚层类B) > 0 Then
                            典周层负B混.Add Item:=X, Key:=CIDL
                '------------------------------------------------------------------------
                '专门处理：/BC劫
                '------------------------------------------------------------------------
                ElseIf InStr(谕组(X, 位谕of周层类合), 常枚层类A) > 0 Then
                        '----------------------------------------------------------------
                        If 谕组(X, 位谕of周基周局) = "4v" Then
                            典周层负A芽非头4v.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of周基周局) = "4w" Then
                            典周层负A芽非头4w.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        ElseIf 谕组(X, 位谕of周层界) = "_初Aa触" Then            '需要区分是否存在【震荡中a触】【中间是否多处未触顶】
                            典周层负初A触a.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of周层界) = "_初Ab触〇" Then
                            典周层负初A触b〇.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of周层界) = "_初Ac震〇" Then
                            典周层负初A震〇.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of周层界) = "_初Ad震芽" Then
                            典周层负初A震芽.Add Item:=X, Key:=CIDL
                        Else
                            典周层负初A震篪.Add Item:=X, Key:=CIDL
                        End If
                '------------------------------------------------------------------------
                '专门处理：/AZ劫/天劫（aAA）
                '------------------------------------------------------------------------
                ElseIf InStr(谕组(X, 位谕of周层类合), 常枚层类G) > 0 Then
                        '----------------------------------------------------------------
                        If 谕组(X, 位谕of周层界) = "_主Ga触" Then         '需要区分是否存在【震荡中a触】【中间是否多处未触顶】
                            典周层负主G触a.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of周层界) = "_主Gb触〇" Then
                            典周层负主G触b〇.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of周层界) = "_主Gc震〇" Then
                            典周层负主G震〇.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of周层界) = "_主Gd震芽" Then
                            典周层负主G震芽.Add Item:=X, Key:=CIDL
                        Else
                            典周层负主G震篪.Add Item:=X, Key:=CIDL
                        End If
                '------------------------------------------------------------------------
                Else
                                典废单错误.Add Item:=X, Key:=CIDL
                End If
                '------------------------------------------------------------------------
        End If
        End If
        '================================================================================
    Next
