                                If Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符升吞 & 常枚并符跌孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符升吞 Then
                                    典日正再_离上_人尾升吞.Add Item:=X, Key:=CIDL
                                ElseIf Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符跌吞 & 常枚并符升孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符跌吞 Then
                                    典日正再_离上_人尾跌吞.Add Item:=X, Key:=CIDL
                                Else
                                    典日正再_离上_人尾其他.Add Item:=X, Key:=CIDL
                                End If
                            ElseIf InStr(谕组(X, 位谕of日层柱排), "跌.") > 0 Then
                                    典日正再_离上_跌.Add Item:=X, Key:=CIDL
                            Else
                                    典日正再_离上_升.Add Item:=X, Key:=CIDL
                            End If
                        Else
                                    典日正再余仓类.Add Item:=X, Key:=CIDL
                        End If
                '------------------------------------------------------------------------
                '单独列示：主
                '------------------------------------------------------------------------
                Else
                        If 谕组(X, 位谕of仓类) = "_aO" Or 谕组(X, 位谕of仓类) = "_bO" Or 谕组(X, 位谕of仓类) = "_dO" Then
                            '需要防止顶部冲高诱多
                            If InStr(谕组(X, 位谕of日层柱排), "人.") > 0 Then
                                If Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符升吞 & 常枚并符跌孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符升吞 Then
                                    典日正主_合上_人尾升吞.Add Item:=X, Key:=CIDL
                                ElseIf Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符跌吞 & 常枚并符升孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符跌吞 Then
                                    典日正主_合上_人尾跌吞.Add Item:=X, Key:=CIDL
                                Else
                                    典日正主_合上_人尾其他.Add Item:=X, Key:=CIDL
                                End If
                            ElseIf InStr(谕组(X, 位谕of日层柱排), "跌.") > 0 Then
                                    典日正主_合上_跌.Add Item:=X, Key:=CIDL
                            Else
                                If 谕组(X, 位谕of日波龄BTPR0) >= 参阈连阳 Then
                                    典日正主_合上_升尾升连久.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of日层柱型), ".升" & 常枚并符升连) > 0 Then
                                    典日正主_合上_升尾升连.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of日层柱型), ".升" & 常枚并符跌孕) > 0 Then
                                    典日正主_合上_升尾跌单.Add Item:=X, Key:=CIDL
                                Else
                                    典日正主_合上_升尾升单.Add Item:=X, Key:=CIDL
                                End If
                            End If
                        ElseIf 谕组(X, 位谕of仓类) = "_sO" Then
                            If InStr(谕组(X, 位谕of日层柱排), "人.") > 0 Then
                                If Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符升吞 & 常枚并符跌孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符升吞 Then
                                    典日正主_离上_人尾升吞.Add Item:=X, Key:=CIDL
                                ElseIf Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符跌吞 & 常枚并符升孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符跌吞 Then
                                    典日正主_离上_人尾跌吞.Add Item:=X, Key:=CIDL
                                Else
                                    典日正主_离上_人尾其他.Add Item:=X, Key:=CIDL
                                End If
                            ElseIf InStr(谕组(X, 位谕of日层柱排), "跌.") > 0 Then
                                    典日正主_离上_跌.Add Item:=X, Key:=CIDL
                            Else
                                    典日正主_离上_升.Add Item:=X, Key:=CIDL
                            End If
                        Else
                                    典日正主余仓类.Add Item:=X, Key:=CIDL
                        End If
                End If
        '--------------------------------------------------------------------------------
        'ZC之下
        '--------------------------------------------------------------------------------
        Else
                '------------------------------------------------------------------------
                '类别：针对坤BCD
                '------------------------------------------------------------------------
                If InStr(谕组(X, 位谕of日层类合), 常枚层类B) > 0 Or InStr(谕组(X, 位谕of日层类合), 常枚层类C) > 0 Or InStr(谕组(X, 位谕of日层类合), 常枚层类D) > 0 Then
                        If InStr(谕组(X, 位谕of日层类合), 常枚层别根) > 0 Then
                                典日层负BCD根.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of日层类合), 常枚层类B) > 0 Then
                                典日层负B管芽.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of日层类合), 常枚层类C) > 0 Then
                                典日层负C管芽.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of日层类合), 常枚层类D) > 0 Then
                                典日层负D管芽.Add Item:=X, Key:=CIDL
                        End If
                '------------------------------------------------------------------------
                '主升层：只针对【G】
                '------------------------------------------------------------------------
                ElseIf InStr(谕组(X, 位谕of日层类合), 常枚层类G) > 0 Then
                        If InStr(谕组(X, 位谕of日层类合), 常枚层别管) > 0 Then
                            If 谕组(X, 位谕of日龟BT合顶哼) > 0 Then     '合顶：防止尾部触顶
                                '注20240410：为了展示完整流程，仅对管进行特殊情况单列。
                                If 谕组(X, 位谕of日层BSLA) <= -8 Then
                                    典日层负G管顶合剔偏大.Add Item:=X, Key:=CIDL
                                ElseIf 谕组(X, 位谕of日层宽哈JC) <= -20 Then
                                    典日层负G管顶合剔宽大.Add Item:=X, Key:=CIDL
                                ElseIf 谕组(X, 位谕of日波龄BTPR0) <= -3 Then
                                    典日层负G管顶合剔连久.Add Item:=X, Key:=CIDL
                                Else
                                    典日层负G管顶合余.Add Item:=X, Key:=CIDL
                                End If
                            Else
                                    典日层负G管顶离.Add Item:=X, Key:=CIDL
                            End If
                        '----------------------------------------------------------------
                        '针对坤G
                        ElseIf InStr(谕组(X, 位谕of日层类合), 常枚层别根) > 0 Then
                            If 谕组(X, 位谕of日龟BT合顶哼) > 0 Then     '合顶：防止尾部触顶
                                    典日层负G根顶合.Add Item:=X, Key:=CIDL
                            Else
                                    典日层负G根顶离.Add Item:=X, Key:=CIDL
                            End If
                        Else
                            If 谕组(X, 位谕of日龟BT合顶哼) > 0 Then    '合顶：防止尾部触顶
                                    典日层负G芽顶合.Add Item:=X, Key:=CIDL
                            Else
                                    典日层负G芽顶离.Add Item:=X, Key:=CIDL
                            End If
                        End If
                '------------------------------------------------------------------------
                '主升层：只针对【A】
                '------------------------------------------------------------------------
                Else
                        '----------------------------------------------------------------
                        If 谕组(X, 位谕of日基日局) = "6w" Then
                                    典日层负C根6w.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日基日局) = "6v" Then
                                    典日层负B根6v.Add Item:=X, Key:=CIDL
                        Else
                            If InStr(谕组(X, 位谕of日层类合), 常枚层别管) > 0 Then
                                    典日层负A管.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层类合), 常枚层别根) > 0 Then
                                    典日层负A根.Add Item:=X, Key:=CIDL
                            Else
                                    典日层负A芽.Add Item:=X, Key:=CIDL
                            End If
                        End If
                        '----------------------------------------------------------------
                End If
                '------------------------------------------------------------------------
        End If
        '================================================================================
    Next
