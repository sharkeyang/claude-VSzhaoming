    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色43绿, 典码输出:=典周层正储栏, 区签:="回落WJA.【周正储】栏", 区释:="初始")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色43绿, 典码输出:=典周层正储栅, 区签:="回落WJA.【周正储】栅", 区释:="初始")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色43绿, 典码输出:=典周层正储杂, 区签:="回落WJA.【周正储】杂", 区释:="初始")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色43绿, 典码输出:=典周层正储枝, 区签:="贯穿WJA.【周正储】枝", 区释:="初始")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色43绿, 典码输出:=典周层正储根, 区签:="贯穿WJA.【周正储】根", 区释:="初始")
    '----------------------------------------------
    If 出全是否 = True Then
        '----------------------------------------------
        '【破】下破WJB，不属于周操作范围。注20250501
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色灰紫, 强列:=位谕of周层界, 强序:=xlAscending, 典码输出:=典周层正破JB排升, 区签:="破WJB【周正破】排升.勿主动进", 区释:="警惕捡漏")
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色灰紫, 强列:=位谕of周层界, 强序:=xlAscending, 典码输出:=典周层正破JB排人, 区签:="破WJB【周正破】排人.勿主动进", 区释:="警惕捡漏")
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色灰紫, 强列:=位谕of周层界, 强序:=xlAscending, 典码输出:=典周层正破JB排跌, 区签:="破WJB【周正破】排跌.勿主动进", 区释:="警惕捡漏")
        '----------------------------------------------
    End If
    '------------------------------------------------------------------------------------
    '【周负向】
    '------------------------------------------------------------------------------------
    If 出全是否 = True Then
       'Call IQQQ展擎出程至页(WB, 表名, 节色:=节色, 节签:=节缀 & "周层负")
        '----------------------------------------------
        '【入区域】：来自【弃区域】，向上进入【主区域】向下进入【弃区域】
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色八蓝, 典码输出:=典周层负D混, 区签:="__再察【周负D混】", 区释:="警惕诱多")
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色八蓝, 典码输出:=典周层负C混, 区签:="__再察【周负C混】", 区释:="警惕诱多")
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色八蓝, 典码输出:=典周层负B混, 区签:="__再察【周负B芽】", 区释:="震平")
        '----------------------------------------------
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色八灰, 典码输出:=典周层负A芽非头4v, 区签:="__储【周负A非】非4v", 区释:="警惕诱多")
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色八灰, 典码输出:=典周层负A芽非头4w, 区签:="__储【周负A非】非4w", 区释:="警惕诱多")
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色四灰, 典码输出:=典周层负A芽非头4b, 区签:="__初【周负A非】非4b", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六灰, 典码输出:=典周层负初A震篪, 区签:="持【周负初A】震篪", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六灰, 典码输出:=典周层负初A震芽, 区签:="持【周负初A】震芽", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六灰, 典码输出:=典周层负初A震〇, 区签:="持【周负初A】震〇", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色四灰, 典码输出:=典周层负初A触b〇, 区签:="持【周负初A】触b〇", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色四灰, 典码输出:=典周层负初A触a, 区签:="持【周负初A】触a", 区释:="")
        '----------------------------------------------
        '【周负层G】
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六灰, 典码输出:=典周层负主G震篪, 区签:="持【周负主G】震篪", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六灰, 典码输出:=典周层负主G震芽, 区签:="持【周负主G】震芽", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六灰, 典码输出:=典周层负主G震〇, 区签:="持【周负主G】震〇", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色四灰, 典码输出:=典周层负主G触b〇, 区签:="持【周负主G】触b〇", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色四灰, 典码输出:=典周层负主G触a, 区签:="持【周负主G】触a", 区释:="")
        '----------------------------------------------
    End If
    '------------------------------------------------------------------------------------
    '【废区域】
    '------------------------------------------------------------------------------------
    If 出全是否 = True Then
        If (典周废单停牌.Count > 0 Or 典废单错误.Count > 0) Then
            Call IQQQ展擎出程至页(WB, 表名, 节色:=节色, 节签:=节缀 & "【废部分】")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色十红, 典码输出:=典周废单停牌, 区签:="【废】停牌", 区释:="")
            Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色十红, 典码输出:=典废单错误, 区签:="【废】错误", 区释:="")
        End If
    End If
    '------------------------------------------------------------------------------------
End If
'========================================================================================
'按【周护】
'========================================================================================
If 出节模式 = "周护" Then
    '--------------------------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色主靛, 典码输出:=典周护型_甲乙, 区签:="【周护型】甲乙", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六靛, 典码输出:=典周护型_己, 区签:="【周护型】己", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六靛, 典码输出:=典周护型_丙, 区签:="【周护型】丙", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六青, 典码输出:=典周护型_丁戊, 区签:="【周护型】丁戊", 区释:="")
    '--------------------------------------------------------------------------------
End If
'========================================================================================
'按【周地】
'========================================================================================
If 出节模式 = "周地" Then
    '--------------------------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色主靛, 典码输出:=典周地型_含0, 区签:="【周地型】含0无", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六靛, 典码输出:=典周地型_含1, 区签:="【周地型】含1栏", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六靛, 典码输出:=典周地型_含2, 区签:="【周地型】含2栅", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六青, 典码输出:=典周地型_含3, 区签:="【周地型】含3杂", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六青, 典码输出:=典周地型_含4暂, 区签:="【周地型】含4暂", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六青, 典码输出:=典周地型_含4蛀, 区签:="【周地型】含4蛀", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色六黄, 典码输出:=典周地型_余, 区签:="【周地型】出现错误分类", 区释:="")
    '--------------------------------------------------------------------------------
End If
'========================================================================================
'输出：周机
        '精分周类：基于周类开口饭机会的投资策略
        '核心理念：(领悟@20210808)这是一场由周类均线JZ、JA、JC、JE参与的游戏。
        '       当JC小于JE时，是由JZ\JA\JC参与的“小游戏”，即使JZ突破JE，也依然是小游戏；
        '       当JC大于JD后，“小游戏”向“大游戏”继续迈进。
        '       当JC突破JE后，“大游戏”模式正式开启；
        '       当JZ下破JD时，“大游戏”暂停。
        '       综上，《周类1b》是至关重要的状态，部分《周类2i》也十分重要，《周类1w》适当参与。
        '筛选原则：仅仅从周类形态出发进行筛选，基于周类均线JZ、JA、JC、JE进行过滤与筛选。
        '条件要求：
        '（2）上周WBSPA不要过大
        '（3）上周最高点不要过大，不要是上影线或十字星
        '（4）不要连续上涨，可以是连续小阳线，最根本还是不要涨幅太大
        '（5）日线走势符合要求，最低要求为I，最好为D【鼎】
'========================================================================================
'返回
'========================================================================================
    IQQQ展擎筛程至D2节按周层 = MSG
'========================================================================================
End Function
