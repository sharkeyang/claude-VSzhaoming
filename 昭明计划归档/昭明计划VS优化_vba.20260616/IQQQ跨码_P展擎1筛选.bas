'========================================================================================
'========================================================================================
'功能：按照池进行筛选
'========================================================================================
'========================================================================================
Function IQQQ展擎筛程至B1书按池( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章签 As String = "" _
        , Optional ByVal 章色 As Long = 常色43绿 _
        , Optional ByVal 是否建表 As Boolean = False _
        ) As String
'========================================================================================
'验证
'========================================================================================
    If VBA.IsEmpty(谕组) = True Then Exit Function
    '------------------------------------------------------------------------------------
    If 典码输出 Is Nothing Then
        Call UTL数据转换_集组码2典码位(典码位:=典码输出, 组码:=谕组)
    End If
'========================================================================================
'输出准备
'========================================================================================
    Dim 计码输出 As Integer
    计码输出 = 典码输出.Count
    Dim 节签前缀 As String
    节签前缀 = IIf(Len(章签) > 0, 章签 & " ", "")
    Dim 章签输出 As String
    章签输出 = ">" & 节签前缀 & "筛按池：" & 计码输出
    Dim MSG As String
    MSG = ">" & 章签输出 & vbCrLf
    IQQQ展擎筛程至B1书按池 = MSG
    '------------------------------------------------------------------------------------
    If 是否建表 = True And UTL判断工表存在(表名, WB) = True Then Call PBASE格程工具_表操工表删除(表名, WB)
    If 计码输出 = 0 Then
        Exit Function
    Else
        Call IQQQ展擎出程至页(WB, 表名, 章色:=章色, 章签:=章签输出, 是否建表:=是否建表)
    End If
'========================================================================================
'声明变量
'========================================================================================
    Dim CIDL As String
'========================================================================================
'定义典
'========================================================================================
    Dim 典码输出池外 As New Dictionary
    Dim 典码输出池持 As New Dictionary
    Dim 典码输出池金 As New Dictionary
    Dim 典码输出池银 As New Dictionary
    Dim 典码输出池铜 As New Dictionary
    Dim 典码输出池黑 As New Dictionary
'========================================================================================
'筛选：微观 以周为粒度进行柱类分析
'========================================================================================
    For Y = 1 To 典码输出.Count
        X = 典码输出.Items(Y - 1)
        CIDL = 谕组(X, 位qt代码)
        '区分所在池
        If 谕组(X, 位qt在池) = 常池名金 Then
            典码输出池金.Add Item:=X, Key:=CIDL
        ElseIf 谕组(X, 位qt在池) = 常池名银 Then
            典码输出池银.Add Item:=X, Key:=CIDL
        ElseIf 谕组(X, 位qt在池) = 常池名铜 Then
            典码输出池铜.Add Item:=X, Key:=CIDL
        ElseIf 谕组(X, 位qt在池) = 常池名黑 Then
            典码输出池黑.Add Item:=X, Key:=CIDL
        ElseIf 谕组(X, 位谕of仓持数) > 0 Then
            '注20230101：将池持放在金银非之后，不打乱池结构
            典码输出池持.Add Item:=X, Key:=CIDL
        Else
            典码输出池外.Add Item:=X, Key:=CIDL
        End If
    Next
'========================================================================================
'输出
'========================================================================================
    '------------------------------------------------------------------------------------
    '池外
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 典码输出池外, 是否建表:=False, 章色:=常色十绿, 章签:="【池外】", 出章模式:="周层", 出节模式:="日乾")
    '----------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 章色:=常色十绿, 章签:="池持")
    MSG = MSG & IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色主黄, 典码输出:=典码输出池持, 区签:="【池持】", 区释:="")
    '----------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 章色:=常色十绿, 章签:="池白")
    MSG = MSG & IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色主黄, 典码输出:=典码输出池金, 区签:="【池金】", 区释:="")
    MSG = MSG & IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色主黄, 典码输出:=典码输出池银, 区签:="【池银】", 区释:="")
    MSG = MSG & IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色主黄, 典码输出:=典码输出池铜, 区签:="【池铜】", 区释:="")
    '----------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 章色:=常色十绿, 章签:="池黑")
    MSG = MSG & IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色主黄, 典码输出:=典码输出池黑, 区签:="【池黑】", 区释:="")
'========================================================================================
'返回
'========================================================================================
    IQQQ展擎筛程至B1书按池 = MSG
'========================================================================================
End Function
