        '注20240526：以WXCD确定大势，以WJC为丘进行必赢操盘。主选区域包括：
        '   阶0（上破WJC才为备选区/M5e/M6v/M1v，WJC之下不要尝试）
        '   阶13（只以DJC之上）由于持续时间较短，与阶0共同展示。
        '   阶7（大涨幅在DJC之上，在DJC与DJD之间时需要依赖并符进行预测是否会回到DJC之上，但即使回到DJC之上也可能不会再有大涨）
        '   阶46（属于下降趋势的反弹，单独列示，以DJC为操盘线）
        '注20240526：对于WJC之下/w6w/w6v处理，本身由于处于WJC之下不具有可操盘资质，但如果已经沿WJA小碎步爬行较久则可进行小仓尝试，其余WJC之下情况都进行舍弃。对于阶7还有可取之处，对于劫0千万不要尝试，对于劫13完全按照WJC进行操作。
        '================================================================================
                        '----------------------------------------------------------------
                        '剔：
                        '----------------------------------------------------------------
                        '过滤：DXCD负交
                        If 谕组(X, 位谕of日类BTCD) < 0 Then
                            If 谕组(X, 位谕of日类BTCE) < 0 Then
                                典日正单DXCD负交CE负.Add Item:=X, Key:=CIDL
                            Else
                                典日正单DXCD负交CE正.Add Item:=X, Key:=CIDL
                            End If
                        '过滤：DXCD正交.月诱
                        ElseIf 谕组(X, 位谕of日类BTCE) < 0 Then
                                典日正单DXCD正交CE负.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        '剔：不符合范围
                        '----------------------------------------------------------------
                        ElseIf 谕组(X, 位谕of日类BTZD) < 0 Then
                                典日正单BTZD负.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日类BTZC) < 0 Then
                                典日正单BTZC负.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        '以下均为：DXCD>0且DXZC>0
'                        '----------------------------------------------------------------
'                        '剔：【管宽】过大
'                        '----------------------------------------------------------------
'                        ElseIf 谕组(X, 位谕of日层偏顶JC) > 20 Then
'                                典日正单宽大20.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        '核心筛选：已经不符合日类规则。只能寄希望于【周类捡漏规则】
                        '----------------------------------------------------------------
                        ElseIf InStr(谕组(X, 位谕of日层界), "破") > 0 Then
                                    典日正界破.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日类BTZA) <= -2 And _
                        (Right(谕组(X, 位谕of日管中符串), 1) = "D" Or Right(谕组(X, 位谕of日管中符串), 1) = "E" Or Right(谕组(X, 位谕of日管中符串), 1) = "F") Then
                                    典日正界DEF余多.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        '核心筛选：再
                        '----------------------------------------------------------------
                        ElseIf InStr(谕组(X, 位谕of日层界), "再") > 0 Then
                            If InStr(谕组(X, 位谕of日层界), "再D") > 0 Then
                                典日正界再D.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层界), "再C") > 0 Then
                                典日正界再C.Add Item:=X, Key:=CIDL
                            Else
                                典日正界再B.Add Item:=X, Key:=CIDL
                            End If
                        '----------------------------------------------------------------
                        '单列：初始突破DJC
                        '----------------------------------------------------------------
                        ElseIf InStr(谕组(X, 位谕of日层界), "初") > 0 Then
                                    典日正界初.Add Item:=X, Key:=CIDL
                        ElseIf InStr(谕组(X, 位谕of日层界), "储") > 0 Then
                                    典日正界储.Add Item:=X, Key:=CIDL
                        '----------------------------------------------------------------
                        '核心筛选：主
                        '----------------------------------------------------------------
                        Else
                            If 谕组(X, 位谕of日层偏顶JC) <= 8 Then
                                典日正界主宽小8.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层界), "Ge") > 0 Then
                                典日正界主Ge.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层界), "Gd") > 0 Then
                                典日正界主Gd.Add Item:=X, Key:=CIDL
                            Else
                                典日正界主Ga.Add Item:=X, Key:=CIDL
                            End If
                        End If
                        '----------------------------------------------------------------
        End If
        '================================================================================
    Next
'========================================================================================
'========================================================================================
'【周机】集中展示
'首先是：WJA介于WJC与WJD之间
'========================================================================================
'走势分类
'========================================================================================
    '--------------------------------------------------------------------------------
    '日局：主
    '--------------------------------------------------------------------------------
    'Call IQQQ展擎出程至页(WB, 表名, 是否建表:=False, 章色:=常色八红, 章签:="【正主】")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色主靛, 典码输出:=典日正界主宽小8, 节签:="【正主】针对管宽(DS哼JC)小【针对初始突破DJC】8")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色八靛, 典码输出:=典日正界主Ga, 节签:="【正主】针对管宽(DS哼JC)中.Gabc")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色八靛, 典码输出:=典日正界主Gd, 节签:="【正主】针对管宽(DS哼JC)中.Gd")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色八靛, 典码输出:=典日正界主Ge, 节签:="【正主】针对管宽(DS哼JC)中.Ge")
    '--------------------------------------------------------------------------------
    '日局：初
    '--------------------------------------------------------------------------------
    'Call IQQQ展擎出程至页(WB, 表名, 是否建表:=False, 章色:=常色43绿, 章签:="【正初】")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色43绿, 典码输出:=典日正界初, 节签:="【正初】")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色43绿, 典码输出:=典日正界储, 区签:="【正储】", 区释:="")
    '--------------------------------------------------------------------------------
    '日局：再
    '--------------------------------------------------------------------------------
    'Call IQQQ展擎出程至页(WB, 表名, 是否建表:=False, 章色:=常色主绿, 章签:="【正再】")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色六紫, 典码输出:=典日正界再B, 节签:="【正再】界B")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色六紫, 典码输出:=典日正界再C, 节签:="【正再】界C")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色六紫, 典码输出:=典日正界再D, 节签:="【正再】界D")
    '--------------------------------------------------------------------------------
    '剔：诱
    '--------------------------------------------------------------------------------
    'Call IQQQ展擎出程至页(WB, 表名, 是否建表:=False, 章色:=常色八红, 章签:="剔除【剔】诱")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色八蓝, 典码输出:=典日正单DXCD正交CE负, 节签:="【剔诱】DXCD正交CE负")
    '--------------------------------------------------------------------------------
    '日局：破
    '--------------------------------------------------------------------------------
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色十橙, 典码输出:=典日正界DEF余多, 节签:="【正初正再】DTZA负.DEF余多")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色八橙, 典码输出:=典日正界破, 节签:="【正破】DTZB负")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色四橙, 典码输出:=典日正单BTZC负, 节签:="【正破】DTZC负")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色四橙, 典码输出:=典日正单BTZD负, 节签:="【正破】DTZD负")
'    '--------------------------------------------------------------------------------
'    '剔：正宽大于20。注20242023：偏离DJC较大属于高位震荡，性质与低波动不同，可以单列。这些只可能属于两种情况，一种是超级主升，另一种是冲高等待回落。两种风险都比较大。
'    '--------------------------------------------------------------------------------
'    'Call IQQQ展擎出程至页(WB, 表名, 是否建表:=False, 章色:=常色八红, 章签:="剔除【正宽】针对管宽≥20")
'    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色十红, 典码输出:=典日正单宽大20, 节签:="【剔诱.正宽】大20")
    '--------------------------------------------------------------------------------
    '剔：弃
    '--------------------------------------------------------------------------------
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色八蓝, 典码输出:=典日正单DXCD负交CE正, 节签:="【剔诱】DXCD负交CE正")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色八蓝, 典码输出:=典日正单DXCD负交CE负, 节签:="【剔诱】DXCD负交CE负")
    '------------------------------------------------------------------------------------
    '剔：停牌
    '------------------------------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色四灰, 典码输出:=典月停牌, 区签:="【停牌】", 区释:="")
'========================================================================================
'返回
'========================================================================================
    IQQQ展擎筛程至D4节按日综 = MSG
'========================================================================================
End Function






Function IQQQ展擎筛程至C1章按护型( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章签 As String = "" _
        , Optional ByVal 章色 As Long = 常色43绿 _
        , Optional ByVal 出章模式 As String = "周护" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'声明变量
'========================================================================================
    Dim CIDL As String
    Dim 是否二筛 As Boolean
'========================================================================================
'定义典
'========================================================================================
    Dim 典周护型停牌 As New Dictionary
    '--------------------------------------------------
    Dim 典月护金A7 As New Dictionary
    Dim 典月护金C7 As New Dictionary
    Dim 典月护金余 As New Dictionary
    Dim 典月护银 As New Dictionary
    Dim 典月护唏 As New Dictionary
    Dim 典月护嘘 As New Dictionary
    Dim 典月护屎 As New Dictionary
    Dim 典月护尿 As New Dictionary
    '--------------------------------------------------
    Dim 典月护金周护ab As New Dictionary
    Dim 典月护金周护r As New Dictionary
    Dim 典月护金周护c As New Dictionary
    Dim 典月护金周护yz As New Dictionary
'========================================================================================
'分类：按【位谕of周层三鳄】第二位精确定位。
'    位谕of周层三鳄 = Left(值WXCD护型,3) & Mid(值WXCD护型,5,1) & Left(周层护型,1) & Mid(周层护型,3,1) & "." & Left(日层护型,1) & Mid(日层护型,3,1)
'    第二位 = Mid(值WXCD护型,2,1)，六种值:
'      金（CD>0.ZC>=ZC）最高品质 → 细分按周道月护 A7/C7/余
'      银（CD<=0.ZD>0）可持有
'      嘘（CD>0.ZC<0）CD嘴.大概率向上
'      唏（CD<=0.ZC>0）CD嘴.大概率向下
'      屎（CD<=0.ZC<=ZC）不触
'      尿（CD>0.ZD<0）不触
'注20260614：改为按三鳄第二位，替代原周道月护InStr模糊匹配。金/银始终输出；嘘唏屎尿由出全是否控制。
'========================================================================================
'========================================================================================
'筛选：微观 以周为粒度进行柱类分析
'========================================================================================
    For Y = 1 To 典码输出.Count
        X = 典码输出.Items(Y - 1)
        CIDL = 谕组(X, 位qt代码)
        '================================================================================
        '按照【月护】进行细分
        '================================================================================
        If 出章模式 = "月护" Then
            If UBCID是代码(CIDL) = False Then
            ElseIf 谕组(X, 位qt停牌) = "S" Then
                        典周护型停牌.Add Item:=X, Key:=CIDL
            Else
                '========================================================================
                        If Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "金" Then
                                    If InStr(谕组(X, 位谕of周道月势), "A7") > 0 Then
                                        典月护金A7.Add Item:=X, Key:=CIDL
                                    ElseIf InStr(谕组(X, 位谕of周道月势), "C7") > 0 Then
                                        典月护金C7.Add Item:=X, Key:=CIDL
                                    Else
                                        典月护金余.Add Item:=X, Key:=CIDL
                                    End If
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "银" Then
                                    典月护银.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "唏" Then
                                    典月护唏.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "嘘" Then
                                    典月护嘘.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "屎" Then
                                    典月护屎.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "尿" Then
                                    典月护尿.Add Item:=X, Key:=CIDL
                        End If
                '========================================================================
            End If
        End If
        '================================================================================
        '按照【周护】进行细分
        '================================================================================
        If 出章模式 = "周护" Then
            If UBCID是代码(CIDL) = False Then
            ElseIf 谕组(X, 位qt停牌) = "S" Then
                        典周护型停牌.Add Item:=X, Key:=CIDL
            Else
                '========================================================================
                        If Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "金" Then
                                    Select Case Mid(谕组(X, 位谕of周层三鳄), 5, 1)
                                    Case "a", "b"
                                        典月护金周护ab.Add Item:=X, Key:=CIDL
                                    Case "r"
                                        典月护金周护r.Add Item:=X, Key:=CIDL
                                    Case "c"
                                        典月护金周护c.Add Item:=X, Key:=CIDL
                                    Case "y", "z"
                                        典月护金周护yz.Add Item:=X, Key:=CIDL
                                    End Select
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "银" Then
                                    典月护银.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "唏" Then
                                    典月护唏.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "嘘" Then
                                    典月护嘘.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "屎" Then
                                    典月护屎.Add Item:=X, Key:=CIDL
                        ElseIf Mid(谕组(X, 位谕of周层三鳄), 2, 1) = "尿" Then
                                    典月护尿.Add Item:=X, Key:=CIDL
                        End If
                '========================================================================
            End If
        End If
        '================================================================================
    Next
'========================================================================================
'按【月护】
'========================================================================================
If 出章模式 = "月护" Then
    '--------------------------------------------------------------------------------
    '始终输出（金/银）
    '--------------------------------------------------------------------------------
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色主靛, 典码输出:=典月护金A7, 节签:="【三鳄】金·A7")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色主靛, 典码输出:=典月护金C7, 节签:="【三鳄】金·C7")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色主靛, 典码输出:=典月护金余, 节签:="【三鳄】金·余")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色八黄, 典码输出:=典月护银, 节签:="【三鳄】银·可持")
    '--------------------------------------------------------------------------------
    '出全是否控制（嘘/唏/屎/尿）
    '--------------------------------------------------------------------------------
    If 出全是否 = True Then
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色四红, 典码输出:=典月护唏, 节签:="【三鳄】唏·CD嘴↓")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色八黄, 典码输出:=典月护嘘, 节签:="【三鳄】嘘·CD嘴↑")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色四红, 典码输出:=典月护屎, 节签:="【三鳄】屎·勿入")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色四红, 典码输出:=典月护尿, 节签:="【三鳄】尿·勿入")
    End If
    '--------------------------------------------------------------------------------
End If
'========================================================================================
'按【周护】
'========================================================================================
If 出章模式 = "周护" Then
    '--------------------------------------------------------------------------------
    '始终输出（金/银）
    '--------------------------------------------------------------------------------
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色主靛, 典码输出:=典月护金周护ab, 节签:="【三鳄】月护金.周护a")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色主靛, 典码输出:=典月护金周护r, 节签:="【三鳄】月护金.周护r")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色主靛, 典码输出:=典月护金周护c, 节签:="【三鳄】月护金.周护c")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色主靛, 典码输出:=典月护金周护yz, 节签:="【三鳄】月护金.周护yz")
    Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色八黄, 典码输出:=典月护银, 节签:="【三鳄】月护银·可持")
    '--------------------------------------------------------------------------------
    '出全是否控制（嘘/唏/屎/尿）
    '--------------------------------------------------------------------------------
    If 出全是否 = True Then
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色四红, 典码输出:=典月护唏, 节签:="【三鳄】月护唏·CD嘴↓")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色八黄, 典码输出:=典月护嘘, 节签:="【三鳄】月护嘘·CD嘴↑")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色四红, 典码输出:=典月护屎, 节签:="【三鳄】月护屎·勿入")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:=出节模式, 出全是否:=出全是否, 节色:=常色四红, 典码输出:=典月护尿, 节签:="【三鳄】月护尿·勿入")
    End If
    '--------------------------------------------------------------------------------
End If
'========================================================================================
    '------------------------------------------------------------------------------------
    '剔：停牌
    '------------------------------------------------------------------------------------
    If 典周护型停牌.Count > 0 Then
        Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色四灰, 典码输出:=典周护型停牌, 区签:="【停牌】", 区释:="", 节色:=常色八灰, 节签:="【停牌】")
    End If
'========================================================================================
'返回
'========================================================================================
    IQQQ展擎筛程至C1章按护型 = MSG
'========================================================================================
End Function




'========================================================================================
'========================================================================================
'功能：按照出节模式输出到块
'是否全部展示：仅【周横】不进行过滤，周局和日局均进行过滤
'模式：/周全/周优/周机/日优
'========================================================================================
'========================================================================================
Function IQQQ展擎筛程至D0节按通用( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章签 As String = "" _
        , Optional ByVal 章色 As Long = 常色十青 _
        , Optional ByVal 节签 As String = "" _
        , Optional ByVal 节色 As Long = 常色十青 _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'验证
'========================================================================================
    If VBA.IsEmpty(谕组) = True Then Exit Function
    '------------------------------------------------------------------------------------
    If 典码输出 Is Nothing Then
        Call UTL数据转换_集组码2典码位(典码位:=典码输出, 组码:=谕组)
    End If
'========================================================================================
'输出准备：设置【节景】节的背景色
'========================================================================================
    Dim 节景 As Long
    If 出节模式 = "周层" Then
        节景 = 常色二红
    ElseIf 出节模式 = "周护" Then
        节景 = 常色五黄
    ElseIf 出节模式 = "周地" Then
        节景 = 常色四黄
    ElseIf 出节模式 = "日层" Then
        节景 = 常色二青
    ElseIf 出节模式 = "日机" Then
        节景 = 常色四青
    End If
'========================================================================================
'输出准备：节签输出
'========================================================================================
    Dim 计码输出 As Integer
    计码输出 = 典码输出.Count
    '------------------------------------------------------------------------------------
    Dim 节签输出 As String
    节签输出 = ">节按" & 出节模式 & ">" & IIf(Len(节签) > 0, 节签, "") & " ：" & 计码输出
    Dim MSG As String
    MSG = 节签输出 & vbCrLf
    IQQQ展擎筛程至D0节按通用 = MSG
    '------------------------------------------------------------------------------------
    If 是否建表 = True And UTL判断工表存在(表名, WB) = True Then Call PBASE格程工具_表操工表删除(表名, WB)
    If 计码输出 = 0 Then
        Exit Function
    ElseIf 是否建表 = True Then
        Call IQQQ展擎出程至页(WB, 表名, 节景:=节景, 节色:=节色, 节签:=节签输出, 是否建表:=是否建表, 章色:=节色)
    Else
        Call IQQQ展擎出程至页(WB, 表名, 节景:=节景, 节色:=节色, 节签:=节签输出)
    End If
'========================================================================================
'输出：出节调用模式
'========================================================================================
    If 出节模式 = "周护" Or 出节模式 = "周地" Or 出节模式 = "周层" Then
        Call IQQQ展擎筛程至D2节按周层(WB, 表名, 谕组, 典码输出, 节色:=节色, 节签:=节签, 出节模式:=出节模式, 出全是否:=出全是否)
    ElseIf InStr(出节模式, "日综") > 0 Then
        Call IQQQ展擎筛程至D4节按日综(WB, 表名, 谕组, 典码输出, 节色:=节色, 节签:=节签, 出节模式:=出节模式, 出全是否:=出全是否)
    ElseIf 出节模式 = "日层" Then
        Call IQQQ展擎筛程至D3节按日层(WB, 表名, 谕组, 典码输出, 节色:=节色, 节签:=节签, 出节模式:=出节模式, 出全是否:=出全是否)
    ElseIf 出节模式 = "日机" Then
        Call IQQQ展擎筛程至D3节按日层(WB, 表名, 谕组, 典码输出, 节色:=节色, 节签:=节签, 出节模式:=出节模式, 出全是否:=出全是否)
    End If
'========================================================================================
End Function



