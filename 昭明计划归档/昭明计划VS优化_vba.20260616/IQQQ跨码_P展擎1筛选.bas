'########################################################################################
'#####################################   QQQ  筛程至页   ################################
'########################################################################################
'########################################################################################






'########################################################################################
'########################################################################################
'#####################################   QQQ  筛程至册   ################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：查看股性分布，主要用来调试池黑
'========================================================================================
'========================================================================================
Function IQQQ展擎筛程至A9册按股性( _
          ByRef WB As Workbook _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章色 As Long = 常色八黄 _
        , Optional ByVal 出章模式 As String = "" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'验证
'========================================================================================
    If VBA.IsEmpty(谕组) = True Then Exit Function
    '------------------------------------------------------------------------------------
    If 典码输出 Is Nothing Then
        Call UTL数据转换_集组码2典码位(典码位:=典码输出, 组码:=谕组)
    End If
''========================================================================================
''输出准备
''========================================================================================
'    Dim 计码输出 As Integer
'    计码输出 = 典码输出.Count
'    Dim MSG As String
'    MSG = MSG & ">" & IIf(Len(章签) > 0, " " & 章签, "") & " 分页按股性：" & 计码输出 & vbCrLf
'    IQQQ展擎筛程至A9册按股性 = MSG
'    '------------------------------------------------------------------------------------
'    If 典码输出.Count = 0 Then Exit Function
'========================================================================================
'定义典
'========================================================================================
    Dim 典跨时类23 As New Dictionary
    Dim 典跨时类22b As New Dictionary
    Dim 典跨时类22a As New Dictionary
    Dim 典跨时类21 As New Dictionary
    Dim 典跨时类33 As New Dictionary
    Dim 典跨时类32 As New Dictionary
    Dim 典跨时类31 As New Dictionary
    Dim 典跨时类13 As New Dictionary
    Dim 典跨时类12 As New Dictionary
    Dim 典跨时类11 As New Dictionary
    Dim 典跨时类0ST退 As New Dictionary
    Dim 典跨时类0停牌 As New Dictionary
    Dim 典跨时类0新股 As New Dictionary
    Dim 典跨时类0萎靡 As New Dictionary
    '------------------------------------------------------------------------------------
    Dim 值幅下限 As Double, 值幅上限 As Double
    Dim CIDL As String
'========================================================================================
'筛选
'========================================================================================
    For Y = 1 To 典码输出.Count
        X = 典码输出.Items(Y - 1)
        CIDL = 谕组(X, 位qt代码)
        If UBCID是中股票(CIDL) = False Then
        Else
        '================================================================================
        '精分股性
        '================================================================================
                '------------------------------------------------------------------------
                '设置波动上下限
                '------------------------------------------------------------------------
                If UBCID是中股票(CIDL) Then
                        值幅下限 = 1.5
                        值幅上限 = 3
                ElseIf UBCID是中股指(CIDL) Or UBCID是中股基(CIDL) Then
                        值幅下限 = 1
                        值幅上限 = 2
                End If
                '------------------------------------------------------------------------
                If InStr(谕组(X, 位qt代称), "ST") > 0 Or InStr(谕组(X, 位qt代称), "退") > 0 Then
                        典跨时类0ST退.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位qt停牌) = "S" Then
                        典跨时类0停牌.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of日段佰计数) < 150 Then
                        典跨时类0新股.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of日段佰均幅高) < 1 Then
                        典跨时类0萎靡.Add Item:=X, Key:=CIDL
                '-------------------------------------------------
                '过滤均高幅：佰小 应分为三类
                ElseIf 谕组(X, 位谕of日段佰均幅高) < 值幅下限 Then
                    If 谕组(X, 位谕of日段仨均幅高) < 值幅下限 Then
                        典跨时类11.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位谕of日段仨均幅高) < 值幅上限 Then
                        典跨时类12.Add Item:=X, Key:=CIDL
                    Else
                        典跨时类13.Add Item:=X, Key:=CIDL
                    End If
                '-------------------------------------------------
                '过滤均高幅：佰大 应分为三类
                ElseIf 谕组(X, 位谕of日段佰均幅高) >= 值幅上限 Then
                    If 谕组(X, 位谕of日段仨均幅高) < 值幅下限 Then
                        典跨时类31.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位谕of日段仨均幅高) < 值幅上限 Then
                        典跨时类32.Add Item:=X, Key:=CIDL
                    Else
                        典跨时类33.Add Item:=X, Key:=CIDL
                    End If
                '-------------------------------------------------
                '过滤均高幅：佰中
                Else
                    If 谕组(X, 位谕of日段仨均幅高) < 值幅下限 Then
                        典跨时类21.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位谕of日段仨均幅高) >= 值幅上限 Then
                        典跨时类23.Add Item:=X, Key:=CIDL
                    ElseIf 谕组(X, 位谕of日段佰均幅高) <= 谕组(X, 位谕of日段仨均幅高) Then
                        典跨时类22a.Add Item:=X, Key:=CIDL
                    Else
                        典跨时类22b.Add Item:=X, Key:=CIDL
                    End If
                End If
                '-------------------------------------------------
        '                '-------------------------------------------------
        ''                If 组历统时(X, 位统时列十均幅高) <值幅下限 Then
        '                If 组历统时(X, 位统时列仨均幅高) + 组历统时(X, 位统时列仨均幅低) > 0 Then
        '                    '远期正常中期正常近期萎靡 冲高回落
        '                    典跨时类22b十低.Add Item:=代称, Key:=CIDL
        '                '过滤：佰均幅高(非小)仨均幅高(非小)
        '                Else
        '                        '远期正常中期正常近期正常
        '                    典跨时类22b十常.Add Item:=代称, Key:=CIDL
        '                End If
        '                '-------------------------------------------------
                '-------------------------------------------------
        End If
    Next
'========================================================================================
'输出
'========================================================================================
    Dim MSG As String
    MSG = MSG & "筛按股性分布：" & 典码输出.Count & vbCrLf
    Dim 表名 As String
    '====================================================================================
    表名 = 常簿缀选日 & "跨时0"
    Call IQQQ展擎出程至页(WB, 表名, 是否建表:=True, 章色:=章色, 章签:="【跨时0】")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 典码输出:=典跨时类0新股, 章色:=章色, 章签:="0新股")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=False, 典码输出:=典跨时类0ST退, 章色:=常色四红, 章签:="0ST退")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=False, 典码输出:=典跨时类0萎靡, 是否建表:=False, 章色:=常色四红, 章签:="0萎靡")
    MSG = MSG & "0停牌" & IQQQ展擎出程至页(WB, 表名, 谕组, 区色:=常色四灰, 典码输出:=典跨时类0停牌, 章签:="0停牌")
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & "跨时X1"
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 典码输出:=典跨时类11, 章色:=章色, 章签:="股性11")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=False, 典码输出:=典跨时类21, 章色:=章色, 章签:="股性21")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=False, 典码输出:=典跨时类31, 章色:=章色, 章签:="股性31")
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & "跨时1"
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 典码输出:=典跨时类13, 章色:=章色, 章签:="股性13")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=False, 典码输出:=典跨时类12, 章色:=章色, 章签:="股性12")
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & "跨时3"
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 典码输出:=典跨时类33, 章色:=章色, 章签:="股性33")
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=False, 典码输出:=典跨时类32, 章色:=章色, 章签:="股性32")
    '------------------------------------------------------------------------------------
    '细分2
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & "跨时23"
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 典码输出:=典跨时类23, 章色:=章色, 章签:="股性23")
    '------------------------------------------------------------------------------------
    '细分22
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & "跨时22a"
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 典码输出:=典跨时类22a, 章色:=章色, 章签:="股性22a")
    '------------------------------------------------------------------------------------
    表名 = 常簿缀选日 & "跨时22b"
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 典码输出:=典跨时类22b, 章色:=章色, 章签:="股性22b")
'========================================================================================
    IQQQ展擎筛程至A9册按股性 = MSG
End Function
