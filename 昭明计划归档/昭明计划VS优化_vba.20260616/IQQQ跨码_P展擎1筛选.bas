Function IQQQ展擎筛程至A2册按市类( _
          ByRef WB As Workbook _
        , ByRef 谕组 As Variant _
        , Optional ByVal 章色 As Long = 常色四灰 _
        , Optional ByVal 出章模式 As String = "" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'准备: 谕组
'========================================================================================
    If VBA.IsEmpty(谕组) = True Then Exit Function
    '------------------------------------------------------------------------------------
    Dim 计数谕组 As Integer
    计数谕组 = UBound(谕组, 1) - LBound(谕组, 1) + 1
    '------------------------------------------------------------------------------------
    Dim 典集谕组 As New Dictionary
    Call UTL数据转换_集组码2典码位(典码位:=典集谕组, 组码:=谕组)
'========================================================================================
'输入：谕组
'========================================================================================
    '------------------------------------------------------------------------------------
    '准备花天
    '------------------------------------------------------------------------------------
    Dim 组花册 As Variant
    Dim WS花天 As Worksheet
    If STBASE外簿工具_花册链接(WS花天, 常花中股) = False Then
        Debug.Print "花册链接失败，无法继续"
        Exit Function
    End If
    Call UTL数据转换_集WS2ARR(组花册, WS花天, 始行:=2, 始列:=1, 总列:=花宽全道)
'========================================================================================
'制作典集
'========================================================================================
    Dim 典集市板Qi As New Dictionary
    Dim 典集市板Qi2 As New Dictionary
    Dim 典集市板Qe As New Dictionary
    Dim 典集市板Qe2 As New Dictionary
    '---------------------------------------
    Dim 典集市板ST As New Dictionary
    Dim 典集市板Q8 As New Dictionary
    Dim 典集市板Qb As New Dictionary
    Dim 典集成分上证50 As New Dictionary
    Dim 典集成分沪深300 As New Dictionary
    Dim 典集成分中证500 As New Dictionary
    Dim 典集成分中证1000 As New Dictionary
    Dim 典集成分中证2000 As New Dictionary
    Dim 典集成分创业板50 As New Dictionary
    Dim 典集成分MSCI中国 As New Dictionary
    Dim 典集成分非 As New Dictionary
'========================================================================================
'输出
'========================================================================================
    Dim CIDL As String
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
            CIDL = 组花册(X, 位列花天CIDL)
            定位谕组行号 = 典集谕组(CIDL)
            '----------------------------------------------------------------------------
            If 组花册(X, 位列花天是否上证50) <> "" Then 典集成分上证50.Add Item:=定位谕组行号, Key:=CIDL
            If 组花册(X, 位列花天是否中股300) <> "" Then 典集成分沪深300.Add Item:=定位谕组行号, Key:=CIDL
            If 组花册(X, 位列花天是否中证500) <> "" Then 典集成分中证500.Add Item:=定位谕组行号, Key:=CIDL
            If 组花册(X, 位列花天是否中证1000) <> "" Then 典集成分中证1000.Add Item:=定位谕组行号, Key:=CIDL
            If 组花册(X, 位列花天是否中证2000) <> "" Then 典集成分中证2000.Add Item:=定位谕组行号, Key:=CIDL
            If 组花册(X, 位列花天是否创业板50) <> "" Then 典集成分创业板50.Add Item:=定位谕组行号, Key:=CIDL
            '----------------------------------------------------------------------------
            If 组花册(X, 位列花天是否MSCI中国) <> "" Then 典集成分MSCI中国.Add Item:=定位谕组行号, Key:=CIDL
            '----------------------------------------------------------------------------
            If 组花册(X, 位列花天是否成分) = "N" Then
                If InStr(组花册(X, 位列花天代称), "ST") > 0 Or InStr(组花册(X, 位列花天代称), "退") > 0 Then
                    典集市板ST.Add Item:=X, Key:=CIDL
                Else
                    典集成分非.Add Item:=定位谕组行号, Key:=CIDL
                End If
            End If
            '----------------------------------------------------------------------------
            If 组花册(X, 位列花天市板) = 常市板指 Then
                    If 谕组(定位谕组行号, 位谕of日段佰均幅高) >= 0.3 Then      '过滤债类产品
                        典集市板Qi.Add Item:=X, Key:=CIDL
                    Else
                        典集市板Qi2.Add Item:=X, Key:=CIDL
                    End If
            ElseIf 组花册(X, 位列花天市板) = 常市板基 Then
                    If 谕组(定位谕组行号, 位谕of日段佰均幅高) >= 0.4 Then      '过滤债类产品
                        典集市板Qe.Add Item:=X, Key:=CIDL
                    Else
                        典集市板Qe2.Add Item:=X, Key:=CIDL
                    End If
            ElseIf 组花册(X, 位列花天市板) = 常市板票Q8 Then
                    典集市板Q8.Add Item:=X, Key:=CIDL
            ElseIf 组花册(X, 位列花天市板) = 常市板票Qb Then
                    典集市板Qb.Add Item:=X, Key:=CIDL
            End If
            '----------------------------------------------------------------------------
    Next
'========================================================================================
'输出：市板
'========================================================================================
    Dim MSG As String
    MSG = MSG & "筛按市类分布：" & vbCrLf
    Dim 表名 As String
    '====================================================================================
    '宽基指数
    '====================================================================================
    '------------------------------------------------------------------------------------
    '剔除
    '------------------------------------------------------------------------------------
'    表名 = 常簿缀选日 & "非"
'    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式,出节模式:=出节模式, 是否建表:=True, 章色:=常色四灰, 典码输出:=典集成分非, 章签:=表名)
    '------------------------------------------------------------------------------------
'    表名 = "It"
'    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色四灰, 典码输出:=典集成分中证2000, 章签:=表名)
'    表名 = "Im"
'    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色四灰, 典码输出:=典集成分中证1000, 章签:=表名)
'    表名 = "IC"
'    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色四灰, 典码输出:=典集成分中证500, 章签:=表名)
'    表名 = "IF"
'    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色四灰, 典码输出:=典集成分沪深300, 章签:=表名)
'    表名 = "IH"
'    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色四灰, 典码输出:=典集成分上证50, 章签:=表名)
    '====================================================================================
    '指数&基金
    '====================================================================================
    表名 = 常市板指
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色二灰, 典码输出:=典集市板Qi, 章签:=表名)
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周德横类, 强序:=xlAscending, 区隐:=区隐, 区色:=常色三灰, 章色:=常色二灰, 典码输出:=典集市板Qi2, 章签:=表名 & "低波", 区释:="")
    表名 = 常市板基
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色二灰, 典码输出:=典集市板Qe, 章签:=表名)
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周德横类, 强序:=xlAscending, 区隐:=区隐, 区色:=常色三灰, 章色:=常色二灰, 典码输出:=典集市板Qe2, 章签:=表名 & "低波", 区释:="")
    WB.Sheets(表名).Columns(位qt代称).ColumnWidth = 15
    '====================================================================================
    '特殊板块
    '====================================================================================
'    表名 = 常簿缀选日 & "MSCI"
'    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组,出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色主黑, 典码输出:=典集成分MSCI中国, 章签:=表名)
    '------------------------------------------------------------------------------------
    表名 = "Qst"     '注20240222：现阶段ST退市风险太大，单独列示，不进行买卖操作。
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色二灰, 典码输出:=典集市板ST, 章签:=表名)
    表名 = 常市板票Q8
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色二灰, 典码输出:=典集市板Q8, 章签:=表名)
    表名 = 常市板票Qb
    MSG = MSG & IQQQ展擎筛程至C0章按通用(WB, 表名, 谕组, 出章模式:=出章模式, 出节模式:=出节模式, 是否建表:=True, 章色:=常色二灰, 典码输出:=典集市板Qb, 章签:=表名)
'========================================================================================
'输出：市板
'========================================================================================
    MSG = ""
    IQQQ展擎筛程至A2册按市类 = MSG
End Function




Function IQQQ展擎筛程至C8章按停( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章签 As String = "" _
        , Optional ByVal 章色 As Long = 常色43绿 _
        , Optional ByVal 出章模式 As String = "" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'声明变量
'========================================================================================
    Dim CIDL As String
'========================================================================================
'定义
'========================================================================================
    Dim 典跨时类停今甲 As New Dictionary
    Dim 典跨时类停今乙 As New Dictionary
    '---------------------------------------
    Dim 典跨时类叠高甲 As New Dictionary
    Dim 典跨时类叠高乙 As New Dictionary
    Dim 典跨时类叠高丙 As New Dictionary
    '---------------------------------------
    Dim 典跨时类停高仨甲 As New Dictionary
    Dim 典跨时类停高仨乙 As New Dictionary
    '---------------------------------------
    Dim 典跨时类停高仨多佰小 As New Dictionary
    Dim 典跨时类停高仨多佰中 As New Dictionary
    Dim 典跨时类停高仨多佰大 As New Dictionary
    Dim 典跨时类停高仨多类0 As New Dictionary
'========================================================================================
'筛选
'========================================================================================
    Dim X As Integer
    For X = LBound(谕组, 1) To UBound(谕组, 1)
    CIDL = 谕组(X, 位qt代码)
    代称 = 谕组(X, 位qt代称)
    If UBCID是中股票(CIDL) Then
            '============================================================================
            '设置波动上下限
            '============================================================================
            If UBCID是中股票(CIDL) Then
                    值幅下限 = 1.5
                    值幅上限 = 3
            ElseIf UBCID是中股指(CIDL) Or UBCID是中股基(CIDL) Then
                    值幅下限 = 1
                    值幅上限 = 2
            End If
            '============================================================================
            '今涨停
            '============================================================================
            If 谕组(X, 位谕of日波龄BTHR9) >= 2 Then
                    典跨时类停今甲.Add Item:=X, Key:=CIDL
            ElseIf 谕组(X, 位谕of日波龄BTHR9) >= 1 Then
                    典跨时类停今乙.Add Item:=X, Key:=CIDL
            '============================================================================
            '叠大涨的标准形态
            '============================================================================
            ElseIf 谕组(X, 位谕of日波叠幅) >= 50 Then
                If InStr(谕组(X, 位谕of日龟顶触), "高") > 0 Or InStr(谕组(X, 位谕of日龟顶触), "撤") > 0 Then
                    典跨时类叠高甲.Add Item:=X, Key:=CIDL
                End If
            ElseIf 谕组(X, 位谕of日波叠幅) >= 40 Then
                If InStr(谕组(X, 位谕of日龟顶触), "高") > 0 Or InStr(谕组(X, 位谕of日龟顶触), "撤") > 0 Then
                    典跨时类叠高乙.Add Item:=X, Key:=CIDL
                End If
            ElseIf 谕组(X, 位谕of日波叠幅) >= 30 Then
                If InStr(谕组(X, 位谕of日龟顶触), "高") > 0 Or InStr(谕组(X, 位谕of日龟顶触), "撤") > 0 Then
                    典跨时类叠高丙.Add Item:=X, Key:=CIDL
                End If
            End If
'            '============================================================================
'            '仨曾涨停数>=3
'            '============================================================================
'            ElseIf 谕组(X, 位谕of日段仨停数高) >= 5 Then
'                    典跨时类停高仨甲.Add Item:=X, Key:=CIDL
'            ElseIf 谕组(X, 位谕of日段仨停数高) >= 3 Then
'                    典跨时类停高仨乙.Add Item:=X, Key:=CIDL
'            '============================================================================
'            '曾涨停：分类
'            '============================================================================
'            ElseIf 谕组(X, 位谕of日段股性) Like "0*" Then
'                If 谕组(X, 位谕of日段仨停数高) >= 2 Then 典跨时类停高仨多类0.Add Item:=X, Key:=CIDL
'            '-------------------------------------------------
'            '过滤均高幅：佰小 应分为三类
'            ElseIf 谕组(X, 位谕of日段佰均幅高) <= 值幅下限 Then
'                If 谕组(X, 位谕of日段仨停数高) >= 2 Then 典跨时类停高仨多佰小.Add Item:=X, Key:=CIDL
'            '-------------------------------------------------
'            '过滤均高幅：佰大 应分为三类
'            ElseIf 谕组(X, 位谕of日段佰均幅高) >= 值幅上限 Then
'                If 谕组(X, 位谕of日段仨停数高) >= 2 Then 典跨时类停高仨多佰大.Add Item:=X, Key:=CIDL
'            '-------------------------------------------------
'            '过滤均高幅：佰中
'            Else
'                If 谕组(X, 位谕of日段仨停数高) >= 2 Then 典跨时类停高仨多佰中.Add Item:=X, Key:=CIDL
'            '============================================================================
'            End If
    End If
    Next
'========================================================================================
'输出
'========================================================================================
'待完成：只有【今涨停】能够参考形态是如何变化的，能够用来提炼标准形态。其他【曾涨停】参考意义并不大。
        '--------------------------------------------------------------------------------
        '今涨停
        '--------------------------------------------------------------------------------
        MSG = MSG & IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色十红, 典码输出:=典跨时类停今甲, 节签:="【今涨停】连板")
        MSG = MSG & IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=True, 节色:=常色十红, 典码输出:=典跨时类停今乙, 节签:="【今涨停】首板")
        '--------------------------------------------------------------------------------
        '叠高
        '--------------------------------------------------------------------------------
