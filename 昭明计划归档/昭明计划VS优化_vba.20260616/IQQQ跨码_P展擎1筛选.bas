'########################################################################################
'########################################################################################
'#####################################   QQQ  筛程至章   ################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：按照出章模式输出到块
'模式：/月护/日乾/活跃/涨停
'========================================================================================
'========================================================================================
Function IQQQ展擎筛程至C0章按通用( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章签 As String = "" _
        , Optional ByVal 章色 As Long = 常色43绿 _
        , Optional ByVal 出章模式 As String = "" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        , Optional ByVal 是否建表 As Boolean = False _
        ) As String
'========================================================================================
'验证
'========================================================================================
    If VBA.IsEmpty(谕组) = True Then Exit Function
    '------------------------------------------------------------------------------------
    If 典码输出 Is Nothing Then
        Call UTL数据转换_集组码2典码位(典码位:=典码输出, 组码:=谕组)
    End If
'========================================================================================
'输出准备：输出模式
'出节调用模式：仅提供【出节模式】自动匹配出章模式。即，[周层]出节模式对应[月护]出章模式；[日层]出节模式对应[日乾]出章模式。
'========================================================================================
    If 出章模式 = "" Then
        If 出节模式 = "周层" Or 出节模式 = "周地" Or 出节模式 = "周护" Then
            出章模式 = "月护"
        ElseIf 出节模式 = "日层" Or 出节模式 = "日机" Then
            出章模式 = "日乾"
        Else
            出章模式 = "混"
        End If
    End If
'========================================================================================
'输出准备：章签
'========================================================================================
    Dim 计码输出 As Integer
    计码输出 = 典码输出.Count
    '------------------------------------------------------------------------------------
    Dim 章签输出 As String
    章签输出 = ">>章按" & IIf(Len(出章模式) > 0, 出章模式, "混") & ">" & IIf(Len(章签) > 0, 章签, "") & "：" & 计码输出
    Dim MSG As String
    MSG = 章签输出 & vbCrLf
    '------------------------------------------------------------------------------------
    If 是否建表 = True And UTL判断工表存在(表名, WB) = True Then Call PBASE格程工具_表操工表删除(表名, WB)
    If 计码输出 = 0 Then
        Exit Function
    Else
        Call IQQQ展擎出程至页(WB, 表名, 是否建表:=是否建表, 章色:=章色, 章签:=章签输出)
    End If
'========================================================================================
'输出：出章调用模式
'========================================================================================
    If InStr(出章模式, "混") > 0 Then
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 典码输出, 出节模式:=出节模式, 出全是否:=出全是否)
    ElseIf InStr(出章模式, "月护") > 0 Or InStr(出章模式, "周护") > 0 Then
        Call IQQQ展擎筛程至C1章按护型(WB, 表名, 谕组, 典码输出, 章色:=章色, 章签:=章签, 出节模式:=出节模式, 出全是否:=出全是否)
    ElseIf InStr(出章模式, "日乾") > 0 Then
        Call IQQQ展擎筛程至C3章按日乾(WB, 表名, 谕组, 典码输出, 章色:=章色, 章签:=章签, 出节模式:=出节模式, 出全是否:=出全是否)
    ElseIf InStr(出章模式, "活") > 0 Then
        Call IQQQ展擎筛程至C8章按活(WB, 表名, 谕组, 典码输出, 章色:=章色, 章签:=章签, 出节模式:=出节模式, 出全是否:=出全是否)
    ElseIf InStr(出章模式, "停") > 0 Then
        MSG = MSG & IQQQ展擎筛程至C8章按停(WB, 表名, 谕组, 典码输出, 章色:=章色, 章签:=章签, 出节模式:=出节模式, 出全是否:=出全是否)
    End If
'========================================================================================
    IQQQ展擎筛程至C0章按通用 = MSG
End Function


