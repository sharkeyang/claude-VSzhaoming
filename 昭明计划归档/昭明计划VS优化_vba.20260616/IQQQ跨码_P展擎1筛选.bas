'========================================================================================
'========================================================================================
'功能：按照活跃进行筛选
'========================================================================================
'========================================================================================
Function IQQQ展擎筛程至C8章按活( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章签 As String = "" _
        , Optional ByVal 章色 As Long = 常色43绿 _
        , Optional ByVal 出章模式 As String = "" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'声明变量
'========================================================================================
    Dim CIDL As String
'========================================================================================
'定义典
'========================================================================================
    '均高幅
    Dim 典集汇活日G3周G6 As New Dictionary
    Dim 典集汇活日G3周G8 As New Dictionary
    Dim 典集汇活日G3周G10 As New Dictionary
    Dim 典集汇活日G3周G14 As New Dictionary
    '---------------------------------------
    Dim 典集汇活日G3周L6日G7 As New Dictionary
    Dim 典集汇活日G3周L6日G5 As New Dictionary
    Dim 典集汇活日G3周L6日G3 As New Dictionary
    '---------------------------------------
    Dim 典集汇活日L3周G10 As New Dictionary
    Dim 典集汇活日L3周G6 As New Dictionary
    Dim 典集汇活日L3周G6低活 As New Dictionary
    '---------------------------------------
    Dim 典集汇活日L3周L6 As New Dictionary
'========================================================================================
'筛选：微观 以周为粒度进行柱类分析
'========================================================================================
    For Y = 1 To 典码输出.Count
        X = 典码输出.Items(Y - 1)
        CIDL = 谕组(X, 位qt代码)
        '================================================================================
        If UBCID是代码(CIDL) = False Then
        ElseIf 谕组(X, 位qt停牌) = "S" Then
        Else
        '================================================================================
            '周均高幅：
            If 谕组(X, 位谕of日段十均幅高) >= 3 Then
                If 谕组(X, 位谕of周波均高幅十) >= 14 Then
                        典集汇活日G3周G14.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of周波均高幅十) >= 10 Then
                        典集汇活日G3周G10.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of周波均高幅十) >= 8 Then
                        典集汇活日G3周G8.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of周波均高幅十) >= 6 Then
                        典集汇活日G3周G6.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of日段十均幅高) >= 7 Then
                        典集汇活日G3周L6日G7.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of日段十均幅高) >= 5 Then
                        典集汇活日G3周L6日G5.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of日段十均幅高) >= 3 Then
                        典集汇活日G3周L6日G3.Add Item:=X, Key:=CIDL
                End If
            ElseIf 谕组(X, 位谕of周波均高幅十) >= 6 Then
                If 谕组(X, 位谕of日段十均幅高) < 2 Then
                        典集汇活日L3周G6低活.Add Item:=X, Key:=CIDL
                ElseIf 谕组(X, 位谕of周波均高幅十) >= 10 Then
                        典集汇活日L3周G10.Add Item:=X, Key:=CIDL
                Else
                        典集汇活日L3周G6.Add Item:=X, Key:=CIDL
                End If
            Else
                        典集汇活日L3周L6.Add Item:=X, Key:=CIDL
            End If
        '================================================================================
        End If
    Next
'========================================================================================
'输出
'========================================================================================
    '--------------------------------------------------------------------------------
    '周均高幅
    '--------------------------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 节色:=常色十青, 节签:="【周均高幅】日G3周G6")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主靛, 典码输出:=典集汇活日G3周G14, 区签:="【周均高幅】>=14", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主靛, 典码输出:=典集汇活日G3周G10, 区签:="【周均高幅】>=10", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主靛, 典码输出:=典集汇活日G3周G8, 区签:="【周均高幅】>=8", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主靛, 典码输出:=典集汇活日G3周G6, 区签:="【周均高幅】>=6", 区释:="")
    '--------------------------------------------------------------------------------
    '日均高幅
    '--------------------------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 节色:=常色十青, 节签:="【日均高幅】日G3")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主黄, 典码输出:=典集汇活日G3周L6日G7, 区签:="【日均高幅】>=7", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主黄, 典码输出:=典集汇活日G3周L6日G5, 区签:="【日均高幅】>=5", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主黄, 典码输出:=典集汇活日G3周L6日G3, 区签:="【日均高幅】>=3", 区释:="")
    '--------------------------------------------------------------------------------
    '周均高幅
    '--------------------------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 节色:=常色十青, 节签:="【周均高幅】日L3周G6")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主白, 典码输出:=典集汇活日L3周G10, 区签:="【活】日L3周G10", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主白, 典码输出:=典集汇活日L3周G6, 区签:="【活】日L3周G6", 区释:="")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色主白, 典码输出:=典集汇活日L3周G6低活, 区签:="【活】日L3周G6", 区释:="")
    '--------------------------------------------------------------------------------
    Call IQQQ展擎出程至页(WB, 表名, 节色:=常色十青, 节签:="【日均高幅】日L3周L6")
    Call IQQQ展擎出程至页(WB, 表名, 谕组, 强列:=位谕of周层三鳄, 强序:=xlDescending, 区色:=常色六灰, 典码输出:=典集汇活日L3周L6, 区签:="【活】日L3周L6", 区释:="")
'========================================================================================
'返回
'========================================================================================
    IQQQ展擎筛程至C8章按活 = MSG
'========================================================================================
End Function






