                                End If
                            ElseIf InStr(谕组(X, 位谕of日层柱排), "跌.") > 0 Then
                                    典日正储初_合上_跌.Add Item:=X, Key:=CIDL
                            Else
                                If 谕组(X, 位谕of日波龄BTPR0) >= 参阈连阳 Then
                                    典日正储初_合上_升尾升连久.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of日层柱型), ".升" & 常枚并符升连) > 0 Then
                                    典日正储初_合上_升尾升连.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of日层柱型), ".升" & 常枚并符跌孕) > 0 Then
                                    典日正储初_合上_升尾跌单.Add Item:=X, Key:=CIDL
                                Else
                                    典日正储初_合上_升尾升单.Add Item:=X, Key:=CIDL
                                End If
                            End If
                        ElseIf 谕组(X, 位谕of仓类) = "_sO" Then
                            If InStr(谕组(X, 位谕of日层柱排), "人.") > 0 Then
                                If Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符升吞 & 常枚并符跌孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符升吞 Then
                                    典日正储初_离上_人尾升吞.Add Item:=X, Key:=CIDL
                                ElseIf Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符跌吞 & 常枚并符升孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符跌吞 Then
                                    典日正储初_离上_人尾跌吞.Add Item:=X, Key:=CIDL
                                Else
                                    典日正储初_离上_人尾其他.Add Item:=X, Key:=CIDL
                                End If
                            ElseIf InStr(谕组(X, 位谕of日层柱排), "跌.") > 0 Then
                                    典日正储初_离上_跌.Add Item:=X, Key:=CIDL
                            Else
                                    典日正储初_离上_升.Add Item:=X, Key:=CIDL
                            End If
                        Else
                                    典日正储初余仓类.Add Item:=X, Key:=CIDL
                        End If
        '--------------------------------------------------------------------------------
        'ZC之上
        '--------------------------------------------------------------------------------
        ElseIf 谕组(X, 位谕of日类BTZC) > 0 Then
                '------------------------------------------------------------------------
                '单独列示：再
                '------------------------------------------------------------------------
                If Left(谕组(X, 位谕of日层界), 1) = "再" Then
                        If 谕组(X, 位谕of日基日局) = "2I" Then
                                    典日正再_漏劫AB2I.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日基日局) = "3h" Then
                                    典日正再_漏劫AB3h.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日基日局) = "2i" Then
                                    典日正再_漏劫AC2i.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of日基日局) = "3u" Then
                                    典日正再_漏劫AC3u.Add Item:=X, Key:=CIDL
                        ElseIf 谕组(X, 位谕of仓类) = "_aO" Or 谕组(X, 位谕of仓类) = "_bO" Or 谕组(X, 位谕of仓类) = "_dO" Then
                            '需要防止顶部冲高诱多
                            If InStr(谕组(X, 位谕of日层柱排), "人.") > 0 Then
                                If Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符升吞 & 常枚并符跌孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符升吞 Then
                                    典日正再_合上_人尾升吞.Add Item:=X, Key:=CIDL
                                ElseIf Right(谕组(X, 位谕of日管并符串), 2) = 常枚并符跌吞 & 常枚并符升孕 Or Right(谕组(X, 位谕of日管并符串), 1) = 常枚并符跌吞 Then
                                    典日正再_合上_人尾跌吞.Add Item:=X, Key:=CIDL
                                Else
                                    典日正再_合上_人尾其他.Add Item:=X, Key:=CIDL
                                End If
                            ElseIf InStr(谕组(X, 位谕of日层柱排), "跌.") > 0 Then
                                    典日正再_合上_跌.Add Item:=X, Key:=CIDL
                            Else
                                If 谕组(X, 位谕of日波龄BTPR0) >= 参阈连阳 Then
                                    典日正再_合上_升尾升连久.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of日层柱型), ".升" & 常枚并符升连) > 0 Then
                                    典日正再_合上_升尾升连.Add Item:=X, Key:=CIDL
                                ElseIf InStr(谕组(X, 位谕of日层柱型), ".升" & 常枚并符跌孕) > 0 Then
                                    典日正再_合上_升尾跌单.Add Item:=X, Key:=CIDL
                                Else
                                    典日正再_合上_升尾升单.Add Item:=X, Key:=CIDL
                                End If
                            End If
