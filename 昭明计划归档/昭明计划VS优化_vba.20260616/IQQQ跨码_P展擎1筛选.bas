'########################################################################################
'========================================================================================
'主程序：按日分类
'特殊组合：主要针对日基周局
'两个重点：一是不被主流覆盖的区域，如6v、5e
'二是：针对周类浪：w2c,2d,2e,3v,1b
'醍醐灌顶20220702：不要针对月线低位过分关注，还是应该遵循周类持仓规则，否则容易落入陷阱。
'领悟20211103：均线走势根据不同的级别可以区分不同的浪。对于大级别均线，如WJCDE，可以用来
'              识别大级别走势，获取大级别利润。但与此同时，在真正的浪中，小级别走势均线
'              DJCDE+DJABC，同样能够区分主升浪。而且，更为重要的是，只有小浪DJABC多头排列，
'              才能够实际赚钱。所以，可以重点关注，三点要求，一是月线阈值要超过，而是周级别
'              多头排列，三是日级别风控（JA破JC清仓；JA破JB关注）
'========================================================================================
'特殊组合
'探索【试仓】机会：
'    【月类】基础2c/1b/1w/1v/2e(只针对6w)
'    【周类】线上：2c/2d/1b/1w/6w/2i/3h
'    【周类】线下：2e/3v/3w(偏离较大)
'执行时间：
'   周四周五周末（SSS）选择本周下跌
'   周一周二周三周四（SCC）选择本周下跌（最好上周也下跌）
'修改目标：只搜索机会进入【机池】，不求全，只求有机会
'========================================================================================
Function IQQQ展擎筛程至C3章按日乾( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 章签 As String = "" _
        , Optional ByVal 章色 As Long = 常色十青 _
        , Optional ByVal 出节模式 As String = "日层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'声明变量
'========================================================================================
    Dim CIDL As String
    Dim 是否二筛 As Boolean
'========================================================================================
'定义典
'========================================================================================
    Dim 典日乾停牌 As New Dictionary
    Dim 典日乾错误 As New Dictionary
    Dim 典日乾禁入 As New Dictionary
'    '---------------------------------------
'    Dim 典日乾正剔宽 As New Dictionary
'    Dim 典日乾正上 As New Dictionary
'    Dim 典日乾正忐 As New Dictionary
'    Dim 典日乾正余 As New Dictionary
'    Dim 典日乾正一 As New Dictionary
'    Dim 典日乾正× As New Dictionary
''    Dim 典日乾正WA入E As New Dictionary
''    Dim 典日乾正WB入D As New Dictionary
''    Dim 典日乾正WC入D As New Dictionary
''    Dim 典日乾正WG主龙 As New Dictionary
'    '---------------------------------------
'    Dim 典日乾负剔宽 As New Dictionary
'    Dim 典日乾负WA入E As New Dictionary
'    Dim 典日乾负WB入D As New Dictionary
'    Dim 典日乾负WC入D As New Dictionary
'    Dim 典日乾负WG主龙 As New Dictionary
    '---------------------------------------
    Dim 典日乾日联屎尿屁 As New Dictionary
    Dim 典日乾日联铜 As New Dictionary
    Dim 典日乾日联银 As New Dictionary
    Dim 典日乾日联金警 As New Dictionary
    Dim 典日乾日联金余 As New Dictionary
    '---------------------------------------
    Dim 典日乾CD正ZC正顶 As New Dictionary
    Dim 典日乾CD正余 As New Dictionary
    Dim 典日乾CD负 As New Dictionary
'========================================================================================
'筛选：微观 以周为粒度进行柱类分析
'========================================================================================
    For Y = 1 To 典码输出.Count
        X = 典码输出.Items(Y - 1)
        CIDL = 谕组(X, 位qt代码)
        值日基月局 = 谕组(X, 位谕of日基月局)
        值日基周局 = 谕组(X, 位谕of日基周局)
        值日基日局 = 谕组(X, 位谕of日基日局)
        '================================================================================
        If UBCID是代码(CIDL) = False Then
                Stop
        ElseIf 谕组(X, 位qt停牌) = "S" Then
                典日乾停牌.Add Item:=X, Key:=CIDL
        '================================================================================
        '注20260426：按WTZA分类：当满足基本条件（WXZC＞0，WXAB＞0，WXZB＞0），按WXZA分类：WTZA≥2（甲）WTZA=1（丙）WTZA=-1（乙）
        '================================================================================
        ElseIf InStr(谕组(X, 位谕of日层联动), "屎") > 0 _
            Or InStr(谕组(X, 位谕of日层联动), "尿") > 0 _
            Or InStr(谕组(X, 位谕of日层联动), "屁") > 0 Then
                典日乾日联屎尿屁.Add Item:=X, Key:=CIDL
        ElseIf InStr(谕组(X, 位谕of日层联动), "铜") > 0 Then
                典日乾日联铜.Add Item:=X, Key:=CIDL
        ElseIf InStr(谕组(X, 位谕of日层联动), "银") > 0 Then
                典日乾日联银.Add Item:=X, Key:=CIDL
        ElseIf InStr(谕组(X, 位谕of日层联动), "警") > 0 Then        '日层段：丁戊
                典日乾日联金警.Add Item:=X, Key:=CIDL
        Else
                典日乾日联金余.Add Item:=X, Key:=CIDL
        End If
'        '================================================================================
'        '注20251220：核心是将WXAB在日类展开，所以选取范围是针对周类(√口)，日类满足（DXCD＞0）或（DXCD＜0且DXZC＞0，最好要求DXZD＞0）；然后进一步在日类展开，其中针对[主]选取触顶ab，其余按照柱排进行展示。
'        '================================================================================
'        ElseIf 谕组(X, 位谕of日类BTCD) > 0 Then
'            If 谕组(X, 位谕of日类BTZC) > 0 Then
'                If (谕组(X, 位谕of仓类) = "_aO" Or 谕组(X, 位谕of仓类) = "_bO") Then
'                        '只针对“龙ab”进行筛选
'                        典日乾CD正ZC正顶.Add Item:=X, Key:=CIDL
'                ElseIf 谕组(X, 位谕of日类BTZD) > 0 Then
'                        典日乾CD正余.Add Item:=X, Key:=CIDL
'                End If
'            Else
'                        '注20251220：要在其中寻找周类可能再次站上WJA的机会。一定要注意WXBC的重要性：所有周类主升，基本都满足DXBC正交；当DXBC负交时，很可能转为跌势。
'                        典日乾CD正余.Add Item:=X, Key:=CIDL
'            End If
'        '------------------------------------------------------------------------
'        Else
'            '由于DXCD负交，所以周层都处于过渡期，不需要进行细分。注意，没有必要包含DJC之下的情况。
'            If 谕组(X, 位谕of日类BTZC) > 0 Then
'                        典日乾CD负.Add Item:=X, Key:=CIDL
'            Else
'                        '当DXCD＜0时，必须要求DXZC＞0，最好进一步要求DXZD＞0。所以，此处不进行筛选。
'            End If
'        End If
        '================================================================================
    Next
'========================================================================================
'类别：日级别筛 其中再分用于后续按日再分
'【龙】等同于：日基周局DJEDC多头排列
'醍醐灌顶20231001：全部按照DJE与DJC进行划分，主要包含：DJE初（W1v-W1b）、DJC初（WXCD/D1v-D1b）、DJC顶段（DXAB/DXAC）、DJC升段（其他/DXZB劫）、DJC末（D3w/WXCE/DJC下DJD上）、DJE末(DJD下DJE上)
'核心思想20231001：利用DJE形成的丘，改进方式为添加以DJC形成的丘进行优化（但不要过分依赖，核心还是DJE）
'========================================================================================
'----------------------------------------------------------------------------------------
'注20260426：配合周日联动，只按照WXZA与DXZA进行分类。
'----------------------------------------------------------------------------------------
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾日联金余, 节签:="【日乾】金.甲乙丙己")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾日联金警, 节签:="【日乾】金.警")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾日联银, 节签:="【日乾】银")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾日联铜, 节签:="【日乾】铜")
        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾日联屎尿屁, 节签:="【日乾】屎尿屁")
''----------------------------------------------------------------------------------------
''注20250303：配合周日联动，只按照DXCD与DXZC进行分类。
''----------------------------------------------------------------------------------------
'        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾CD正ZC正顶, 节签:="【日乾】日CD正.ZC正顶（日级别主升）")
'        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾CD正余, 节签:="【日乾】日CD正.余（包含ZC正&ZC负）")
'        Call IQQQ展擎筛程至D0节按通用(WB, 表名, 谕组, 出节模式:="日层", 出全是否:=出全是否, 节色:=章色, 典码输出:=典日乾CD负, 节签:="【日乾】日CD负（不含DJC以下）")
'========================================================================================
'返回
'========================================================================================
    IQQQ展擎筛程至C3章按日乾 = MSG
'========================================================================================
End Function





'========================================================================================
'========================================================================================
'功能：按照出节模式输出到块
'模式：日全
'注20250601：不要以柱排作为筛选原则，而要以日类中符进行分类，并按照日层（初主、再、储/6v/6w/1v/1w）分类展示。
'针对日中符，存在以下分类原则：日中符为ABC柱（首鼎很可能诱多（DTZA≤1）、WJA上多柱最有把握（DTZA≥2））日中符为DEF柱可能震仓（首薡（DTZA≥-1）、WJA下多柱（DTZA≤-2））
'注20251220：细分原则，先[日层]再[柱排]，针对特殊情况使用[顶型]。对于[日层：初储再]，由于存续时间较短，只按照[柱排]分类，不具体按顶型分类；对于[日层：主]，由于存续时间可能很长，需要先根据[顶型]筛选主升，再依赖[柱排]确定方向。
'注20251220：必须突出DXBC重要性，当周类处于主升阶段时，必然满足DXBC＞0；反之，当DXBC负交，很可能已经转为周级别下跌趋势，不应再参与。
'注20251220：日类的作用是作为周类的展开，必须严格贯彻WXAB护丘原则，抓住（DXCD＞0）以及（DXCD＜0且DXZC＞0）区域。对于处于（DXCD>0且DXZC<0）的情况，当DXZD＞0，但出现再次上破DJC迹象时，可参与。
'========================================================================================
'========================================================================================
Function IQQQ展擎筛程至D3节按日层( _
          ByRef WB As Workbook _
        , ByVal 表名 As String _
        , ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 节签 As String = "" _
        , Optional ByVal 节色 As Long = 常色十青 _
        , Optional ByVal 出节模式 As String = "日层" _
        , Optional ByVal 出全是否 As Boolean = True _
        ) As String
'========================================================================================
'声明变量
'========================================================================================
    Dim CIDL As String
    Dim 是否筛机 As Boolean
    '------------------------------------------------------------------------------------
    Dim 参阈连阳 As Integer
    参阈连阳 = 4
'========================================================================================
'定义典
'========================================================================================
    Dim 典日正破_ABC假鼎 As New Dictionary
    Dim 典日正破_ABC初三 As New Dictionary
    Dim 典日正破_ABC余升排 As New Dictionary
    Dim 典日正破_ABC余非升 As New Dictionary
    Dim 典日正破_DEF初首 As New Dictionary
    Dim 典日正破_DEF余多 As New Dictionary
    '---------------------------------------------------
    Dim 典日正主_梯升连冲 As New Dictionary
    Dim 典日正主_梯升孕冲 As New Dictionary
    Dim 典日正主_梯升调待 As New Dictionary
    Dim 典日正主_梯交调待 As New Dictionary
    Dim 典日正主_梯交跌警 As New Dictionary
    Dim 典日正主_栏调吞冲 As New Dictionary
    Dim 典日正主_栏调孕待 As New Dictionary
    Dim 典日正主_栏调吞待 As New Dictionary
    Dim 典日正主_栅调吞冲 As New Dictionary
    Dim 典日正主_栅调孕待 As New Dictionary
    Dim 典日正主_栅调吞待 As New Dictionary
    Dim 典日正主_枝启升冲 As New Dictionary
    Dim 典日正主_枝贯连待 As New Dictionary
    Dim 典日正主_枝启踩警 As New Dictionary
    Dim 典日正主_枝贯单待 As New Dictionary
    Dim 典日正主_根全 As New Dictionary
    Dim 典日正主_杂全 As New Dictionary
    '---------------------------------------
    Dim 典日正再_梯升连冲 As New Dictionary
    Dim 典日正再_梯升孕冲 As New Dictionary
    Dim 典日正再_梯升调待 As New Dictionary
    Dim 典日正再_梯交调待 As New Dictionary
    Dim 典日正再_梯交跌警 As New Dictionary
    Dim 典日正再_栏调吞冲 As New Dictionary
    Dim 典日正再_栏调孕待 As New Dictionary
    Dim 典日正再_栏调吞待 As New Dictionary
    Dim 典日正再_栅调吞冲 As New Dictionary
    Dim 典日正再_栅调孕待 As New Dictionary
    Dim 典日正再_栅调吞待 As New Dictionary
    Dim 典日正再_枝启升冲 As New Dictionary
    Dim 典日正再_枝贯连待 As New Dictionary
    Dim 典日正再_枝启踩警 As New Dictionary
    Dim 典日正再_枝贯单待 As New Dictionary
    Dim 典日正再_根全 As New Dictionary
    Dim 典日正再_杂全 As New Dictionary
    '---------------------------------------
    Dim 典日正初储_梯升连冲 As New Dictionary
    Dim 典日正初储_梯升孕冲 As New Dictionary
    Dim 典日正初储_梯升调待 As New Dictionary
    Dim 典日正初储_梯交调待 As New Dictionary
    Dim 典日正初储_梯交跌警 As New Dictionary
    Dim 典日正初储_栏调吞冲 As New Dictionary
    Dim 典日正初储_栏调孕待 As New Dictionary
    Dim 典日正初储_栏调吞待 As New Dictionary
    Dim 典日正初储_栅调吞冲 As New Dictionary
    Dim 典日正初储_栅调孕待 As New Dictionary
    Dim 典日正初储_栅调吞待 As New Dictionary
    Dim 典日正初储_枝启升冲 As New Dictionary
    Dim 典日正初储_枝贯连待 As New Dictionary
    Dim 典日正初储_枝启踩警 As New Dictionary
    Dim 典日正初储_枝贯单待 As New Dictionary
    Dim 典日正初储_根全 As New Dictionary
    Dim 典日正初储_杂全 As New Dictionary
    '---------------------------------------------------
    Dim 典日层负A_BC负交芽 As New Dictionary
    Dim 典日层负A_BC负交根 As New Dictionary
    Dim 典日层负A_BC负交管 As New Dictionary
    Dim 典日层负A_BC正交4v As New Dictionary
    Dim 典日层负A_BC正交4w As New Dictionary
    Dim 典日层负A_BC正交4b As New Dictionary
    Dim 典日层负A_BC正交4e As New Dictionary
    '-------------
    Dim 典日层负G管顶合余 As New Dictionary
    Dim 典日层负G管顶合剔偏大 As New Dictionary
    Dim 典日层负G管顶合剔宽大 As New Dictionary
    Dim 典日层负G管顶合剔连久 As New Dictionary
    Dim 典日层负G管顶离 As New Dictionary
    Dim 典日层负G根 As New Dictionary
    Dim 典日层负G芽 As New Dictionary
    '-------------
    Dim 典日层负B管芽 As New Dictionary
    Dim 典日层负C管芽 As New Dictionary
    Dim 典日层负D管芽 As New Dictionary
    Dim 典日层负BCD根 As New Dictionary
    '-------------
    Dim 典日层负C根6w As New Dictionary
    Dim 典日层负B根6v As New Dictionary
    '---------------------------------------------------
    Dim 典日层废单停牌 As New Dictionary
'========================================================================================
'筛选：微观 以周为粒度进行柱类分析
'========================================================================================
    For Y = 1 To 典码输出.Count
        X = 典码输出.Items(Y - 1)
        CIDL = 谕组(X, 位qt代码)
        值日基日局 = 谕组(X, 位谕of日基日局)
        是否筛机 = False
        '================================================================================
        If UBCID是代码(CIDL) = False Then
        ElseIf 谕组(X, 位qt停牌) = "S" Then     '测试用
                        典日层废单停牌.Add Item:=X, Key:=CIDL
        '--------------------------------------------------------------------------------
        '控制输出：【出全是否】是否只输出DJD之上。因为K柱围绕DJC波动，所以利用DJD来进行限制。
        '注20251220：不要用DXZD＞0来限制输出，当WXAB＞0时即使DXZD＜0，仍然属于可捡漏情况。所以将此处条件注销，是否限制DXZD＞0，需要在上级外部条件进行过滤。
        '--------------------------------------------------------------------------------
        'ElseIf 出全是否 = False And 谕组(X, 位谕of日类BTZD) < 0 Then
        '--------------------------------------------------------------------------------
        '单独列示：破
        '--------------------------------------------------------------------------------
        ElseIf Left(谕组(X, 位谕of日层界), 1) = "破" Then
                        If Right(谕组(X, 位谕of日管中符串), 1) = "A" Or Right(谕组(X, 位谕of日管中符串), 1) = "B" Or Right(谕组(X, 位谕of日管中符串), 1) = "C" Then
                            If 谕组(X, 位谕of日类BTZA) <= 0 Then    '假鼎
                                典日正破_ABC假鼎.Add Item:=X, Key:=CIDL
                            ElseIf 谕组(X, 位谕of日类BTZA) <= 3 Then    '包含：初始突破WJA
                                典日正破_ABC初三.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层柱排), "升.") > 0 Then
                                典日正破_ABC余升排.Add Item:=X, Key:=CIDL
                            Else
                                典日正破_ABC余非升.Add Item:=X, Key:=CIDL
                            End If
                        Else
                            If 谕组(X, 位谕of日类BTZA) >= -1 Then '首薡
                                典日正破_DEF初首.Add Item:=X, Key:=CIDL
                            Else
                                典日正破_DEF余多.Add Item:=X, Key:=CIDL
                            End If
                        End If
        '--------------------------------------------------------------------------------
        '单独列示：储/初
        '注：在WJA之上凡是逆趋势（跌孕/跌吞/跌连）都是机会，需要甄别。
        '--------------------------------------------------------------------------------
        ElseIf Left(谕组(X, 位谕of日层界), 1) = "储" Or Left(谕组(X, 位谕of日层界), 1) = "初" Then
                        If InStr(谕组(X, 位谕of日层柱型), "梯") > 0 Then
                            If InStr(谕组(X, 位谕of日层柱型), "梯升连冲") > 0 Then
                                典日正初储_梯升连冲.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层柱型), "梯升孕冲") > 0 Then
                                典日正初储_梯升孕冲.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层柱型), "梯升调待") > 0 Then
                                典日正初储_梯升调待.Add Item:=X, Key:=CIDL
                            ElseIf InStr(谕组(X, 位谕of日层柱型), "梯交调待") > 0 Then
                                典日正初储_梯交调待.Add Item:=X, Key:=CIDL
                            Else
                                典日正初储_梯交跌警.Add Item:=X, Key:=CIDL
