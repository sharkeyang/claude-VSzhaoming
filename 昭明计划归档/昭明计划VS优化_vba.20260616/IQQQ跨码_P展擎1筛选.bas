'========================================================================================
'========================================================================================
'功能：验证昨日指标对于今日涨幅的指导作用
'注意：结算要用SCC
'========================================================================================
'========================================================================================
Sub IQQQ展擎筛程_统计本页前调日类()
'========================================================================================
'验明正身
'========================================================================================
    Dim WSAS As Worksheet
    Set WSAS = ActiveSheet
'    Set WSAS = ThisWorkbook.Sheets(".SSD")
    If PSOP格整理质程_是否适用首列(WSAS.Name) = False Then
        Exit Sub
    End If
'========================================================================================
'设置工作表
'========================================================================================
    Dim WSTO As Worksheet
    Call PBASE格程工具_表操工表新增(WSTO, "SSS" & WSAS.Name, 基色底:=常色主黄)
    With WSTO.Cells
        .Interior.ColorIndex = 2
    End With
'========================================================================================
'统计日类：一定为SCC
'========================================================================================
    Call IQQQ展擎瓜页引擎基程(WSAS, "更新排否", 实结类型:="sCCC", 基色底:=常色勿动)
    '------------------------------------------------------------------------------------
    '统计
    '------------------------------------------------------------------------------------
    Call IQQQ展擎筛程_统计本页基程(WSTO, WSAS, 被研指题:="日涨" & "*日局态", 被研指标:=位谕of日参竖态)
    Call IQQQ展擎筛程_统计本页基程(WSTO, WSAS, 被研指题:="日涨" & "*周局态", 被研指标:=位谕of周德横类)
    '--------------------------------------------
    Call IQQQ展擎筛程_统计本页基程(WSTO, WSAS, 被研指题:="日涨" & "*日层局", 被研指标:=位谕of日基坤局)
    Call IQQQ展擎筛程_统计本页基程(WSTO, WSAS, 被研指题:="日涨" & "*日乾局", 被研指标:=位谕of日基乾局)
'========================================================================================
'统计周类：一定为SSC
'========================================================================================
    Call IQQQ展擎瓜页引擎基程(WSAS, "更新排否", 实结类型:="sCCC", 基色底:=常色勿动)
    '------------------------------------------------------------------------------------
    '统计
    '--------------------------------------------
    Call IQQQ展擎筛程_统计本页基程(WSTO, WSAS, 被研指题:="周今涨" & "*周局态", 被研指标:=位谕of周德横类, 基色底:=常色43绿)
    Call IQQQ展擎筛程_统计本页基程(WSTO, WSAS, 被研指题:="周昨涨" & "*周局态", 被研指标:=位谕of周德横类, 基色底:=常色43绿)
'========================================================================================
    MSG = MSG & vbCrLf & WSAS.Name
    Set WSAS = Nothing
    Set WSTO = Nothing
    MsgBox MSG, vbOKOnly, "统计本页"
End Sub


Function IQQQ展擎筛程_统计本页基程(WSTO As Worksheet, WSAS As Worksheet, 被研指题 As String, 被研指标 As Integer, Optional 基色底 As Long = 常色八靛) As String
'========================================================================================
'搜索目标：遍历顺序一定要是倒序
'========================================================================================
    Dim 典集本页 As New Dictionary
    Dim CIDL As String
    Dim 行号遍历 As Integer
    For 行号遍历 = WSAS.Cells(65536, 1).End(xlUp).Row To 2 Step -1
        CIDL = WSAS.Cells(行号遍历, 位qt代码)
        If UBCID是代码(CIDL) And 典集本页.Exists(CIDL) = False Then
            典集本页.Add Item:=行号遍历, Key:=CIDL
        End If
    Next
    If 典集本页.Count = 0 Then Exit Function
'========================================================================================
'操作：制作数组数据
'========================================================================================
    Dim 计数被分 As Integer
    计数被分 = 典集本页.Count
    Dim 维横 As Integer
    维横 = PBASE格程工具_表参末列指定(WSAS, 1)
    '------------------------------------------------------------------------------------
    '制作数组
    '------------------------------------------------------------------------------------
    Dim 典码输出 As New Dictionary
    ReDim 元组被分(1 To 计数被分, 1 To 维横) As Variant
    Dim ARROW As Variant
    
    Dim 当行 As Integer
    Dim X As Integer
    Dim Y As Integer
    For X = 1 To 典集本页.Count
        当行 = 典集本页.Items(X - 1)
        CIDL = 典集本页.Keys(X - 1)
        典码输出.Add Item:=X, Key:=CIDL
        ARROW = WSAS.Cells(当行, 1).Resize(1, 维横)
        For Y = 1 To 维横
            元组被分(X, Y) = ARROW(1, Y)
        Next
        Erase ARROW
    Next
'========================================================================================
'操作：统计
'========================================================================================
    Dim 典集标数 As New Dictionary
    Dim 典集标涨数 As New Dictionary
    Dim 典集标高数G3 As New Dictionary
    Dim 典集标高数G1 As New Dictionary
    Dim 典集标高数G0 As New Dictionary
    Dim 典集标涨幅 As New Dictionary
    Dim 典集标高幅 As New Dictionary
    '------------------------------------------------------------------------------------
    '归集指标
    '------------------------------------------------------------------------------------
    Dim N As Integer
    N = 0
    For X = LBound(元组被分, 1) To UBound(元组被分, 1)
        值指标 = 元组被分(X, 被研指标)
        If 典集标数.Exists(值指标) = False Then
            N = N + 1
            典集标数.Add Item:=0, Key:=值指标
            典集标涨数.Add Item:=0, Key:=值指标
            典集标涨幅.Add Item:=0, Key:=值指标
            典集标高数G3.Add Item:=0, Key:=值指标
            典集标高数G1.Add Item:=0, Key:=值指标
            典集标高数G0.Add Item:=0, Key:=值指标
        End If
    Next
    '------------------------------------------------------------------------------------
    '统计指标
    '------------------------------------------------------------------------------------
    Dim 值位涨幅 As Integer
    Dim 值位高幅 As Integer
    If InStr(被研指题, "日涨") > 0 Then
        值位涨幅 = 位qt今涨幅
        值位高幅 = 位qt今高幅
    ElseIf InStr(被研指题, "周今涨") > 0 Then
        值位涨幅 = 位谕of周波临涨幅
        值位高幅 = 位谕of周波临高幅
    ElseIf InStr(被研指题, "周昨涨") > 0 Then
        值位涨幅 = 位谕of周波今涨幅
        值位高幅 = 位谕of周波今高幅
    End If
    For X = LBound(元组被分, 1) To UBound(元组被分, 1)
        值指标 = 元组被分(X, 被研指标)
        值涨幅 = 元组被分(X, 值位涨幅)
        值高幅 = 元组被分(X, 值位高幅)
        
        典集标数(值指标) = 典集标数(值指标) + 1
        典集标涨数(值指标) = 典集标涨数(值指标) + IIf(值涨幅 >= 0, 1, 0)
        If 值高幅 >= 3 Then
            典集标高数G3(值指标) = 典集标高数G3(值指标) + 1
            典集标高数G1(值指标) = 典集标高数G1(值指标) + 1
            典集标高数G0(值指标) = 典集标高数G0(值指标) + 1
        ElseIf 值高幅 >= 1 Then
            典集标高数G1(值指标) = 典集标高数G1(值指标) + 1
            典集标高数G0(值指标) = 典集标高数G0(值指标) + 1
        ElseIf 值高幅 >= 0 Then
            典集标高数G0(值指标) = 典集标高数G0(值指标) + 1
        End If
        If 值涨幅 <> "S" Then
        典集标涨幅(值指标) = 典集标涨幅(值指标) + 值涨幅
        典集标高幅(值指标) = 典集标高幅(值指标) + 值高幅
        End If
    Next
'========================================================================================
'输出
'========================================================================================
    Dim 母行 As Integer
    母行 = PBASE格程工具_表参末行指定(WSTO, 1)
    If 母行 = 1 Then
    Else
        母行 = 母行 + 3
    End If
    '------------------------------------------------------------------------------------
    '设置元信息
    '------------------------------------------------------------------------------------
    With WSTO.Rows(母行)
        .VerticalAlignment = xlBottom
        .Cells(1, 1) = "统计表" & vbCrLf & 被研指题
        .Cells(1, 2) = WSAS.Name
        .Cells(1, 3) = 典集本页.Count
    End With
    母行 = 母行 + 1
    '------------------------------------------------------------------------------------
    '设置参数
    '------------------------------------------------------------------------------------
    Dim 内列标名 As Integer
    Dim 内列标数总 As Integer
    Dim 内列标数涨 As Integer
    Dim 内列标比涨 As Integer
    Dim 内列标比高G3 As Integer
    Dim 内列标比高G1 As Integer
    Dim 内列标比高G0 As Integer
    Dim 内列标涨幅和 As Integer
    Dim 内列标涨幅均 As Integer
    Dim 内列标高幅和 As Integer
    Dim 内列标高幅均 As Integer
    内列标名 = 1
    内列标数总 = 2
    内列标数涨 = 3
    内列标比涨 = 4
    内列标涨幅和 = 5
    内列标涨幅均 = 6
    内列标比高G3 = 7
    内列标比高G1 = 8
    内列标比高G0 = 9
    内列标高幅和 = 10
    内列标高幅均 = 11
    Dim 内列标数列 As Integer
    内列标数列 = 11
    '------------------------------------------------------------------------------------
    '格式化
    '------------------------------------------------------------------------------------
    With WSTO.Cells(母行, 1)
        .Resize(1, 内列标数列).Interior.Color = 常色主靛
        .Resize(1, 内列标数列).Font.Bold = True
        .Cells(1, 内列标名) = "指标"
        .Cells(1, 内列标数总) = "数总"
        .Cells(1, 内列标数涨) = "数涨"
        .Cells(1, 内列标比涨) = "比涨+"
        .Cells(1, 内列标涨幅和) = "涨幅和"
        .Cells(1, 内列标涨幅均) = "涨幅均"
        .Cells(1, 内列标比高G3) = "比高G3"
        .Cells(1, 内列标比高G1) = "比高G1"
        .Cells(1, 内列标比高G0) = "比高G0"
        .Cells(1, 内列标高幅和) = "高幅和"
        .Cells(1, 内列标高幅均) = "高幅均"
    End With
    '------------------------------------------------------------------------------------
    '输出指标
    '------------------------------------------------------------------------------------
    For N = 1 To 典集标数.Count
        目行 = 母行 + N
        '--------------------------------------------------------------------------------
        WSTO.Cells(目行, 内列标名) = 典集标数.Keys(N - 1)
        '统计：数
        WSTO.Cells(目行, 内列标数总) = 典集标数.Items(N - 1)
        WSTO.Cells(目行, 内列标数涨) = 典集标涨数.Items(N - 1)
        If 典集标数.Items(N - 1) > 5 Then
            WSTO.Cells(目行, 内列标比涨) = Round(典集标涨数.Items(N - 1) / 典集标数.Items(N - 1), 1)
            WSTO.Cells(目行, 内列标比高G3) = Round(典集标高数G3.Items(N - 1) / 典集标数.Items(N - 1), 1)
            WSTO.Cells(目行, 内列标比高G1) = Round(典集标高数G1.Items(N - 1) / 典集标数.Items(N - 1), 1)
            WSTO.Cells(目行, 内列标比高G0) = Round(典集标高数G0.Items(N - 1) / 典集标数.Items(N - 1), 1)
        End If
        '统计：涨幅
        WSTO.Cells(目行, 内列标涨幅和) = 典集标涨幅.Items(N - 1)
        WSTO.Cells(目行, 内列标涨幅均) = Round(典集标涨幅.Items(N - 1) / 典集标数.Items(N - 1), 1)
        '统计：高幅
        WSTO.Cells(目行, 内列标高幅和) = 典集标高幅.Items(N - 1)
        WSTO.Cells(目行, 内列标高幅均) = Round(典集标高幅.Items(N - 1) / 典集标数.Items(N - 1), 1)
        '--------------------------------------------------------------------------------
        '格式化：分行
        '--------------------------------------------------------------------------------
        If WSTO.Cells(目行, 内列标数总) > 5 Then
            WSTO.Cells(目行, 1).Resize(1, 内列标数列).Interior.ColorIndex = 36
        Else
            WSTO.Cells(目行, 1).Resize(1, 内列标数列).Interior.ColorIndex = 15
        End If
        With WSTO.Cells(目行, 1)
            .Interior.Color = 基色底
            If InStr(.Value, "2c") > 0 Then
                .Interior.TintAndShade = -0.5
            ElseIf InStr(.Value, "2d") > 0 Then
                .Interior.TintAndShade = -0.4
            ElseIf InStr(.Value, "2e") > 0 Then
                .Interior.TintAndShade = -0.3
            ElseIf InStr(.Value, "1b") > 0 Or InStr(.Value, "1w") > 0 Or InStr(.Value, "1e") > 0 Then
                .Interior.TintAndShade = -0.1
            End If
        End With
        '--------------------------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    '排序
    '------------------------------------------------------------------------------------
    With WSTO.Cells(母行, 1).Resize(1 + 典集标数.Count, 内列标数列)
        .Sort key1:=.Cells(1, 内列标名), order1:=xlAscending, _
                Header:=xlYes
                
    End With
'    For N = 2 To WSTO.Cells(65536, 2).End(xlUp).Row
'        If WSTO.Cells(N, 内列标数总) > 5 Then
'            WSTO.Cells(N, 1).Resize(1, 内列标数列).Interior.ColorIndex = 36
'        Else
'            WSTO.Cells(N, 1).Resize(1, 内列标数列).Interior.ColorIndex = 15
'        End If
'        WSTO.Cells(N, 1).Interior.ColorIndex = 37
'    Next
    '--------------------------------------------
    WSTO.Columns.HorizontalAlignment = xlRight
    WSTO.Columns(1).HorizontalAlignment = xlLeft
    WSTO.Columns(1).ColumnWidth = 15
    WSTO.Columns(1).Font.Bold = True
    WSTO.Columns(内列标涨幅和).NumberFormatLocal = 全设格式of零位
    WSTO.Columns(内列标高幅和).NumberFormatLocal = 全设格式of零位
    WSTO.Columns(内列标比涨).Font.Bold = True
    WSTO.Columns(内列标比涨).Font.ColorIndex = 15
    WSTO.Columns(内列标比涨).NumberFormatLocal = 全设格式of百分
    WSTO.Columns(内列标比高G3).Font.Bold = True
    WSTO.Columns(内列标比高G3).Font.ColorIndex = 15
    WSTO.Columns(内列标比高G3).NumberFormatLocal = 全设格式of百分
    WSTO.Columns(内列标比高G1).Font.Bold = True
    WSTO.Columns(内列标比高G1).Font.ColorIndex = 15
    WSTO.Columns(内列标比高G1).NumberFormatLocal = 全设格式of百分
    WSTO.Columns(内列标比高G0).Font.Bold = True
    WSTO.Columns(内列标比高G0).Font.ColorIndex = 15
    WSTO.Columns(内列标比高G0).NumberFormatLocal = 全设格式of百分
    WSTO.Columns(内列标涨幅均).Font.Bold = True
    WSTO.Columns(内列标高幅均).Font.Bold = True
''========================================================================================
''操作：筛选
''========================================================================================
'    UTL宏工具_BEGIN
'    '------------------------------------------------------------------------------------
'    MSG = MSG & vbCrLf
'    MSG = MSG & "【QQQ本页决策】"
'    MSG = MSG & vbCrLf
'    MSG = MSG & "工表名：" & 当前表名
'
'    TTT = Timer
'    计时过程 = CInt(Timer - TTT)
'
'    MSG = MSG & vbCrLf
'    MSG = MSG & "QQQ筛选用时：" & 计时过程
'    '------------------------------------------------------------------------------------
'    UTL宏工具_END
'========================================================================================
'返回
'========================================================================================
    MSG = MSG & vbCrLf & WSAS.Name & vbCrLf & 典集本页.Count
    Set 典集本页 = Nothing
    Erase 元组被分
'========================================================================================
    IQQQ展擎筛程_统计本页基程 = MSG
End Function










