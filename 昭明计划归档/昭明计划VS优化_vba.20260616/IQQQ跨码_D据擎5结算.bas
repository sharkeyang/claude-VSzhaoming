'########################################################################################
'########################################################################################
'##################################  结算引擎_区间基码  ##################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：导入结算质程
'注意20220831：在上层调用中应对【指定结期上限】，使其是所在库（藏库/外库）其中能取到的最大结期
'========================================================================================
'========================================================================================
Function STBASE结算引擎_区间基码数程( _
          ByRef ARRCSVD As Variant _
        , ByRef ARROSD As Variant _
        , ByRef ARROSW As Variant _
        , ByRef ARROSM As Variant _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        , Optional ByVal 是否统时 As Boolean = False _
        ) As Integer
'========================================================================================
'验明正身
'把此检验放入上级调用程序
'========================================================================================
'    If 是否统时 = True Then
'        If UBound(ARROSD) - LBound(ARROSD) + 1 < 位os容积 Then Exit Function
'    End If
'========================================================================================
'准备数据
'注20241017：属于试验性质，原程序对于周级别与月级别，只保留去重数据；为了在展示算法中保留周中信息，现在不进行去重。
'========================================================================================
    If VBA.IsEmpty(ARRCSVD) = True Then Exit Function
    '------------------------------------------------------------------------------------
    '日类：导入外部数据
    '------------------------------------------------------------------------------------
    Dim ARRDATAD As Variant
    Dim 计数日类 As Integer
    计数日类 = STBASE取据引擎_工具结算数据转换(ARRCSVD, ARRDATAD, 常期类为日, 是否去重:=False)
    '------------------------------------------------------------------------------------
    '周类：转换外部数据
    '------------------------------------------------------------------------------------
    Dim ARRDATAW As Variant
    Dim 计数周类 As Integer
    计数周类 = STBASE取据引擎_工具结算数据转换(ARRCSVD, ARRDATAW, 常期类为周, 是否去重:=False)
    '------------------------------------------------------------------------------------
    '月类：转换外部数据
    '------------------------------------------------------------------------------------
    Dim ARRDATAM As Variant
    Dim 计数月类 As Integer
    计数月类 = STBASE取据引擎_工具结算数据转换(ARRCSVD, ARRDATAM, 常期类为月, 是否去重:=False)
'========================================================================================
'结算
'========================================================================================
    '------------------------------------------------------------------------------------
    '结算初始设置：判断是否全新结算（如果结收不等于零）
    '------------------------------------------------------------------------------------
    Dim 是否全新结算 As Boolean
    是否全新结算 = (Len(ARROSD(位os结收)) = 0)
    If 是否全新结算 = True And 计数日类 > 0 Then
        Call STBASE结算引擎_单点初始核程(ARROSD, ARRDATAD)
        Call STBASE结算引擎_单点初始核程(ARROSW, ARRDATAW)
        Call STBASE结算引擎_单点初始核程(ARROSM, ARRDATAM)
    End If
    '------------------------------------------------------------------------------------
    '日类结算
    '------------------------------------------------------------------------------------
    Dim 计期已结算日类 As Integer
    计期已结算日类 = STBASE结算引擎_区间基组数程(ARROSD, ARRDATAD, 是否统时:=是否统时, 指定结期上限:=指定结期上限)
    Call STBASE结算引擎_单点衍生核程(ARROSD)
    '------------------------------------------------------------------------------------
    '周类结算
    '------------------------------------------------------------------------------------
    Dim 计期已结算周类 As Integer
    计期已结算周类 = STBASE结算引擎_区间基组数程(ARROSW, ARRDATAW, 是否统时:=是否统时, 指定结期上限:=指定结期上限)
    Call STBASE结算引擎_单点衍生核程(ARROSW)
    '------------------------------------------------------------------------------------
    '月类结算
    '------------------------------------------------------------------------------------
    Dim 计期已结算月类 As Integer
    计期已结算月类 = STBASE结算引擎_区间基组数程(ARROSM, ARRDATAM, 是否统时:=是否统时, 指定结期上限:=指定结期上限)
    Call STBASE结算引擎_单点衍生核程(ARROSM)
'========================================================================================
'返回
'========================================================================================
    Erase ARRDATAD
    Erase ARRDATAW
    Erase ARRDATAM
    STBASE结算引擎_区间基码数程 = 计期已结算日类
End Function



'========================================================================================
'========================================================================================
'功能：基于准备完善的数组进行结算
'========================================================================================
'========================================================================================
Function STBASE结算引擎_区间基组数程( _
          ByRef ARROS As Variant _
        , ByRef ARRDATA As Variant _
        , ByVal 指定结期上限 As Date _
        , Optional ByVal 是否统时 As Boolean = False _
        ) As Integer
'========================================================================================
'验证非空
'========================================================================================
    If VBA.IsEmpty(ARRDATA) = True Then Exit Function
'========================================================================================
'变量声明
'========================================================================================
    Dim 临期 As Date, 临收#, 临开#, 临高#, 临低#
    Dim 是否应结算  As Boolean
    Dim 计期已结算 As Integer
    计期已结算 = 0
    Dim 指定期类 As String
    指定期类 = ARROS(位os期类)
'========================================================================================
'遍历结算
'========================================================================================
    Dim 遍历序号 As Integer
    For 遍历序号 = LBound(ARRDATA, 1) To UBound(ARRDATA, 1)
        '--------------------------------------------------------------------------------
        '读取数据
        '--------------------------------------------------------------------------------
        临期 = ARRDATA(遍历序号, 位列TS结期)
        临收 = ARRDATA(遍历序号, 位列TS结收)
        临开 = ARRDATA(遍历序号, 位列TS结开)
        临高 = ARRDATA(遍历序号, 位列TS结高)
        临低 = ARRDATA(遍历序号, 位列TS结低)
        '--------------------------------------------------------------------------------
        '总体控制：指定结期上限
        '--------------------------------------------------------------------------------
        If 临期 <= 指定结期上限 Then
            '----------------------------------------------------------------------------
            '步骤：更新【临】
            '注意20220829：可以不区分期类，直接用周类逻辑进行更新，因为只要结算过临信息就被清零。
            '----------------------------------------------------------------------------
            If 临期 > ARROS(位os临期) Then
                    '--------------------------------------------------------------------
                    If 指定期类 = 常期类为日 Then
                            ARROS(位os临期) = 临期
                            ARROS(位os临收) = 临收
                            ARROS(位os临开) = 临开
                            ARROS(位os临高) = 临高
                            ARROS(位os临低) = 临低
                    Else
                        If 临期 - STBASE取据引擎_工具期类第几日(临期, 指定期类) = ARROS(位os临期) - STBASE取据引擎_工具期类第几日(ARROS(位os临期), 指定期类) Then
                            '属于同一期，本期非首个交易日
                            ARROS(位os临期) = 临期
                            ARROS(位os临收) = 临收
                            If 临高 > ARROS(位os临高) Then ARROS(位os临高) = 临高
                            If 临低 < ARROS(位os临低) Then ARROS(位os临低) = 临低
                        Else
                            If ARROS(位os临收) > 0 Then
                                '前期信息未清零，有可能前结算时已停牌，应先结算再更新
                                计期已结算 = 计期已结算 + STBASE结算引擎_单点结算核程(ARROS)
                                'If 是否统时 = True Then Call STBASE结算引擎_单点统时核程(ARROS)
                            End If
                            '本期首个交易日 (所有临时价格已经在上期正式结算中清零)
                            ARROS(位os临期) = 临期
                            ARROS(位os临收) = 临收
                            ARROS(位os临开) = 临开
                            ARROS(位os临高) = 临高
                            ARROS(位os临低) = 临低
                        End If
                    End If
                    '--------------------------------------------------------------------
                    '计算：值临PR
                    '注20241020：因为不会进入正式结算，所以必须放在外面，与临数据共同赋值。
                    '--------------------------------------------------------------------
                    If ARROS(位os结收) <> 0 Then
                        ARROS(位os临幅PR) = Round((ARROS(位os临收) / ARROS(位os结收) - 1) * 100, 2)
                        ARROS(位os临幅HR) = Round((ARROS(位os临高) / ARROS(位os结收) - 1) * 100, 2)
                        ARROS(位os临幅LR) = Round((ARROS(位os临低) / ARROS(位os结收) - 1) * 100, 2)
                    End If
                    '--------------------------------------------------------------------
            End If
            '----------------------------------------------------------------------------
            '步骤：进行结算
            '----------------------------------------------------------------------------
            If 临期 > ARROS(位os结期) Then
                    '--------------------------------------------------------------------
                    If 指定期类 = 常期类为日 Then
                            '日类：全部进行结算
                            是否应结算 = True
                    ElseIf 指定期类 = 常期类为周 Then
                        If 临期 - Weekday(临期) < 指定结期上限 - Weekday(指定结期上限) Then
                            '周类：与[指定结期上限]不属于同一期都结算
                            是否应结算 = ARRDATA(遍历序号, 位列TS结IS)
                        ElseIf 时程结期判断IS类周(临期) = True Then
                            '周类：与[指定结期上限]属于同一周，要对日期进行判断
                            是否应结算 = True
                        Else
                            是否应结算 = False
                        End If
                    ElseIf 指定期类 = 常期类为月 Then
                        If 临期 - Day(临期) < 指定结期上限 - Day(指定结期上限) Then
                            '月类：与[指定结期上限]不属于同一期都结算
                            是否应结算 = ARRDATA(遍历序号, 位列TS结IS)
                        ElseIf 时程结期判断IS类月(临期) = True Then
                            '月类：与[指定结期上限]属于同一期，要对日期进行判断
                            是否应结算 = True
                        Else
                            是否应结算 = False
                        End If
                    Else
                            Stop '错误
                    End If
                    '--------------------------------------------------------------------
                    If 是否应结算 = True Then
                        计期已结算 = 计期已结算 + STBASE结算引擎_单点结算核程(ARROS)
                        'If 是否统时 = True Then Call STBASE结算引擎_单点统时核程(ARROS)
                    End If
                    '--------------------------------------------------------------------
            End If
            '----------------------------------------------------------------------------
        End If
    Next
'========================================================================================
'返回
'========================================================================================
    STBASE结算引擎_区间基组数程 = 计期已结算
End Function









