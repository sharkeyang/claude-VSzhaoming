                ARROS(位os龟结哈) = Application.Min(ARROS(位os龟临哈), ARROS(位os价L4))
                ARROS(位os龟BT哈) = STBASE结算工具_衍生交叉天数(ARROS(位os龟BT哈), CDbl(ARROS(位os龟结哈)), 值结低)
                '========================================================================
                '增幅：哼哈
                '========================================================================
                If ARROS(位os龟前哼) <> 0 Then
                    ARROS(位os龟结哼幅) = (ARROS(位os龟结哼) / ARROS(位os龟前哼) - 1) * 100
                End If
                If ARROS(位os龟前哈) <> 0 Then
                    ARROS(位os龟结哈幅) = (ARROS(位os龟结哈) / ARROS(位os龟前哈) - 1) * 100
