Function STBASE结算工具_衍生色度按鳄鱼(值鳄鱼 As String) As Long
        Dim 值色数 As Long
        Dim 值浅深 As String
        值浅深 = Mid(值鳄鱼, 5, 1)
        '--------------------------------------------------------------------------------
        Select Case Mid(值鳄鱼, 2, 2)
        '金a：靛色系
        Case "金a"
            Select Case 值浅深
            Case "a", "b", "r":  值色数 = 常色十靛
            Case "c", "y", "z":  值色数 = 常色四靛
            Case Else:           值色数 = 常色主白
            End Select
        '金b：靛色系
        Case "金b"
            Select Case 值浅深
            Case "a", "b", "r":  值色数 = 常色八靛
            Case "c", "y", "z":  值色数 = 常色四靛
            Case Else:           值色数 = 常色主白
            End Select
        '银r：青色系
        Case "银r"
            Select Case 值浅深
            Case "a", "b", "r":  值色数 = 常色六青
            Case "c", "y", "z":  值色数 = 常色四青
            Case Else:           值色数 = 常色主白
            End Select
        '唏y：蓝色系
        Case "唏y"
            Select Case 值浅深
            Case "a", "b", "r":  值色数 = 常色六蓝
            Case "c", "y", "z":  值色数 = 常色二蓝
            Case Else:           值色数 = 常色主白
            End Select
        '嘘b：深橙色系
        Case "嘘b"
            Select Case 值浅深
            Case "a", "b", "r":  值色数 = 常色四橙
            Case "c", "y", "z":  值色数 = 常色二橙
            Case Else:           值色数 = 常色主白
            End Select
        '尿c：深红色系
        Case "尿c"
            Select Case 值浅深
            Case "a", "b", "r":  值色数 = 常色三红
            Case "c", "y", "z":  值色数 = 常色二红
            Case Else:           值色数 = 常色主白
            End Select
        '屎y, 屎z：深灰色系
        Case "屎y", "屎z"
            Select Case 值浅深
            Case "a", "b", "r":  值色数 = 常色三灰
            Case "c", "y", "z":  值色数 = 常色二灰
            Case Else:           值色数 = 常色主白
            End Select
        Case Else
            值色数 = 常色一灰
        End Select
        '--------------------------------------------------------------------------------
        STBASE结算工具_衍生色度按鳄鱼 = 值色数
End Function
Function STBASE结算工具_衍生色度按仓类(值仓类 As String) As Long
        Dim 值色数 As Long
        '--------------------------------------------------------------------------------
        Select Case 值仓类
        '系列D：靛绿色 (与本系统日类色系相符)
        Case "_aO"
            值色数 = 常色十绿
        '系列W：靛色 (与本系统周类色系相符)
        Case "_bO"
            值色数 = 常色八绿
        Case "_aX", "_bX"
            值色数 = 常色主绿
        Case "_dO"
            值色数 = 常色六青
        Case "_dX"
            值色数 = 常色四青
        '----------------------------------------
        Case "_sO"
            值色数 = 常色八蓝
        Case "_sX"
            值色数 = 常色四蓝
        '----------------------------------------
        '系列M1：青色
        Case "w"
            值色数 = 常色四橙
        Case "y"
            值色数 = 常色二红
        Case "z"
            值色数 = 常色二灰
        End Select
        '--------------------------------------------------------------------------------
        STBASE结算工具_衍生色度按仓类 = 值色数
End Function
Function STBASE结算工具_衍生目标涨幅按仓类(值仓类 As String) As String
        Dim 值目标涨幅 As String
        '--------------------------------------------------------------------------------
        Select Case 值仓类
        '系列D：靛绿色 (与本系统日类色系相符)
        Case "_aO"
            值目标涨幅 = "2%"
        '系列W：靛色 (与本系统周类色系相符)
        Case "_bO"
            值目标涨幅 = "2%"
        Case "_aX", "_bX"
            值目标涨幅 = "被动持仓"
        Case "_dO"
            值目标涨幅 = "1%"
        Case "_dX"
            值目标涨幅 = "被动持仓"
        '----------------------------------------
        Case "_sO"
            值目标涨幅 = "慎入"
        Case "_sX"
            值目标涨幅 = "被动持仓"
        '----------------------------------------
        '系列M1：青色
        Case "w"
            值目标涨幅 = "清仓"
        Case "y"
            值目标涨幅 = "清仓"
        Case "z"
            值目标涨幅 = "清仓"
        End Select
        '--------------------------------------------------------------------------------
        STBASE结算工具_衍生目标涨幅按仓类 = 值目标涨幅
End Function




Function STBASE结算工具_衍生色度按涨幅(值涨幅 As Double) As Long
        Dim 值色索引 As Long
        '--------------------------------------------------------------------------------
        Select Case 值涨幅
        Case Is > 9.8
            值色索引 = 常色十红      '赤
        Case Is > 8
            值色索引 = 常色八红      '赤
        Case Is > 6
