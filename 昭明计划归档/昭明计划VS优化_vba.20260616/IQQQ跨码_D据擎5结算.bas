Function STBASE结算工具_衍生交叉天数(前值 As Variant, 今快 As Double, 今慢 As Double) As Integer
    Dim 今值 As Integer
    '------------------------------------------------------------------------------------
    If 前值 > 0 Then
        If 今快 >= 今慢 Then
            今值 = 前值 + 1
        Else
            今值 = -1
        End If
    Else
        If 今快 < 今慢 Then
            今值 = 前值 - 1
        Else
            今值 = 1
        End If
    End If
    '------------------------------------------------------------------------------------
    STBASE结算工具_衍生交叉天数 = 今值
End Function



Function STBASE结算工具_衍生局(JZ As Double, JA As Double, JB As Double, JC As Double) As String
        '--------------------------------------------------------------------------------
        If JB < JC Then
                If JZ >= JC Then
                        If JA >= JC Then
                            STBASE结算工具_衍生局 = IIf(JZ >= JA, "1b", "1e")
                        ElseIf JA >= JB Then
                            STBASE结算工具_衍生局 = "1w"
                        Else
                            STBASE结算工具_衍生局 = "1v"
                        End If
                ElseIf JZ >= JB Then
                        If JA >= JC Then
                            STBASE结算工具_衍生局 = "6u"
                        ElseIf JA < JB Then
                            STBASE结算工具_衍生局 = "6v"
                        ElseIf JZ >= JA Then
                            STBASE结算工具_衍生局 = "6w"
                        Else
                            STBASE结算工具_衍生局 = "6h"
                        End If
                Else
                        If JA >= JC Then
                            STBASE结算工具_衍生局 = "5i"
                        ElseIf JA >= JB Then
                            STBASE结算工具_衍生局 = "5I"
                        ElseIf JZ < JA Then
                            STBASE结算工具_衍生局 = "5c"
                        Else
                            STBASE结算工具_衍生局 = "5e"
                        End If
                End If
        '------------------------------------------------
        Else
                If JZ >= JB Then
                        If JA < JC Then
                            STBASE结算工具_衍生局 = "2i"
                        ElseIf JA < JB Then
                            STBASE结算工具_衍生局 = "2I"
                        ElseIf JZ >= JA Then
                            STBASE结算工具_衍生局 = "2c"
                        Else
                            STBASE结算工具_衍生局 = "2e"
                        End If
                ElseIf JZ >= JC Then
                        If JA < JC Then
                            STBASE结算工具_衍生局 = "3u"
                        ElseIf JA >= JB Then
                            STBASE结算工具_衍生局 = "3v"
                        ElseIf JZ < JA Then
                            STBASE结算工具_衍生局 = "3w"
                        Else
                            STBASE结算工具_衍生局 = "3h"
                        End If
                Else
                        If JA < JC Then
                            STBASE结算工具_衍生局 = IIf(JZ < JA, "4b", "4e")
                        ElseIf JA < JB Then
                            STBASE结算工具_衍生局 = "4w"
                        Else
                            STBASE结算工具_衍生局 = "4v"
                        End If
                End If
        End If
End Function



