                '========================================================================
                ARROS(位os龟BT合顶) = STBASE结算工具_衍生交叉天数(ARROS(位os龟BT合顶), CDbl(ARROS(位os龟结哼)), CDbl(ARROS(位os龟结顶)))
                ARROS(位os龟BT合底) = STBASE结算工具_衍生交叉天数(ARROS(位os龟BT合底), CDbl(ARROS(位os龟结底)), CDbl(ARROS(位os龟结哈)))    '注意顺序不同
