Function STBASE结算工具_衍生势局(值月局 As String, Optional 值周局 As String, Optional 值日局 As String = "") As String
        Dim 值势局 As String
        '================================================================================
        If 值月局 = "2c" Or 值月局 = "2d" Then
                '----------------------------------------
                If 值周局 = "2e" Then
                       值势局 = "We"        'ZA劫
                ElseIf 值周局 = "2I" Or 值周局 = "3h" Or 值周局 = "2i" Or 值周局 = "3u" Then
                       值势局 = "Wi"        'AB劫
                ElseIf 值周局 = "1w" Or 值周局 = "1v" Then
                       值势局 = "W1"        'AC劫
                ElseIf 值周局 = "3v" Or 值周局 = "3w" Then
                       值势局 = "W3"        'ZB劫 放弃
                '----------------------------------------
                ElseIf 值周局 = "1b" Or 值周局 = "1e" Then
                        值势局 = "Wb"
                Else    '值周局：2c(2d)
                    If 值日局 = "" Then
                        If 值周局 = "2d" Then
                           值势局 = "Wd"
                        Else
                           值势局 = "Wc"
                        End If
                    ElseIf 值日局 = "2e" Then
                           值势局 = "De"        'ZA劫
                    ElseIf 值日局 = "2d" Or 值日局 = "2c" Then
                           值势局 = "Dc"
                    ElseIf 值日局 = "1b" Or 值日局 = "1e" Or 值日局 = "1w" Or 值日局 = "1v" Then
                           值势局 = "D1"        'AC劫
                    ElseIf 值日局 = "2I" Or 值日局 = "2i" Or 值日局 = "3h" Or 值日局 = "3u" Then
                           值势局 = "Di"        'AB劫
                    ElseIf 值日局 = "3v" Or 值日局 = "3w" Then
                           值势局 = "D3"        'AC劫
                    Else
                           值势局 = "D错"
                    End If
                End If
                '----------------------------------------
        ElseIf 值月局 = "2e" Then
               值势局 = "Me"                        '主升浪调整
        ElseIf 值月局 = "1b" Or 值月局 = "1e" Then
               值势局 = "Mb"                        '主升浪开始
        '--------------------------------------------------------------------------------
        ElseIf 值月局 = "1w" Or 值月局 = "6w" Then
               值势局 = "Mw"                        '升浪尝试
        ElseIf 值月局 = "1v" Or 值月局 = "6v" Then
               值势局 = "Mv"                        '跌浪终结
        '--------------------------------------------------------------------------------
        ElseIf 值月局 = "5I" Or 值月局 = "5i" Or 值月局 = "6h" Or 值月局 = "6u" Then
               值势局 = "Mi"                        '放弃
        ElseIf 值月局 = "2I" Or 值月局 = "2i" Or 值月局 = "3h" Or 值月局 = "3u" Then
               值势局 = "Ni"                        '放弃
        '--------------------------------------------------------------------------------
        ElseIf 值月局 = "3v" Or 值月局 = "4v" Then
               值势局 = "Nv"
        ElseIf 值月局 = "3w" Or 值月局 = "4w" Then
               值势局 = "Nw"
        '----------------------------------------
        ElseIf 值月局 = "4b" Then
               值势局 = "Nb"
        ElseIf 值月局 = "5e" Or 值月局 = "4e" Then
               值势局 = "Ne"
        ElseIf 值月局 = "5c" Then
               值势局 = "Nc"
        '--------------------------------------------------------------------------------
        Else
               值势局 = "NN"
        End If
        '================================================================================
        STBASE结算工具_衍生势局 = 值势局
End Function
'醍醐灌顶20220727：仅仅是粗分类，按照月局设置颜色，不要考虑周局。
