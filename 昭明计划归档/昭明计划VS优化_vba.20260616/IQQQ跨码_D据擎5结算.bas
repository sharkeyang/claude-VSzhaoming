                ARROS(位os龟叠幅4) = ARROS(位os龟叠幅3)
                ARROS(位os龟叠幅3) = ARROS(位os龟叠幅2)
                ARROS(位os龟叠幅2) = ARROS(位os龟叠幅1)
                ARROS(位os龟叠幅1) = ARROS(位os龟叠幅0)
                If ARROS(位os龟结哼) <> 0 And ARROS(位os龟结哈) <> 0 Then
                        ARROS(位os龟叠幅0) = 1 * Round((ARROS(位os龟结哼) / ARROS(位os龟结哈) - 1) * 100, 0)
                End If
        '================================================================================
'########################################################################################
'##################################      OS衍生      ####################################
'##################################   均线时间指标   ####################################
'########################################################################################
                

'########################################################################################
'##################################     迭代衍生     ####################################
'##################################   工具类型指标   ####################################
'########################################################################################
        '================================================================================
        '衍生：管工具箱
        '依赖：均线 顶哼
        '================================================================================
                '========================================================================
                '上符串
                '功能：记录五周期内【触哼】情况
                '注释：为什么添加【BT哼】而不是【BT顶】，因为对于G类型合顶两者没有区别，仅仅针对逐类有区别，可以依赖【BT合顶哼】进行识别。
                '========================================================================
                值单形上符 = ""
                If ARROS(位os龟BT顶) > 0 Then     '触顶必触哼
                    值单形上符 = 常枚上符顶 & ARROS(位os龟BT哼)
                ElseIf ARROS(位os龟BT哼) > 0 Then '触哼
                    值单形上符 = 常枚上符哼 & ARROS(位os龟BT哼)
                ElseIf ARROS(位os龟BT哈) > 0 Then '触哈
                    值单形上符 = 常枚上符哈 & ARROS(位os龟BT哈)
                ElseIf ARROS(位os龟BT底) > 0 Then '触底必触哈
                    值单形上符 = 常枚上符底 & ARROS(位os龟BT哈)
                Else                            '未触
                    值单形上符 = 常枚上符无
                End If
                ARROS(位os具上符串) = Right(ARROS(位os具上符串), 4) & Left(值单形上符, 1)
                '----------------------------------------------
                ARROS(位os具上符4) = ARROS(位os具上符3)
                ARROS(位os具上符3) = ARROS(位os具上符2)
                ARROS(位os具上符2) = ARROS(位os具上符1)
                ARROS(位os具上符1) = ARROS(位os具上符0)
                ARROS(位os具上符0) = 值单形上符
                '========================================================================
                '宽符串
                '========================================================================
                If JZ >= JC Then
                        If ARROS(位os龟结哼) > 0 And JA > 0 Then
                                '撤：从WJA到哼的最大涨幅，即从WJA开仓曾经达到的最大涨幅。代表喇叭的宽度。
                                值叭宽 = Int((ARROS(位os龟结哼) / JA - 1) * 100)
                        End If
                Else
                        If ARROS(位os龟结哈) > 0 And JA > 0 Then
                                值叭宽 = Int((1 - ARROS(位os龟结哈) / JA) * 100)
                        End If
                End If
                '------------------------------------------------------------------------
                值单形宽符 = ""
                If 值叭宽 >= 50 Then
                    值单形宽符 = "X"
                ElseIf 值叭宽 >= 40 Then
                    值单形宽符 = "4"
                ElseIf 值叭宽 >= 30 Then
                    值单形宽符 = "3"
                ElseIf 值叭宽 >= 20 Then
                    值单形宽符 = "2"
                ElseIf 值叭宽 >= 15 Then
                    值单形宽符 = "K"    '代表15+
                ElseIf 值叭宽 >= 10 Then
                    值单形宽符 = "I"    '代表1X
                ElseIf 值叭宽 >= 5 Then
                    值单形宽符 = "s"    '代表5
                ElseIf 值叭宽 >= 0 Then
                    值单形宽符 = "o"    '代表0
                Else
                    值单形宽符 = "_"
                End If
                ARROS(位os具宽符串) = Right(ARROS(位os具宽符串), 4) & 值单形宽符
                '========================================================================
                '并符串
                '========================================================================
                值单形并符 = ""
                If ARROS(位os结幅PR0) < 0 Then
                    If ARROS(位os结幅PR1) < 0 Then
                        值单形并符 = 常枚并符跌连
                        '注意20230707：此方法必须保证BTZB>=5，从而连阴当时必是w2d/w2e。
                    ElseIf ARROS(位os价C0) < ARROS(位os价O1) Then
                        值单形并符 = 常枚并符跌吞
                    Else
                        值单形并符 = 常枚并符跌孕
                    End If
                Else
                    If ARROS(位os结幅PR1) >= 0 Then
                        值单形并符 = 常枚并符升连
                        '注意20230707：此方法必须使用在/w3v/w3w/w2e。
                    ElseIf ARROS(位os价C0) >= ARROS(位os价O1) Then
                        值单形并符 = 常枚并符升吞
                    Else
                        值单形并符 = 常枚并符升孕
                    End If
                End If
                ARROS(位os具并符串) = Right(ARROS(位os具并符串), 4) & 值单形并符
                ARROS(位os具并符0) = 值单形并符
                '========================================================================
                '中符串
                '功能：记录五周期内【柱与均线JA相交】情况
                '========================================================================
                值单形中符 = ""
                If 值结低 >= JA Then
                    值单形中符 = 常枚中符上全 '全上
                ElseIf 值结收 >= JA And 值结开 >= JA And 值结低 < JA Then
                    值单形中符 = 常枚中符上探  '柱上影破
                ElseIf 值结收 >= JA And 值结开 < JA And 值结低 < JA Then
                    值单形中符 = 常枚中符鼎正  '鼎
                ElseIf 值结开 >= JA Then
                    值单形中符 = 常枚中符薡反  '反鼎
                ElseIf 值结高 >= JA Then
                    值单形中符 = 常枚中符下探  '柱下影破
                Else
                    值单形中符 = 常枚中符下全  '全下
                End If
                ARROS(位os具中符串) = Right(ARROS(位os具中符串), 4) & 值单形中符
                ARROS(位os具中符0) = 值单形中符
        '================================================================================
'########################################################################################
'##################################     迭代衍生     ####################################
'##################################   工具类型指标   ####################################
'########################################################################################
'========================================================================================
'返回
'========================================================================================
        STBASE结算引擎_单点结算核程 = 1
End Function
