                ARROS(位os龟临顶) = Application.Max( _
                                  ARROS(位os价H0) _
                                , ARROS(位os价H1) _
                                , ARROS(位os价H2) _
                                , ARROS(位os价H3) _
                                , ARROS(位os价H4) _
                                , ARROS(位os价H5) _
                                , ARROS(位os价H6) _
                                , ARROS(位os价H7) _
                                , ARROS(位os价H8))
                ARROS(位os龟前顶) = ARROS(位os龟结顶)
                ARROS(位os龟结顶) = Application.Max(ARROS(位os龟临顶), ARROS(位os价H9))
                ARROS(位os龟BT顶) = STBASE结算工具_衍生交叉天数(ARROS(位os龟BT顶), 值结高, CDbl(ARROS(位os龟结顶)))
                '----------------------------------------------
                ARROS(位os龟临底) = Application.Min( _
                                  ARROS(位os价L0) _
                                , ARROS(位os价L1) _
                                , ARROS(位os价L2) _
                                , ARROS(位os价L3) _
                                , ARROS(位os价L4) _
                                , ARROS(位os价L5) _
                                , ARROS(位os价L6) _
                                , ARROS(位os价L7) _
                                , ARROS(位os价L8))
