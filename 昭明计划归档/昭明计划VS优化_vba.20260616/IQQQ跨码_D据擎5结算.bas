Attribute VB_Name = "IQQQ跨码_D据擎5结算"
'-----------------------------------------------
Public Const 常枚上符顶 = "A"
Public Const 常枚上符哼 = "B"
Public Const 常枚上符哈 = "v"
Public Const 常枚上符底 = "w"
Public Const 常枚上符无 = "_"
'-----------------------------------------------
Public Const 常枚并符升连 = "Q"
Public Const 常枚并符升吞 = "O"
Public Const 常枚并符升孕 = "o"
Public Const 常枚并符跌连 = "W"
Public Const 常枚并符跌吞 = "V"
Public Const 常枚并符跌孕 = "v"
'-----------------------------------------------
Public Const 常枚中符上全 = "A"
Public Const 常枚中符上探 = "B"
Public Const 常枚中符鼎正 = "C"
Public Const 常枚中符薡反 = "D"
Public Const 常枚中符下探 = "E"
Public Const 常枚中符下全 = "F"
'-----------------------------------------------
Public Const 常枚层类G = "G"
Public Const 常枚层类A = "A"    '劫BC
Public Const 常枚层类B = "B"    '劫BZ
Public Const 常枚层类C = "C"    '劫BA
Public Const 常枚层类D = "D"    '劫CA
'-----------------------------------------------
'分类原则：根据均线区分为【芽】【根】，在同一方向，根据长短区分为【管(相当于波)】【粒】对应于波粒二象性。
Public Const 常枚层别管 = "Z"
Public Const 常枚层别芽 = "I"
Public Const 常枚层别根 = "e"
'-----------------------------------------------






'########################################################################################
'########################################################################################
'#################################  结算引擎_继点  #######################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：OS计算逻辑（最核心基础计算逻辑）
'运行条件：【位os结日】小于【位os临日】
'运行结果：1/0，用于外部调用直接计数
'运行注意：结算前必须将结算价写入【位os临收】。必备信息【位os临日】【位os基累龄】【位os期类】
'----------------------
'必须放到OS中的计算包括：
'   (1)不同周期进行同样逻辑的计算，如均线；
'   (2)进行累计运算，如统计。
'========================================================================================
'========================================================================================
Function STBASE结算引擎_单点结算核程(ByRef ARROS As Variant) As Integer
'========================================================================================
'运行判断
'========================================================================================
        If CDate(ARROS(位os结期)) >= CDate(ARROS(位os临期)) Then
            '注意20230701：一定要用CDate转换从花天读取的日期，否则会保存为字符格式，导致错误。
            STBASE结算引擎_单点结算核程 = 0
            Exit Function
        End If
'========================================================================================
        
        
        
        
'########################################################################################
'##################################      OS基础      #####################################
'##################################   基础递归部分   #####################################
'########################################################################################
        '================================================================================
        '基础递归
        '================================================================================
                ARROS(位os基累龄) = ARROS(位os基累龄) + 1
                '========================================================================
                ARROS(位os前期) = ARROS(位os结期)
                ARROS(位os前收) = ARROS(位os结收)
                ARROS(位os前开) = ARROS(位os结开)
                ARROS(位os前高) = ARROS(位os结高)
                ARROS(位os前低) = ARROS(位os结低)
                ARROS(位os前交量) = ARROS(位os结交量)
                ARROS(位os前换手) = ARROS(位os结换手)
                ARROS(位os前量比) = ARROS(位os结量比)
                '----------------------
                ARROS(位os结期) = ARROS(位os临期)
                ARROS(位os结收) = ARROS(位os临收)
                ARROS(位os结开) = ARROS(位os临开)
                ARROS(位os结高) = ARROS(位os临高)
                ARROS(位os结低) = ARROS(位os临低)
                ARROS(位os结交量) = ARROS(位os临交量)
                ARROS(位os结换手) = ARROS(位os临换手)
                ARROS(位os结量比) = ARROS(位os临量比)
                '----------------------
                '注20241019：作为标志位，代表当周结算已经结束。主要用于判断非正常结束周期是否应该结算。
                ARROS(位os临收) = 0
                ARROS(位os临开) = 0
                ARROS(位os临高) = 0
                ARROS(位os临低) = 0
        '================================================================================
'########################################################################################
'##################################      OS基础      ####################################
'##################################   基础递归部分   ####################################
'########################################################################################
        
        
        
        
        
'########################################################################################
'##################################      OS基础      ####################################
'##################################   价格相关指标   ####################################
'########################################################################################
        '================================================================================
        '读取取值
        '================================================================================
                Dim 值结收#, 值结开#, 值结高#, 值结低#
                值结收 = ARROS(位os结收)
                值结开 = ARROS(位os结开)
                值结高 = ARROS(位os结高)
                值结低 = ARROS(位os结低)
        '================================================================================
        '计算：值结PR
        '================================================================================
                Dim 值前收#
                值前收 = ARROS(位os前收)
                Dim 值结PR#, 值结HR#, 值结LR#
                If 值前收 <> 0 Then
                    值结PR = (值结收 / 值前收 - 1) * 100
                    值结HR = (值结高 / 值前收 - 1) * 100
                    值结LR = (值结低 / 值前收 - 1) * 100
                End If
                '----------------------------------------------
                ARROS(位os结幅PR9) = ARROS(位os结幅PR8)
                ARROS(位os结幅PR8) = ARROS(位os结幅PR7)
                ARROS(位os结幅PR7) = ARROS(位os结幅PR6)
                ARROS(位os结幅PR6) = ARROS(位os结幅PR5)
                ARROS(位os结幅PR5) = ARROS(位os结幅PR4)
                ARROS(位os结幅PR4) = ARROS(位os结幅PR3)
                ARROS(位os结幅PR3) = ARROS(位os结幅PR2)
                ARROS(位os结幅PR2) = ARROS(位os结幅PR1)
                ARROS(位os结幅PR1) = ARROS(位os结幅PR0)
                ARROS(位os结幅PR0) = Round(值结PR, 2)
                '----------------------------------------------
                ARROS(位os结幅HR9) = ARROS(位os结幅HR8)
                ARROS(位os结幅HR8) = ARROS(位os结幅HR7)
                ARROS(位os结幅HR7) = ARROS(位os结幅HR6)
                ARROS(位os结幅HR6) = ARROS(位os结幅HR5)
                ARROS(位os结幅HR5) = ARROS(位os结幅HR4)
                ARROS(位os结幅HR4) = ARROS(位os结幅HR3)
                ARROS(位os结幅HR3) = ARROS(位os结幅HR2)
                ARROS(位os结幅HR2) = ARROS(位os结幅HR1)
                ARROS(位os结幅HR1) = ARROS(位os结幅HR0)
                ARROS(位os结幅HR0) = Round(值结HR, 2)
                '----------------------------------------------
                ARROS(位os结幅LR9) = ARROS(位os结幅LR8)
                ARROS(位os结幅LR8) = ARROS(位os结幅LR7)
                ARROS(位os结幅LR7) = ARROS(位os结幅LR6)
                ARROS(位os结幅LR6) = ARROS(位os结幅LR5)
                ARROS(位os结幅LR5) = ARROS(位os结幅LR4)
                ARROS(位os结幅LR4) = ARROS(位os结幅LR3)
                ARROS(位os结幅LR3) = ARROS(位os结幅LR2)
                ARROS(位os结幅LR2) = ARROS(位os结幅LR1)
                ARROS(位os结幅LR1) = ARROS(位os结幅LR0)
                ARROS(位os结幅LR0) = Round(值结LR, 2)
                '========================================================================
                '衍生：组柱波动
                '========================================================================
                ARROS(位osBTPRb) = STBASE结算工具_衍生交叉天数(ARROS(位osBTPRb), 值结收, 值前收 * 0.98)
                ARROS(位osBTPR0) = STBASE结算工具_衍生交叉天数(ARROS(位osBTPR0), 值结收, 值前收)
                ARROS(位osBTPR1) = STBASE结算工具_衍生交叉天数(ARROS(位osBTPR1), 值结收, 值前收 * 1.01)
                ARROS(位osBTPR3) = STBASE结算工具_衍生交叉天数(ARROS(位osBTPR3), 值结收, 值前收 * 1.03)
                ARROS(位osBTPR9) = STBASE结算工具_衍生交叉天数(ARROS(位osBTPR9), 值结收, 值前收 * 1.09)
                '----------------------------------------------
                ARROS(位osBTHR0) = STBASE结算工具_衍生交叉天数(ARROS(位osBTHR0), 值结高, 值前收)
                ARROS(位osBTHR1) = STBASE结算工具_衍生交叉天数(ARROS(位osBTHR1), 值结高, 值前收 * 1.01)
                ARROS(位osBTHR3) = STBASE结算工具_衍生交叉天数(ARROS(位osBTHR3), 值结高, 值前收 * 1.03)
                ARROS(位osBTHR9) = STBASE结算工具_衍生交叉天数(ARROS(位osBTHR9), 值结高, 值前收 * 1.09)
        '================================================================================
'########################################################################################
'##################################      OS基础      ####################################
'##################################   价格相关指标   ####################################
'########################################################################################



    
'########################################################################################
'##################################      OS核心      ####################################
'##################################   均线基础迭代   ####################################
'########################################################################################
        '================================================================================
        '读取数据
        '================================================================================
                Dim 均基#
                Dim JZ#, JA#, JB#, JC#, JD#, JE#, JF#, JG#
                '----------------------------------------------
                JZ = ARROS(位osJZ)
                JA = ARROS(位osJA)
                JB = ARROS(位osJB)
                JC = ARROS(位osJC)
                JD = ARROS(位osJD)
                JE = ARROS(位osJE)
                JF = ARROS(位osJF)
                JG = ARROS(位osJG)
                '----------------------------------------------
                '均线迭代
                '----------------------------------------------
                JZ = (1 / 3) * JZ + (2 / 3) * 值结收
                均基 = JZ
                JA = (4 / 6) * JA + (2 / 6) * 均基
                JB = (11 / 13) * JB + (2 / 13) * 均基
                JC = (25 / 27) * JC + (2 / 27) * 均基
                JD = (59 / 61) * JD + (2 / 61) * 均基
                JE = (119 / 121) * JE + (2 / 121) * 均基
                JF = (239 / 241) * JF + (2 / 241) * 均基
                JG = (479 / 481) * JG + (2 / 481) * 均基
                '========================================================================
                '衍生：局系统（使用未Round精确值）
                '依赖：均线
                '========================================================================
                Dim 值局ZEFG$, 值局ZCDE$, 值局ZABC$
                值局ZEFG = STBASE结算工具_衍生局(JZ, JE, JF, JG)
                值局ZCDE = STBASE结算工具_衍生局(JZ, JC, JD, JE)
                值局ZABC = STBASE结算工具_衍生局(JZ, JA, JB, JC)
                If 值局ZABC = "2c" And 值结收 < 值前收 Then 值局ZABC = "2d"
                ARROS(位os局ZEFG) = 值局ZEFG
                ARROS(位os局ZCDE) = 值局ZCDE
                ARROS(位os局ZABC) = 值局ZABC
                '----------------------------------------------
                If ARROS(位os期类) = 常期类为日 Then
                    ARROS(位os局势日基) = STBASE结算工具_衍生势局(值局ZEFG, 值局ZCDE, 值局ZABC)
                ElseIf ARROS(位os期类) = 常期类为周 Then
                    ARROS(位os局势周基) = STBASE结算工具_衍生势局(值局ZCDE, 值局ZABC)
                End If
                '========================================================================
                '写入数组（存入前Round，下次迭代读回与原行为一致）
                '========================================================================
                JZ = Round(JZ, 3)
                JA = Round(JA, 3)
                JB = Round(JB, 3)
                JC = Round(JC, 3)
                JD = Round(JD, 3)
                JE = Round(JE, 3)
                JF = Round(JF, 3)
                JG = Round(JG, 3)
                ARROS(位osJZ) = JZ
                ARROS(位osJA) = JA
                ARROS(位osJB) = JB
                ARROS(位osJC) = JC
                ARROS(位osJD) = JD
                ARROS(位osJE) = JE
                ARROS(位osJF) = JF
                ARROS(位osJG) = JG
        '================================================================================
'########################################################################################
'##################################      OS核心      ####################################
'##################################   均线基础迭代   ####################################
'########################################################################################



'########################################################################################
'##################################      月尊指标     ###################################
'########################################################################################
        '================================================================================
        '衍生：月尊
        '================================================================================
                Dim 结中#
                结中 = (值结高 + 值结低) / 2
                '用I来代表中点
                ARROS(位os具BTIB) = STBASE结算工具_衍生交叉天数(ARROS(位os具BTIB), 结中, JB)
                '----------------------------------------------
                '柱被JB切割比例
                If 值结低 >= JB Then
                    ARROS(位os具比柱JB) = "A"
                ElseIf 值结高 < JB Then
                    ARROS(位os具比柱JB) = "D"
                Else
                    ARROS(位os具比柱JB) = IIf(结中 >= JB, "B", "C") & CInt(100 * (值结高 - JB) / (值结高 - 值结低))
                End If
        '================================================================================
'########################################################################################
'##################################      月尊指标     ###################################
'########################################################################################



'########################################################################################
'##################################      OS衍生      ####################################
'##################################   均线时间指标   ####################################
'########################################################################################
        '================================================================================
        '衍生：均线交叉累期系统
        '================================================================================
                '----------------------------------------------
                '注20251212：用于缓存前五柱与WJA的关系，用于判断①是否频繁贯穿、②是否确认穿越WJA。从WJA之上下破WJA通常包含贯穿WJA的震荡。
                '用于计算：下破WJA前在WJA之上有几柱（应≤3）、上破WJA前在WJA之下有几柱（应≤3）。
                '----------------------------------------------
                ARROS(位osBTZA5) = ARROS(位osBTZA4)
                ARROS(位osBTZA4) = ARROS(位osBTZA3)
                ARROS(位osBTZA3) = ARROS(位osBTZA2)
                ARROS(位osBTZA2) = ARROS(位osBTZA1)
                ARROS(位osBTZA1) = ARROS(位osBTZA)
                ARROS(位osBTZA) = STBASE结算工具_衍生交叉天数(ARROS(位osBTZA), JZ, JA)
                '【判定上破WJA前是否短暂下破：下破三柱之内】
                '注20251212：三柱以内都认为是暂。
                '注20260426：只考虑针对向上的方向，是否之前只是暂下破WJA：上破WJA前是否只下破了WJA三柱以内；下破WJA后，是否只下破三柱以内。（勿改动20260426）
'                If ARROS(位osBTZA1) = 0 Then
'                        ARROS(位osBTZA暂下破) = ""  '针对开天辟地第一柱
'                ElseIf ARROS(位osBTZA) >= 4 Or ARROS(位osBTZA) <= -4 Then
'                        ARROS(位osBTZA暂下破) = ""
'                ElseIf ARROS(位osBTZA) = 1 Then
'                    If ARROS(位osBTZA1) >= -3 Then
'                        ARROS(位osBTZA暂下破) = "暂"
'                    End If
'                ElseIf ARROS(位osBTZA) < 0 Then
'                        ARROS(位osBTZA暂下破) = "暂"
''                ElseIf ARROS(位osBTZA) = -1 Then
''                    If ARROS(位osBTZA1) <= 3 Then
''                        ARROS(位osBTZA暂下破) = "暂"
''                    End If
'                Else
'                        ARROS(位osBTZA暂下破) = ARROS(位osBTZA暂下破)
'                End If
                '----------------------------------------------
                If ARROS(位osBTZA1) = 0 Then
                        ARROS(位osBTZA暂下破) = ""  '针对开天辟地第一柱
                ElseIf ARROS(位osBTZA) >= 4 Or ARROS(位osBTZA) <= -4 Then
                        ARROS(位osBTZA暂下破) = ""
                ElseIf ARROS(位osBTZA) = 1 Then
                    If ARROS(位osBTZA1) >= -3 Then
                        ARROS(位osBTZA暂下破) = "暂"
                    End If
                ElseIf ARROS(位osBTZA) = -1 Then
                    If ARROS(位osBTZA1) <= 3 Then
                        ARROS(位osBTZA暂下破) = "暂"
                    Else
                        ARROS(位osBTZA暂下破) = ""
                    End If
                Else
                        ARROS(位osBTZA暂下破) = ARROS(位osBTZA暂下破)
                End If
                '----------------------------------------------
                ARROS(位osBTZB) = STBASE结算工具_衍生交叉天数(ARROS(位osBTZB), JZ, JB)
                ARROS(位osBTZC) = STBASE结算工具_衍生交叉天数(ARROS(位osBTZC), JZ, JC)
                ARROS(位osBTZD) = STBASE结算工具_衍生交叉天数(ARROS(位osBTZD), JZ, JD)
                ARROS(位osBTZE) = STBASE结算工具_衍生交叉天数(ARROS(位osBTZE), JZ, JE)
                ARROS(位osBTZF) = STBASE结算工具_衍生交叉天数(ARROS(位osBTZF), JZ, JF)
                ARROS(位osBTZG) = STBASE结算工具_衍生交叉天数(ARROS(位osBTZG), JZ, JG)
                '----------------------------------------------
                ARROS(位osBTAB) = STBASE结算工具_衍生交叉天数(ARROS(位osBTAB), JA, JB)
                ARROS(位osBTAC) = STBASE结算工具_衍生交叉天数(ARROS(位osBTAC), JA, JC)
                ARROS(位osBTBC) = STBASE结算工具_衍生交叉天数(ARROS(位osBTBC), JB, JC)
                ARROS(位osBTAD) = STBASE结算工具_衍生交叉天数(ARROS(位osBTAD), JA, JD)
                ARROS(位osBTBD) = STBASE结算工具_衍生交叉天数(ARROS(位osBTBD), JB, JD)
                ARROS(位osBTCD) = STBASE结算工具_衍生交叉天数(ARROS(位osBTCD), JC, JD)
                ARROS(位osBTAE) = STBASE结算工具_衍生交叉天数(ARROS(位osBTAE), JA, JE)
                ARROS(位osBTCE) = STBASE结算工具_衍生交叉天数(ARROS(位osBTCE), JC, JE)
                ARROS(位osBTDE) = STBASE结算工具_衍生交叉天数(ARROS(位osBTDE), JD, JE)
                ARROS(位osBTAF) = STBASE结算工具_衍生交叉天数(ARROS(位osBTAF), JA, JF)
                ARROS(位osBTCF) = STBASE结算工具_衍生交叉天数(ARROS(位osBTCF), JC, JF)
                ARROS(位osBTDF) = STBASE结算工具_衍生交叉天数(ARROS(位osBTDF), JD, JF)
                ARROS(位osBTEF) = STBASE结算工具_衍生交叉天数(ARROS(位osBTEF), JE, JF)
                ARROS(位osBTAG) = STBASE结算工具_衍生交叉天数(ARROS(位osBTAG), JA, JG)
                ARROS(位osBTCG) = STBASE结算工具_衍生交叉天数(ARROS(位osBTCG), JC, JG)
                ARROS(位osBTEG) = STBASE结算工具_衍生交叉天数(ARROS(位osBTEG), JE, JG)
                ARROS(位osBTFG) = STBASE结算工具_衍生交叉天数(ARROS(位osBTFG), JF, JG)
        '================================================================================
        '衍生：丘启系统
        '依赖：均线交叉累期系统
        '================================================================================
'                '========================================================================
'                '衍生：WJEDC最后相交类型（DE/CE/ED/EC）
'                '注意20220806：主要用于日类判断DEDC最后交叉类型：DE/CE/CD，其中本过程主要用来判断DE/CE，CD在最后DE交叉的基础上再进行判断。
'                '醍醐灌顶20230101：分为四组，每组为前后两个方向，例如EDce/DEce为在ce情况下WJD与WJE交叉情况。
'                '========================================================================
'                '月级别周类
'                If ARROS(位osBTDE) = 1 Then
'                        ARROS(位os奏丘启XEDC) = IIf(ARROS(位osBTCE) > 1, "DEce", "DEec")
'                ElseIf ARROS(位osBTDE) = -1 Then
'                        ARROS(位os奏丘启XEDC) = IIf(ARROS(位osBTCE) < -1, "EDec", "EDce")
'                ElseIf ARROS(位osBTCE) = 1 Then
'                        ARROS(位os奏丘启XEDC) = IIf(ARROS(位osBTDE) > 1, "CEde", "CEed")
'                ElseIf ARROS(位osBTCE) = -1 Then
'                        ARROS(位os奏丘启XEDC) = IIf(ARROS(位osBTDE) < -1, "ECed", "ECde")
'                Else
'                        ARROS(位os奏丘启XEDC) = ARROS(位os奏丘启XEDC)
'                End If
'                '--------------------------------------------------------
'                '月级别月类
'                If ARROS(位osBTBC) = 1 Then
'                        ARROS(位os奏丘启XCBA) = IIf(ARROS(位osBTAC) > 1, "BCac", "BCca")
'                ElseIf ARROS(位osBTBC) = -1 Then
'                        ARROS(位os奏丘启XCBA) = IIf(ARROS(位osBTAC) < -1, "CBca", "CBac")
'                ElseIf ARROS(位osBTAC) = 1 Then
'                        ARROS(位os奏丘启XCBA) = IIf(ARROS(位osBTBC) > 1, "ACbc", "ACcb")
'                ElseIf ARROS(位osBTAC) = -1 Then
'                        ARROS(位os奏丘启XCBA) = IIf(ARROS(位osBTBC) < -1, "CAcb", "CAbc")
'                Else
'                        ARROS(位os奏丘启XCBA) = ARROS(位os奏丘启XCBA)
'                End If
'                '========================================================================
'                'DE上叉数：DC/CB/EZ/DZ
'                '注20220623：计数大周期上小周期个数，要在小周期下穿的地方，而不能等到上穿时，否则下次状态不正确
'                '========================================================================
'                If JD < JE Then
'                        ARROS(位os奏数DE叉DC) = 0
'                Else
'                        ARROS(位os奏数DE叉DC) = ARROS(位os奏数DE叉DC) - IIf(ARROS(位osBTCD) = -1, 1, 0)
'                End If
'                If JD < JE Then
'                        ARROS(位os奏数DE叉CB) = 0
'                Else
'                        ARROS(位os奏数DE叉CB) = ARROS(位os奏数DE叉CB) - IIf(ARROS(位osBTBC) = -1, 1, 0)
'                End If
'                '--------------------------------------------------------
'                If JD < JE Then
