'########################################################################################
'##################################  结算引擎_全点结算  ##################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：全点结算
'适用：LLL
'逻辑：改写交易规则，按照交易规则进行操作，改写今仓、今手、今赚、累赚、累持等指标
'逻辑：参考CSV进行编写，应用不同的持仓策略，在LLL上做实验，然后放到CSV上进行批量运行
'========================================================================================
'========================================================================================
Function STBASE结算引擎_全点基组数程( _
          ByRef ARRLX As Variant _
        , ByRef ARRDATA As Variant _
        , ByVal 指定代码 As String _
        , ByVal 指定期类 As String _
        ) As Integer
'========================================================================================
'验证非空
'========================================================================================
    If VBA.IsEmpty(ARRDATA) Then Exit Function
'========================================================================================
'初始赋值
'========================================================================================
    '数组：全点结算
    ReDim ARRLX(LBound(ARRDATA, 1) To UBound(ARRDATA, 1), 1 To 花宽单道) As Variant
'========================================================================================
'初始赋值
'========================================================================================
    '数组：单点结算
    Dim ARROS(1 To 花宽单道) As Variant
    ARROS(位os代码) = 指定代码
    ARROS(位os期类) = 指定期类
    Call STBASE结算引擎_单点初始核程(ARROS, ARRDATA)
'========================================================================================
'遍历结算
'========================================================================================
    For 遍历序号 = LBound(ARRDATA, 1) To UBound(ARRDATA, 1)
            '----------------------------------------------------------------------------
            '专供：不去重结算
            '----------------------------------------------------------------------------
            ARROS(位os临收) = ARRDATA(遍历序号, 位列TS结收)
            ARROS(位os临开) = ARRDATA(遍历序号, 位列TS结开)
            ARROS(位os临高) = ARRDATA(遍历序号, 位列TS结高)
            ARROS(位os临低) = ARRDATA(遍历序号, 位列TS结低)
            ARROS(位os临期) = ARRDATA(遍历序号, 位列TS结期)
            '计算：值临PR
            '注20241020：因为不会进入正式结算，所以必须放在外面，与临数据共同赋值。
            If ARROS(位os结收) <> 0 Then
                ARROS(位os临幅PR) = Round((ARROS(位os临收) / ARROS(位os结收) - 1) * 100, 2)
                ARROS(位os临幅HR) = Round((ARROS(位os临高) / ARROS(位os结收) - 1) * 100, 2)
                ARROS(位os临幅LR) = Round((ARROS(位os临低) / ARROS(位os结收) - 1) * 100, 2)
            End If
            '结算
            If ARRDATA(遍历序号, 位列TS结IS) = True Then
                Call STBASE结算引擎_单点结算核程(ARROS)
                Call STBASE结算引擎_单点衍生核程(ARROS)
            End If
            '----------------------------------------------------------------------------
            '专供：去重结算
            '----------------------------------------------------------------------------
'            ARROS(位os临收) = ARRDATA(遍历序号, 位列TS结收)
'            ARROS(位os临开) = ARRDATA(遍历序号, 位列TS结开)
'            ARROS(位os临高) = ARRDATA(遍历序号, 位列TS结高)
'            ARROS(位os临低) = ARRDATA(遍历序号, 位列TS结低)
'            ARROS(位os临期) = ARRDATA(遍历序号, 位列TS结期)
'            '应对最后一条日期进行判断是否结算，但全点结算主要用于展示，可以直接进行结算
'            Call STBASE结算引擎_单点结算核程(ARROS)
'            Call STBASE结算引擎_单点衍生核程(ARROS)
            '----------------------------------------------------------------------------
            For X = 1 To 花宽单道
                ARRLX(遍历序号, X) = ARROS(X)
            Next
            'ARRLX(遍历序号, 位os基累龄) = ARRDATA(遍历序号, 位列TS结龄)
            '----------------------------------------------------------------------------
    Next 遍历序号
'========================================================================================
End Function
