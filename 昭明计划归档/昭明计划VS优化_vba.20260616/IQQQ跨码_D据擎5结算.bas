                ARROS(位os价O7) = ARROS(位os价O6)
                ARROS(位os价O6) = ARROS(位os价O5)
                ARROS(位os价O5) = ARROS(位os价O4)
                ARROS(位os价O4) = ARROS(位os价O3)
                ARROS(位os价O3) = ARROS(位os价O2)
                ARROS(位os价O2) = ARROS(位os价O1)
