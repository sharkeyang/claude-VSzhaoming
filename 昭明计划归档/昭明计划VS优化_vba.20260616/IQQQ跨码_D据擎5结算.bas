                ARROS(位os价H8) = ARROS(位os价H7)
                ARROS(位os价H7) = ARROS(位os价H6)
                ARROS(位os价H6) = ARROS(位os价H5)
                ARROS(位os价H5) = ARROS(位os价H4)
                ARROS(位os价H4) = ARROS(位os价H3)
                ARROS(位os价H3) = ARROS(位os价H2)
                ARROS(位os价H2) = ARROS(位os价H1)
                ARROS(位os价H1) = ARROS(位os价H0)
                ARROS(位os价H0) = 值结高
                '----------------------------------------------
                ARROS(位os价L9) = ARROS(位os价L8)
                ARROS(位os价L8) = ARROS(位os价L7)
                ARROS(位os价L7) = ARROS(位os价L6)
                ARROS(位os价L6) = ARROS(位os价L5)
                ARROS(位os价L5) = ARROS(位os价L4)
                ARROS(位os价L4) = ARROS(位os价L3)
                ARROS(位os价L3) = ARROS(位os价L2)
                ARROS(位os价L2) = ARROS(位os价L1)
                ARROS(位os价L1) = ARROS(位os价L0)
                ARROS(位os价L0) = 值结低
        '================================================================================
        '衍生：龟系统
        '命名十：顶/底；
        '命名五：哼/哈；
