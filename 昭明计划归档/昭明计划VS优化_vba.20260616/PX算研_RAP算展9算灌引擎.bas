Function XL算比模板前调粗比( _
          被研期类 As String _
        , Optional 是否外簿 As Boolean = True _
        )
    '------------------------------------------------------------------------------------
    Dim 组被研算法 As Variant
    
    组被研算法 = Array(常算比类型为粗比 _
            , "s@持日", "s@决策日DE" _
            , "s@乾坤C", "s@乾坤D", "s@乾坤DG" _
            , "s@均权大周期" _
            , "s@均<AB>", "s@均<AC>", "s@均<AD>", "s@均<AE>", "s@均<AF>", "s@均<AG>" _
            , "s@均<BC>" _
            , "s@均<CD>" _
            , "s@均<CE>" _
            , "s@均<DE>" _
            , "s@均<CF>" _
            , "s@均<EF>" _
            , "s@均<CG>", "s@均<EG>", "s@均<FG>" _
            )
    组被研算法 = Array(常算比类型为粗比 _
            , "s@持日", "s@决策日DE" _
            , "s@乾坤C", "s@乾坤D", "s@乾坤DG" _
            )
    '------------------------------------------------------------------------------------
    Call XL算比模板前调基程( _
              被研期类:=被研期类 _
            , 组被研算法:=组被研算法 _
            , 是否外簿:=是否外簿 _
            )
    '------------------------------------------------------------------------------------
End Function









'########################################################################################
'########################################################################################
'###################################   算灌引擎跨期   ####################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'算法对比：跨期算法
'========================================================================================
'========================================================================================
Function XL算灌引擎跨期( _
          ARRLLL As Variant _
        , 规则算法 As String _
        ) As Integer
'========================================================================================
'检查
'========================================================================================
    If VBA.IsEmpty(ARRLLL) Or Len(规则算法) = 0 Then
        GoTo 返点
    End If
'========================================================================================
'变量声明
'========================================================================================
    Dim 基位 As Integer
    Dim 规则月类 As Boolean
    Dim 规则周类 As Boolean
    Dim 规则日类 As Boolean
    '====================================================================================
    Dim 周类今日 As Date
    Dim 周类前日 As Date
    '---------------------
    Dim 周类今收 As Double
    Dim 周类前收 As Double
    '------------------------------------------------
    Dim 周类前仓 As Double
    Dim 周类前手 As Double
    '---------------------
    Dim 周类今仓 As Double
    Dim 周类今手 As Double
    Dim 周类今资 As Long
    Dim 周类今赚 As Long
    Dim 周类累赚 As Long
    Dim 周类累持 As Integer
    '------------------------------------------------
    Dim 周类JZ#, 周类JA#, 周类JB#, 周类JC#, 周类JD#, 周类JE#, 周类JF#, 周类JG#
    Dim 周类BTZA%
    Dim 周类BTZB%, 周类BTAB%
    Dim 周类BTZC%, 周类BTAC%, 周类BTBC%
    Dim 周类BTAG%, 周类BTAD%, 周类BTCG%, 周类BTCD%
    Dim 周类BTEG%, 周类BTAE%, 周类BTFG%, 周类BTCE%, 周类BTDE%
    Dim 周类BTAF%
    Dim 周类MDIF#, 周类MDEA#, 周类MACD#
    '====================================================================================
    Dim 日类今日 As Date
    Dim 日类前日 As Date
    '---------------------
    Dim 日类今收 As Double
    Dim 日类前收 As Double
    '------------------------------------------------
    Dim 日类前仓 As Double
    Dim 日类前手 As Double
    '---------------------
    Dim 日类今仓 As Double
    Dim 日类今手 As Double
    Dim 日类今资 As Long
    Dim 日类今赚 As Long
    Dim 日类累赚 As Long
    Dim 日类累持 As Integer
    '------------------------------------------------
    Dim 日类JZ#, 日类JA#, 日类JB#, 日类JC#, 日类JD#, 日类JE#, 日类JF#, 日类JG#
    Dim 日类BTZA%
    Dim 日类BTZB%, 日类BTAB%
    Dim 日类BTZC%, 日类BTAC%, 日类BTBC%
    Dim 日类BTZG%, 日类BTAD%, 日类BTCG%, 日类BTCD%
    Dim 日类BTEG%, 日类BTAE%, 日类BTFG%, 日类BTCE%, 日类BTDE%
    Dim 日类BTAF%
    Dim 日类MDIF#, 日类MDEA#, 日类MACD#
'========================================================================================
'遍历
'========================================================================================
    Dim 行号遍历 As Integer
    For 行号遍历 = LBound(ARRLLL, 1) To UBound(ARRLLL, 1)
        '================================================================================
        '获取变量：周类
        '================================================================================
        基位 = 花偏乙道
        '------------------------------------------
        周类前日 = 周类今日
        周类今日 = ARRLLL(行号遍历, 基位 + 位os结期)
        If 周类前日 <> 周类今日 Then
            周类前仓 = 周类今仓
            周类前手 = 周类今手
        End If
        '------------------------------------------
        周类今收 = ARRLLL(行号遍历, 基位 + 位os结收)
        周类前收 = ARRLLL(行号遍历, 基位 + 位os前收)
        周类JZ = ARRLLL(行号遍历, 基位 + 位osJZ)
        周类JA = ARRLLL(行号遍历, 基位 + 位osJA)
        周类JB = ARRLLL(行号遍历, 基位 + 位osJB)
        周类JC = ARRLLL(行号遍历, 基位 + 位osJC)
        周类JD = ARRLLL(行号遍历, 基位 + 位osJD)
        周类JE = ARRLLL(行号遍历, 基位 + 位osJE)
        周类BTZA = ARRLLL(行号遍历, 基位 + 位osBTZA)
        周类BTZB = ARRLLL(行号遍历, 基位 + 位osBTZB)
        周类BTAB = ARRLLL(行号遍历, 基位 + 位osBTAB)
        周类BTZC = ARRLLL(行号遍历, 基位 + 位osBTZC)
        周类BTAC = ARRLLL(行号遍历, 基位 + 位osBTAC)
        周类BTBC = ARRLLL(行号遍历, 基位 + 位osBTBC)
        周类BTAG = ARRLLL(行号遍历, 基位 + 位osBTAG)
        周类BTAD = ARRLLL(行号遍历, 基位 + 位osBTAD)
        周类BTCG = ARRLLL(行号遍历, 基位 + 位osBTCG)
        周类BTCD = ARRLLL(行号遍历, 基位 + 位osBTCD)
        周类BTEG = ARRLLL(行号遍历, 基位 + 位osBTEG)
        周类BTAE = ARRLLL(行号遍历, 基位 + 位osBTAE)
        周类BTFG = ARRLLL(行号遍历, 基位 + 位osBTFG)
        周类BTCE = ARRLLL(行号遍历, 基位 + 位osBTCE)
        周类BTDE = ARRLLL(行号遍历, 基位 + 位osBTDE)
        周类BTAF = ARRLLL(行号遍历, 基位 + 位osBTAF)
        周类BTEF = ARRLLL(行号遍历, 基位 + 位osBTEF)
        '================================================================================
        '获取变量：日类
        '================================================================================
        基位 = 花偏甲道
        '------------------------------------------
        日类前日 = 日类今日
        日类今日 = ARRLLL(行号遍历, 基位 + 位os结期)
            日类前仓 = 日类今仓
            日类前手 = 日类今手
        '------------------------------------------
        日类今收 = ARRLLL(行号遍历, 基位 + 位os结收)
        日类前收 = ARRLLL(行号遍历, 基位 + 位os前收)
        日类JZ = ARRLLL(行号遍历, 基位 + 位osJZ)
        日类JA = ARRLLL(行号遍历, 基位 + 位osJA)
        日类JB = ARRLLL(行号遍历, 基位 + 位osJB)
        日类JC = ARRLLL(行号遍历, 基位 + 位osJC)
        日类JD = ARRLLL(行号遍历, 基位 + 位osJD)
        日类JE = ARRLLL(行号遍历, 基位 + 位osJE)
        日类JF = ARRLLL(行号遍历, 基位 + 位osJF)
        日类JG = ARRLLL(行号遍历, 基位 + 位osJG)
        日类BTZA = ARRLLL(行号遍历, 基位 + 位osBTZA)
        日类BTZB = ARRLLL(行号遍历, 基位 + 位osBTZB)
        日类BTAB = ARRLLL(行号遍历, 基位 + 位osBTAB)
        日类BTZC = ARRLLL(行号遍历, 基位 + 位osBTZC)
        日类BTAC = ARRLLL(行号遍历, 基位 + 位osBTAC)
        日类BTBC = ARRLLL(行号遍历, 基位 + 位osBTBC)
        日类BTZD = ARRLLL(行号遍历, 基位 + 位osBTZD)
        日类BTAD = ARRLLL(行号遍历, 基位 + 位osBTAD)
        日类BTCG = ARRLLL(行号遍历, 基位 + 位osBTCG)
        日类BTCD = ARRLLL(行号遍历, 基位 + 位osBTCD)
        日类BTEG = ARRLLL(行号遍历, 基位 + 位osBTEG)
        日类BTZE = ARRLLL(行号遍历, 基位 + 位osBTZE)
        日类BTAE = ARRLLL(行号遍历, 基位 + 位osBTAE)
        日类BTFG = ARRLLL(行号遍历, 基位 + 位osBTFG)
        日类BTCE = ARRLLL(行号遍历, 基位 + 位osBTCE)
        日类BTDE = ARRLLL(行号遍历, 基位 + 位osBTDE)
        日类BTZF = ARRLLL(行号遍历, 基位 + 位osBTZF)
        日类BTEF = ARRLLL(行号遍历, 基位 + 位osBTEF)
        '================================================================================
        



'########################################################################################
'########################################################################################
'算法规则汇总
'########################################################################################
'########################################################################################
    '====================================================================================
    '规则【均线】：JZ JB | 改进算法，主要比较周类与日类，是否需要按小周期进行操作
    '====================================================================================
    '(月类JZ >= 月类JB) = (月类阶丑 = "U" Or 月类阶丑 = "t")
    '====================================================================================
    '规则【均线】：JZ JB | 改进算法，主要比较周类与日类，是否需要按小周期进行操作
    '====================================================================================
    If 规则算法 = "T@乾坤" Then
'        规则周类 = IIf(周类JZ > 周类JD And 周类BTAB > 0 And 周类BTZC > 0, True, False)
'        规则日类 = IIf(日类BTAE > 0 And 日类BTCD > 0 And 日类BTAD > 0, True, False)
'        规则周类 = IIf(周类JZ > 周类JD And 周类BTCD > 0, True, False)
'        规则日类 = IIf(日类BTAF > 0 And 日类BTEF > 0, True, False)
        规则周类 = IIf(周类BTZC > 0 And 周类BTZB > 0, True, False)
        规则日类 = IIf(日类BTZE > 0 And 日类BTZD > 0, True, False)
    ElseIf 规则算法 = "T@乾坤B" Then
        规则周类 = IIf(周类JZ > 周类JE And 周类BTAD > 0 And 周类BTZC > 0 And 周类BTZB > 0, True, False)
        规则日类 = IIf(日类BTAF > 0 And 日类BTCE > 0 And 日类BTZC > 0, True, False)
    '====================================================================================
    '规则【均线】：JZ JC | 改进算法，主要比较周类与日类，是否需要按小周期进行操作
    '====================================================================================
    '均线JC 远逊于 均线JB，考虑以或为关系对 JB与JC 进行验证
    ElseIf 规则算法 = "S@均<ZC>" Then
        规则周类 = (周类JZ >= 周类JC)
        规则日类 = (日类JZ >= 日类JC)
'========================================================================================
    End If
'########################################################################################
'########################################################################################
'########################################################################################
'########################################################################################
        
        
        
    
        
        
    '====================================================================================
    '持仓规则：周
    '====================================================================================
        If 周类前日 <> 周类今日 Then
            If 规则周类 Then
                周类今仓 = 1
            Else
                周类今仓 = 0
            End If
        
            '周类今资 = 周类今仓 * 10000
            '周类今手 = Round(周类今资 / 周类JZ, 2)
            If 周类今仓 > 0 Then
                If 周类前手 = 0 Then 周类今手 = Round(10000 / 周类JZ, 2)
            Else
                周类今手 = 0
            End If
            '-------------------------------------------------------------------------------
            If 规则算法 = "T@山丘" Then
            
                周类今仓 = 1 * IIf(周类BTAB > 0, 1, -1) _
                                + 1 * IIf(周类BTAC > 0, 1, -1) _
                                + 1 * IIf(周类BTAD > 0, 1, -1) _
                                + 1 * IIf(周类BTAE > 0, 1, -1)
                                
                周类变仓 = 1 * IIf(周类BTAB = 1, 1, 0) _
                            - 1 * IIf(周类BTAB = -1, 1, 0) _
                            + 1 * IIf(周类BTAC = 1, 1, 0) _
                            - 1 * IIf(周类BTAC = -1, 1, 0) _
                            + 1 * IIf(周类BTAD = 1, 1, 0) _
                            - 1 * IIf(周类BTAD = -1, 1, 0) _
                            + 1 * IIf(周类BTAE = 1, 1, 0) _
                            - 1 * IIf(周类BTAE = -1, 1, 0)
                            
                If 周类今仓 > 0 Then
                    If 周类变仓 <> 0 Then
                        周类今手 = Round(2500 * 周类今仓 / 周类JZ, 2)
                    Else
                        周类今手 = 周类前手
                    End If
                Else
                    周类今手 = 0
                End If
            End If
            '-------------------------------------------------------------------------------
            周类今赚 = 周类前手 * (周类今收 - 周类前收)
            周类累赚 = IIf(周类前仓 > 0, 周类累赚 + 周类今赚, 0)
            周类累持 = IIf(周类今仓 > 0, 周类累持 + 1, 0)
        End If
        '--------------------------------------------------------------------------------
        '回写
        '--------------------------------------------------------------------------------
        ARRLLL(行号遍历, 花偏乙道 + 位os算今仓) = 周类今仓
        ARRLLL(行号遍历, 花偏乙道 + 位os算今手) = 周类今手
        ARRLLL(行号遍历, 花偏乙道 + 位os算今赚) = 周类今赚
        ARRLLL(行号遍历, 花偏乙道 + 位os算累赚) = 周类累赚
        ARRLLL(行号遍历, 花偏乙道 + 位os算累持) = 周类累持
        ARRLLL(行号遍历, 花偏乙道 + 位os算法名) = 规则算法
    '====================================================================================
    '持仓规则：日
    '====================================================================================
        If 规则日类 = True Then
            日类今仓 = 1
        Else
            日类今仓 = 0
        End If
        
        '日类今资 = 日类今仓 * 10000
        '日类今手 = Round(日类今资 / 日类JZ, 2)
        If 日类今仓 > 0 Then
            If 日类前手 = 0 Then 日类今手 = Round(10000 / 日类JZ, 2)
        Else
            日类今手 = 0
        End If
        '--------------------------------------------------------------------------------
        日类今赚 = 日类前手 * (日类今收 - 日类前收)
        日类累赚 = IIf(日类前仓 > 0, 日类累赚 + 日类今赚, 0)
        日类累持 = IIf(日类今仓 > 0, 日类累持 + 1, 0)
        '--------------------------------------------------------------------------------
        '回写
        '--------------------------------------------------------------------------------
        ARRLLL(行号遍历, 花偏甲道 + 位os算今仓) = 日类今仓
        ARRLLL(行号遍历, 花偏甲道 + 位os算今手) = 日类今手
        ARRLLL(行号遍历, 花偏甲道 + 位os算今赚) = 日类今赚
        ARRLLL(行号遍历, 花偏甲道 + 位os算累赚) = 日类累赚
        ARRLLL(行号遍历, 花偏甲道 + 位os算累持) = 日类累持
        ARRLLL(行号遍历, 花偏甲道 + 位os算法名) = 规则算法
    '====================================================================================
    Next 行号遍历
'========================================================================================
'返回
'========================================================================================
返点:
    XL算灌引擎跨期 = 基行
End Function
