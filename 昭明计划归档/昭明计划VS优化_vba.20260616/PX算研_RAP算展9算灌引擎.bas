'========================================================================================
'========================================================================================
'功能：算法适用数据的类型 单期/跨期
'========================================================================================
'========================================================================================
Function XL算灌引擎判断算法类型(被研算法 As String) As String
    '------------------------------------------------------------------------------------
    Dim 算法类型 As String
    '------------------------------------------------------------------------------------
    Select Case Left(被研算法, 1)
    Case "S", "T", "B"
        算法类型 = 常算法类型为跨期
    Case Else
        算法类型 = 常算法类型为单期
    End Select
    '------------------------------------------------------------------------------------
    XL算灌引擎判断算法类型 = 算法类型
End Function

