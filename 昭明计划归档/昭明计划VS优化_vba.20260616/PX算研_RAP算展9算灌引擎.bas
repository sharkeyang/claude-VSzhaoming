'增加一个路数组，ARRAL，作为算法专道
'设置仓位哲学的思考：如果仅仅以是否突破某条均线来设置1/0仓位，其实是用堵的方法；而用多只均线按照权重来设置，是用疏导的办法。
'########################################################################################
'########################################################################################
'###################################   算灌引擎单期   ####################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'算法对比：单期算法
'========================================================================================
'========================================================================================
Function XL算灌引擎单期( _
          ARRLA As Variant _
        , 规则算法 As String _
        ) As Integer
'========================================================================================
'检查
'========================================================================================
    '不设置算法即采用默认算法
    If VBA.IsEmpty(ARRLA) Or Len(规则算法) = 0 Then
        GoTo 返点
    End If
'========================================================================================
'变量声明
'========================================================================================
    Dim 基位 As Integer
    Dim 规则本类 As Boolean
    '====================================================================================
    Dim 本类今日 As Date
    '---------------------
    Dim 本类今收 As Double
    Dim 本类前收 As Double
    '------------------------------------------------
    Dim 本类前仓 As Double
    Dim 本类前手 As Double
    '---------------------
    Dim 本类今仓 As Double
    Dim 本类今手 As Double
    Dim 本类今资 As Long
    Dim 本类今赚 As Long
    Dim 本类累赚 As Long
    Dim 本类累持 As Integer
    '------------------------------------------------
    Dim 本类JZ#, 本类JA#, 本类JB#, 本类JC#, 本类JD#, 本类JE#, 本类JF#, 本类JG#
    Dim 本类BTZA%, 本类BTZB%, 本类BTZC%
    Dim 本类BTAB%
    Dim 本类BTAC%, 本类BTBC%
    Dim 本类BTAD%, 本类BTCD%
    Dim 本类BTAE%, 本类BTCE%, 本类BTDE%
    Dim 本类BTAF%, 本类BTEF%
    Dim 本类BTAG%, 本类BTCG%, 本类BTEG%, 本类BTFG%
    '------------------------------------------------
    Dim 本类阶金 As Integer, 本类阶鍂 As Integer, 本类阶鑫 As String
    Dim 本类阶口 As Integer, 本类阶吕 As Integer, 本类阶品 As String
    Dim 本类阶木 As Integer, 本类阶林 As Integer, 本类阶森 As String
'========================================================================================
'遍历
'========================================================================================
    Dim 行号遍历 As Integer
    For 行号遍历 = LBound(ARRLA, 1) To UBound(ARRLA, 1)
        '================================================================================
        '获取变量
        '================================================================================
        基位 = 花偏甲道
        '------------------------------------------
        本类前仓 = 本类今仓
        本类前手 = 本类今手
        '------------------------------------------
        本类今日 = ARRLA(行号遍历, 基位 + 位os结期)
        本类今收 = ARRLA(行号遍历, 基位 + 位os结收)
        本类前收 = ARRLA(行号遍历, 基位 + 位os前收)
        '------------------------------------------
        本类JZ = ARRLA(行号遍历, 基位 + 位osJZ)
        本类JA = ARRLA(行号遍历, 基位 + 位osJA)
        本类JB = ARRLA(行号遍历, 基位 + 位osJB)
        本类JC = ARRLA(行号遍历, 基位 + 位osJC)
        本类JD = ARRLA(行号遍历, 基位 + 位osJD)
        本类JE = ARRLA(行号遍历, 基位 + 位osJE)
        本类JF = ARRLA(行号遍历, 基位 + 位osJF)
        本类JG = ARRLA(行号遍历, 基位 + 位osJG)
        '------------------------------------------
        本类BTZA = ARRLA(行号遍历, 基位 + 位osBTZA)
        本类BTZB = ARRLA(行号遍历, 基位 + 位osBTZB)
        本类BTAB = ARRLA(行号遍历, 基位 + 位osBTAB)
        本类BTZC = ARRLA(行号遍历, 基位 + 位osBTZC)
        本类BTAC = ARRLA(行号遍历, 基位 + 位osBTAC)
        本类BTBC = ARRLA(行号遍历, 基位 + 位osBTBC)
        本类BTAD = ARRLA(行号遍历, 基位 + 位osBTAD)
        本类BTCD = ARRLA(行号遍历, 基位 + 位osBTCD)
        本类BTAE = ARRLA(行号遍历, 基位 + 位osBTAE)
        本类BTCE = ARRLA(行号遍历, 基位 + 位osBTCE)
        本类BTDE = ARRLA(行号遍历, 基位 + 位osBTDE)
        本类BTAF = ARRLA(行号遍历, 基位 + 位osBTAF)
        本类BTEF = ARRLA(行号遍历, 基位 + 位osBTEF)
        本类BTAG = ARRLA(行号遍历, 基位 + 位osBTAG)
        本类BTCG = ARRLA(行号遍历, 基位 + 位osBTCG)
        本类BTEG = ARRLA(行号遍历, 基位 + 位osBTEG)
        本类BTFG = ARRLA(行号遍历, 基位 + 位osBTFG)
        '------------------------------------------
        本类阶金 = 1 * IIf(本类JE >= 本类JF, 1, 0) + 2 * IIf(本类JE >= 本类JG, 1, 0) + 4 * IIf(本类JF >= 本类JG, 1, 0)
        本类阶鍂 = 1 * IIf(本类JC >= 本类JE, 1, 0) + 2 * IIf(本类JC >= 本类JF, 1, 0) + 4 * IIf(本类JC >= 本类JG, 1, 0)
        本类阶鑫 = CStr(本类阶金) & "_" & CStr(本类阶鍂)
        '------------------------------------------
        本类阶口 = 1 * IIf(本类JC >= 本类JD, 1, 0) + 2 * IIf(本类JC >= 本类JE, 1, 0) + 4 * IIf(本类JD >= 本类JE, 1, 0)
        本类阶吕 = 1 * IIf(本类JA >= 本类JC, 1, 0) + 2 * IIf(本类JA >= 本类JD, 1, 0) + 4 * IIf(本类JA >= 本类JE, 1, 0)
        本类阶品 = CStr(本类阶口) & "_" & CStr(本类阶吕)
        '------------------------------------------
        本类阶木 = 1 * IIf(本类JA >= 本类JB, 1, 0) + 2 * IIf(本类JA >= 本类JC, 1, 0) + 4 * IIf(本类JB >= 本类JC, 1, 0)
        本类阶林 = 1 * IIf(本类JZ >= 本类JA, 1, 0) + 2 * IIf(本类JZ >= 本类JB, 1, 0) + 4 * IIf(本类JZ >= 本类JC, 1, 0)
        本类阶森 = CStr(本类阶木) & "_" & CStr(本类阶林)
        '================================================================================
        
        
    

'########################################################################################
'########################################################################################
'算法归类：非加权算法
'########################################################################################
'########################################################################################
Select Case 规则算法
    '====================================================================================
    '规则：均线
    '====================================================================================
    Case "s@均<ZA>"
        规则本类 = (本类JZ >= 本类JA)
    '--------------------------------
    Case "s@均<ZB>"
        规则本类 = (本类JZ >= 本类JB)
    Case "s@均<AB>"
        规则本类 = (本类JA >= 本类JB)
    '--------------------------------
    Case "s@均<ZC>"
        规则本类 = (本类JZ >= 本类JC)
    Case "s@均<AC>"
        规则本类 = (本类JA >= 本类JC)
    Case "s@均<BC>"
        规则本类 = (本类JB >= 本类JC)
    '--------------------------------
    Case "s@均<AD>"
        规则本类 = (本类JA >= 本类JD)
    Case "s@均<CD>"
        规则本类 = (本类JC >= 本类JD)
    '--------------------------------
    Case "s@均<ZE>"
        规则本类 = (本类JZ >= 本类JE)
    Case "s@均<AE>"
        规则本类 = (本类JA >= 本类JE)
    Case "s@均<BE>"
        规则本类 = (本类JB >= 本类JE)
    Case "s@均<CE>"
        规则本类 = (本类JC >= 本类JE)
    Case "s@均<DE>"
        规则本类 = (本类JD >= 本类JE)
    '--------------------------------
    Case "s@均<AF>"
        规则本类 = (本类JA >= 本类JF)
    Case "s@均<BF>"
        规则本类 = (本类JB >= 本类JF)
    Case "s@均<CF>"
        规则本类 = (本类JC >= 本类JF)
    Case "s@均<DF>"
        规则本类 = (本类JD >= 本类JF)
    Case "s@均<EF>"
        规则本类 = (本类JE >= 本类JF)
    '--------------------------------
    Case "s@均<AG>"
        规则本类 = (本类JA >= 本类JG)
    Case "s@均<CG>"
        规则本类 = (本类JC >= 本类JG)
    Case "s@均<EG>"
        规则本类 = (本类JE >= 本类JG)
    Case "s@均<FG>"
        规则本类 = (本类JF >= 本类JG)
    '====================================================================================
'非均线算法均有待参考，不一定效果好
    '====================================================================================
    '规则：持日 待删除
    '====================================================================================
'    Case "s@持日1"
'        规则本类 = (本类JZ >= 本类JE And 本类JZ >= 本类JF)
'    Case "s@持日2"
'        规则本类 = (本类JZ >= 本类JE And 本类JZ >= 本类JF) And (本类JZ >= 本类JG)
    Case "s@持日"
        规则本类 = (本类JZ >= 本类JE And 本类JZ >= 本类JF) And (本类JZ >= 本类JG) And (本类JZ >= 本类JD)
    Case "s@决策日DE"
        规则本类 = (本类JZ >= 本类JE And 本类JZ >= 本类JE) And (本类JZ >= 本类JG) And (本类JD >= 本类JE)
    '====================================================================================
    '规则：持日 待删除
    '====================================================================================
    Case "s@乾坤C"
        规则本类 = (本类JA >= 本类JF And 本类JC >= 本类JE) And (本类JZ >= 本类JC)
    Case "s@乾坤D"
        规则本类 = (本类JA >= 本类JF And 本类JC >= 本类JE) And (本类JZ >= 本类JD)
    Case "s@乾坤DG"
        规则本类 = (本类JA >= 本类JF And 本类JC >= 本类JE) And (本类JZ >= 本类JD) And (本类JZ >= 本类JG)
    '====================================================================================
    '规则：阶森
    '====================================================================================
    Case "s@阶鑫<IA>"
        规则本类 = (本类阶鑫 = "7_7")
    '------------------------------------------------------------------------------------
    Case "s@阶鑫<IAB>"
        规则本类 = (本类阶鑫 = "7_7") _
                Or (本类阶鑫 = "3_7")
    '------------------------------------------------------------------------------------
    Case "s@阶鑫<IABC>"
        规则本类 = (本类阶鑫 = "7_7") _
                Or (本类阶鑫 = "3_7") _
                Or (本类阶鑫 = "1_7" Or 本类阶鑫 = "1_3")
    '------------------------------------------------------------------------------------
    Case "s@阶鑫<IABCD>"
        规则本类 = (本类阶鑫 = "7_7") _
                Or (本类阶鑫 = "3_7") _
                Or (本类阶鑫 = "1_7" Or 本类阶鑫 = "1_3") _
                Or (本类阶鑫 = "0_7" Or 本类阶鑫 = "0_3")
    '====================================================================================
    '规则：阶品
    '====================================================================================
    Case "s@阶品<IA>"
        规则本类 = (本类阶品 = "7_7")
    '------------------------------------------------------------------------------------
    Case "s@阶品<IAB>"
        规则本类 = (本类阶品 = "7_7") _
                Or (本类阶品 = "3_7")
    '------------------------------------------------------------------------------------
    Case "s@阶品<IABC>"
        规则本类 = (本类阶品 = "7_7") _
                Or (本类阶品 = "3_7") _
                Or (本类阶品 = "1_7" Or 本类阶品 = "1_3")
    '------------------------------------------------------------------------------------
    Case "s@阶品<IABCD>"
        规则本类 = (本类阶品 = "7_7") _
                Or (本类阶品 = "3_7") _
                Or (本类阶品 = "1_7" Or 本类阶品 = "1_3") _
                Or (本类阶品 = "0_7" Or 本类阶品 = "0_3")
    '====================================================================================
    '====================================================================================
    Case "s@常在"
        规则本类 = 1
    Case Else
    '====================================================================================
End Select
本类今仓 = IIf(规则本类, 1, 0)
'########################################################################################
'########################################################################################
'算法归类：无仓位变化
'########################################################################################
'########################################################################################
        '修改 本类今仓 算法，使得仓位参考更多因素
        '修改 规则本类 算法，使得图谱更加光滑，至少在一个趋势之中
        '================================================================================
        '持仓规则：确定仓位
        '================================================================================
        '对于加权算法
        If 规则算法 = "s@均权大周期" Then
            本类今仓 = _
                  IIf(本类JZ >= 本类JF, 1, 0) * 0.5 _
                + IIf(本类JZ >= 本类JE, 1, 0) * 0.2 _
                + IIf(本类JZ >= 本类JD, 1, 0) * 0.2 _
                + IIf(本类JZ >= 本类JC, 1, 0) * 0.1
        
        
        '选择重要性均线进行组合，并赋以适当的权重
        '以下几个算法要废弃
        ElseIf 规则算法 = "s@均权E" Then
            本类今仓 = _
                  IIf(本类JA >= 本类JE, 1, 0) * 0.4 _
                + IIf(本类JA >= 本类JD, 1, 0) * 0.4 _
                + IIf(本类JA >= 本类JC, 1, 0) * 0.2
        ElseIf 规则算法 = "s@均权DE" Then
            本类今仓 = _
                  IIf(本类JA >= 本类JE, 1, 0) * 0.5 _
                + IIf(本类JA >= 本类JD, 1, 0) * 0.5
        ElseIf 规则算法 = "s@均同DE" Then
            本类今仓 = _
                  IIf(本类JA >= 本类JD And 本类JA >= 本类JE, 1, 0)
        ElseIf 规则算法 = "s@均权D" Then
            本类今仓 = _
                  IIf(本类JA >= 本类JD, 1, 0) * 0.5 _
                + IIf(本类JA >= 本类JC, 1, 0) * 0.5
        ElseIf 规则算法 = "s@均权C" Then
            本类今仓 = _
                  IIf(本类JA >= 本类JC, 1, 0) * 0.6 _
                + IIf(本类JA >= 本类JB, 1, 0) * 0.4
        End If
'########################################################################################
'########################################################################################
'########################################################################################
'########################################################################################
        
        
        
        
        

        '================================================================================
        '持仓规则：本类
        '================================================================================
'        本类今资 = 本类今仓 * 10000
'        本类今手 = Round(本类今资 / 本类JZ, 2)
        
        If 本类今仓 > 0 Then
            If 本类前手 = 0 Or 本类今仓 <> 本类前仓 Then
                本类今手 = Round(10000 * 本类今仓 / 本类JZ, 2)
            End If
        Else
            本类今手 = 0
        End If
        '================================================================================
        本类今赚 = 本类前手 * (本类今收 - 本类前收)
        本类累赚 = IIf(本类前仓 > 0, 本类累赚 + 本类今赚, 0)
        本类累持 = IIf(本类今仓 > 0, 本类累持 + 1, 0)
        '================================================================================
        '回写
        '================================================================================
        ARRLA(行号遍历, 花偏甲道 + 位os算今仓) = 本类今仓
        ARRLA(行号遍历, 花偏甲道 + 位os算今手) = 本类今手
        ARRLA(行号遍历, 花偏甲道 + 位os算今赚) = 本类今赚
        ARRLA(行号遍历, 花偏甲道 + 位os算累赚) = 本类累赚
        ARRLA(行号遍历, 花偏甲道 + 位os算累持) = 本类累持
        ARRLA(行号遍历, 花偏甲道 + 位os算法名) = 规则算法
        '================================================================================
    Next 行号遍历
'========================================================================================
'返回
'========================================================================================
返点:
    XL算灌引擎单期 = 基位
End Function
