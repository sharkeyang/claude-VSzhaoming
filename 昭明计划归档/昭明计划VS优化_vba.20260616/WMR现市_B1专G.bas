'========================================================================================
'========================================================================================
'中国 金融期货
'========================================================================================
'========================================================================================
Function 现市特程_CN_金融期货( _
          MS As Worksheet _
        , 始行 As Integer _
        , 始列 As Integer _
        , Optional 是否标题 As Boolean = False _
        , Optional 是否返列 As Boolean = True _
        ) As Integer
'========================================================================================
'设置
'========================================================================================
    Dim 目行 As Integer
    Dim 目列 As Integer
    目行 = 始行
    目列 = 始列
    '------------------------------------------------------------------------------------
    If 是否标题 = True Then
        With MS.Cells(目行, 目列).Cells(1, 位简式名称)
            .Value = "中国金融期货"
            .Font.Bold = True
        End With
        目行 = 目行 + 1
    End If
'========================================================================================
'列表：国内金融期货
'      http://hq.sinajs.cn/list=CFF_LIST
'========================================================================================
    Dim 码典国内股指期货 As New Dictionary
'    With 码典国内股指期货
'        .Add Item:="sh000016", Key:="上证50"
'        .Add Item:="CFF_RE_IH0", Key:="_IH0"
'        .Add Item:="sh000300", Key:="沪深300"
'        .Add Item:="CFF_RE_IF0", Key:="_IF0"
'        .Add Item:="sh000905", Key:="中证500"
'        .Add Item:="CFF_RE_IC0", Key:="_IC0"
'        .Add Item:="sh000852", Key:="中证1000"
'        .Add Item:="CFF_RE_IM0", Key:="_IM0"
'        .Add Item:="", Key:="占位"
'    End With
    '------------------------------------------------------------------------------------
    '推算股指期货
    '------------------------------------------------------------------------------------
    Dim 结算月 As Date
    Dim 计数周五 As Integer
    Dim X As Integer
    结算月 = Date
    结算月 = 结算月 - Day(结算月) + 1 - 1   '结算月前月最后一日
    计数周五 = 0
    For X = 1 To 30
        结算月 = 结算月 + 1
        If Weekday(结算月, vbMonday) = 5 Then
            计数周五 = 计数周五 + 1
            Debug.Print 结算月, 计数周五
            If 计数周五 = 3 Then
                Exit For
            End If
        End If
    Next
    
    If Date >= 结算月 Then 结算月 = DateAdd("m", 1, 结算月)
    '-----------------------------------------------------
    Dim 组股指期货结算月(1 To 4) As Variant
    组股指期货结算月(1) = Format(结算月, "yymm")
    结算月 = DateAdd("m", 1, 结算月)
    组股指期货结算月(2) = Format(结算月, "yymm")
    结算月 = DateSerial(Year(结算月), Int(Month(结算月) / 3) * 3, 1)
    结算月 = DateAdd("q", 1, 结算月)
    组股指期货结算月(3) = Format(结算月, "yymm")
    结算月 = DateAdd("q", 1, 结算月)
    组股指期货结算月(4) = Format(结算月, "yymm")
    '-----------------------------------------------------
    码典国内股指期货.Add Item:="sh000016", Key:="现货上证50"
    For I = LBound(组股指期货结算月, 1) To UBound(组股指期货结算月, 1)
        码典国内股指期货.Add Item:="CFF_RE_IH" & 组股指期货结算月(I), Key:="IH" & 组股指期货结算月(I)
    Next
    码典国内股指期货.Add Item:="", Key:="占位1"
    '-----------------------------------------------------
    码典国内股指期货.Add Item:="sh000300", Key:="现货沪深300"
    For I = LBound(组股指期货结算月, 1) To UBound(组股指期货结算月, 1)
        码典国内股指期货.Add Item:="CFF_RE_IF" & 组股指期货结算月(I), Key:="IF" & 组股指期货结算月(I)
    Next
    码典国内股指期货.Add Item:="", Key:="占位2"
    '-----------------------------------------------------
    码典国内股指期货.Add Item:="sh000905", Key:="现货中证500"
    For I = LBound(组股指期货结算月, 1) To UBound(组股指期货结算月, 1)
        码典国内股指期货.Add Item:="CFF_RE_IC" & 组股指期货结算月(I), Key:="IC" & 组股指期货结算月(I)
    Next
    码典国内股指期货.Add Item:="", Key:="占位3"
    '-----------------------------------------------------
    码典国内股指期货.Add Item:="sh000852", Key:="现货中证1000"
    For I = LBound(组股指期货结算月, 1) To UBound(组股指期货结算月, 1)
        码典国内股指期货.Add Item:="CFF_RE_IM" & 组股指期货结算月(I), Key:="IM" & 组股指期货结算月(I)
    Next
    码典国内股指期货.Add Item:="", Key:="占位4"
    '------------------------------------------------------------------------------------
    '输出
    '------------------------------------------------------------------------------------
    目行 = 查程混市码典(码典国内股指期货, MS, 目行, 目列, 是否返列:=False)
    Set 码典国内股指期货 = Nothing
    '------------------------------------------------------------------------------------
    '判断趋势
    '------------------------------------------------------------------------------------
    Dim 间隔 As Integer
    Dim 是否升水 As Double
    Dim 标志升水 As Double
    Dim 标志贴水 As Double
    标志升水 = 0.2
    标志贴水 = -0.1
    With MS.Cells(始行, 始列)
    For X = 1 To 4
        间隔 = (X - 1) * 5
        值现货 = .Offset(间隔, 3)
        For Y = 1 To 4
            值期货 = .Offset(间隔 + Y, 3)
            If VBA.IsNumeric(值期货) = True Then
                If 值现货 <> 0 Then 是否升水 = Round(100 * (值期货 / 值现货 - 1), 2)
            Else
                是否升水 = 0
            End If
            .Offset(间隔 + Y, 4) = 是否升水
            .Offset(间隔 + Y, 0).Resize(1, 5).Interior.TintAndShade = IIf(是否升水 >= 0, 标志升水, 标志贴水)
        Next Y
        With .Offset(间隔 + 4, 0).Resize(1, 5).Borders(xlEdgeBottom)
            .LineStyle = xlContinuous
            .Color = 常色主黑
            .Weight = xlThin
        End With
    Next X
    End With
'========================================================================================
'列表：国债期货
'========================================================================================
    Dim 码典国内国债期货 As New Dictionary
    '------------------------------------------------------------------------------------
    '推算国债期货
    '------------------------------------------------------------------------------------
    结算月 = Date
    结算月 = 结算月 - Day(结算月) + 1
    计数周五 = 0
    For X = 1 To 30
        结算月 = 结算月 + 1
        If Weekday(结算月, vbMonday) = 5 Then
            计数周五 = 计数周五 + 1
            Debug.Print 结算月, 计数周五
            If 计数周五 = 2 Then
                Exit For
            End If
        End If
    Next
    
    If Date >= 结算月 Then
        结算月 = DateSerial(Year(结算月), (Int(Month(结算月) / 3) + 1) * 3, 1)
    Else
        结算月 = DateSerial(Year(结算月), Int(Month(结算月) / 3) * 3, 1)
    End If
'    结算月 = Date
'    结算月 = DateSerial(Year(结算月), Int(Month(结算月) / 3) * 3 + 3, 1)
    '-----------------------------------------------------
    Dim 组国债期货结算月(1 To 3) As Variant
    组国债期货结算月(1) = Format(结算月, "yymm")
    结算月 = DateAdd("q", 1, 结算月)
    组国债期货结算月(2) = Format(结算月, "yymm")
    结算月 = DateAdd("q", 1, 结算月)
    组国债期货结算月(3) = Format(结算月, "yymm")
    '-----------------------------------------------------
    For I = LBound(组国债期货结算月, 1) To UBound(组国债期货结算月, 1)
        码典国内国债期货.Add Item:="CFF_RE_TL" & 组国债期货结算月(I), Key:="TL" & 组国债期货结算月(I)
    Next
    码典国内国债期货.Add Item:="", Key:="占位11"
    For I = LBound(组国债期货结算月, 1) To UBound(组国债期货结算月, 1)
        码典国内国债期货.Add Item:="CFF_RE_T" & 组国债期货结算月(I), Key:="T" & 组国债期货结算月(I)
    Next
    码典国内国债期货.Add Item:="", Key:="占位12"
    For I = LBound(组国债期货结算月, 1) To UBound(组国债期货结算月, 1)
        码典国内国债期货.Add Item:="CFF_RE_TF" & 组国债期货结算月(I), Key:="TF" & 组国债期货结算月(I)
    Next
    码典国内国债期货.Add Item:="", Key:="占位13"
    For I = LBound(组国债期货结算月, 1) To UBound(组国债期货结算月, 1)
        码典国内国债期货.Add Item:="CFF_RE_TS" & 组国债期货结算月(I), Key:="TS" & 组国债期货结算月(I)
    Next
    '------------------------------------------------------------------------------------
    '输出
    '------------------------------------------------------------------------------------
    目行 = 目行 + 2
    始行 = 目行
    目行 = 查程混市码典(码典国内国债期货, MS, 目行, 目列, 是否返列:=False)
    Set 码典国内国债期货 = Nothing
    '------------------------------------------------------------------------------------
    '判断趋势
    '------------------------------------------------------------------------------------
    With MS.Cells(始行, 始列)
    With .Resize(1, 5).Borders(xlEdgeTop)
        .LineStyle = xlContinuous
        .Color = 常色主黑
        .Weight = xlThin
    End With
    For X = 1 To 4
        间隔 = (X - 1) * 3
        值现货 = .Offset(间隔, 3)
        For Y = 1 To 2
            If VBA.IsNumeric(.Offset(间隔 + Y, 3)) Then
                值期货 = .Offset(间隔 + Y, 3)
            Else
                值期货 = 0
            End If
            If VBA.IsNumeric(值现货) = True Then
                是否升水 = Round(100 * (值期货 / 值现货 - 1), 2)
            Else
                是否升水 = 0
            End If
            .Offset(间隔 + Y, 4) = 是否升水
            .Offset(间隔 + Y, 0).Resize(1, 5).Interior.TintAndShade = IIf(是否升水 >= 0, 标志升水, 标志贴水)
        Next Y
        With .Offset(间隔 + 2, 0).Resize(1, 5).Borders(xlEdgeBottom)
            .LineStyle = xlContinuous
            .Color = 常色主黑
            .Weight = xlThin
        End With
    Next X
    End With
'========================================================================================
'列表：逆回购利率
'========================================================================================
    Dim 码典国内利率 As New Dictionary
    With 码典国内利率
        .Add Item:="sz131810", Key:="Ｒ-001"
        .Add Item:="sz131811", Key:="Ｒ-002"
        .Add Item:="sz131800", Key:="Ｒ-003"
        .Add Item:="sz131809", Key:="Ｒ-004"
        .Add Item:="sz131801", Key:="Ｒ-007"
        .Add Item:="sz131802", Key:="Ｒ-014"
        .Add Item:="sz131803", Key:="Ｒ-028"
        .Add Item:="sz131805", Key:="Ｒ-091"
        .Add Item:="sz131806", Key:="Ｒ-182"
    End With
    '------------------------------------------------------------------------------------
    '输出
    '------------------------------------------------------------------------------------
    目行 = 目行 + 2
    始行 = 目行
    现市特程_CN_金融期货 = 查程混市码典(码典国内利率, MS, 目行, 目列, 是否返列:=是否返列)
    '------------------------------------------------------------------------------------
    '判断趋势
    '------------------------------------------------------------------------------------
    For I = 1 To 码典国内利率.Count
        With MS.Cells(目行, 目列).Offset(I - 1, 0)
            If .Offset(0, 3) > 3 Then
                .Offset(0, 3).Font.ColorIndex = 6
            End If
        End With
    Next I
    Set 码典国内利率 = Nothing
'========================================================================================
'格式化
'========================================================================================
    MS.Columns(目列).Columns(5).ColumnWidth = 8
    MS.Columns(目列).Columns(5).HorizontalAlignment = xlCenter
    MS.Columns(目列).Columns(5).NumberFormatLocal = "0.0_);[黑色](0.0)"
End Function



Sub 测试国债期货日期()
    Dim 初始日期 As Date
    初始日期 = "2020/6/13"


    结算月 = 初始日期
    结算月 = 结算月 - Day(结算月) + 1
    计数周五 = 0
    For X = 1 To 30
        结算月 = 结算月 + 1
        If Weekday(结算月, vbMonday) = 5 Then
            计数周五 = 计数周五 + 1
            Debug.Print 结算月, 计数周五
            If 计数周五 = 2 Then
                Exit For
            End If
        End If
    Next
    
    
    If 初始日期 >= 结算月 Then
        结算月 = DateSerial(Year(结算月), (Int(Month(结算月) / 3) + 1) * 3, 1)
    Else
        结算月 = DateSerial(Year(结算月), Int(Month(结算月) / 3) * 3, 1)
    End If
    Debug.Print 结算月
End Sub


