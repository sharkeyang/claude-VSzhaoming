'热门股票
'http://finance.sina.com.cn/realstock/company/hotstock_daily_a.js
'========================================================================================
'========================================================================================
Function 现市特程_CN_热门股票( _
          MS As Worksheet _
        , 始行 As Integer _
        , 始列 As Integer _
        , Optional 是否标题 As Boolean = False _
        ) As Integer
'========================================================================================
'设置
'========================================================================================
    Dim 目行 As Integer
    Dim 目列 As Integer
    目行 = 始行
    目列 = 始列
    '------------------------------------------------------------------------------------
    If 是否标题 = True Then
        With MS.Cells(目行, 目列).Cells(1, 位简式名称)
            .Value = "沪深热门股票"
            .Font.Bold = True
        End With
        目行 = 目行 + 1
    End If
'========================================================================================
'列表：热门股票
'========================================================================================
    Dim CIDL As String
    Dim 码典热门股票 As New Dictionary
    '------------------------------------------------------------------------------------
    Dim sURL As String
    Dim sSEP As String
    Dim sRESP As String
    Dim aRESP As Variant
    '------------------------------------------------------------------------------------
    '查询信息
    '------------------------------------------------------------------------------------
    sURL = "http://finance.sina.com.cn/realstock/company/hotstock_daily_a.js"
    sSEP = ","
    sRESP = UBHTTP通用_查程回全通用(sURL)
    '------------------------------------------------------------------------------------
    '处理信息
    '------------------------------------------------------------------------------------
    Dim iStt As Integer
    Dim iEnd As Integer
    
    If InStr(sRESP, ",") > 1 Then
        iStt = InStr(1, sRESP, "[[") + 2
        iEnd = InStrRev(sRESP, "]]") - 1
        sRESP = Mid(sRESP, iStt, iEnd - iStt + 1)
        aRESP = Split(sRESP, "],[")
        
        For I = LBound(aRESP, 1) To UBound(aRESP, 1)
            CIDL = Mid(aRESP(I), InStr(aRESP(I), """") + 1, 8)
            码典热门股票.Add Item:=CIDL, Key:=CIDL
        Next
    End If
'========================================================================================
'输出
'========================================================================================
    目列 = 查程混市码典(码典热门股票, MS, 目行, 目列, True)
    Set 码典热门股票 = Nothing
    '------------------------------------------------------------------------------------
    现市特程_CN_热门股票 = 目列
End Function




