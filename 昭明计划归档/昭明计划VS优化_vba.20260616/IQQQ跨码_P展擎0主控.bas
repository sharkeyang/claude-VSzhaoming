'========================================================================================
'========================================================================================
'QQQ：某时版 批处理
'========================================================================================
'========================================================================================
Sub IQQQ展擎主前调_某时版批处理()
'----------------------------------------------------------------------------------------
    Dim 研究日期开始 As Date
    Dim 研究日期结束 As Date
    研究日期开始 = "2017/6/1"
    研究日期结束 = "2017/6/2"
    '------------------------------------------------------------------------------------
    Dim 研究日期 As Date
    For 研究日期 = 研究日期开始 To 研究日期结束
        If 时程结期判断IS类日(研究日期) Then
            Debug.Print 研究日期
            MSG = MSG & vbCrLf & IQQQ展擎主前调正程(研究日期:=研究日期)
        End If
    Next 研究日期
'----------------------------------------------------------------------------------------
    MsgBox MSG, Title:="QQQ 外簿某时版批处理"
End Sub
'========================================================================================
'========================================================================================
'QQQ：某时版
'========================================================================================
'========================================================================================
Sub IQQQ展擎主前调_某时版本簿()
    Dim 研究日期 As Date
    研究日期 = "2019/2/22"
    MSG = IQQQ展擎主前调正程(是否外簿:=False, 研究日期:=研究日期, 参of筛决策剔池:=True, 是否筛频谱:=True)
    MSG = "QQQ研究日期：" & 研究日期 & vbCrLf & MSG
    MsgBox MSG, Title:="QQQ 本簿某时版"
End Sub
Sub IQQQ展擎主前调_某时版()
    Dim 研究日期 As Date
    研究日期 = "2014/7/1"
    MSG = IQQQ展擎主前调正程(研究日期:=研究日期, 参of筛决策剔池:=True, 是否筛频谱:=True)
    MSG = "QQQ研究日期：" & 研究日期 & vbCrLf & MSG
    MsgBox MSG, Title:="QQQ 外簿某时版"
End Sub
