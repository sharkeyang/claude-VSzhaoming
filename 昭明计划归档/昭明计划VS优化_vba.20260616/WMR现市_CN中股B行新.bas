Function 现市基程_族行业新浪( _
          MS As Worksheet _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 始行 As Integer = 3 _
        , Optional 始列 As Integer = 3 _
        , Optional 天组 As Variant _
        , Optional 天典 As Dictionary _
        ) As Boolean
    '=============================================================================================================================
    '页面格式设置
    '=============================================================================================================================
    MS.Cells.Font.Size = 10
    MS.Columns.ColumnWidth = 2
    '-----------------------------------------------------------------------------------------------------------------------------
    MS.Cells(始行, 始行 + 1) = "芥蓝"
    MS.Columns(始行 + 1).ColumnWidth = 12
    MS.Columns(始行 + 2).ColumnWidth = 6
    MS.Columns(始行 + 3).ColumnWidth = 5
    '=============================================================================================================================
    '分程调用列表：族行业新浪
    '=============================================================================================================================
    Dim 当列 As Integer
    当列 = 始行 + 5
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_金融类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_周期类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_电子制造类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_制造类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_汽车类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_互联网类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_农业类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_医药类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_饮食类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_消费类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_运输类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_文化类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_化工类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_公共类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_商贸类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业新浪_基建类族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '=============================================================================================================================
    '页面格式设置
    '=============================================================================================================================
    MS.Rows(始行).Font.Bold = True
    MS.Rows(始行).HorizontalAlignment = xlLeft
    MS.Rows(始行).Borders(xlEdgeBottom).Weight = xlThin
    '-----------------------------------------------------------------------------------------------------------------------------
    If 是否排序 = xlAscending Or 是否排序 = xlDescending Then
        With MS.Cells(始行 + 1, 始行 + 1)
            .Resize(.Offset(65536, 0).End(xlUp).Row, 3).Sort _
            key1:=.Offset(0, 1), order1:=是否排序, Header:=xlNo
        End With
    End If
    '-----------------------------------------------------------------------------------------------------------------------------
    MS.Activate
    Call PBASE格程工具_表冻结锁定(MS, 0, 始行 + 3)
    '=============================================================================================================================
End Function
