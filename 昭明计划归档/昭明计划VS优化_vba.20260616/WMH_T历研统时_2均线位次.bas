'========================================================================================
'========================================================================================
'设置数组：典均线
'========================================================================================
'========================================================================================
Function XLSOP统时全码基程_设置典均线(典均线 As Dictionary, 期类 As String) As Integer
    Dim 组均线 As Variant
    组均线 = Array( _
          "ZA", "ZB", "ZC", "ZD", "ZE", "ZF" _
        , "AB", "AC", "AD", "AE", "AF" _
        , "BC", "BD", "BE", "BF" _
        , "CD", "CE", "CF" _
        , "DE", "DF" _
        , "EF" _
    )
    '组均线 = Array( _
          "ZA" _
        , "ZB", "AB" _
        , "ZC", "AC", "BC" _
        , "ZD", "AD", "BD", "CD" _
        , "ZE", "AE", "BE", "CE", "DE" _
        , "ZF", "AF", "BF", "CF", "DF", "EF" _
        )
    '------------------------------------------------------------------------------------
    序数典集 = 0
    Dim X As Integer
    For X = LBound(组均线) To UBound(组均线)
        序数典集 = 序数典集 + 1
        元素典集 = 组均线(X)
        典均线.Add Item:=元素典集, Key:=序数典集
    Next
    '------------------------------------------------------------------------------------
    Erase 组均线
'========================================================================================
'返回：个数
'========================================================================================
    XLSOP统时全码基程_设置典均线 = 典均线.Count
End Function
