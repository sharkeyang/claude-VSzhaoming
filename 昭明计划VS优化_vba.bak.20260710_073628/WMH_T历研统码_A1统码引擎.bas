                End If
            '----------------------------------------------------------------------------
            ElseIf 组历统序(X, 位统码排列仨累高数) >= 9 Then
                组历统序(X, 位统码排列轮动类型) = "A仨g9热"
                If 组历统序(X, 位统码排列十累高数) >= 5 Then
                        组历统序(X, 位统码排列轮动类型) = 组历统序(X, 位统码排列轮动类型) & "_什g5热"
                        If 组历统序(X, 位统码排列十累低数) >= 3 Then 组历统序(X, 位统码排列轮动类型) = 组历统序(X, 位统码排列轮动类型) & "_巨震"
                Else
                        If 组历统序(X, 位统码排列十累高数) >= 3 Then
                            组历统序(X, 位统码排列轮动类型) = 组历统序(X, 位统码排列轮动类型) & "_什k中"
                        Else
                            组历统序(X, 位统码排列轮动类型) = 组历统序(X, 位统码排列轮动类型) & "_什l2〇"
                        End If
                        '根据“十累低数”进行分类：
                        If 组历统序(X, 位统码排列十累低数) >= 4 Then
                            '若什内，低点数超过5，代表跌得猛。
                            组历统序(X, 位统码排列轮动类型) = 组历统序(X, 位统码排列轮动类型) & "_警W什低g4"
                        ElseIf 组历统序(X, 位统码排列十累低数) > 组历统序(X, 位统码排列十累高数) Then
                            '若什内，低点数未超过5。但低比高多，代表转跌。
                            组历统序(X, 位统码排列轮动类型) = 组历统序(X, 位统码排列轮动类型) & "_警V低比高多"
                        End If
                End If
            '----------------------------------------------------------------------------
            Else
                组历统序(X, 位统码排列轮动类型) = "L仨l9〇"
                If 组历统序(X, 位统码排列十累高数) >= 5 Then
                        组历统序(X, 位统码排列轮动类型) = 组历统序(X, 位统码排列轮动类型) & "_什g5热"
                Else
