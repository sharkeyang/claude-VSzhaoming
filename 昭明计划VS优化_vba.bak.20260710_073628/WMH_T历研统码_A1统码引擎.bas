Function 历研统码引擎4幅排序输程( _
          WSTO As Worksheet _
        , ByRef 矩历码期值 As Variant _
        , Optional 数序输出 As Integer = 10 _
        , Optional 始行 As Integer = 1 _
        , Optional 始列 As Integer = 1 _
        , Optional 指定期类 As String = 常期类为日 _
        , Optional ByVal 显否神谕主页 As Boolean = False _
        , Optional ByVal 表名统码 As String = "" _
        , Optional ByVal 基色底 As Long = 常色六青 _
      ) As Integer
'========================================================================================
'验证
'========================================================================================
    If WSTO Is Nothing Then Exit Function
    If VBA.IsEmpty(矩历码期值) Then Exit Function
    If 数序输出 > UBound(矩历码期值, 1) Then Exit Function
'########################################################################################
'########################################################################################
'模块：排序列表
'########################################################################################
'########################################################################################
'========================================================================================
'加工数组：排序
'========================================================================================
    Dim 总行数 As Integer
    总行数 = UBound(矩历码期值, 1) - LBound(矩历码期值, 1) + 1
    Dim 总列数 As Integer
    总列数 = UBound(矩历码期值, 2) - LBound(矩历码期值, 2) + 1
    '------------------------------------------------------------------------------------
    '制作数组：按照幅排序
    '------------------------------------------------------------------------------------
    Dim 矩历码期序 As Variant
    Call 历研数据引擎_基础数据排序(矩历码期序, 矩历码期值)
    '------------------------------------------------------------------------------------
    '声明组序
    '------------------------------------------------------------------------------------
    ReDim 组序幅高(1 To 数序输出, LBound(矩历码期值, 2) To UBound(矩历码期值, 2)) As Variant
    ReDim 组序幅低(1 To 数序输出, LBound(矩历码期值, 2) To UBound(矩历码期值, 2)) As Variant
    '------------------------------------------------------------------------------------
    Dim X As Integer, Y As Integer
    Dim 第三维 As Integer
    Dim 定位行矩值 As Integer
    For X = 1 To 数序输出
        '--------------------------------------------------------------------------------
        '输出：高幅排序
        '--------------------------------------------------------------------------------
        组序幅高(X, 0) = "高序" & X
        第三维 = 2
        For Y = 1 To UBound(矩历码期值, 2)
            定位行矩值 = 矩历码期序(X, Y, 第三维)
            组序幅高(X, Y) = 矩历码期值(定位行矩值, 0, 第三维) & ":" & 矩历码期值(定位行矩值, Y, 第三维)
        Next
        '--------------------------------------------------------------------------------
        '输出：低幅排序
        '--------------------------------------------------------------------------------
        组序幅低(数序输出 + 1 - X, 0) = "低序" & X
        第三维 = 3
        For Y = 1 To UBound(矩历码期值, 2)
            定位行矩值 = 矩历码期序(X, Y, 第三维)
            组序幅低(数序输出 + 1 - X, Y) = 矩历码期值(定位行矩值, 0, 第三维) & ":" & 矩历码期值(定位行矩值, Y, 第三维)
        Next
        '--------------------------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    '输出
    '------------------------------------------------------------------------------------
    Call UTL数据转换_集ARR2WS(组序幅高, WSTO, 始行, 始列)
    Erase 组序幅高
    Call UTL数据转换_集ARR2WS(组序幅低, WSTO, 始行 + 数序输出, 始列)
    Erase 组序幅低
'========================================================================================
'输出格式化
'========================================================================================
    '------------------------------------------------------------------------------------
    '格式化：字体
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Resize(数序输出 * 2, 总列数)
        .HorizontalAlignment = xlLeft
        .Font.Size = 8
    End With
    '格式化列：首列
    With WSTO.Cells(始行, 始列).Resize(数序输出, 1)
        .Font.Color = 常色六灰
        .Font.Size = 9
    End With
    With WSTO.Cells(始行 + 数序输出, 始列).Resize(数序输出, 1)
        .Font.Color = 常色四灰
        .Font.Size = 9
    End With
    '------------------------------------------------------------------------------------
    '格式化：排名
    '------------------------------------------------------------------------------------
    Dim 区展示 As Range
    Dim 值展示 As Variant
    For X = 1 To 数序输出 * 2
        For Y = 1 To UBound(矩历码期值, 2)
            Set 区展示 = WSTO.Cells(始行, 始列).Cells(X, 1 + Y)
            值展示 = Mid$(区展示.Value, InStr(区展示.Value, ":") + 1)
            Call UTL展示幅度(区展示, 值展示)
            区展示.Font.Color = 常色五青
            Set 区展示 = Nothing
        Next
    Next
    '------------------------------------------------------------------------------------
    '格式化：日期边框
    '------------------------------------------------------------------------------------
    Dim 值当期 As Date, 值前期 As Date
    If 指定期类 = 常期类为日 Then
        For Y = 1 To UBound(矩历码期值, 2) - 1
            值当期 = 矩历码期值(0, Y, 1)
            值前期 = 矩历码期值(0, Y + 1, 1)
            If 值当期 - Weekday(值当期, vbMonday) <> 值前期 - Weekday(值前期, vbMonday) Then
                With WSTO.Cells(始行, 始列).Cells(1, 1 + Y).Resize(数序输出 * 2, 1).Borders(xlRight)
                   .Color = 常色轮框
                   .Weight = xlThin
                End With
            End If
        Next
    End If
    '------------------------------------------------------------------------------------
    '格式化：行边框
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Cells(1, 1).Resize(1, 总列数).Borders(xlEdgeTop)
       .Color = 常色四灰
       .Weight = xlMedium
    End With
    With WSTO.Cells(始行, 始列).Cells(数序输出 * 2, 1).Resize(1, 总列数).Borders(xlEdgeBottom)
       .Color = 常色四灰
       .Weight = xlMedium
    End With
    '------------------------------------------------------------------------------------
'########################################################################################
'########################################################################################
'模块：排序统计
'########################################################################################
'########################################################################################
'========================================================================================
'声明变量
'========================================================================================
    Dim 位统码排列CIDL As Integer
    Dim 位统码排列代称 As Integer
    Dim 位统码排列结期 As Integer
    Dim 位统码排列十累高数 As Integer
    Dim 位统码排列十累低数 As Integer
    Dim 位统码排列仨累高数 As Integer
    Dim 位统码排列仨累低数 As Integer
    Dim 位统码排列佰累高数 As Integer
    Dim 位统码排列佰累低数 As Integer
    '------------------------------------------------------------------------------------
    位统码排列代称 = 1
    '--------------------------------------
    位统码排列族当日 = 2
    位统码排列当高值 = 位统码排列族当日 + 0
    位统码排列当高序 = 位统码排列族当日 + 1
    位统码排列当涨值 = 位统码排列族当日 + 2
    位统码排列当涨序 = 位统码排列族当日 + 3
    位统码排列当低值 = 位统码排列族当日 + 4
    位统码排列当低序 = 位统码排列族当日 + 5
    '--------------------------------------
    位统码排列族计数 = 位统码排列族当日 + 6
    位统码排列十累高数 = 位统码排列族计数 + 0
    位统码排列十累低数 = 位统码排列族计数 + 1
    位统码排列仨累高数 = 位统码排列族计数 + 2
    位统码排列仨累低数 = 位统码排列族计数 + 3
    位统码排列佰累高数 = 位统码排列族计数 + 4
    位统码排列佰累低数 = 位统码排列族计数 + 5
    '--------------------------------------
    位统码排列龄族选高 = 位统码排列族计数 + 6
    位统码排列龄选高1 = 位统码排列龄族选高 + 0
    位统码排列龄选高2 = 位统码排列龄族选高 + 1
    位统码排列龄选高3 = 位统码排列龄族选高 + 2
    位统码排列龄选高4 = 位统码排列龄族选高 + 3
    位统码排列龄选高5 = 位统码排列龄族选高 + 4
    位统码排列龄选高6 = 位统码排列龄族选高 + 5
    位统码排列龄选高7 = 位统码排列龄族选高 + 6
    位统码排列龄选高8 = 位统码排列龄族选高 + 7
    位统码排列龄选高9 = 位统码排列龄族选高 + 8
    位统码排列龄选高10 = 位统码排列龄族选高 + 9
    位统码排列龄选高隔一 = 位统码排列龄族选高 + 10
    位统码排列龄选高隔二 = 位统码排列龄族选高 + 11
    位统码排列龄选高隔四 = 位统码排列龄族选高 + 12
    位统码排列龄选高隔十 = 位统码排列龄族选高 + 13
    '--------------------------------------
    位统码排列龄族选低 = 位统码排列龄族选高 + 14
    位统码排列龄选低1 = 位统码排列龄族选低 + 0
    位统码排列龄选低2 = 位统码排列龄族选低 + 1
    位统码排列龄选低3 = 位统码排列龄族选低 + 2
    位统码排列龄选低4 = 位统码排列龄族选低 + 3
    位统码排列龄选低5 = 位统码排列龄族选低 + 4
    位统码排列龄选低6 = 位统码排列龄族选低 + 5
    位统码排列龄选低7 = 位统码排列龄族选低 + 6
    位统码排列龄选低8 = 位统码排列龄族选低 + 7
    位统码排列龄选低9 = 位统码排列龄族选低 + 8
    位统码排列龄选低10 = 位统码排列龄族选低 + 9
    位统码排列龄选低隔一 = 位统码排列龄族选低 + 10
    位统码排列龄选低隔二 = 位统码排列龄族选低 + 11
    位统码排列龄选低隔四 = 位统码排列龄族选低 + 12
    位统码排列龄选低隔十 = 位统码排列龄族选低 + 13
    '--------------------------------------
    位统码排列龄族基本 = 位统码排列龄族选低 + 14
    位统码排列结期 = 位统码排列龄族基本 + 0
    位统码排列CIDL = 位统码排列龄族基本 + 1
    位统码排列轮动类型 = 位统码排列龄族基本 + 2
    '--------------------------------------
    位统码排列总数 = 位统码排列龄族基本 + 2
    '------------------------------------------------------------------------------------
    ReDim 组历统序(LBound(矩历码期值, 1) To UBound(矩历码期值, 1), 1 To 位统码排列总数) As Variant
    '--------------------------------------
    组历统序(0, 位统码排列CIDL) = "CIDL"
    组历统序(0, 位统码排列代称) = "代称"
    组历统序(0, 位统码排列结期) = "结期"
    组历统序(0, 位统码排列当高序) = "Hn" & vbCrLf & "今"
    组历统序(0, 位统码排列当高值) = "Hv" & vbCrLf & "今"
    组历统序(0, 位统码排列当涨序) = "Pn" & vbCrLf & "今"
    组历统序(0, 位统码排列当涨值) = "Pv" & vbCrLf & "今"
    组历统序(0, 位统码排列当低序) = "Ln" & vbCrLf & "今"
    组历统序(0, 位统码排列当低值) = "Lv" & vbCrLf & "今"
    组历统序(0, 位统码排列十累高数) = "#H" & vbCrLf & "十"
    组历统序(0, 位统码排列十累低数) = "#L" & vbCrLf & "十"
    组历统序(0, 位统码排列仨累高数) = "#H" & vbCrLf & "仨"
    组历统序(0, 位统码排列仨累低数) = "#L" & vbCrLf & "仨"
    组历统序(0, 位统码排列佰累高数) = "#H" & vbCrLf & "佰"
    组历统序(0, 位统码排列佰累低数) = "#L" & vbCrLf & "佰"
    组历统序(0, 位统码排列龄选高1) = "H1"
    组历统序(0, 位统码排列龄选高2) = "H2"
    组历统序(0, 位统码排列龄选高3) = "H3"
    组历统序(0, 位统码排列龄选高4) = "H4"
    组历统序(0, 位统码排列龄选高5) = "H5"
    组历统序(0, 位统码排列龄选高6) = "H6"
    组历统序(0, 位统码排列龄选高7) = "H7"
    组历统序(0, 位统码排列龄选高8) = "H8"
    组历统序(0, 位统码排列龄选高9) = "H9"
    组历统序(0, 位统码排列龄选高10) = "H10"
    组历统序(0, 位统码排列龄选低1) = "L1"
    组历统序(0, 位统码排列龄选低2) = "L2"
    组历统序(0, 位统码排列龄选低3) = "L3"
    组历统序(0, 位统码排列龄选低4) = "L4"
    组历统序(0, 位统码排列龄选低5) = "L5"
    组历统序(0, 位统码排列龄选低6) = "L6"
    组历统序(0, 位统码排列龄选低7) = "L7"
    组历统序(0, 位统码排列龄选低8) = "L8"
    组历统序(0, 位统码排列龄选低9) = "L9"
    组历统序(0, 位统码排列龄选低10) = "L10"
    组历统序(0, 位统码排列龄选高隔一) = "H1" & vbCrLf & "隔"
    组历统序(0, 位统码排列龄选高隔二) = "H2" & vbCrLf & "隔"
    组历统序(0, 位统码排列龄选高隔四) = "H4" & vbCrLf & "隔"
    组历统序(0, 位统码排列龄选高隔十) = "H10" & vbCrLf & "隔"
    组历统序(0, 位统码排列龄选低隔一) = "L1" & vbCrLf & "隔"
    组历统序(0, 位统码排列龄选低隔二) = "L2" & vbCrLf & "隔"
    组历统序(0, 位统码排列龄选低隔四) = "L4" & vbCrLf & "隔"
    组历统序(0, 位统码排列龄选低隔十) = "L10" & vbCrLf & "隔"
    组历统序(0, 位统码排列轮动类型) = "轮动类型"
'========================================================================================
'加工数据：组历统序
'========================================================================================
    For Y = UBound(矩历码期序, 2) To 1 Step -1  '按期
            '----------------------------------------------------------------------------
            '统计排序：幅高
            '----------------------------------------------------------------------------
            For X = 1 To 数序输出 '按码
                    定位行矩值 = 矩历码期序(X, Y, 2)
                    If VBA.IsEmpty(定位行矩值) = True Then
                    Else
                            If Y <= 10 Then
                                组历统序(定位行矩值, 位统码排列十累高数) = 组历统序(定位行矩值, 位统码排列十累高数) + 1
                            End If
                            If Y <= 30 Then
                                组历统序(定位行矩值, 位统码排列仨累高数) = 组历统序(定位行矩值, 位统码排列仨累高数) + 1
                            End If
                            If Y <= 100 Then
                                组历统序(定位行矩值, 位统码排列佰累高数) = 组历统序(定位行矩值, 位统码排列佰累高数) + 1
                            End If
                            '历次入选
                            组历统序(定位行矩值, 位统码排列龄选高10) = 组历统序(定位行矩值, 位统码排列龄选高9)
                            组历统序(定位行矩值, 位统码排列龄选高9) = 组历统序(定位行矩值, 位统码排列龄选高8)
                            组历统序(定位行矩值, 位统码排列龄选高8) = 组历统序(定位行矩值, 位统码排列龄选高7)
                            组历统序(定位行矩值, 位统码排列龄选高7) = 组历统序(定位行矩值, 位统码排列龄选高6)
                            组历统序(定位行矩值, 位统码排列龄选高6) = 组历统序(定位行矩值, 位统码排列龄选高5)
                            组历统序(定位行矩值, 位统码排列龄选高5) = 组历统序(定位行矩值, 位统码排列龄选高4)
                            组历统序(定位行矩值, 位统码排列龄选高4) = 组历统序(定位行矩值, 位统码排列龄选高3)
                            组历统序(定位行矩值, 位统码排列龄选高3) = 组历统序(定位行矩值, 位统码排列龄选高2)
                            组历统序(定位行矩值, 位统码排列龄选高2) = 组历统序(定位行矩值, 位统码排列龄选高1)
                            组历统序(定位行矩值, 位统码排列龄选高1) = Y '& ":" & 矩历码期值(定位行矩值, Y, 2) & "," & 矩历码期值(定位行矩值, Y, 3)
                    End If
            Next
            '----------------------------------------------------------------------------
            '统计排序：幅低
            '----------------------------------------------------------------------------
            For X = 1 To 数序输出 '按码
                    定位行矩值 = 矩历码期序(X, Y, 3)
                    If VBA.IsEmpty(定位行矩值) = True Then
                    Else
                            If Y <= 10 Then
                                组历统序(定位行矩值, 位统码排列十累低数) = 组历统序(定位行矩值, 位统码排列十累低数) + 1
                            End If
                            If Y <= 30 Then
                                组历统序(定位行矩值, 位统码排列仨累低数) = 组历统序(定位行矩值, 位统码排列仨累低数) + 1
                            End If
                            If Y <= 100 Then
                                组历统序(定位行矩值, 位统码排列佰累低数) = 组历统序(定位行矩值, 位统码排列佰累低数) + 1
                            End If
                            '历次入选
                            组历统序(定位行矩值, 位统码排列龄选低10) = 组历统序(定位行矩值, 位统码排列龄选低9)
                            组历统序(定位行矩值, 位统码排列龄选低9) = 组历统序(定位行矩值, 位统码排列龄选低8)
                            组历统序(定位行矩值, 位统码排列龄选低8) = 组历统序(定位行矩值, 位统码排列龄选低7)
                            组历统序(定位行矩值, 位统码排列龄选低7) = 组历统序(定位行矩值, 位统码排列龄选低6)
                            组历统序(定位行矩值, 位统码排列龄选低6) = 组历统序(定位行矩值, 位统码排列龄选低5)
                            组历统序(定位行矩值, 位统码排列龄选低5) = 组历统序(定位行矩值, 位统码排列龄选低4)
                            组历统序(定位行矩值, 位统码排列龄选低4) = 组历统序(定位行矩值, 位统码排列龄选低3)
                            组历统序(定位行矩值, 位统码排列龄选低3) = 组历统序(定位行矩值, 位统码排列龄选低2)
                            组历统序(定位行矩值, 位统码排列龄选低2) = 组历统序(定位行矩值, 位统码排列龄选低1)
                            组历统序(定位行矩值, 位统码排列龄选低1) = Y '& ":" & 矩历码期值(定位行矩值, Y, 2) & "," & 矩历码期值(定位行矩值, Y, 3)
                    End If
            Next
            '----------------------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    For X = 1 To UBound(矩历码期值, 1)
            '------------------------------------------------
            If 组历统序(X, 位统码排列龄选高1) > 0 Then 组历统序(X, 位统码排列龄选高隔一) = 组历统序(X, 位统码排列龄选高1)
            If 组历统序(X, 位统码排列龄选高2) > 0 Then 组历统序(X, 位统码排列龄选高隔二) = Round((组历统序(X, 位统码排列龄选高2) - 组历统序(X, 位统码排列龄选高1)) / 1, 0)
            If 组历统序(X, 位统码排列龄选高4) > 0 Then 组历统序(X, 位统码排列龄选高隔四) = Round((组历统序(X, 位统码排列龄选高4) - 组历统序(X, 位统码排列龄选高2)) / 2, 0)
            If 组历统序(X, 位统码排列龄选高10) > 0 Then 组历统序(X, 位统码排列龄选高隔十) = Round((组历统序(X, 位统码排列龄选高10) - 组历统序(X, 位统码排列龄选高4)) / 6, 0)
            '------------------------------------------------
            If 组历统序(X, 位统码排列龄选低1) > 0 Then 组历统序(X, 位统码排列龄选低隔一) = 组历统序(X, 位统码排列龄选低1)
            If 组历统序(X, 位统码排列龄选低2) > 0 Then 组历统序(X, 位统码排列龄选低隔二) = Round((组历统序(X, 位统码排列龄选低2) - 组历统序(X, 位统码排列龄选低1)) / 1, 0)
            If 组历统序(X, 位统码排列龄选低4) > 0 Then 组历统序(X, 位统码排列龄选低隔四) = Round((组历统序(X, 位统码排列龄选低4) - 组历统序(X, 位统码排列龄选低2)) / 2, 0)
            If 组历统序(X, 位统码排列龄选低10) > 0 Then 组历统序(X, 位统码排列龄选低隔十) = Round((组历统序(X, 位统码排列龄选低10) - 组历统序(X, 位统码排列龄选低4)) / 6, 0)
            '------------------------------------------------
            '基本信息
            CIDL = 矩历码期值(X, 位矩历二维下限, 位矩历三维价收)     '从-1获取CIDL
            组历统序(X, 位统码排列CIDL) = CIDL
            组历统序(X, 位统码排列代称) = 矩历码期值(X, 位矩历二维下限, 位矩历三维幅涨)
            组历统序(X, 位统码排列结期) = 矩历码期值(位矩历一维下限, 1, 位矩历三维幅涨)
            '------------------------------------------------
            '根据【索引】，赋以所在的序位
            组历统序(矩历码期序(X, 1, 2), 位统码排列当高序) = X
            组历统序(X, 位统码排列当高值) = 矩历码期值(X, 1, 位矩历三维幅高)
            '根据【索引】，赋以所在的序位
            组历统序(矩历码期序(X, 1, 1), 位统码排列当涨序) = X
            组历统序(X, 位统码排列当涨值) = 矩历码期值(X, 1, 位矩历三维幅涨)
            '根据【索引】，赋以所在的序位
            组历统序(矩历码期序(X, 1, 3), 位统码排列当低序) = X
