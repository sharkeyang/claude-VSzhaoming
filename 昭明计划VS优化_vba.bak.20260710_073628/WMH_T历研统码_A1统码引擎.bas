Attribute VB_Name = "WMH_T历研统码_A1统码引擎"
'Option Explicit
'【历研范围】历研统码主要研究：固定时间点维度，研究在此时点各码特征。主要为轮动。
Public Const 位统码行总始 = 1
'-------------------------------------
Public Const 位统码行结期 = 位统码行总始 + 0
'-------------------------------------
Public Const 位统码行涨始 = 位统码行结期 + 1
Public Const 位统码行涨正5 = 位统码行涨始 + 0
Public Const 位统码行涨正4 = 位统码行涨始 + 1
Public Const 位统码行涨正3 = 位统码行涨始 + 2
Public Const 位统码行涨正2 = 位统码行涨始 + 3
Public Const 位统码行涨正1 = 位统码行涨始 + 4
Public Const 位统码行涨负1 = 位统码行涨始 + 5
Public Const 位统码行涨负2 = 位统码行涨始 + 6
Public Const 位统码行涨负3 = 位统码行涨始 + 7
Public Const 位统码行涨负4 = 位统码行涨始 + 8
Public Const 位统码行涨负5 = 位统码行涨始 + 9
Public Const 位统码行涨终 = 位统码行涨始 + 9
'-------------------------------------
Public Const 位统码行高始 = 位统码行涨终 + 1
Public Const 位统码行高正5 = 位统码行高始 + 0
Public Const 位统码行高正4 = 位统码行高始 + 1
Public Const 位统码行高正3 = 位统码行高始 + 2
Public Const 位统码行高正2 = 位统码行高始 + 3
Public Const 位统码行高正1 = 位统码行高始 + 4
Public Const 位统码行高负1 = 位统码行高始 + 5
Public Const 位统码行高负2 = 位统码行高始 + 6
Public Const 位统码行高负3 = 位统码行高始 + 7
Public Const 位统码行高终 = 位统码行高始 + 7
'-------------------------------------
Public Const 位统码行算始 = 位统码行高终 + 1
Public Const 位统码行数非停 = 位统码行算始 + 0
Public Const 位统码行中幅正比 = 位统码行算始 + 1
Public Const 位统码行中幅均 = 位统码行算始 + 2
'描述市场：（1）均高幅（2）均涨幅（3）涨幅>0的比例与涨幅分布（4）涨身比：代表整个K柱的变化历程。所以依次展示。
Public Const 位统码行高幅均 = 位统码行算始 + 3  '【高幅,涨幅,低幅】相当于整个市场的K柱。振幅的重要性不如K柱，必须放在这三个维度的后面
Public Const 位统码行涨幅均 = 位统码行算始 + 4
Public Const 位统码行低幅均 = 位统码行算始 + 5
Public Const 位统码行振幅均 = 位统码行算始 + 6
Public Const 位统码行涨身比 = 位统码行算始 + 7
Public Const 位统码行算终 = 位统码行算始 + 7
'-------------------------------------
Public Const 位统码行总终 = 位统码行算终
'========================================================================================
Public Const 常色轮框 = 常色二灰

'一、入口调程 → 核心调用
'  调程              数据源     输出签    调用目标        展宽基 排名 马赛克 神谕
'  展日码总R版       票+行业    轮总R     基程_展日码总   —     —    —     —
'  展日码总RL版       票+行业    轮总L     基程_展日码总   —     —    —     —
'  展日码核RL版       核心行业   轮核L     引擎1主程       True  True True  True
'  展日码票RL版       市池票     轮票L     引擎1主程       —     —    —     —
'  展周码核          核心行业   历码核    引擎1主程       —     True True  —
'  展周码基          基必选     历码基    引擎1主程       —     True True  —
'  展周码指          指必选     历码指    引擎1主程       —     True True  —
'  展周码票          市池票     历码票    引擎1主程       —     —    —     —
'  展日 8 个（含注释掉的基/指），展周 4 个
'  TR 更新：展日 True（日线），展周 False（周线自动关闭）
'二、核心函数调用链
'  基程_展日码总 (L56-82)                历研统码引擎1主程 (L216-401)
'  ├─ PBASE格程工具_表操工表新增         ├─ 历研数据引擎_基础数据准备         ←数据准备
'  ├─ STCALL花册工具_提取典码花天按市池  ├─ PBASE格程工具_表操工表新增        ←建表
'  ├─ 引擎1主程("历码票",...)  票段      ├─ 历研统码引擎3幅分布输程          ←分布(可选)
'  ├─ 后台_WA_设置典核心行业             ├─ 历研数据引擎_基础数据准备(宽基)   ←国内宽基
'  └─ 引擎1主程("历码核",...)  行业段     │  └─ 引擎5输程马赛克×3(鳄鱼/仓日类/幅涨)
'                                         ├─ 历研数据引擎_基础数据准备(宽基)   ←海外宽基
'                                         │  └─ 引擎5输程马赛克×3(鳄鱼/仓日类/幅涨)
'                                         ├─ 历研统码引擎4幅排序输程          ←排名(可选)
'                                         └─ 引擎5输程马赛克×6                ←马赛克(可选)
'                                           (鳄鱼/仓日类/涨幅/高幅/低幅/涨身比)

'########################################################################################
'########################################################################################
'###################################   历统码调程 展日码总   ##############################
'########################################################################################
'########################################################################################
Function 历研统码基程_展日码总( _
          ByVal 指定期类 As String _
        , ByVal 表名统码 As String _
        , Optional ByVal 指定结期下限 As Date = 常结期下限历短 _
        , Optional ByVal wb As Workbook _
        ) As String
    Dim 典码称 As New Dictionary
    Dim MSG As String
    Dim TT历码 As Single: TT历码 = Timer
    If wb Is Nothing Then Set wb = ThisWorkbook
    '------------------------------------------------------------------------------------
    '---- 票 ----
    '------------------------------------------------------------------------------------
    Dim TT票 As Single: TT票 = Timer
    Call STCALL花册工具_提取典码花天按市池(典码称, 包含市指:=False, 包含市基:=False, 包含市票:=True, 测试限数:=-1)
    Dim MSG票计 As String
    MSG票计 = 历研统码引擎1主程("历码票", 典码称, 指定期类, 指定结期下限:=指定结期下限, 是否神谕指标:=False, 显否宽基:=False, 显否排名:=False, 显否马赛克:=False, 显否神谕主页:=False, 表名统码:=表名统码, 是否建表:=True, wb:=wb)
    MSG = MSG & ">>历码票耗时：" & CInt(Timer - TT票) & vbCrLf
    典码称.RemoveAll
    '------------------------------------------------------------------------------------
    '---- 行业 ----
    '------------------------------------------------------------------------------------
    Dim TT行业 As Single: TT行业 = Timer
    Call 后台族非票精分调程_WA_设置典核心行业(典码称)
    Dim MSG核计 As String
    MSG核计 = 历研统码引擎1主程("历码核", 典码称, 指定期类, 指定结期下限:=指定结期下限, 是否神谕指标:=True, 显否宽基:=True, 显否排名:=True, 显否马赛克:=True, 显否神谕主页:=True, 表名统码:=表名统码, 是否建表:=False, wb:=wb)
    MSG = MSG & ">>历码核耗时：" & CInt(Timer - TT行业) & vbCrLf
    典码称.RemoveAll
    '------------------------------------------------------------------------------------
    MSG = MSG & ">>历码全部耗时：" & CInt(Timer - TT历码) & vbCrLf
    Debug.Print MSG票计 & vbCrLf & MSG核计
    历研统码基程_展日码总 = MSG
End Function
