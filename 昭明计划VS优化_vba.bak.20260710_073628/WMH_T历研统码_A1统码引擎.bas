'========================================================================================
'标注同一对象
'========================================================================================
Sub 历研统码工具点灯()
    '------------------------------------------------------------------------------------
    Dim 被选颜色 As Integer
    被选颜色 = CInt(50 * Rnd) + 6
    '------------------------------------------------------------------------------------
    Dim 被选名称 As String
    被选名称 = Selection.Cells(1, 1).Value
    
    If Len(被选名称) = 0 Then
        Exit Sub
    ElseIf InStr(被选名称, ":") > 0 Then
        被选名称 = Left$(被选名称, InStr(被选名称, ":") - 1)
    End If
    '------------------------------------------------------------------------------------
    Dim CL As Range
    For Each CL In ActiveSheet.UsedRange
        If Left$(CL.Value, Len(被选名称)) = 被选名称 Then
            With CL
                .Interior.ColorIndex = 被选颜色
                .Font.Bold = True
            End With
        End If
    Next
    '------------------------------------------------------------------------------------
End Sub

