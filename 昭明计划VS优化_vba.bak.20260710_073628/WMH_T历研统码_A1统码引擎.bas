            If .Cells(X, 位统码排列十累高数) >= 4 Then .Cells(X, 位统码排列十累高数).Font.Bold = True
            If .Cells(X, 位统码排列十累低数) >= 4 Then .Cells(X, 位统码排列十累低数).Font.Bold = True
            If .Cells(X, 位统码排列仨累高数) >= 10 Then .Cells(X, 位统码排列仨累高数).Font.Bold = True
            If .Cells(X, 位统码排列仨累低数) >= 10 Then .Cells(X, 位统码排列仨累低数).Font.Bold = True
            If .Cells(X, 位统码排列佰累高数) >= 20 Then .Cells(X, 位统码排列佰累高数).Font.Bold = True
            If .Cells(X, 位统码排列佰累低数) >= 20 Then .Cells(X, 位统码排列佰累低数).Font.Bold = True
            '标注：持续时间比平均时间长
            If .Cells(X, 位统码排列龄选高隔一) > .Cells(X, 位统码排列龄选高隔二) Then .Cells(X, 位统码排列龄选高隔二).Font.Color = 常色八黄
            If .Cells(X, 位统码排列龄选高隔一) > .Cells(X, 位统码排列龄选高隔四) Then .Cells(X, 位统码排列龄选高隔四).Font.Color = 常色八黄
            If .Cells(X, 位统码排列龄选高隔一) > .Cells(X, 位统码排列龄选高隔十) Then .Cells(X, 位统码排列龄选高隔十).Font.Color = 常色八黄
            If .Cells(X, 位统码排列龄选低隔一) > .Cells(X, 位统码排列龄选低隔二) Then .Cells(X, 位统码排列龄选低隔二).Font.Color = 常色八黄
            If .Cells(X, 位统码排列龄选低隔一) > .Cells(X, 位统码排列龄选低隔四) Then .Cells(X, 位统码排列龄选低隔四).Font.Color = 常色八黄
            If .Cells(X, 位统码排列龄选低隔一) > .Cells(X, 位统码排列龄选低隔十) Then .Cells(X, 位统码排列龄选低隔十).Font.Color = 常色八黄
        Next
    End With
    '----------------------------------------------------
    '格式化：列边框
    '----------------------------------------------------
    With WSSUM.Cells(目行, 目列).Cells(1, 位统码排列当低序).Resize(总行数, 1).Borders(xlEdgeRight)
       .Color = 常色二灰
       .Weight = xlThick
    End With
    With WSSUM.Cells(目行, 目列).Cells(1, 位统码排列佰累低数).Resize(总行数, 1).Borders(xlEdgeRight)
       .Color = 常色二灰
       .Weight = xlThick
    End With
    '------------------------------------------------------------------------------------
    '特殊格式化
    '------------------------------------------------------------------------------------
    With WSSUM.Cells(目行, 目列).Cells(1, 1).Resize(总行数, 位统码排列总数)
        .ColumnWidth = 4
        .Font.Size = 9
    End With
    '----------------------------------------------------
    '格式化：特殊
    '----------------------------------------------------
    WSSUM.Cells(目行, 目列).Cells(1, 位统码排列轮动类型).Resize(总行数, 1).Interior.Color = 常色八靛
    WSSUM.Columns(目列).Columns(位统码排列轮动类型).ColumnWidth = 25
    WSSUM.Columns(目列).Columns(位统码排列CIDL).Hidden = True
    WSSUM.Columns(目列).Columns(位统码排列结期).Hidden = True
    '----------------------------------------------------
    '格式化：首列
    '----------------------------------------------------
    With WSSUM.Cells(目行, 目列).Cells(1, 1).Resize(总行数, 1)
        .Font.Size = 9
        .Font.Color = 常色主黑
        .Interior.Color = 常色八橙
        .HorizontalAlignment = xlLeft
        .ColumnWidth = 15
        .Font.Bold = True
    End With
    '----------------------------------------------------
    '格式化：首行
    '----------------------------------------------------
    With WSSUM.Cells(目行, 目列).Resize(1, 位统码排列总数)
        .Interior.Color = 常色蒂芙尼蓝
        .Font.Color = 常色主黑
        .Font.Bold = True
    End With
    '----------------------------------------------------
    '格式化：排序
    '----------------------------------------------------
    总列数 = WSSUM.Cells(目行, 9999).End(xlToLeft).Column + 1
    With WSSUM.Cells(目行, 1).Resize(总行数, 总列数)
        .Sort key1:=.Cells(目列).Cells(1, 位统码排列十累高数), order1:=xlDescending, _
              key2:=.Cells(目列).Cells(1, 位统码排列当高序), order2:=xlAscending, _
              key3:=.Cells(目列).Cells(1, 位统码排列仨累高数), order3:=xlDescending, _
              Header:=xlYes
        .Sort key1:=.Cells(目列).Cells(1, 位统码排列轮动类型), order1:=xlAscending, _
              Header:=xlYes
    End With
'========================================================================================
End Function





'========================================================================================
'========================================================================================
'功能：按照第三维度【幅度】进行展示
'========================================================================================
'========================================================================================
Function 历研统码引擎5输程马赛克( _
          矩历码期值 As Variant _
        , WSTO As Worksheet _
        , Optional 始行 As Integer = 3 _
        , Optional 始列 As Integer = 1 _
        , Optional 第三维 As Integer = 1 _
        , Optional 指定期类 As String = 常期类为日 _
        , Optional ByVal 显否日期 As Boolean = True _
        , Optional ByVal 显否数值 As Boolean = False _
        , Optional ByVal 配色类型 As String = "幅" _
        ) As Integer
    '------------------------------------------------------------------------------------
    '输出数据
    '------------------------------------------------------------------------------------
    Dim 总行数 As Integer
    总行数 = UBound(矩历码期值, 1) - LBound(矩历码期值, 1) + 1 ' UTL表参_总行数指定(wsto, 1)
    Dim 总列数 As Integer
    总列数 = UBound(矩历码期值, 2) - LBound(矩历码期值, 2) + 1
    '------------------------------------------------------------------------------------
    '格式化：基础
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Resize(总行数, 总列数)
        .Font.Size = 6
        .EntireColumn.ColumnWidth = 3
        .NumberFormatLocal = 全设格式of一位
    End With
    With WSTO.Columns(始列)
        If .ColumnWidth < 12 Then .ColumnWidth = 12
    End With
    '首列
    With WSTO.Cells(始行, 始列).Resize(总行数, 1)
        .Font.Size = 9
        .Font.Color = 常色六灰
    End With
    '首行
    With WSTO.Cells(始行, 始列).Resize(1, 总列数)
        .Font.Size = 10
        .Font.Bold = True
        .NumberFormatLocal = "d"
        .Interior.Color = 常色蒂芙尼蓝
    End With
    If 显否日期 = False Then WSTO.Rows(始行).Hidden = True
    '------------------------------------------------------------------------------------
    '格式化：特殊
    '------------------------------------------------------------------------------------
    '输出首列：名称
    Dim X As Integer, Y As Integer
    Dim 值展示 As Variant
    For X = LBound(矩历码期值, 1) To UBound(矩历码期值, 1)
        WSTO.Cells(始行 + X, 始列) = 矩历码期值(X, 位矩历二维下限, 第三维)
    Next
    '输出首行：日期
    For Y = LBound(矩历码期值, 2) + 1 To UBound(矩历码期值, 2)
        WSTO.Cells(始行, 始列 + Y) = 矩历码期值(位矩历一维下限, Y, 第三维)
    Next
    '输出数据：主区域
    For X = LBound(矩历码期值, 1) + 1 To UBound(矩历码期值, 1)
    For Y = LBound(矩历码期值, 2) + 1 To UBound(矩历码期值, 2)
        值展示 = 矩历码期值(X, Y, 第三维)
        If 配色类型 = "幅" Then
            Call UTL展示幅度(WSTO.Cells(始行 + X, 始列 + Y), 值展示)
        ElseIf 配色类型 = "仓日类" Then
            WSTO.Cells(始行 + X, 始列 + Y).Interior.Color = STBASE结算工具_衍生色度按仓日类(CStr(矩历码期值(X, Y, 第三维)))
        ElseIf 配色类型 = "仓周类" Then
            WSTO.Cells(始行 + X, 始列 + Y).Interior.Color = STBASE结算工具_衍生色度按仓周类(CStr(矩历码期值(X, Y, 第三维)))
        End If
        If 显否数值 = True Then WSTO.Cells(始行 + X, 始列 + Y) = 值展示
    Next
    Next
    '------------------------------------------------------------------------------------
    '格式化：日期边框
    '------------------------------------------------------------------------------------
    Dim 值当期 As Date, 值前期 As Date
    If 指定期类 = 常期类为日 Then
        For Y = 2 To 总列数 - 1
            值当期 = WSTO.Cells(始行, Y)
            值前期 = WSTO.Cells(始行, Y + 1)
            If 值当期 - Weekday(值当期, vbMonday) <> 值前期 - Weekday(值前期, vbMonday) Then
                With WSTO.Cells(始行, Y).Resize(总行数, 1).Borders(xlRight)
                   .Color = 常色六灰
                   .Weight = xlThin
                End With
            End If
        Next
    End If
    '------------------------------------------------------------------------------------
    '格式化：行边框
    '------------------------------------------------------------------------------------
    With WSTO.Cells(始行, 始列).Cells(总行数, 1).Resize(1, 总列数).Borders(xlEdgeBottom)
       .Color = 常色四灰
       .Weight = xlThin
    End With
    '------------------------------------------------------------------------------------
    历研统码引擎5输程马赛克 = 始行 + 总行数 - 1
End Function
