'########################################################################################
'########################################################################################
'###################################   历研统码引擎   ###################################
'########################################################################################
'########################################################################################
Function 历研统码引擎1主程( _
          ByVal 码签 As String _
        , ByRef 典码称 As Dictionary _
        , Optional ByVal 指定期类 As String = 常期类为日 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限历短 _
        , Optional ByVal 是否全新源AK As Boolean = False _
        , Optional ByVal 是否更新源TR As Boolean = True _
        , Optional ByVal 是否神谕指标 As Boolean = False _
        , Optional ByVal 始行 As Integer = 1 _
        , Optional ByVal 始列 As Integer = 1 _
        , Optional ByVal 显否分布 As Boolean = True _
        , Optional ByVal 显否排名 As Boolean = False _
        , Optional ByVal 显否马赛克 As Boolean = False _
        , Optional ByVal 显否宽基 As Boolean = True _
        , Optional ByVal 显否神谕主页 As Boolean = False _
        , Optional ByVal 是否建表 As Boolean = True _
        , Optional ByVal 表名统码 As String = "" _
        , Optional ByVal 基色底 As Long = 常色六青 _
        , Optional ByVal wb As Workbook _
        ) As String
'========================================================================================
'准备数据
'========================================================================================
    Dim TT_总 As Single: TT_总 = Timer
    Dim TT_段 As Single
    Dim TT_MSG As String
    TT_段 = Timer
    If 指定期类 <> 常期类为日 Then 是否更新源TR = False
    '------------------------------------------------------------------------------------
    Dim 矩历码期值 As Variant
    Dim 码数 As Integer
    码数 = 历研数据引擎_基础数据准备(矩历码期值, 典码称, 指定期类, 指定结期下限:=指定结期下限, 是否全新源AK:=是否全新源AK, 是否更新源TR:=是否更新源TR, 是否神谕指标:=是否神谕指标)
    If 码数 = 0 Then Exit Function
    TT_MSG = TT_MSG & 码签 & " [数据] " & Format(Timer - TT_段, "0.0s") & vbCrLf
'========================================================================================
'输出工表
'========================================================================================
    TT_段 = Timer
    If wb Is Nothing Then
        Set wb = ThisWorkbook
    End If
    '------------------------------------------------------------------------------------
    '建页
    '------------------------------------------------------------------------------------
    If Len(表名统码) = 0 Then
        If Len(码签) > 0 Then
            表名统码 = 码签
        Else
            表名统码 = "表名为空"
        End If
    End If
    Dim WSTO As Worksheet
    If 是否建表 = True Or UTL判断工表存在(表名统码, wb) = False Then
        Call PBASE格程工具_表操工表新增(WSTO, 表名统码, wb, 基色底:=基色底)
        With WSTO.Cells
            .HorizontalAlignment = xlRight
            .Interior.Color = 常色主黑
            .Font.Size = 8
            .Font.Name = "宋体"
        End With
        WSTO.Cells.ColumnWidth = 4
        With WSTO.Columns(始列)
            .ColumnWidth = 16
            .HorizontalAlignment = xlLeft
        End With
        Call PBASE格程工具_表冻结锁定(WSTO, 3, 始列, 缩放:=100)
    End If
    Set WSTO = wb.Sheets(表名统码)
    Dim 末行 As Integer
    末行 = PBASE格程工具_表参末行指定(WSTO, 1)
    '------------------------------------------------------------------------------------
    '工表标题
    '------------------------------------------------------------------------------------
    If Len(码签) > 0 Then
        末行 = IIf(末行 = 1, 1, 末行 + 1)
        With WSTO.Rows(末行)
            .RowHeight = 30
            .Font.Bold = True
            .Font.Color = 常色主白
            .VerticalAlignment = xlBottom
            With .Cells(1, 始列)
                .Value = 码签 & " [" & 码数 & "]"
                .Font.Size = 16
            End With
        End With
        末行 = 末行 + 1
    End If
    TT_MSG = TT_MSG & 码签 & " [建表] " & Format(Timer - TT_段, "0.0s") & vbCrLf
'========================================================================================
'输出：显否分布
'========================================================================================
    TT_段 = Timer
    If 显否分布 = True Then
            末行 = PBASE格程工具_表参末行指定(WSTO, 1)
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎3幅分布输程(WSTO, 矩历码期值, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类)
    End If
    TT_MSG = TT_MSG & 码签 & " [分布] " & Format(Timer - TT_段, "0.0s") & IIf(显否分布, "", "(skip)") & vbCrLf
'========================================================================================
'输出：显否宽基
'========================================================================================
    If 显否宽基 = True Then
            '----------------------------------------------------------------------------
            '国内宽基：盘面
            '----------------------------------------------------------------------------
            TT_段 = Timer
            Dim 典码称宽基 As New Dictionary
            Call 后台族非票精分调程_WA_设置典核心宽基(典码称宽基)
            Dim 矩历码期值宽基 As Variant
            Call 历研数据引擎_基础数据准备(矩历码期值宽基, 典码称宽基, 指定期类, 指定结期下限:=指定结期下限, 是否全新源AK:=是否全新源AK, 是否更新源TR:=是否更新源TR, 是否神谕指标:=True)
            TT_MSG = TT_MSG & 码签 & " [国内宽基-数据] " & Format(Timer - TT_段, "0.0s") & vbCrLf
            TT_段 = Timer
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值宽基, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维指标仓周类, 显否日期:=False, 配色类型:="仓周类", 显否数值:=True) '仓周类：三鳄
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值宽基, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维指标仓日类, 显否日期:=False, 配色类型:="仓日类", 显否数值:=True) '仓日类
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值宽基, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维幅涨, 显否日期:=False, 配色类型:="幅", 显否数值:=True) '涨幅
            典码称宽基.RemoveAll
            TT_MSG = TT_MSG & 码签 & " [国内宽基-马赛克] " & Format(Timer - TT_段, "0.0s") & vbCrLf
            '----------------------------------------------------------------------------
            '甄别盘面风格：最后一行
            '----------------------------------------------------------------------------
            TT_段 = Timer
            Dim 总列数 As Integer
            总列数 = UBound(矩历码期值宽基, 2) - LBound(矩历码期值宽基, 2) + 1
            末行 = 末行 + 1
            With WSTO.Cells(末行, 始列)
                .Value = "盘面风格"
                .Font.Color = 常色六灰
            End With
            With WSTO.Cells(末行, 始列).Resize(1, 总列数)
                .Font.Size = 9
                With .Borders(xlEdgeBottom)
                   .Color = 常色四灰
                   .Weight = xlThin
                End With
            End With
            Dim Y As Integer
            For Y = 2 To 总列数
                With WSTO.Cells(末行, Y)
                    .Value = IIf(.Offset(-2, 0) >= .Offset(-1, 0), 1, -1) _
                            + IIf(.Offset(-3, 0) >= .Offset(-2, 0), 1, -1) _
                            + IIf(.Offset(-4, 0) >= .Offset(-3, 0), 1, -1) _
                            + IIf(.Offset(-5, 0) >= .Offset(-4, 0), 1, -1)
                    .Interior.Color = 常色五青
                    .Interior.TintAndShade = (0 - .Value) / 4.2
                    .Font.Color = .Interior.Color
                End With
            Next
            WSTO.Rows(末行).RowHeight = 20
            TT_MSG = TT_MSG & 码签 & " [盘面风格] " & Format(Timer - TT_段, "0.0s") & vbCrLf
            '----------------------------------------------------------------------------
            '海外宽基
            '----------------------------------------------------------------------------
            TT_段 = Timer
            Call 后台族非票精分调程_WA_设置典核心大盘(典码称宽基)
            Call 历研数据引擎_基础数据准备(矩历码期值宽基, 典码称宽基, 指定期类, 指定结期下限:=指定结期下限, 是否全新源AK:=是否全新源AK, 是否更新源TR:=是否更新源TR, 是否神谕指标:=True)
            TT_MSG = TT_MSG & 码签 & " [海外宽基-数据] " & Format(Timer - TT_段, "0.0s") & vbCrLf
            TT_段 = Timer
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值宽基, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维指标仓周类, 显否日期:=False, 配色类型:="仓周类", 显否数值:=True) '三鳄
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值宽基, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维指标仓日类, 显否日期:=False, 配色类型:="仓日类", 显否数值:=True) '仓日类
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值宽基, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维幅涨, 显否日期:=False, 配色类型:="幅", 显否数值:=True) '涨幅
            典码称宽基.RemoveAll
            TT_MSG = TT_MSG & 码签 & " [海外宽基-马赛克] " & Format(Timer - TT_段, "0.0s") & vbCrLf
            '----------------------------------------------------------------------------
    End If
'========================================================================================
'输出：显否排名
'========================================================================================
    TT_段 = Timer
    If 显否排名 = True Then
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎4幅排序输程(WSTO, 矩历码期值, 数序输出:=10, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 显否神谕主页:=显否神谕主页, 表名统码:=表名统码, 基色底:=基色底)
    End If
    TT_MSG = TT_MSG & 码签 & " [排名] " & Format(Timer - TT_段, "0.0s") & IIf(显否排名, "", "(skip)") & vbCrLf
'========================================================================================
'输出：显否马赛克
'========================================================================================
    TT_段 = Timer
    If 显否马赛克 = True Then
            '----------------------------------------------------------------------------
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维指标仓周类, 配色类型:="仓周类", 显否数值:=True)  '神谕三鳄
            '----------------------------------------------------------------------------
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维指标仓日类, 配色类型:="仓日类", 显否数值:=True)  '神谕仓日类
            '----------------------------------------------------------------------------
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维幅涨, 配色类型:="幅")   '涨幅
            '----------------------------------------------------------------------------
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维幅高, 配色类型:="幅")   '高幅
            '----------------------------------------------------------------------------
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维幅低, 配色类型:="幅")   '低幅
            '----------------------------------------------------------------------------
            WSTO.Rows(末行 + 1).Hidden = True
            末行 = 历研统码引擎5输程马赛克(矩历码期值, WSTO, 始行:=末行 + 2, 始列:=1, 指定期类:=指定期类, 第三维:=位矩历三维幅比, 配色类型:="幅")   '涨身比
            '----------------------------------------------------------------------------
    End If
    TT_MSG = TT_MSG & 码签 & " [马赛克] " & Format(Timer - TT_段, "0.0s") & IIf(显否马赛克, "", "(skip)") & vbCrLf
'========================================================================================
    TT_MSG = TT_MSG & 码签 & " [总计] " & Format(Timer - TT_总, "0.0s")
    历研统码引擎1主程 = TT_MSG
End Function



'========================================================================================
'========================================================================================
'功能：按照【典码称输出】所含代码输出【组历统码】
'========================================================================================
'========================================================================================
Function 历研统码引擎3幅分布输程( _
          WSTO As Worksheet _
        , ByRef 矩历码期值 As Variant _
        , Optional 始行 As Integer = 1 _
        , Optional 始列 As Integer = 1 _
        , Optional 指定期类 As String = 常期类为日 _
      ) As Integer
'========================================================================================
'验证
'========================================================================================
    If WSTO Is Nothing Then Exit Function
    If VBA.IsEmpty(矩历码期值) Then Exit Function
    'If 数序输出 > UBound(矩历码期值, 1) Then Exit Function
'========================================================================================
'加工数组：基础排序
'========================================================================================
    Dim 组历统码 As Variant
    Call 历研统码引擎3幅分布数程(组历统码, 矩历码期值)
'========================================================================================
'格式化：定位坐标
'========================================================================================
    Dim 总列数 As Integer
    总列数 = UBound(组历统码, 2) - LBound(组历统码, 2) + 1
    '------------------------------------------------------------------------------------
    '柱图：定位坐标
    '------------------------------------------------------------------------------------
    Dim 柱图行始 As Integer
    柱图行始 = 始行 + 位统码行总终
    Dim 柱图行数 As Integer
    Dim 柱图行零 As Integer
    柱图行数 = 100
    柱图行零 = 柱图行始 + 柱图行数
    WSTO.Cells(柱图行零, 始列).Offset(柱图行数 - 1, 0) = "_"        '占位
    '------------------------------------------------------------------------------------
    '柱图：统计表格
    '------------------------------------------------------------------------------------
    Dim 统表行始 As Integer
    统表行始 = 始行
    Dim 统表行数 As Integer
    统表行数 = UBound(组历统码, 1) - LBound(组历统码, 1) + 1
    Dim 总数非停 As Double
'========================================================================================
'输出工表：统表
'========================================================================================
    '------------------------------------------------------------------------------------
    '格式化：字体
    '------------------------------------------------------------------------------------
    With WSTO.Cells(统表行始, 始列).Resize(统表行数, 总列数)
        .Font.Color = 常色主黑
        .Font.Size = 8
        .EntireColumn.ColumnWidth = 3
    End With
    With WSTO.Columns(始列)
        If .ColumnWidth < 12 Then .ColumnWidth = 12
    End With
    '格式化列：首列
    With WSTO.Cells(统表行始, 始列).Resize(统表行数, 1)
        .Font.Color = 常色六灰
        .Font.Size = 9
        '.Font.Bold = True
    End With
    '格式化行：首行
    With WSTO.Cells(统表行始, 始列).Resize(1, 总列数)
        .NumberFormatLocal = "d"    '一定要放在输出数据之前，否则无法设置格式
        .Interior.Color = 常色蒂芙尼蓝
        .Font.Bold = True
        .Font.Color = 常色主黑
        .Font.Size = 9
    End With
    '------------------------------------------------------------------------------------
    '输出数据
    '------------------------------------------------------------------------------------
    Call UTL数据转换_集ARR2WS(组历统码, WSTO, 统表行始, 始列)
'========================================================================================
'格式化：统表
'========================================================================================
    '------------------------------------------------------------------------------------
    '格式化行：矩阵幅涨
    '------------------------------------------------------------------------------------
    Dim Y As Integer, X As Integer
    For Y = 2 To 总列数
        总数非停 = WSTO.Cells(统表行始, 始列).Cells(位统码行数非停, Y)
        If 总数非停 > 0 Then
        For X = 位统码行涨始 To 位统码行涨终
            With WSTO.Cells(统表行始, 始列).Cells(X, Y)
                    '--------------------------------------------------------------------
                    '格式：全部单元
                    '--------------------------------------------------------------------
                    If X <= 位统码行涨正1 Then
                        .Interior.Color = 常色十青
                        .Interior.TintAndShade = Round(.Value / 总数非停 - 0.9, 1)   '[0,100]对应色度范围[-0.9,0]
                        .Font.Color = .Interior.Color
                        .Font.TintAndShade = -0.1
                    Else
                        .Interior.Color = 常色五灰
                        .Interior.TintAndShade = Round(.Value / 总数非停 - 0.9, 1)   '[0,100]对应色度范围[-0.9,0]
                        .Font.Color = .Interior.Color
                        If .Value > 0 Then .Font.TintAndShade = -0.1
                    End If
                    '--------------------------------------------------------------------
                    '格式：首行 尾行
                    '--------------------------------------------------------------------
                    If X = 位统码行涨始 Or X = 位统码行涨终 Then
                        If .Value / 总数非停 >= 0.02 Then
                            .Font.Color = 常色十红
                        ElseIf .Value / 总数非停 >= 0.01 Then
                            .Font.Color = 常色十黄
                        ElseIf .Value > 0 Then
                            .Font.TintAndShade = 0.2
                        End If
                    End If
                    '--------------------------------------------------------------------
            End With
        Next
        End If
    Next
    '------------------------------------------------------------------------------------
    '格式化行：矩阵幅高
    '------------------------------------------------------------------------------------
    For X = 位统码行高始 To 位统码行高终
        WSTO.Rows(统表行始).Rows(X).NumberFormatLocal = 全设格式of零位
    Next
    For Y = 2 To 总列数
        总数非停 = WSTO.Cells(统表行始, 始列).Cells(位统码行数非停, Y)
        For X = 位统码行高始 To 位统码行高终
            With WSTO.Cells(统表行始, 始列).Cells(X, Y)
                    '--------------------------------------------------------------------
                    '格式：全部单元
                    '--------------------------------------------------------------------
                    If X <= 位统码行高正1 Then
                        .Interior.Color = 常色十青
                        .Interior.TintAndShade = Round(.Value / 100 - 0.9, 1)   '[0,100]对应色度范围[-0.9,0]
                        .Font.Color = .Interior.Color
                        .Font.TintAndShade = -0.1
                    Else
                        .Interior.Color = 常色五灰
                        .Interior.TintAndShade = Round(.Value / 100 - 0.9, 1)   '[0,100]对应色度范围[-0.9,0]
                        .Font.Color = .Interior.Color
                        If .Value > 0 Then .Font.TintAndShade = 0.1
                    End If
                    '--------------------------------------------------------------------
                    '格式：首行 尾行
                    '--------------------------------------------------------------------
                    If X = 位统码行高始 Or X = 位统码行高终 Then
                        If .Value / 100 >= 0.03 Then
                            .Font.Color = 常色十红
                        ElseIf .Value / 100 >= 0.02 Then
                            .Font.Color = 常色十黄
                        ElseIf .Value > 0 Then
                            .Font.TintAndShade = 0.2
                        End If
                    End If
                    '--------------------------------------------------------------------
            End With
        Next
    Next
    '------------------------------------------------------------------------------------
    '格式化行：位统码行涨身比
    '------------------------------------------------------------------------------------
    With WSTO.Rows(统表行始).Rows(位统码行涨身比)
        .NumberFormatLocal = 全设格式of百分
        .RowHeight = 20
    End With
    For Y = 2 To 总列数
        With WSTO.Cells(统表行始, 始列).Cells(位统码行涨身比, Y)
            If .Value > 0.75 Then
                .Interior.Color = 常色十红
            ElseIf .Value > 0.5 Then
                .Interior.Color = 常色主黄
            ElseIf .Value > 0.25 Then
                .Interior.Color = 常色十绿
            Else
                .Interior.Color = 常色十蓝
            End If
        End With
    Next
    '------------------------------------------------------------------------------------
    '格式化行：均幅
    '------------------------------------------------------------------------------------
    WSTO.Rows(统表行始).Rows(位统码行高幅均).NumberFormatLocal = "[黑色]0_);[蓝色](0)"
    WSTO.Rows(统表行始).Rows(位统码行涨幅均).NumberFormatLocal = "[黑色]0_);[蓝色](0)"
    WSTO.Rows(统表行始).Rows(位统码行低幅均).NumberFormatLocal = "[黑色]0_);[蓝色](0)"
    WSTO.Rows(统表行始).Rows(位统码行振幅均).NumberFormatLocal = "[黑色]0_);[蓝色](0)"
    WSTO.Rows(统表行始).Rows(位统码行中幅均).NumberFormatLocal = "[黑色]0_);[蓝色](0)"
    '振幅底色：振幅没有大小之分。剔除异常情况（≥10），其余应用单一色。
    For Y = 2 To 总列数
        X = 位统码行振幅均
        With WSTO.Cells(统表行始, 始列).Cells(X, Y)
            If .Value >= 10 Then
                .Interior.Color = 常色十红
            ElseIf .Value < 5 Then
                .Interior.Color = 常色五灰
                .Interior.TintAndShade = (.Value - 5) / 5
            Else
                If WSTO.Cells(统表行始, 始列).Cells(位统码行涨幅均, Y) < 0 Then
                    .Interior.Color = 常色五蓝
                    '.Interior.TintAndShade = (.Value - 5) / 5
                Else
                    .Interior.Color = 常色五黄
                    '.Interior.TintAndShade = (.Value - 5) / 5
                End If
            End If
            .Font.Color = 常色主黑
        End With
    Next
    For Y = 2 To 总列数
        For X = 位统码行高幅均 To 位统码行低幅均
            Call UTL展示幅度(WSTO.Cells(统表行始, 始列).Cells(X, Y))
        Next
    Next
'    '------------------------------------------------------------------------------------
'    '格式化行：位统码行中幅正比
'    '------------------------------------------------------------------------------------
'    With WSTO.Rows(统表行始).Rows(位统码行中幅正比)
'        .NumberFormatLocal = 全设格式of百分
'        .RowHeight = 20
'    End With
'    For Y = 2 To 总列数
'        With WSTO.Cells(统表行始, 始列).Cells(位统码行中幅正比, Y)
'            If .Value > 0.75 Then
'                .Interior.Color = 常色十红
'            ElseIf .Value > 0.5 Then
'                .Interior.Color = 常色主黄
'            ElseIf .Value > 0.25 Then
'                .Interior.Color = 常色主碧
'            Else
'                .Interior.Color = 常色四灰
'            End If
'        End With
'    Next
'    For Y = 2 To 总列数
'            Call UTL展示幅度(WSTO.Cells(统表行始, 始列).Cells(X, Y))
'    Next
    WSTO.Rows(统表行始).Rows(位统码行中幅正比).Hidden = True
    WSTO.Rows(统表行始).Rows(位统码行中幅均).Hidden = True
    '------------------------------------------------------------------------------------
    '格式化：日期边框
    '------------------------------------------------------------------------------------
    Dim 值当期 As Date
    Dim 值前期 As Date
    If 指定期类 = 常期类为日 Then
        For Y = 2 To 总列数
            值当期 = WSTO.Cells(统表行始, 始列).Cells(1, Y)
            值前期 = WSTO.Cells(统表行始, 始列).Cells(1, Y + 1)
            If 值当期 - Weekday(值当期, vbMonday) <> 值前期 - Weekday(值前期, vbMonday) Then
                With WSTO.Cells(统表行始, Y).Resize(统表行数, 1).Borders(xlRight)
                   .Color = 常色轮框
                   .Weight = xlThin
                End With
            End If
        Next
    End If
    '------------------------------------------------------------------------------------
    '格式化：行边框
    '------------------------------------------------------------------------------------
    With WSTO.Cells(统表行始, 始列).Cells(位统码行涨终, 1).Resize(1, 总列数).Borders(xlEdgeBottom)
       .Color = 常色四灰
       .Weight = xlThin
    End With
    With WSTO.Cells(统表行始, 始列).Cells(位统码行高终, 1).Resize(1, 总列数).Borders(xlEdgeBottom)
       .Color = 常色四灰
       .Weight = xlThin
    End With
    If 总列数 > 1 Then
    With WSTO.Cells(统表行始, 始列).Cells(位统码行振幅均, 2).Resize(1, 总列数 - 1).Borders(xlEdgeTop)
       .Color = 常色四灰
       .Weight = xlThin
    End With
    With WSTO.Cells(统表行始, 始列).Cells(位统码行涨身比, 2).Resize(1, 总列数 - 1).Borders(xlEdgeTop)
       .Color = 常色四灰
       .Weight = xlThin
    End With
    With WSTO.Cells(统表行始, 始列).Cells(位统码行算终, 1).Resize(1, 总列数).Borders(xlEdgeBottom)
       .Color = 常色四灰
       .Weight = xlMedium
    End With
    End If
    '------------------------------------------------------------------------------------
    '格式化：显示
    '------------------------------------------------------------------------------------
    WSTO.Rows(统表行始).Rows(位统码行数非停).Font.Color = 常色二灰
    WSTO.Rows(统表行始).Rows(位统码行数非停).Hidden = True
'========================================================================================
'格式化：涨幅柱图
'========================================================================================
    '------------------------------------------------------------------------------------
    '在原有数据上计算比例用于柱图
    '------------------------------------------------------------------------------------
    For Y = 1 To UBound(组历统码, 2)  '按日
            '----------------------------------------------------------------------------
            If 组历统码(位统码行数非停, Y) > 0 Then
                    总数非停 = 组历统码(位统码行数非停, Y)
                    组历统码(位统码行涨正5, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨正5, Y) / 总数非停, 1)
                    组历统码(位统码行涨正4, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨正4, Y) / 总数非停, 1)
                    组历统码(位统码行涨正3, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨正3, Y) / 总数非停, 1)
                    组历统码(位统码行涨正2, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨正2, Y) / 总数非停, 1)
                    组历统码(位统码行涨正1, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨正1, Y) / 总数非停, 1)
                    组历统码(位统码行涨负1, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨负1, Y) / 总数非停, 1)
                    组历统码(位统码行涨负2, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨负2, Y) / 总数非停, 1)
                    组历统码(位统码行涨负3, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨负3, Y) / 总数非停, 1)
                    组历统码(位统码行涨负4, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨负4, Y) / 总数非停, 1)
                    组历统码(位统码行涨负5, Y) = WorksheetFunction.Floor(100 * 组历统码(位统码行涨负5, Y) / 总数非停, 1)
            End If
            '----------------------------------------------------------------------------
    Next Y
    '------------------------------------------------------------------------------------
    '柱图：首列
    '------------------------------------------------------------------------------------
    With WSTO.Cells(柱图行始, 始列).Resize(柱图行数 * 2, 1)
        .RowHeight = 1
        .HorizontalAlignment = xlRight
        .Font.Color = 常色六灰
        .Font.Size = 9
    End With
    With WSTO.Cells(柱图行始, 始列).Resize(柱图行数, 1)
        .ClearContents
        .Merge
        .Value = "涨幅分布正向"
        .VerticalAlignment = xlBottom
        With .EntireRow
                .RowHeight = 1
                With .Borders(xlEdgeTop)
                    .Color = 常色四灰
                    .Weight = xlThin
                End With
                With .Borders(xlEdgeBottom)
                    .Color = 常色二灰
                    .Weight = xlThin
                End With
        End With
    End With
    With WSTO.Cells(柱图行零, 始列).Resize(柱图行数 - 1, 1)
        .ClearContents
        .Merge
        .Value = "涨幅分布负向"
        .VerticalAlignment = xlTop
        With .EntireRow
                .RowHeight = 1
                With .Borders(xlEdgeBottom)
                    .Color = 常色四灰
                    .Weight = xlThin
                End With
        End With
    End With
    '------------------------------------------------------------------------------------
    '柱图：柱图
    '------------------------------------------------------------------------------------
    Dim 柱目行始 As Integer
    Dim 柱目行数 As Integer
    For Y = 1 To UBound(组历统码, 2)  '按日
            '----------------------------------------------------------
            '涨幅为正
            '----------------------------------------------------------
            柱目行始 = 柱图行零
            柱目行数 = 组历统码(位统码行涨正1, Y)
            柱目行始 = 柱目行始 - 柱目行数
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色四绿
            柱目行数 = 组历统码(位统码行涨正2, Y)
            柱目行始 = 柱目行始 - 柱目行数
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色主碧
            柱目行数 = 组历统码(位统码行涨正3, Y)
            柱目行始 = 柱目行始 - 柱目行数
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色十黄
            柱目行数 = 组历统码(位统码行涨正4, Y)
            柱目行始 = 柱目行始 - 柱目行数
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色十橙
            柱目行数 = 组历统码(位统码行涨正5, Y)
            柱目行始 = 柱目行始 - 柱目行数
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色十红
            '----------------------------------------------------------
            '涨幅为负
            '----------------------------------------------------------
            柱目行始 = 柱图行零
            柱目行数 = 组历统码(位统码行涨负1, Y)
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色六蓝
            柱目行始 = 柱目行始 + 柱目行数
            柱目行数 = 组历统码(位统码行涨负2, Y)
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色十蓝
            柱目行始 = 柱目行始 + 柱目行数
            柱目行数 = 组历统码(位统码行涨负3, Y)
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色十黄
            柱目行始 = 柱目行始 + 柱目行数
            柱目行数 = 组历统码(位统码行涨负4, Y)
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色十橙
            柱目行始 = 柱目行始 + 柱目行数
            柱目行数 = 组历统码(位统码行涨负5, Y)
            If 柱目行数 > 0 Then WSTO.Cells(柱目行始, 始列).Offset(0, Y).Resize(柱目行数, 1).Interior.Color = 常色十红
            '----------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    '格式化：日期边框
    '------------------------------------------------------------------------------------
    If 指定期类 = 常期类为日 Then
        For Y = 2 To 总列数
            值当期 = WSTO.Cells(统表行始, 始列).Cells(1, Y)
            值前期 = WSTO.Cells(统表行始, 始列).Cells(1, Y + 1)
            If 值当期 - Weekday(值当期, vbMonday) <> 值前期 - Weekday(值前期, vbMonday) Then
                With WSTO.Cells(柱图行始, Y).Resize(柱图行数 * 2, 1).Borders(xlRight)
                   .Color = 常色轮框
                   .Weight = xlThin
                End With
            End If
        Next
    End If
'========================================================================================
    Erase 组历统码
    历研统码引擎3幅分布输程 = 柱图行始 + 柱图行数 * 2 - 1
'    历研统码引擎3幅分布输程 = 统表行始 + 位统码行总终 - 1
End Function
Function 历研统码引擎3幅分布数程( _
          ByRef 组历统码 As Variant _
        , ByRef 矩历码期值 As Variant _
        )
    '====================================================================================
    '统计数据
    '====================================================================================
    ReDim 组历统码(位统码行总始 To 位统码行总终, LBound(矩历码期值, 2) To UBound(矩历码期值, 2)) As Variant
    '------------------------------------------------------------------------------------
    组历统码(位统码行结期, 0) = "幅分布"
    组历统码(位统码行涨正5, 0) = "#涨[10,++]"
    组历统码(位统码行涨正4, 0) = "#涨[ 6,10]"
    组历统码(位统码行涨正3, 0) = "#涨[ 3, 6]"
    组历统码(位统码行涨正2, 0) = "#涨[ 1, 3]"
    组历统码(位统码行涨正1, 0) = "#涨[ 0, 1]"
    组历统码(位统码行涨负1, 0) = "#涨[-1, 0]"
    组历统码(位统码行涨负2, 0) = "#涨[-3,-1]"
    组历统码(位统码行涨负3, 0) = "#涨[-6,-3]"
    组历统码(位统码行涨负4, 0) = "#涨[-9,-6]"
    组历统码(位统码行涨负5, 0) = "#涨[--,-9]"
    组历统码(位统码行高正5, 0) = "%高[10,++]"
    组历统码(位统码行高正4, 0) = "%高[ 6,10]"
    组历统码(位统码行高正3, 0) = "%高[ 3, 6]"
    组历统码(位统码行高正2, 0) = "%高[ 1, 3]"
    组历统码(位统码行高正1, 0) = "%高[ 0, 1]"
    组历统码(位统码行高负1, 0) = "%高[-1, 0]"
    组历统码(位统码行高负2, 0) = "%高[-3,-1]"
    组历统码(位统码行高负3, 0) = "%高[--,-3]"
    组历统码(位统码行中幅正比, 0) = "%均高低心>0"
    组历统码(位统码行涨身比, 0) = "%涨身比"
    组历统码(位统码行高幅均, 0) = "均高幅"
    组历统码(位统码行低幅均, 0) = "均低幅"
    组历统码(位统码行涨幅均, 0) = "均涨幅"
    组历统码(位统码行振幅均, 0) = "均振幅(高-低)"
    组历统码(位统码行中幅均, 0) = "均中幅(高+低)"
    组历统码(位统码行数非停, 0) = "总数非停"
    '------------------------------------------------------------------------------------
    '统计
    '------------------------------------------------------------------------------------
    Dim 组排名 As Variant
    Dim 是否停牌 As Boolean
    Dim 总数非停 As Integer
    Dim X As Integer, Y As Integer
    For Y = 1 To UBound(矩历码期值, 2)  '按日
            组历统码(位统码行结期, Y) = 矩历码期值(位矩历一维下限, Y, 1)
            组历统码(位统码行数非停, Y) = 0
            组历统码(位统码行涨幅均, Y) = 0
            组历统码(位统码行高幅均, Y) = 0
            组历统码(位统码行低幅均, Y) = 0
            For X = 1 To UBound(矩历码期值, 1)  '按码
                是否停牌 = IIf(VBA.IsNumeric(矩历码期值(X, Y, 位矩历三维幅涨)) = True, False, True)
                If 是否停牌 = False Then
                        '----------------------------------------------------------
                        组历统码(位统码行数非停, Y) = 组历统码(位统码行数非停, Y) + 1
                        组历统码(位统码行涨幅均, Y) = 组历统码(位统码行涨幅均, Y) + 矩历码期值(X, Y, 位矩历三维幅涨)
                        组历统码(位统码行高幅均, Y) = 组历统码(位统码行高幅均, Y) + 矩历码期值(X, Y, 位矩历三维幅高)
                        组历统码(位统码行低幅均, Y) = 组历统码(位统码行低幅均, Y) + 矩历码期值(X, Y, 位矩历三维幅低)
                        If 矩历码期值(X, Y, 位矩历三维幅高) + 矩历码期值(X, Y, 位矩历三维幅低) >= 0 Then 组历统码(位统码行中幅正比, Y) = 组历统码(位统码行中幅正比, Y) + 1
                        '----------------------------------------------------------
                        Select Case 矩历码期值(X, Y, 位矩历三维幅涨)
                        Case Is >= 10
                            组历统码(位统码行涨正5, Y) = 组历统码(位统码行涨正5, Y) + 1
                        Case Is >= 6
                            组历统码(位统码行涨正4, Y) = 组历统码(位统码行涨正4, Y) + 1
                        Case Is >= 3
                            组历统码(位统码行涨正3, Y) = 组历统码(位统码行涨正3, Y) + 1
                        Case Is >= 1
                            组历统码(位统码行涨正2, Y) = 组历统码(位统码行涨正2, Y) + 1
                        Case Is >= 0
                            组历统码(位统码行涨正1, Y) = 组历统码(位统码行涨正1, Y) + 1
                        Case Is >= -1
                            组历统码(位统码行涨负1, Y) = 组历统码(位统码行涨负1, Y) + 1
                        Case Is >= -3
                            组历统码(位统码行涨负2, Y) = 组历统码(位统码行涨负2, Y) + 1
                        Case Is >= -6
                            组历统码(位统码行涨负3, Y) = 组历统码(位统码行涨负3, Y) + 1
                        Case Is >= -9
                            组历统码(位统码行涨负4, Y) = 组历统码(位统码行涨负4, Y) + 1
                        Case Else
                            组历统码(位统码行涨负5, Y) = 组历统码(位统码行涨负5, Y) + 1
                        End Select
                        '----------------------------------------------------------
                        Select Case 矩历码期值(X, Y, 位矩历三维幅高)
                        Case Is >= 10
                            组历统码(位统码行高正5, Y) = 组历统码(位统码行高正5, Y) + 1
                        Case Is >= 6
                            组历统码(位统码行高正4, Y) = 组历统码(位统码行高正4, Y) + 1
                        Case Is >= 3
                            组历统码(位统码行高正3, Y) = 组历统码(位统码行高正3, Y) + 1
                        Case Is >= 1
                            组历统码(位统码行高正2, Y) = 组历统码(位统码行高正2, Y) + 1
                        Case Is >= 0
                            组历统码(位统码行高正1, Y) = 组历统码(位统码行高正1, Y) + 1
                        Case Is >= -1
                            组历统码(位统码行高负1, Y) = 组历统码(位统码行高负1, Y) + 1
                        Case Is >= -3
                            组历统码(位统码行高负2, Y) = 组历统码(位统码行高负2, Y) + 1
                        Case Else
                            组历统码(位统码行高负3, Y) = 组历统码(位统码行高负3, Y) + 1
                        End Select
                        '----------------------------------------------------------
                End If
            Next X
            '----------------------------------------------------------------------------
            If 组历统码(位统码行数非停, Y) > 0 Then
                        总数非停 = 组历统码(位统码行数非停, Y)
                        '----------------------------------------------------------
                        '注20240301：幅高仅计算比例
                        组历统码(位统码行高正5, Y) = Round(100 * 组历统码(位统码行高正5, Y) / 总数非停, 1)
                        组历统码(位统码行高正4, Y) = Round(100 * 组历统码(位统码行高正4, Y) / 总数非停, 0)
                        组历统码(位统码行高正3, Y) = Round(100 * 组历统码(位统码行高正3, Y) / 总数非停, 0)
                        组历统码(位统码行高正2, Y) = Round(100 * 组历统码(位统码行高正2, Y) / 总数非停, 0)
                        组历统码(位统码行高正1, Y) = Round(100 * 组历统码(位统码行高正1, Y) / 总数非停, 0)
                        组历统码(位统码行高负1, Y) = Round(100 * 组历统码(位统码行高负1, Y) / 总数非停, 0)
                        组历统码(位统码行高负2, Y) = Round(100 * 组历统码(位统码行高负2, Y) / 总数非停, 0)
                        组历统码(位统码行高负3, Y) = Round(100 * 组历统码(位统码行高负3, Y) / 总数非停, 1)
                        '----------------------------------------------------------
                        组历统码(位统码行中幅正比, Y) = Round(组历统码(位统码行中幅正比, Y) / 总数非停, 1)
                        组历统码(位统码行涨幅均, Y) = Round(组历统码(位统码行涨幅均, Y) / 总数非停, 1)
                        组历统码(位统码行高幅均, Y) = Round(组历统码(位统码行高幅均, Y) / 总数非停, 1)
                        组历统码(位统码行低幅均, Y) = Round(组历统码(位统码行低幅均, Y) / 总数非停, 1)
                        组历统码(位统码行振幅均, Y) = Round(组历统码(位统码行高幅均, Y) - 组历统码(位统码行低幅均, Y), 1)
                        组历统码(位统码行中幅均, Y) = Round((组历统码(位统码行高幅均, Y) + 组历统码(位统码行低幅均, Y)) / 2, 1)
                        '----------------------------------------------------------
            End If
            If 组历统码(位统码行高幅均, Y) - 组历统码(位统码行低幅均, Y) > 0 Then
                组历统码(位统码行涨身比, Y) = Round((组历统码(位统码行涨幅均, Y) - 组历统码(位统码行低幅均, Y)) / (组历统码(位统码行高幅均, Y) - 组历统码(位统码行低幅均, Y)), 2)
            End If
    Next Y
    '====================================================================================
    '返回
    '====================================================================================
    Dim 码数 As Integer
    码数 = UBound(矩历码期值, 1)
    历研统码引擎3幅分布数程 = 码数
End Function


'========================================================================================
'功能：通用根据幅度赋色
'色范围：正（红橙黄）负（绿蓝灰）
'========================================================================================
Function UTL展示幅度(RNG展示 As Range, Optional 值展示 As Variant = "")
    If 值展示 = "" Then 值展示 = RNG展示.Value
    With RNG展示
            If VBA.IsNumeric(值展示) = False Then
                    .Interior.Color = 常色主黑
            Else
                    '----------------------------------------------------------------
                    If 值展示 >= 20 Then
                        '.Font.Color = 常色三红  '常色十紫
                        .Interior.Color = 常色三红  '常色十紫
                    ElseIf 值展示 >= 10 Then
                        .Interior.Color = 常色十红  '常色十紫
                        .Interior.TintAndShade = Round((10 - 值展示) / 20, 1)    '幅度[10,20]对应范围[0,-0.5]
                        '.Font.Color = 常色十红  '常色十紫
                    ElseIf 值展示 >= 5 Then
                        .Interior.Color = 常色十橙
                        .Interior.TintAndShade = Round((5 - 值展示) / 10, 1)      '幅度[5,10]对应范围[0,-0.5]
                        '.Font.Color = 常色十橙
                    ElseIf 值展示 >= 0 Then
                        .Interior.Color = 常色十黄
                        .Interior.TintAndShade = 0.8 - 1.6 * Round((值展示 - 0) / 10, 1)  '幅度[0,5]对应范围[0.8,0]。目的是淡化此范围的颜色显示。
                        '.Font.Color = 常色十黄
                        '.Font.TintAndShade = 0.1 + WorksheetFunction.Floor(.Interior.TintAndShade, 0.1)
                    '----------------------------------------------------------------
                    ElseIf 值展示 >= -5 Then
                        .Interior.Color = 常色三灰
                        .Interior.TintAndShade = 1.6 * Round((值展示 + 5) / 10, 1)  '幅度[-5,0]对应范围[0,0.8]。目的是淡化此范围的颜色显示。
                        '.Font.Color = 常色三灰
                        '.Font.TintAndShade = 0.1 + WorksheetFunction.Floor(.Interior.TintAndShade, 0.1)
                    ElseIf 值展示 >= -10 Then
                        .Interior.Color = 常色十蓝
                        .Interior.TintAndShade = Round((值展示 + 5) / 10, 1)      '幅度[-10,-5]对应范围[-0.5,0]
                        '.Font.Color = 常色十蓝
                    Else
                        '.Font.Color = 常色三灰
                        .Interior.Color = 常色三灰
                    End If
                    '----------------------------------------------------------------
            End If
    End With
End Function
