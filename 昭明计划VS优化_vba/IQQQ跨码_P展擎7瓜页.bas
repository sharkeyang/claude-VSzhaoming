'========================================================================================
'========================================================================================
'功能：加壳提高效率，外部调用基程
'========================================================================================
'========================================================================================
Function IQQQ展擎瓜页引擎正程( _
          Optional ByRef WSAS As Worksheet _
        , Optional ByVal 瓜分类型 As String = "更新" _
        , Optional ByVal 实结类型 As String = "cCCC" _
        , Optional ByVal 基色底 As Long = 常色指金 _
        , Optional ByVal 禁弹消息 As Boolean = False _
        ) As String
    '------------------------------------------------------------------------------------
    UTL宏工具_BEGIN
    MSG = IQQQ展擎瓜页引擎基程(WSAS, 瓜分类型, 实结类型, 基色底)
    UTL宏工具_END
    '------------------------------------------------------------------------------------
    If 禁弹消息 = False Then
        MsgBox MSG, vbOKOnly, IIf(InStr(瓜分类型, "更新") > 0, "更新本页", "瓜分本页")
    End If
End Function
Function IQQQ展擎瓜页引擎基程( _
          Optional ByRef WSAS As Worksheet _
        , Optional ByVal 瓜分类型 As String = "更新" _
        , Optional ByVal 实结类型 As String = "cCCC" _
        , Optional ByVal 基色底 As Long = 常色指金 _
        ) As String
    TTT = Timer
'========================================================================================
'验明正身
'========================================================================================
    If WSAS Is Nothing Then Exit Function
    '验明正身
    If PSOP格整理质程_是否适用首列(WSAS.Name) = False Then
        If WSAS.Name = "G" Then
            Call 现市单程_全局全球
            Exit Function
        End If
    End If
    '------------------------------------------------------------------------------------
    Dim wb As Workbook
    Set wb = WSAS.Parent
'========================================================================================
'输入
'要选取 【核心指数】以上部分
'========================================================================================
    Dim 当前表名  As String
    当前表名 = WSAS.Name
    '---------------------------------------------------------------------------------
    Dim 始行  As Integer
    始行 = 2
    Dim 末行 As Integer
    末行 = PBASE格程工具_表参定位特征行号(WSAS, 特征值:="核心指数")
    Dim 总行 As Integer
    总行 = 末行 - 始行 + 1
    If 总行 < 1 Then Exit Function
    '------------------------------------------------------------------------------------
    Dim 元组本页 As Variant
    元组本页 = WSAS.Cells(始行, 1).Resize(总行, 位谕列终全部)
'========================================================================================
'操作：设置工表
'========================================================================================
    Dim 指定表名 As String
    If 瓜分类型 = "更新排日" Or 瓜分类型 = "更新排周" Or 瓜分类型 = "更新排仓" Then
        指定表名 = 当前表名
        Call IQQQ展擎出程至页(wb, 指定表名, 是否建表:=True, 章色:=常色主碧, 章签:="")
    ElseIf 瓜分类型 = "更新排否" Then
        指定表名 = 当前表名
        'WSAS.Cells.ClearContents
        Call IQQQ展擎出程至页(wb, 指定表名, 是否建表:=True, 章色:=常色主碧, 章签:="")
    '------------------------------------------------------------------------------------
    ElseIf 瓜分类型 = "周局" Or 瓜分类型 = "池" Then
        指定表名 = 当前表名
        Call IQQQ展擎出程至页(wb, 指定表名, 是否建表:=True, 章色:=常色主碧, 章签:=指定表名)
    '------------------------------------------------------------------------------------
    Else
        指定表名 = 瓜分类型 & 当前表名
        Call IQQQ展擎出程至页(wb, 指定表名, 是否建表:=True, 章色:=常色主碧, 章签:="")
    End If
    '====================================================================================
    Dim MSG As String
    MSG = MSG & "【QQQ本页瓜分】" & 瓜分类型 & vbCrLf
    MSG = MSG & ">来表：" & 当前表名 & vbCrLf
    MSG = MSG & ">去表：" & 指定表名 & vbCrLf
'========================================================================================
'操作：瓜分
'========================================================================================
    '------------------------------------------------------------------------------------
    '按章按节
    '------------------------------------------------------------------------------------
    If 瓜分类型 = "周仓周护" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="周仓", 出节模式:="周护", 出全是否:=True)
    ElseIf 瓜分类型 = "周仓周地" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="周仓", 出节模式:="周地", 出全是否:=False)
    ElseIf 瓜分类型 = "周仓周层" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="周仓", 出节模式:="周层", 出全是否:=True)
    ElseIf 瓜分类型 = "周仓日综" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="周仓", 出节模式:="日综", 出全是否:=True)
    ElseIf 瓜分类型 = "周仓日综滤" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="周仓", 出节模式:="日综", 出全是否:=False)
    ElseIf 瓜分类型 = "周仓日层" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="周仓", 出节模式:="日层", 出全是否:=True)
    '------------------------------------------------------------------------------------
    ElseIf 瓜分类型 = "日仓日综" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="日仓", 出节模式:="日综", 出全是否:=True)
    ElseIf 瓜分类型 = "日仓日层" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="日仓", 出节模式:="日层", 出全是否:=True)
    ElseIf 瓜分类型 = "日仓日层滤" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="日仓", 出节模式:="日层", 出全是否:=False)
    ElseIf 瓜分类型 = "日仓日机" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="日仓", 出节模式:="日机", 出全是否:=False)
    '------------------------------------------------------------------------------------
    ElseIf 瓜分类型 = "活" Then
            MSG = MSG & IQQQ展擎筛程至C0章按通用(wb, 指定表名, 元组本页, 出章模式:="活", 出全是否:=True)
    '------------------------------------------------------------------------------------
    '混按节
    '------------------------------------------------------------------------------------
    ElseIf 瓜分类型 = "混日综" Then
            MSG = MSG & IQQQ展擎筛程至D0节按通用(wb, 指定表名, 元组本页, 出节模式:="日综", 出全是否:=True)
    ElseIf 瓜分类型 = "混周层" Then
            MSG = MSG & IQQQ展擎筛程至D0节按通用(wb, 指定表名, 元组本页, 出节模式:="周层", 出全是否:=True)
    ElseIf 瓜分类型 = "混周机" Then
            MSG = MSG & IQQQ展擎筛程至D0节按通用(wb, 指定表名, 元组本页, 出节模式:="周机", 出全是否:=False)
    ElseIf 瓜分类型 = "混日层" Then
            MSG = MSG & IQQQ展擎筛程至D0节按通用(wb, 指定表名, 元组本页, 出节模式:="日层", 出全是否:=True)
    ElseIf 瓜分类型 = "混日机" Then
            MSG = MSG & IQQQ展擎筛程至D0节按通用(wb, 指定表名, 元组本页, 出节模式:="日机", 出全是否:=True)
    '------------------------------------------------------------------------------------
    ElseIf 瓜分类型 = "池" Then
            MSG = MSG & IQQQ展擎筛程至B1书按池(wb, 指定表名, 元组本页)
    '------------------------------------------------------------------------------------
    ElseIf 瓜分类型 = "更新排否" Then
            MSG = MSG & IQQQ展擎筛程_出程更新通用(wb, 指定表名, 元组本页, 实结类型:=实结类型, 基色底:=基色底)
    ElseIf 瓜分类型 = "更新排周" Then
            MSG = MSG & IQQQ展擎筛程_出程更新通用(wb, 指定表名, 元组本页, 实结类型:=实结类型, 基色底:=基色底, 排序按周:=True, 仓日类型:=当前表名)
            If 当前表名 = 常仓名宝福 Or 当前表名 = 常仓名宝合 Then
                Dim 典核心指数 As New Dictionary
                Call 后台族非票精分调程_WA_设置典核心宽基(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心指数")
                Call 后台族非票精分调程_WA_设置典核心行业(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心行业指数")
                Call 后台族非票精分调程_WA_设置典核心大盘(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心大盘指数")
            End If
    ElseIf 瓜分类型 = "更新排日" Then
            MSG = MSG & IQQQ展擎筛程_出程更新通用(wb, 指定表名, 元组本页, 实结类型:=实结类型, 基色底:=基色底, 排序按日:=True, 仓日类型:=当前表名)
            If 当前表名 = 常仓名宝福 Or 当前表名 = 常仓名宝合 Then
                Call 后台族非票精分调程_WA_设置典核心宽基(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心指数")
                Call 后台族非票精分调程_WA_设置典核心行业(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心行业指数")
                Call 后台族非票精分调程_WA_设置典核心大盘(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心大盘指数")
            End If
    ElseIf 瓜分类型 = "更新排仓" Then
            MSG = MSG & IQQQ展擎筛程_出程更新通用(wb, 指定表名, 元组本页, 实结类型:=实结类型, 基色底:=基色底, 排序按仓:=True, 仓日类型:=当前表名)
            If 当前表名 = 常仓名宝福 Or 当前表名 = 常仓名宝合 Then
                Call 后台族非票精分调程_WA_设置典核心宽基(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心指数")
                Call 后台族非票精分调程_WA_设置典核心行业(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心行业指数")
                Call 后台族非票精分调程_WA_设置典核心大盘(典核心指数)
                Call IQQQ展擎筛程_出程更新通用(wb, 指定表名, 典码输出:=典核心指数, 实结类型:=实结类型, 基色底:=基色底, 区签:="核心大盘指数")
            End If
            If 当前表名 = 常仓名宝合 Or 当前表名 = 常仓名宝福 Or 当前表名 = 常仓名宝彦 Then
                wb.Sheets(指定表名).Columns(位qt仓主).Hidden = False
                wb.Sheets(指定表名).Columns(位qt仓周).Hidden = False
            End If
    End If
    '------------------------------------------------------------------------------------
    Erase 元组本页
'========================================================================================
'返回
'========================================================================================
    'MSG = MSG & vbCrLf & "QQQ筛选用时：" & CInt(Timer - TTT)
    Debug.Print MSG
    IQQQ展擎瓜页引擎基程 = MSG
End Function
