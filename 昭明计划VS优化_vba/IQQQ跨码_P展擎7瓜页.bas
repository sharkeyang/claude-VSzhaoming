Function IQQQ展擎筛程_出程更新通用( _
          ByRef wb As Workbook _
        , ByVal 指定表名 As String _
        , Optional ByRef 谕组 As Variant _
        , Optional ByRef 典码输出 As Dictionary _
        , Optional ByVal 实结类型 As String = "cCCC" _
        , Optional ByVal 基色底 As Long = 常色指金 _
        , Optional ByVal 区签 As String = "" _
        , Optional ByVal 排序按周 As Boolean = False _
        , Optional ByVal 排序按日 As Boolean = False _
        , Optional ByVal 排序按仓 As Boolean = False _
        , Optional ByVal 仓日类型 As String = 常仓名宝福 _
        ) As String
'========================================================================================
'验证
'========================================================================================
        If UTL判断工表存在(指定表名, wb) = False Then Exit Function
        '--------------------------------------------------------------------------------
        '如果【谕组】不空，用谕组；否则，用典码输出。
        '--------------------------------------------------------------------------------
        If VBA.IsMissing(谕组) = True Then
            If 典码输出 Is Nothing Then
                Exit Function
            Else
                Call UTL数据转换_集典码2组码(谕组, 典码输出)
            End If
        End If
        '--------------------------------------------------------------------------------
        Dim WS As Worksheet
        Set WS = wb.Sheets(指定表名)
        WS.Tab.Color = 基色底
'========================================================================================
'声明变量
'========================================================================================
        Dim MSG As String
        Dim 表名 As String
        Dim 始行  As Integer
        始行 = PBASE格程工具_表参末行指定(WS, 1) + 1
        Dim 末行 As Integer
        Dim 行号标签 As Integer
        Dim 行号数始 As Integer
        Dim i As Integer
'========================================================================================
'主程序：规制代码
'========================================================================================
        Dim CIDV As Variant
        Dim CIDL As String
        Dim 遍历序号 As Integer
        For 遍历序号 = LBound(谕组, 1) To UBound(谕组, 1)
            CIDV = 谕组(遍历序号, 位qt代码)
            CIDL = UBCID规制代码(CIDV)
            谕组(遍历序号, 位qt代码) = CIDL                    '替换为全码
        Next 遍历序号
'========================================================================================
'实结类型：只有行情
'========================================================================================
        If 实结类型 = "S___" Then
            If Not UBHTTP腾实_查是否断网 Then
                Call IQQQ跨码据擎_数程查询行情(谕组)
            End If
            Call UTL数据转换_集ARR2WS(谕组, WS, 始行:=2)
            Erase 谕组
            Exit Function
        End If
'========================================================================================
'实结类型：行情&系统
'========================================================================================
        '================================================================================
        '更新数据
        '================================================================================
        Call IQQQ跨码据擎_数程生成全息(谕组, 常花中股, 实结类型:=实结类型, 仓日类型:=仓日类型)
        '================================================================================
        '输出类型一：没有区标签，原样输出不改变格式
        '================================================================================
        If Len(区签) = 0 And 排序按周 = False And 排序按日 = False And 排序按仓 = False Then
                '------------------------------------------------------------------------
                '定位
                '------------------------------------------------------------------------
                末行 = PBASE格程工具_表参末行指定(WS, 1)
                行号数始 = 末行 + 1
                '------------------------------------------------------------------------
                '输出数据
                '------------------------------------------------------------------------
                Call UTL数据转换_集ARR2WS(谕组, WS, 始行:=行号数始)
                Erase 谕组
                '------------------------------------------------------------------------
                '格式化：数据
                '------------------------------------------------------------------------
                For i = PBASE格程工具_表参末行全页(WS) To 行号数始 Step -1
                    Debug.Print "更新", i
                    If UBCID是代码(WS.Cells(i, 1).Value) = False Then
                            With WS.Cells(i, 1).Resize(1, 位谕列终全部)
                                .Interior.Color = 基色底
                                .Interior.TintAndShade = -0.8
                                .Font.Color = 常色主白
                                .Font.Bold = True
                                .Font.Size = 12
                                .RowHeight = 20
                                .Borders(xlInsideVertical).LineStyle = xlNone
                                .HorizontalAlignment = xlLeft
                            End With
                            WS.Rows(i).ClearComments
                    Else
                            With WS.Cells(i, 1).Resize(1, 位qt主宽)
                                .Interior.Color = 基色底
                                .Interior.TintAndShade = 0.8
                            End With
                            WS.Cells(i, 位qt代称).Interior.TintAndShade = 0.5
                    End If
                Next
        '================================================================================
        '输出类型一：有区标签，重新输出
        '================================================================================
        Else
                '------------------------------------------------------------------------
                '定位
                '------------------------------------------------------------------------
                末行 = PBASE格程工具_表参末行指定(WS, 1)
                行号标签 = 末行 + 1
                行号数始 = 末行 + 2
                计数输出 = UBound(谕组, 1) - LBound(谕组, 1) + 1
                '------------------------------------------------------------------------
                '输出数据
                '------------------------------------------------------------------------
                Call UTL数据转换_集ARR2WS(谕组, WS, 始行:=行号数始)
                Erase 谕组
                '------------------------------------------------------------------------
                '删除非数据行
                '------------------------------------------------------------------------
                末行 = PBASE格程工具_表参末行指定(WS, 1)
                For i = 末行 To 行号数始 Step -1
                    If UBCID是代码(WS.Cells(i, 1).Value) = False Then
                        WS.Rows(i).Delete
                    End If
                Next
                '------------------------------------------------------------------------
                '格式化
                '------------------------------------------------------------------------
                末行 = PBASE格程工具_表参末行指定(WS, 1)
                计数输出 = 末行 - 行号数始 + 1
                If 计数输出 > 0 Then
                    '--------------------------------------------------------------------
                    '格式化：数据
                    '--------------------------------------------------------------------
                    With WS.Cells(行号数始, 1)
                        With .Resize(计数输出, 位qt主宽)
                            .Interior.Color = 基色底
                            .Interior.TintAndShade = 0.8
                        End With
                        .Cells(1, 位qt代称).Resize(计数输出, 1).Interior.TintAndShade = 0.5
                    End With
                    '--------------------------------------------------------------------
                    '排序
                    '--------------------------------------------------------------------
                    Dim 区域排序 As Range
                    Set 区域排序 = WS.Cells(行号数始, 1).Resize(计数输出, 1).EntireRow
                    '排序：周类排序
                    If 排序按周 = True Then
                            With 区域排序
                                .Sort _
                                    key1:=.Cells(1, 位谕of周层三鳄), order1:=xlDescending, _
                                    key2:=.Cells(1, 位qt行业), order2:=xlDescending, _
                                    Header:=xlNo
                                .Sort _
                                    key1:=.Cells(1, 位谕of周层大局), order1:=xlAscending, _
                                    key2:=.Cells(1, 位谕of周层护型), order2:=xlAscending, _
                                    key3:=.Cells(1, 位谕of周层柱型), order3:=xlDescending, _
                                    Header:=xlNo
                            End With
                            WS.Columns(位qt盯盘类别).Hidden = False
                    '排序：按照日类进行排序
                    ElseIf 排序按日 = True Then
                            With 区域排序
                                .Sort _
                                    key1:=.Cells(1, 位谕of周层大局), order1:=xlAscending, _
                                    key2:=.Cells(1, 位谕of周层护型), order2:=xlDescending, _
                                    Header:=xlNo
                                .Sort _
                                    key1:=.Cells(1, 位qt行业), order1:=xlDescending, _
                                    key2:=.Cells(1, 位qt代码), order2:=xlAscending, _
                                    Header:=xlNo
                            End With
                            WS.Columns(位qt盯盘类别).Hidden = False
                    '排序：按照仓位进行排序
                    ElseIf 排序按仓 = True Then
                            With 区域排序
                                .Sort _
                                    key1:=.Cells(1, 位谕of周层大局), order1:=xlAscending, _
                                    key2:=.Cells(1, 位谕of周层护型), order2:=xlAscending, _
                                    key3:=.Cells(1, 位谕of周层柱型), order3:=xlDescending, _
                                    Header:=xlNo
                                .Sort _
                                    key1:=.Cells(1, 位qt盯盘类别), order1:=xlDescending, _
                                    key2:=.Cells(1, 位qt行业), order2:=xlAscending, _
                                    key3:=.Cells(1, 位qt代码), order3:=xlAscending, _
                                    Header:=xlNo
                                .Sort _
                                    key1:=.Cells(1, 位qt仓主), order1:=xlDescending, _
                                    Header:=xlNo
                            End With
                            WS.Columns(位qt盯盘类别).Hidden = False
                    End If
                    Set 区域排序 = Nothing
                    '--------------------------------------------------------------------
                    '格式化：标签
                    '--------------------------------------------------------------------
                    With WS.Rows(行号标签)
                        With .Cells(1, 1)
                            .Value = IIf(Len(区签) > 0, 区签, 实结类型)
                            .Cells(1, 常列标签计数) = 计数输出 & "只"
                            With .Resize(1, 位谕列终全部)
                                .Interior.Color = 基色底
                                .Interior.TintAndShade = -0.8
                                .Font.Color = 常色主白
                                .Font.Bold = True
                                .Font.Size = 12
                                .RowHeight = 20
                                .Borders(xlInsideVertical).LineStyle = xlNone
                                .HorizontalAlignment = xlLeft
                            End With
                        End With
                    End With
                    '--------------------------------------------------------------------
                End If
                '------------------------------------------------------------------------
        End If
        '================================================================================
        '特殊处理
        '检视持仓区域   (仅应用于持仓工表)
        '================================================================================
        If WS.Name = 常仓名宝福 Or WS.Name = 常仓名宝彦 Then
                WS.Tab.Color = 常色主黑
                MSG = IQQQ跨码展擎_校验持仓区域(WS)
        End If
        Call IQQQ跨码展擎_按行汇总(WS, 基行:=始行, 是否跨码:=True)
'========================================================================================
'返回
'========================================================================================
        IQQQ展擎筛程_出程更新通用 = MSG
'========================================================================================
End Function
