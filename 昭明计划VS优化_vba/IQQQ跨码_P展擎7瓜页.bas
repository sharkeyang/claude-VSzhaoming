Attribute VB_Name = "IQQQ跨码_P展擎7瓜页"

'########################################################################################
'##################################    定时运行引擎    ##################################
'########################################################################################
Public RunWhen As Double
Public Const cRunWhat = "UGSOP定时引擎刷新持页"

Sub UGSOP定时引擎开始()
    RunWhen = Now + TimeSerial(0, 0, 5)
    Application.OnTime EarliestTime:=RunWhen, procedure:=cRunWhat, schedule:=True
End Sub

Sub UGSOP定时引擎停止()
    On Error Resume Next
    Application.OnTime EarliestTime:=RunWhen, procedure:=cRunWhat, schedule:=False
End Sub

Sub UGSOP定时引擎刷新持页()
    Dim Sheet1 As Worksheet
    Set Sheet1 = ThisWorkbook.Sheets(常仓名宝合)
    Call IQQQ展擎瓜页引擎正程(Sheet1, "更新排日", "sSSC", 基色底:=常色指金, 禁弹消息:=True)
    Call UGSOP定时引擎开始
End Sub
