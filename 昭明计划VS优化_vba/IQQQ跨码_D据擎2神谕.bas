                    '        '注20241119：一般情况，WJC为生死线，WJB为病危线。在下破WJB后可以清仓；在日线级别，处于DJE与DJC之下，但在WJB之上，给与底仓。
                    'End If
                    '====================================================================
                    '====================================================================
                    '位谕of仓限倍：以周为准
                    '====================================================================
                    '====================================================================
                    谕组(X, 位谕of仓限倍) = 0
                    If InStr(谕组(X, 位谕of周层三鳄), "金") > 0 Then
                            谕组(X, 位谕of仓限倍) = 5
                    ElseIf InStr(谕组(X, 位谕of周层三鳄), "银") > 0 Then
                            谕组(X, 位谕of仓限倍) = 2
                    ElseIf InStr(谕组(X, 位谕of周层三鳄), "唏") > 0 Or InStr(谕组(X, 位谕of周层三鳄), "嘘") > 0 Then
                            谕组(X, 位谕of仓限倍) = 1
                    End If
            '============================================================================
'########################################################################################
            
            
            
            
            
            
'########################################################################################
'########################################################################################
'日周联动
'########################################################################################
'########################################################################################

            '============================================================================
            '============================================================================
            '周联动
            '变量元素包括：
            '注20240911：周日联动的纽带是WJA，根据【周层阶段】【WJA柱排列】【DJCBA】设置。
            '注20250409：只按照属于周类范围时，按WJA进行分类，并仅按照【WJA→DJC】作为周日联合的纽带。具体信息改为：是否符合周类范围？周类上个柱是否在WJA之上（ABCD）？本周是否在DJC之上？本周临涨幅？
            '注20250409：【不要轻易更改】核心思想就是行动要慢，不要以日线为准冲动押注，要以周线为基准，在周线允许的情况下，再按日线进行操作。
            '注20260425：'限制范围：①WXCD＞0（一定要舍弃WXCD＜0）；②WJC之上；③WXAB＞0；④WXZB＞0；
            '============================================================================
            '============================================================================
            谕组(X, 位谕of日层联动) = ""
            '----------------------------------------------------------------------------
                    '====================================================================
                    '位1：获取周类仓位性质。金银铜，都可取。
                    '====================================================================
                    谕组(X, 位谕of日层联动) = Mid$(谕组(X, 位谕of周层三鳄), 2, 1)
                    '====================================================================
                    '位2：获取 DJE走势等级（V0~V9 / E0~E9），可排序+直观展示所处阶段
                    ' DJE之下=V系列(止跌修复)  DJE之上=E系列(瓦解衰退)
                    ' VBA变量→文档条件对照:
                    '   BTCD→CD(护级)  BTZC→ZC(站上C)  BTBC→BC(护段)
                    '   BTAB→AB(护段)  BTZA→ZA(站上A)  BTZB→ZB(站上B)
                    '   BTZD→ZD(站上D)  BTZE→ZE(站上E)
                    '====================================================================
                    If 日类BTZE > 0 Then        'DJE之上 → E系列（从最强→最弱）
                        'E0上：5项全正（最强）
                        If 日类BTCD > 0 And 日类BTZC > 0 And 日类BTBC > 0 _
                            And 日类BTAB > 0 And 日类BTZA > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "E0上"
                        'E1上：失去ZA+ZB（站上A+B均转负）
                        ElseIf 日类BTCD > 0 And 日类BTZC > 0 And 日类BTBC > 0 _
                            And 日类BTAB > 0 And 日类BTZA <= 0 And 日类BTZB <= 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "E1上"
                        'E2上：失去ZA但ZB仍在（站上A失守，站上B未破）
                        ElseIf 日类BTCD > 0 And 日类BTZC > 0 And 日类BTBC > 0 _
                            And 日类BTAB > 0 And 日类BTZB > 0 And 日类BTZA <= 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "E2上"
                        'E3上：AB转负（护段AB转负）
                        ElseIf 日类BTCD > 0 And 日类BTZC > 0 _
                            And 日类BTBC > 0 And 日类BTAB <= 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "E3上"
                        'E4上：BC跌破（护段BC转负）
                        ElseIf 日类BTCD > 0 And 日类BTZC > 0 And 日类BTBC <= 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "E4上"
                        'E5中：失去ZC（站上C转负，但ZD仍正）
                        ElseIf 日类BTCD > 0 And 日类BTZD > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "e5中"
                        'E6下：失去ZD（站上D转负，亦失去ZC）
                        ElseIf 日类BTCD > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "e6下"
                        'E7忑：CD转负（护级CD转负，ZC亦负）
                        ElseIf 日类BTCD <= 0 And 日类BTZC <= 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "e7忑"
                        'E8忠：ZC回弹但ZD仍负
                        ElseIf 日类BTCD <= 0 And 日类BTZC > 0 And 日类BTZD <= 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "e8忠"
                        'E9忐：ZD回弹但CD仍负
                        ElseIf 日类BTCD <= 0 And 日类BTZD > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "E9忐"
                        '→转空：跌破DJE（E系列末级退路）
                        Else
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & ">转空"
                        End If
                    Else                            'DJE之下 → V系列（从最差→最好）
                        'V7上：CD转正且站上C（CD正交恢复）
                        '注：检查顺序从最好→最差，先命中高的等级
                        If 日类BTCD > 0 Then
                            If 日类BTZC > 0 Then
                                谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "V7上"
                            ElseIf 日类BTZD > 0 Then
                                谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "V8中"
                            Else
                                谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "v9下"
                            End If
                        'V6忐：ZD修复但CD未转正
                        ElseIf 日类BTZD > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "V6忐"
                        'V5忠：站上C
                        ElseIf 日类BTZC > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "V5忠"
                        'V4忑：BC修复（护段BC转正）
                        ElseIf 日类BTBC > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "v4忑"
                        'V3忑：AB正交（护段AB转正）
                        ElseIf 日类BTAB > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "v3忑"
                        'V2忑：站上B
                        ElseIf 日类BTZB > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "v2忑"
                        'V1忑：站上A（初现修复信号）
                        ElseIf 日类BTZA > 0 Then
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "v1忑"
                        'V0忑：全部负（最深空头）
                        Else
                            谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & "v0忑"
                        End If
                    End If
                    '====================================================================
                    '位3：获取DXAB关系。
                    '注20260529：DXAB与WXAB大部分时间同向，可以利用DXAB判断进入时机，但不要利用DXAB进行止损。
                    '====================================================================
                    If InStr(谕组(X, 位谕of日层护型), "甲") > 0 _
                    Or InStr(谕组(X, 位谕of日层护型), "乙") > 0 _
                    Or InStr(谕组(X, 位谕of日层护型), "己") > 0 Then
                        '应持有
                    ElseIf InStr(谕组(X, 位谕of日层护型), "丙") > 0 Then
                        谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & ".被"
                    Else
                        谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & ".警"
                    End If
                    '====================================================================
                    '风控指标
                    '注20241011：触顶属于非正常形态，【偏离大】【连阳】都可能出现，不要受止盈指标束缚。
                    '====================================================================
                    If 谕组(X, 位谕of日层盈提示) <> "" Then
                        谕组(X, 位谕of日层联动) = 谕组(X, 位谕of日层联动) & ".盈"
                    End If
                    '====================================================================
                    '====================================================================
                    '====================================================================
                    '====================================================================
                    '四区划 + 周层猪操作（2026-06-30重写）
                    '大前提：WXZC>0且DXZE>0 = 可参与的基本门槛
                    '  长多 = 金/银 + 甲/乙/己（可参与）
                    '   _可被仓 = 其他满足大前提的
                    '不满足大前提：
                    '  _勿长空 = 屎/尿 + 丙/丁/戊
                    '  _勿可看 = 剩余
                    '猪操作格式：大区域 + 仓位 + ":" + 等级串
                    '仅长多区有下周冲高、下日冲高策略
                    '====================================================================
                    谕组(X, 位谕of周层猪操作) = ""

                    '--- 从日层联动解析等级串 ---
                    Dim 联动值 As String
                    联动值 = 谕组(X, 位谕of日层联动)
                    If Len(联动值) >= 2 Then
                        Dim 点位置 As Integer
                        Dim 等级串 As String
                        点位置 = InStr(联动值, ".")
                        If 点位置 > 0 Then
                            等级串 = Mid$(联动值, 2, 点位置 - 2)
                        Else
                            等级串 = Mid$(联动值, 2)
                        End If
                    End If

                    '--- 提取区划要素 ---
                    Dim 联动首字 As String
                    联动首字 = Left$(联动值, 1)
                    Dim 护型首字 As String
                    护型首字 = Left$(谕组(X, 位谕of日层护型), 1)

                    '--- 四区划判定 ---
                    Dim 区划 As String
                    If 周类BTZC > 0 And 日类BTZE > 0 Then    'WXZC>0且DXZE>0 = 可参与门槛
                        If (联动首字 = "金" Or 联动首字 = "银") _
                            And (护型首字 = "甲" Or 护型首字 = "乙" Or 护型首字 = "己") Then
                            区划 = "长多"
                        Else
                            区划 = "_可被仓"
                        End If
                    Else                                        '不满足参与门槛
                        If (联动首字 = "屎" Or 联动首字 = "尿") _
                            And (护型首字 = "丙" Or 护型首字 = "丁" Or 护型首字 = "戊") Then
                            区划 = "_勿长空"          '最差情况：屎尿+丙丁戊
                        Else
                            区划 = "_勿可看"
                        End If
                    End If

                    '--- 猪操作：仅长多区有仓位细分 ---
                    If 区划 = "长多" Then
                        If 日类BTZE > 0 Then
                            If 日类BTZC > 0 Then
                                If 日类BTZA > 0 Then
                                    谕组(X, 位谕of周层猪操作) = "长多基仓:" & 等级串
                                Else
                                    谕组(X, 位谕of周层猪操作) = "长多浮仓:" & 等级串
                                End If
                            Else
                                谕组(X, 位谕of周层猪操作) = "长多减仓:" & 等级串
                            End If
                        Else
                            谕组(X, 位谕of周层猪操作) = "长多清仓:" & 等级串
                        End If

                        '--- 止盈（仅长多区）---
                        If 谕组(X, 位谕of日层盈提示) <> "" And 等级串 <> "" Then
                            Dim 基础策略 As String
                            基础策略 = 谕组(X, 位谕of周层猪操作)
                            If InStr(基础策略, ":") > 0 Then
                                基础策略 = Left$(基础策略, InStr(基础策略, ":") - 1)
                            End If
                            谕组(X, 位谕of周层猪操作) = 基础策略 & "/止盈:" & 等级串
                        End If
                    ElseIf 区划 = "_可被仓" Then
                        谕组(X, 位谕of周层猪操作) = "_可被仓:" & 等级串
                    ElseIf 区划 = "_勿长空" Then
                        谕组(X, 位谕of周层猪操作) = "_勿长空:" & 等级串
                    Else
                        谕组(X, 位谕of周层猪操作) = "可看:" & 等级串
                    End If
                    '====================================================================

                    '--- 下周冲高信号（仅在长多区有效）---
                    谕组(X, 位谕of策周浮仓) = ""
                    If 区划 = "长多" Then
                        If 日类BTZE > 0 And InStr(谕组(X, 位谕of周层下柱冲高提示), "冲") > 0 Then
                            谕组(X, 位谕of策周浮仓) = "下周可冲"
                        Else
                            谕组(X, 位谕of策周浮仓) = "禁入"
                        End If
                    Else
                        谕组(X, 位谕of策周浮仓) = "禁入"
                    End If

                    '--- 下日冲高信号（仅在长多区+日机+防日诱）---
                    谕组(X, 位谕of策日浮仓) = ""
                    If 区划 = "长多" And 日类BTZE > 0 Then
                        Dim 日机符合 As Boolean
                        日机符合 = (Left$(谕组(X, 位谕of日层柱排), 1) = "升") _
                               And (日类BTZA >= 0) _
                               And (InStr(谕组(X, 位谕of周层下柱冲高提示), "冲") > 0)
                        Dim 防日诱 As Boolean
                        If InStr(谕组(X, 位谕of日层护型), "甲") > 0 _
                            Or InStr(谕组(X, 位谕of日层护型), "乙") > 0 _
                            Or InStr(谕组(X, 位谕of日层护型), "己") > 0 Then
                            防日诱 = True
                        Else
                            防日诱 = False
                        End If

                        If 日机符合 And 防日诱 Then
                            谕组(X, 位谕of策日浮仓) = "下日可冲"
                        Else
                            谕组(X, 位谕of策日浮仓) = "禁入"
                        End If
                    Else
                        谕组(X, 位谕of策日浮仓) = "禁入"
                    End If
                    '====================================================================
            '============================================================================
'########################################################################################
'########################################################################################
'宏观衍生：冲机系统
'功能20240915：保持单一功能，实现下周冲高，达到设定涨幅就止盈。不要进行扩充，仅仅需要维持此单一目标。
'########################################################################################
'########################################################################################
            '============================================================================
            '设置：位谕of日层漏提示
            '核心原则：只买阴柱
            '时间：L（上周已经出现的信号：本周123可买）__（本周期望出现的信号：本周345可买）
            '类型：阴（单柱下跌）低（负向偏离较大）连（连续下跌）
            '注20250810：触顶应保持底仓，不应重仓。
            '注20250810：初：DJCBA为放射状，最有大升潜力；再：很可能震荡；主：可能为震荡；破：下破DJB务必谨慎。但在实际中，不要限制日层。
            '过滤流程的子集包含关系是：周范围》周操作区域》日范围（DJE&DJC）》日DJB之上》日DJB之上且合顶。
            '注20260602：核心原则（勿删），针对WXAB与DXAB的共振，在相同方向上，WXAB的变化速度要慢于DXAB的变化速度，这时要先让WXAB变到正向，再参考DXAB，不要本末倒置。
            '============================================================================
            谕组(X, 位谕of日层漏提示) = ""
            值日层漏提示 = ""
            是否提供日漏信息 = False
            '步骤1：确定周类为主升。
            If InStr(谕组(X, 位谕of周层三鳄), "屎") > 0 _
            Or InStr(谕组(X, 位谕of周层三鳄), "尿") > 0 _
            Or InStr(谕组(X, 位谕of周层三鳄), "唏") > 0 _
            Or InStr(谕组(X, 位谕of周层三鳄), "嘘") > 0 Then
                    '只针对（金）：WXCD＞0且WXZC＞0
            '----------------------------------------------------------------------------
            ElseIf InStr(谕组(X, 位谕of周层三鳄), "银") > 0 Then
                    '因为下破WJB，仍属于周级别持有条件，但不要放入日级别捡漏机会。
            ElseIf InStr(谕组(X, 位谕of周层护型), "己") > 0 Then
                    '因WXAB＜0，属于周级别介入机会，但不要放入日漏机会。
            '----------------------------------------------------------------------------
            '主战场：①金②层段=甲乙（对于日级别，只针对WXAB＞0）
            '是否要求WXAB＞0：要求，只要“甲乙”就可以；“已”存续时间太短，且存在不确定性；“丙”属于已下破WJB，可能有机会，但更多机会存在于“甲乙”。
            '----------------------------------------------------------------------------
            ElseIf InStr(谕组(X, 位谕of周层护型), "甲") > 0 _
                Or InStr(谕组(X, 位谕of周层护型), "乙") > 0 Then
                    '====================================================================
                    '限制WXCD
                    '====================================================================
                    '值日层漏提示 = 值日层漏提示 &  "金"
                    '====================================================================
                    '注20251220：新逻辑不再按照【周中符】进行分类，而要按照【周√口】进一步区分潜在的【主升/震荡】进行筛选。
                    '====================================================================
                    If InStr(谕组(X, 位谕of周层大局), "龙猪") Then
                        值日层漏提示 = 值日层漏提示 & "猪"
                    ElseIf InStr(谕组(X, 位谕of周层大局), "龙管") Then
                        值日层漏提示 = 值日层漏提示 & "管"
                    ElseIf InStr(谕组(X, 位谕of周层大局), "震正〇") Then
                        值日层漏提示 = 值日层漏提示 & "〇"    '震正〇
                    ElseIf InStr(谕组(X, 位谕of周层大局), "头") Then
                        值日层漏提示 = 值日层漏提示 & "头"
                    Else
                        值日层漏提示 = 值日层漏提示 & "震"
                    End If
                    '====================================================================
                    '按WTZA分类：按WXZA分类：WTZA≥2（甲）WTZA=1（丙）WTZA=-1（乙）。要求前柱在WJA之上，若前柱在WJA之下，不认为存在日类机会。所有这些是基于理念，在JA之上就会有下注冲高。
                    '====================================================================
                    值日层漏提示 = 值日层漏提示 & Mid$(谕组(X, 位谕of周层护型), 2, 1)
                    If 周类BTZA >= 2 Then
                        值日层漏提示 = 值日层漏提示 & "②"
                        是否提供日漏信息 = True
                    ElseIf 周类BTZA = 1 Then
                        值日层漏提示 = 值日层漏提示 & "①"
                        是否提供日漏信息 = True
                    Else
                        是否提供日漏信息 = False
                    End If
                    '====================================================================
            End If
            '----------------------------------------------------------------------------
            '漏斗：过滤特定周柱排。
            '----------------------------------------------------------------------------
            If 是否提供日漏信息 = True Then
                    '====================================================================
                    '特殊周柱型1：连阳
                    '====================================================================
                    If Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符升连 Then
                        值日层漏提示 = 值日层漏提示 & "升连"
                    '====================================================================
                    '特殊柱型2：继鼎
                    '====================================================================
                    ElseIf InStr(组结算(X, 基位周类 + 位os基竖态), "鼎继") > 0 Then
                        值日层漏提示 = 值日层漏提示 & "鼎继"
                    '====================================================================
                    '特殊柱型2：首鼎
                    '====================================================================
                    ElseIf InStr(组结算(X, 基位周类 + 位os基竖态), "鼎首") > 0 Then
                        值日层漏提示 = 值日层漏提示 & "鼎首"
                    '====================================================================
                    Else
                        是否提供日漏信息 = False
                    End If
                    '====================================================================
            End If
            '----------------------------------------------------------------------------
            '漏斗：过滤日类信息。
            '----------------------------------------------------------------------------
            If 是否提供日漏信息 = True Then
                    谕组(X, 位谕of日层漏提示) = 值日层漏提示
                    谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & "."
                    '====================================================================
                    '按日层类分类：（甲乙己）存在机会；（丙）被动持有；（丁戊）警告且被动持有，不算做捡漏。
                    '然后再根据日类柱型进行分类。
            '针对“甲乙己”，若为阴柱后阳柱，则为机。增加“鼎”参考价值。
                    '====================================================================
                    '--------------------------------------------------------------------
                    '理论上当前周WTZA≥1，本周只要DTZA＜0就应考虑是否属于漏。
                    '情况1：但是，若日为“丁戊”，则不要认为是日漏，需要报警。
                    '--------------------------------------------------------------------
                    If InStr(谕组(X, 位谕of日层护型), "丁") > 0 _
                    Or InStr(谕组(X, 位谕of日层护型), "戊") > 0 Then
                        谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & Mid$(谕组(X, 位谕of日层护型), 2, 1) & "被"
                        '当满足（DXZC＞0且DXAB＞0）但（护型为丁戊）：只被动持有，勿主动介入。未下破WJC或DJD，不要止损。
                    '--------------------------------------------------------------------
                    '情况2：丙。
                    '--------------------------------------------------------------------
                    ElseIf InStr(谕组(X, 位谕of日层护型), "丙") > 0 Then
                        谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & "丙漏"
                    '--------------------------------------------------------------------
                    '情况3：针对日层段（甲乙己）
                    '--------------------------------------------------------------------
                    Else
                        If 日类BTZA < 0 Then
                                '针对DJA之下：应出现a-b-c反弹，才认为是日漏
                                谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & "乙e漏"
                                '如果在DJA之下出现阳柱，要提示
                        ElseIf 日类BTZA <= 1 Then
                                '当DTZA=1，要看是否为诱多
                                谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & Mid$(谕组(X, 位谕of日层护型), 2, 1) & "首防诱"
                        Else
                            If 日类今涨 <= 0 Then
                                谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & Mid$(谕组(X, 位谕of日层护型), 2, 1) & "上漏" & Right(组结算(X, 基位日类 + 位os具并符串), 1)
                                '典型漏：当属于龙b，且本阴柱为跌孕时，可以捡漏。
                                '当在DJA之上，出现回调，且出现阳柱时，才是进入之时。
                                '对于阴柱后阳柱，也提示为漏
                                '对与鼎（特别是继鼎），也提示为漏。
                            Else
                                谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & Mid$(谕组(X, 位谕of日层护型), 2, 1) & "上持"
                                
                            End If
                        End If
                        '================================================================
                        '添加鼎
                        '================================================================
                        If 谕组(X, 位谕of日层BT鼎) = 1 Then
                            谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & "鼎"
                        End If
                        '================================================================
                        '添加柱型
                        '================================================================
                        If InStr(谕组(X, 位谕of日层柱型), "梯") > 0 _
                        Or InStr(谕组(X, 位谕of日层柱型), "栏") > 0 _
                        Or InStr(谕组(X, 位谕of日层柱型), "栅") > 0 _
                        Or InStr(谕组(X, 位谕of日层柱型), "枝") > 0 Then
                            谕组(X, 位谕of日层漏提示) = 谕组(X, 位谕of日层漏提示) & Left$(谕组(X, 位谕of日层柱型), 4)
                        End If
                        '================================================================
                    End If
                    '====================================================================
            End If
            '============================================================================
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'策分: 周浮仓评分 (0~100), 基于真高幅回测数据
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'策分: 周浮仓评分 (0~100), 基于真高幅回测数据
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
    Dim 策分 As Integer: 策分 = 0
    Dim 周局 As String: 周局 = 谕组(X, 位谕of周层大局)
    Dim 周护 As String: 周护 = 谕组(X, 位谕of周层护型)
    Dim 周ZA As Double: 周ZA = 谕组(X, 位谕of周类BTZA)
    Dim 周柱排 As String: 周柱排 = 谕组(X, 位谕of周层柱排)
    Dim 周盈提 As String: 周盈提 = 谕组(X, 位谕of周层盈提示)
    Dim 周波型 As String: 周波型 = 谕组(X, 位谕of周层波型)
    '----------------------------------------------------------------------------------------
    '① 四域 (20分)
    If InStr(周局, "金") > 0 And InStr(周护, "甲") + InStr(周护, "乙") + InStr(周护, "己") > 0 Then
        策分 = 策分 + 20
    ElseIf InStr(周局, "银") > 0 And InStr(周护, "甲") + InStr(周护, "乙") + InStr(周护, "己") > 0 Then
        策分 = 策分 + 15
    ElseIf InStr(周局, "金") > 0 Then
        策分 = 策分 + 5
    End If
    '----------------------------------------------------------------------------------------
    '② ZA区间 (30分)
    If 周ZA > 5 And 周ZA <= 10 Then
        策分 = 策分 + 30
    ElseIf (周ZA >= 3 And 周ZA <= 5) Or 周ZA > 10 Then
        策分 = 策分 + 20
    ElseIf 周ZA >= 1 And 周ZA < 3 Then
        策分 = 策分 + 10
    End If
    '----------------------------------------------------------------------------------------
    '③ 柱排+盈提示 (25分)
    If InStr(周柱排, "尾反孕") = 0 And InStr(周盈提, "高") > 0 And Left$(周柱排, 1) = "升" Then
        策分 = 策分 + 25
    ElseIf Left$(周柱排, 1) = "升" Then
        策分 = 策分 + 15
    ElseIf InStr(周柱排, "人") > 0 Then
        策分 = 策分 + 8
    ElseIf Left$(周柱排, 1) = "跌" Then
        策分 = 策分 + 5
    End If
    '----------------------------------------------------------------------------------------
    '④ 波型 (25分)
    If InStr(周波型, "龙猪") > 0 Or InStr(周波型, "龙管") > 0 Then
        策分 = 策分 + 25
    ElseIf InStr(周波型, "头正") > 0 Then
        策分 = 策分 + 15
    ElseIf InStr(周波型, "头负") > 0 Or InStr(周波型, "震负") > 0 Then
        策分 = 策分 + 10
    ElseIf InStr(周波型, "震正") > 0 Then
        策分 = 策分 + 5
    End If
    '----------------------------------------------------------------------------------------
    谕组(X, 位谕of策分周浮仓) = 策分

    '@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
    '策分: 概率即分数 — 匹配策略 + 查概率表
    '@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
    Dim 周策略 As String: 周策略 = ""
    Dim 周市板 As String: 周市板 = 谕组(X, 位qt市板)
    ' 市板为空时，从花册单行查询
    If 周市板 = "" Then 周市板 = 获取单码市板(CIDL)

    '按条件严格度降序匹配（最严格优先）
    If InStr(周局, "金") > 0 And InStr(周护, "甲") + InStr(周护, "乙") + InStr(周护, "己") > 0 Then
        If Left$(周柱排, 1) = "升" And InStr(周柱排, "尾反孕") = 0 Then
            If InStr(周盈提, "高") > 0 Then
                If InStr(周波型, "龙猪") > 0 Or InStr(周波型, "龙管") > 0 Then
                    周策略 = "金最优(全部)"
                Else
                    周策略 = "金+多长+升排+非孕+盈高"
                End If
            Else
                周策略 = "金+多长+升排+非孕"
            End If
        ElseIf Left$(周柱排, 1) = "升" Then
            周策略 = "金+多长+升排"
        Else
            周策略 = "金+多长"
        End If
    ElseIf InStr(周局, "银") > 0 Then
        If InStr(周盈提, "高") > 0 Or InStr(周盈提, "宽") > 0 Then
            周策略 = "银+盈提示有"
        ElseIf Left$(周柱排, 1) = "升" Then
            周策略 = "银+柱排=升"
        ElseIf InStr(周波型, "龙猪") > 0 Then
            周策略 = "银+龙猪"
        ElseIf 周ZA > 5 And 周ZA <= 10 Then
            周策略 = "银+ZA5~10"
        End If
    End If

    '查概率表并写入
    If 周策略 <> "" And 周市板 <> "" Then
        谕组(X, 位谕of周冲策略) = 周策略
        谕组(X, 位谕of周冲策分) = 查概率表(周策略, 周市板)
    End If
    '@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'########################################################################################
'########################################################################################
'仓系统
'属于跨码信息，应该放入跨码基础 中
'########################################################################################
'########################################################################################
    If 是否跨码 = True Then
        '================================================================================
        '获取仓数量
        '================================================================================
        If InStr(组结算(X, 位列花天仓宝福), ",") > 0 Then
            谕组(X, 位谕of仓持数) = Left$(组结算(X, 位列花天仓宝福), InStr(组结算(X, 位列花天仓宝福), ",") - 1)
            值仓成本 = Mid$(组结算(X, 位列花天仓宝福), InStr(组结算(X, 位列花天仓宝福), ",") + 1)
        ElseIf InStr(组结算(X, 位列花天仓宝彦), ",") > 0 Then
            谕组(X, 位谕of仓持数) = Left$(组结算(X, 位列花天仓宝彦), InStr(组结算(X, 位列花天仓宝彦), ",") - 1)
            值仓成本 = Mid$(组结算(X, 位列花天仓宝彦), InStr(组结算(X, 位列花天仓宝彦), ",") + 1)
        Else
            谕组(X, 位谕of仓持数) = 0
        End If
        值仓持数 = 谕组(X, 位谕of仓持数) / 100
        '================================================================================
        '对于持仓：只有【CID是代码】且【持仓数量>0】进行考虑
        '================================================================================
        If 值仓持数 > 0 Then
                '========================================================================
                '重新计算金额相关：市值、收益
                '========================================================================
                值今收 = 组结算(X, 基位日类 + 位os结收)
                值今高 = 组结算(X, 基位日类 + 位os结高)
                值今低 = 组结算(X, 基位日类 + 位os结低)
                值前收 = 组结算(X, 基位日类 + 位os前收)
                值仓持额 = 0
                值仓赚收 = 0
                值仓赚高 = 0
                值仓赚低 = 0
                If UBCID是中股票(CIDL) = True Or UBCID是中股基(CIDL) = True Then
                    值仓持额 = Round(100 * 值仓持数 * 值今收 / 1000, 1)
                    值仓赚收 = Round(100 * 值仓持数 * (值今收 - 值前收), 0)
                    值仓赚高 = Round(100 * 值仓持数 * (值今高 - 值前收), 0)
                    值仓赚低 = Round(100 * 值仓持数 * (值今低 - 值前收), 0)
                    值仓肉垫 = Round(100 * 值仓持数 * (值今收 - 周类JC), 0)
                ElseIf UBCID是港股票(CIDL) = True Then
                    值仓持额 = Round(常汇率港币 * 100 * 值仓持数 * 值今收 / 1000, 1)
                    值仓赚收 = Round(常汇率港币 * 100 * 值仓持数 * (值今收 - 值前收), 0)
                    值仓赚高 = Round(常汇率港币 * 100 * 值仓持数 * (值今高 - 值前收), 0)
                    值仓赚低 = Round(常汇率港币 * 100 * 值仓持数 * (值今低 - 值前收), 0)
                    值仓肉垫 = Round(常汇率港币 * 100 * 值仓持数 * (值今收 - 周类JC), 0)
                End If
                '计算仓赚
                谕组(X, 位谕of仓成本) = 值仓成本
                谕组(X, 位谕of仓持额) = 值仓持额
                谕组(X, 位谕of仓赚收) = 值仓赚收
                谕组(X, 位谕of仓赚高) = 值仓赚高
                谕组(X, 位谕of仓赚低) = 值仓赚低
                谕组(X, 位谕of仓赚损) = IIf(值仓赚高 > 0, 值仓赚收 - 值仓赚高, 0)
                谕组(X, 位谕of仓肉垫) = 值仓肉垫
                '========================================================================
                '计算盈亏比例
                '========================================================================
                If 值仓成本 > 0 Then
                    值仓盈比 = Round(值今收 / 值仓成本 - 1, 2)
                Else
                    值仓盈比 = 1
                End If
                谕组(X, 位谕of仓盈比) = Format(值仓盈比, "0%")
                '========================================================================
                '定义操盘类型与盯盘类型
                '操盘类型：把周期信息放到最前面，基本不涉及仓位数量信息
                '盯盘类型：把周期信息放到后面，把数量信息放到前面，从而适合于盯盘
                '========================================================================
                    '【类别】停牌
                    If 谕组(X, 位qt停牌) = "S" Then
                            谕组(X, 位谕of仓操类) = "操盘停牌"
                    '【类别】ETF类
                    ElseIf UBCID是中股基(CIDL) = True Then
                            '判别是否为ETF（单独放到后面）
                            谕组(X, 位谕of仓操类) = "操盘ETF类"
                            谕组(X, 位谕of仓限总) = IIf(谕组(X, 位谕of仓限倍) > 0, CInt(10000 / 100 / 值今收), 0) '将仓限金额转化为手数
                    '--------------------------------------------------------------------
                    '【类别】池金
                    ElseIf 谕组(X, 位qt在池) = 常池名金 Then
                            谕组(X, 位谕of仓操类) = "操盘在池"
                            谕组(X, 位谕of仓限单) = (常值仓限底仓额 / 100 / 值今收)
                            谕组(X, 位谕of仓限总) = CInt(谕组(X, 位谕of仓限单) * 谕组(X, 位谕of仓限倍))
                    '【类别】池银 池铜
                    ElseIf 谕组(X, 位qt在池) = 常池名银 Or 谕组(X, 位qt在池) = 常池名铜 Then
                            谕组(X, 位谕of仓操类) = "操盘在池"
                            谕组(X, 位谕of仓限单) = (常值仓限底仓额 / 100 / 值今收)
                            谕组(X, 位谕of仓限总) = CInt(谕组(X, 位谕of仓限单) * 谕组(X, 位谕of仓限倍))   '将仓限金额转化为手数
                    '--------------------------------------------------------------------
                    '【类别】操盘日类：快进快出
                    Else
                            谕组(X, 位谕of仓操类) = "操盘快"
                            谕组(X, 位谕of仓限单) = (常值仓限底仓额 / 100 / 值今收)
                            谕组(X, 位谕of仓限总) = CInt(谕组(X, 位谕of仓限单) * 谕组(X, 位谕of仓限倍))   '将仓限金额转化为手数
                    End If
                '========================================================================
                '计算仓位比
                '制定周级别持仓策略
                '醍醐灌顶20211225：必须以周线为操盘依据，以前一周末持仓作为本周操盘依据
                '醍醐灌顶20220220：持仓须两防，一防仓位过高，见好不收；二防仓位过低，踏空。
                '========================================================================
                谕组(X, 位qt盯盘类别) = ""
                If VBA.IsNumeric(谕组(X, 位谕of仓限总)) = True Then
                    '--------------------------------------------------------------------
                    If Left$(谕组(X, 位谕of周层界), 1) = "_" Then
                            谕组(X, 位qt盯盘类别) = "X旨"
                            谕组(X, 位谕of仓位比) = "仓限禁旨"
                    ElseIf 谕组(X, 位谕of仓限总) = 0 Then
                            谕组(X, 位qt盯盘类别) = "O无"
                            谕组(X, 位谕of仓位比) = "仓限为0"
                    Else
                        
                            值仓位比 = Round(值仓持数 / 谕组(X, 位谕of仓限总), 1)
                            谕组(X, 位谕of仓位比) = IIf(值仓位比 > 1, 值仓位比 & "倍", 值仓位比)
                            '按照仓位数额进行分类，如果只剩底仓可以长期持有；如有浮仓则需要盯盘。
                            If 谕组(X, 位谕of仓持额) * 1000 <= 常值仓限底仓额 Then
                                谕组(X, 位qt盯盘类别) = "H恒"
                            Else
                                谕组(X, 位qt盯盘类别) = "K狙"
                            End If
                    End If
                    '--------------------------------------------------------------------
                    '类别：是否持仓金额过大
                    If InStr(谕组(X, 位谕of周层界), "_") > 0 Then
                            谕组(X, 位qt盯盘类别) = 谕组(X, 位qt盯盘类别) & "X周"
                    ElseIf 谕组(X, 位谕of仓持额) * 1000 >= 常值仓限底仓额 * 2 Then
                            谕组(X, 位qt盯盘类别) = 谕组(X, 位qt盯盘类别) & "H重"
                    ElseIf VBA.IsNumeric(值仓位比) And 值仓位比 > 1 Then
                            谕组(X, 位qt盯盘类别) = 谕组(X, 位qt盯盘类别) & "C超"
                    End If
                    If 谕组(X, 位谕of仓操类) = "操盘ETF类" Then
                            '注20240508：把ETF放到持仓最后。
                            谕组(X, 位qt盯盘类别) = "ETF." & 谕组(X, 位qt盯盘类别)
                    End If
                    '--------------------------------------------------------------------
'                    If 值仓位比 > 1 Then
                            If Weekday(Date, vbMonday) <= 5 And (Time >= "09:29:00" And Time <= "15:00:00") Then
                                '处于交易时间
                                If 谕组(X, 位qt今高幅) >= 3 And 谕组(X, 位谕of日波上身) < 50 Then
                                    谕组(X, 位qt盯盘类别) = 谕组(X, 位qt盯盘类别) & "_落"
                                End If
                            End If
'                    End If
                '========================================================================
                '周类操盘策略：根据（具体仓位）与（操作建议）提示操作：包含目标价与数量
                '========================================================================
                        谕组(X, 位谕of仓操作) = ""
                        If 谕组(X, 位谕of仓限总) = 0 Then
                                谕组(X, 位谕of仓操作) = "清" & 值仓持数 & "手"
                        Else
                                If 值仓位比 > 1 Then 谕组(X, 位谕of仓操作) = "削" & (值仓持数 - 谕组(X, 位谕of仓限总)) & "手"
                        End If
                End If
                '========================================================================
        End If
        '================================================================================
    End If
'########################################################################################
'########################################################################################
'测试系统
'########################################################################################
'########################################################################################
            '============================================================================
            '============================================================================
'########################################################################################
'########################################################################################
End If
Next
'========================================================================================
'返回
'========================================================================================
End Function








