'代码位置选择：
'（1）迭代放在【单点结算】（2）多周期公用逻辑放在【单点衍生】（3）需要调试复杂逻辑放在【神谕】
'========================================================================================
'========================================================================================
'功能：
'以下指标原来在神谕中衍生，但在不同周期适用相同逻辑，放在此处仅仅为提高效率。
'衍生结点：由于指标仅依赖于单条数据，可以在最后一个结点再调用提高效率。
'========================================================================================
'========================================================================================
Function STBASE结算引擎_单点衍生核程(ByRef ARROS As Variant) As Integer
'########################################################################################
'##################################     工具衍生     ####################################
'##################################   工具衍生指标   ####################################
'########################################################################################
            '============================================================================
            '并符串：范
            '功能：用于对A5进行五柱二阴判断。一定要注意，仅适用于极端A5情况。
            '============================================================================
                ARROS(位os具并符范) = 0
                If Len(ARROS(位os具并符串)) = 5 Then
                    For i = 1 To 5
                        值具并符单形 = Mid(ARROS(位os具并符串), i, 1)
                        Select Case 值具并符单形
                        Case 常枚并符跌连, 常枚并符跌吞, 常枚并符跌孕
                            ARROS(位os具并符范) = ARROS(位os具并符范) + 1
                        End Select
                    Next
                End If
            '============================================================================
            '中符串：范
            '============================================================================
                Dim 值具中符范 As Integer
                ARROS(位os具中符范) = 0
                ARROS(位os具中符数A) = 0
                ARROS(位os具中符数B) = 0
                ARROS(位os具中符数C) = 0
                ARROS(位os具中符数D) = 0
                If Len(ARROS(位os具中符串)) = 5 Then
                    For i = 1 To 5
                        值单形中符 = Mid(ARROS(位os具中符串), i, 1)
                        Select Case 值单形中符
                        Case 常枚中符上全
                            值具中符范 = 1000
                            ARROS(位os具中符数A) = ARROS(位os具中符数A) + 1
                        Case 常枚中符上探
                            值具中符范 = 100
                            ARROS(位os具中符数B) = ARROS(位os具中符数B) + 1
                        Case 常枚中符鼎正
                            值具中符范 = 10
                            ARROS(位os具中符数C) = ARROS(位os具中符数C) + 1
                        Case 常枚中符薡反
                            值具中符范 = 1
                            ARROS(位os具中符数D) = ARROS(位os具中符数D) + 1     '反鼎不作为上壁考虑的有利因素
                        Case Else
                            值具中符范 = 0
                        End Select
                        ARROS(位os具中符范) = ARROS(位os具中符范) + CInt(值具中符范)
                    Next
                End If
            '============================================================================
            '上符串：范
            '============================================================================
                ARROS(位os具上符数触顶) = 0
                ARROS(位os具上符数触哼) = 0
                ARROS(位os具上符数触哈) = 0
                ARROS(位os具上符数触底) = 0
                If Len(ARROS(位os具上符串)) = 5 Then
                    For i = 1 To 5
                        值单符上壁形 = Mid(ARROS(位os具上符串), i, 1)
                        If 值单符上壁形 = 常枚上符顶 Then
                            ARROS(位os具上符数触顶) = ARROS(位os具上符数触顶) + 1
                            ARROS(位os具上符数触哼) = ARROS(位os具上符数触哼) + 1
                        ElseIf 值单符上壁形 = 常枚上符哼 Then
                            ARROS(位os具上符数触哼) = ARROS(位os具上符数触哼) + 1
                        ElseIf 值单符上壁形 = 常枚上符哈 Then
                            ARROS(位os具上符数触哈) = ARROS(位os具上符数触哈) + 1
                        ElseIf 值单符上壁形 = 常枚上符底 Then
                            ARROS(位os具上符数触底) = ARROS(位os具上符数触底) + 1
                            ARROS(位os具上符数触哈) = ARROS(位os具上符数触哈) + 1
                        End If
                    Next
                End If
                '------------------------------------------------------------------------
                '要求：最低要求大于200（排除单柱触哼）
                值具上符范 = 0
                If ARROS(位osBTZC) > 0 Then
                    值具上符范 = 值具上符范 + 10 * IIf(ARROS(位os龟BT哼) > 0, ARROS(位os龟BT哼), 0)
                    值具上符范 = 值具上符范 + 1 * ARROS(位os具上符数触哼)
                ElseIf ARROS(位osBTZC) < 0 Then
                    值具上符范 = 值具上符范 + 10 * IIf(ARROS(位os龟BT哈) > 0, ARROS(位os龟BT哈), 0)
                    值具上符范 = 值具上符范 + 1 * ARROS(位os具上符数触哈)
                End If
                ARROS(位os具上符范) = 值具上符范
            '============================================================================
            '具幅符串
            '============================================================================
                值具当高符 = ""
                值具当涨符 = ""
                值具当低符 = ""
                ARROS(位os具幅符串) = ""
                For i = 2 To 0 Step -1
                        值具当高幅 = ARROS(位os结幅HR0 + i)
                        值具当涨幅 = ARROS(位os结幅PR0 + i)
                        值具当低幅 = ARROS(位os结幅LR0 + i)
                        '------------------------------------------------------------
                        Select Case 值具当高幅
                        Case Is >= 20
                            值具当高符 = "Z"
                        Case Is >= 10
                            值具当高符 = "Y"
                        Case Is >= 5
                            值具当高符 = "B"
                        Case Is >= 1
                            值具当高符 = "A"
                        Case Is >= 0
                            值具当高符 = "O"
                        Case Is >= -1
                            值具当高符 = "o"
                        Case Is >= -5
                            值具当高符 = "a"
                        Case Is >= -10
                            值具当高符 = "b"
                        Case Is >= -20
                            值具当高符 = "y"
                        Case Else
                            值具当高符 = "z"
                        End Select
                        '------------------------------------------------------------
                        Select Case 值具当涨幅
                        Case Is >= 20
                            值具当涨符 = "Z"
                        Case Is >= 10
                            值具当涨符 = "Y"
                        Case Is >= 5
                            值具当涨符 = "B"
                        Case Is >= 1
                            值具当涨符 = "A"
                        Case Is >= 0
                            值具当涨符 = "O"
                        Case Is >= -1
                            值具当涨符 = "o"
                        Case Is >= -5
                            值具当涨符 = "a"
                        Case Is >= -10
                            值具当涨符 = "b"
                        Case Is >= -20
                            值具当涨符 = "y"
                        Case Else
                            值具当涨符 = "z"
                        End Select
                        '------------------------------------------------------------
                        Select Case 值具当低幅
                        Case Is >= 20
                            值具当低符 = "Z"
                        Case Is >= 10
                            值具当低符 = "Y"
                        Case Is >= 5
                            值具当低符 = "B"
                        Case Is >= 1
                            值具当低符 = "A"
                        Case Is >= 0
                            值具当低符 = "O"
                        Case Is >= -1
                            值具当低符 = "o"
                        Case Is >= -5
                            值具当低符 = "a"
                        Case Is >= -10
                            值具当低符 = "b"
                        Case Is >= -20
                            值具当低符 = "y"
                        Case Else
                            值具当低符 = "z"
                        End Select
                        '------------------------------------------------------------
                        ARROS(位os具幅符串) = ARROS(位os具幅符串) & 值具当低符 & 值具当高符 & 值具当涨符 & " "
                Next
            '============================================================================
            '衍生：锚系统
            '依赖：均线交叉累期系统
            '============================================================================
                If ARROS(位osBTZD) = 1 Then
                    ARROS(位os具锚ZD) = ARROS(位osJD)
                ElseIf ARROS(位osBTZD) < 0 Then
                    ARROS(位os具锚ZD) = 0
                End If
                '--------------------------------------------------------
                If ARROS(位osBTZC) = 1 Then
                    ARROS(位os具锚ZC) = ARROS(位osJC)
                ElseIf ARROS(位osBTZC) < 0 Then
                    ARROS(位os具锚ZC) = 0
                End If
            '============================================================================
'########################################################################################
'##################################     工具衍生     ####################################
'##################################   工具衍生指标   ####################################
'########################################################################################



'########################################################################################
'##################################     中观衍生     ####################################
'##################################   横类衍生指标   ####################################
'########################################################################################
            '============================================================================
            '横类
            '主要原则：区分【鸡蛋挑骨头】与【沙子里淘金】
            '思路20210921：
            '   理论上，当JZ上破JC时进入，当JZ下破JC时退出，可以将这一过程视为一个黑盒，在整个过程中不进行干预。
            '   但是由于可能存在上涨过快调整，或小碎步撤退的情况，可能造成利润回撤，因此在某些特殊情况下应进行干预。
            '   减仓操作的目的是以更好的心态守住持仓；加仓操作的目的是加厚利润。切记千万不要重仓押注，即使该股票非常好。
            '醍醐灌顶20220312：
            '   横向操盘主要由两个变量进行总分控制：横类、竖类。注意两点：（横）不要被（竖）打乱，所以在（竖类）中不要出现（竖）的内容，只依赖均线的情况。大局把握放在（横类），将偏大警示放在（横类）中。
            '醍醐灌顶20230703：
            '   核心思想：对WJABC排列进行分类，核心是JB与JC关系，分为[a多b劫y运z空]/a多头排列/b劫/y运/z空头排列，后两位代表主导横向形态，末位代表是否在WJB之上（即是否在小通道中）。【u】代表大于JB，【v】代表小于JB，存在人为强制的情况。
            '   命名规则：前缀【入】非多头排列；【始】代表横y系；【试】代表空头排列；【继】代表横b系；【再】代表ZB劫；前缀【安（天劫）】【多（ZA劫/ZB劫/其他劫）】多头排列；
            '============================================================================
            值局类 = ARROS(位os局ZABC)
            值横类 = ""
            '----------------------------------------------------------------------------
            '正向JC以上
            '----------------------------------------------------------------------------
            If ARROS(位osBTZC) > 0 Then
                    '--------------------------------------------------------------------
                    '阶段：【BC劫】残局
                    '--------------------------------------------------------------------
                    If 值局类 = "1b" Or 值局类 = "1e" Then
                                值横类 = "yACu_入始"
                    ElseIf 值局类 = "1w" Then
                                值横类 = "yABu_入始"
                    ElseIf 值局类 = "1v" Then
                                值横类 = "zZBu_入试"
                    '--------------------------------------------------------------------
                    '阶段：【BA劫】残局
                    '醍醐灌顶20220601：取消ZC劫分类，仅保留BA劫、CA劫。
                    '--------------------------------------------------------------------
                    ElseIf 值局类 = "3u" Or 值局类 = "2i" Then
                                值横类 = "bCAu_入继"
                    ElseIf 值局类 = "3h" Or 值局类 = "2I" Then
                                值横类 = IIf(ARROS(位osBTAC) <= 5, "bCAu_入继", "bBAu_入继")
                    ElseIf 值局类 = "3w" Then
                                值横类 = "bBAv_出始"
                    '--------------------------------------------------------------------
                    '阶段：【BZ劫】残局
                    '醍醐灌顶20220820：3v不必退出
                    '已解决问题20240115：是否将3v放入多头排列之中。参考【友邦吊顶20140620】。不要分散3v，集中展示比较好。不需要再讨论这个问题。
                    '--------------------------------------------------------------------
                    ElseIf 值局类 = "3v" Then
                                值横类 = "aBZv_出试"
                    '--------------------------------------------------------------------
                    '以下针对2c/2d/2e
                    '前缀多：代表WJABC多头排列
                    '--------------------------------------------------------------------
                    Else
                            '------------------------------------------------------------
                            '阶段：【BC劫】彻底调整，必须放到最前面
                            '以下状态：2c/2d/2e
                            If ARROS(位osBTBC) <= 4 Then        '
                                    值横类 = "aACu_多始"
                            ElseIf ARROS(位osBTAB) <= 4 Then
                                    值横类 = IIf(ARROS(位osBTAC) <= 9, "aCAu_多继", "aBAu_多继")
                            '------------------------------------------------------------
                            ElseIf 值局类 = "2e" Then
                                    值横类 = IIf(ARROS(位osBTZB) <= 5, "aBZu_多Be", "aAZu_多Ae")
                            '------------------------------------------------------------
