            '############################################################################
            '中观衍生：层界
            '############################################################################
             谕组(X, 位谕of周层界) = 组结算(X, 基位周类 + 位os层界)
             谕组(X, 位谕of日层界) = 组结算(X, 基位日类 + 位os层界)
            '############################################################################
            '中观衍生：层护型
            '############################################################################
             谕组(X, 位谕of周层护型) = 组结算(X, 基位周类 + 位os层护型)
             谕组(X, 位谕of日层护型) = 组结算(X, 基位日类 + 位os层护型)
