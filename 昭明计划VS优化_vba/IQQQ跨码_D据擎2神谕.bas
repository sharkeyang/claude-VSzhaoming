            '-----------------------------------------------------------------
                Else        '包含DEce
                        '-----------------------------------------------------
                        '筛选：丘启DE劫DC已
                        If 谕组(X, 位谕of周奏数DE叉DC) < 0 Then
                                If 谕组(X, 位谕of周奏数CD叉CB) < -1 Then
                                    谕组(X, 位谕of周奏丘) = "启DE【DC已CB多】"
                                ElseIf 谕组(X, 位谕of周奏数CD叉CB) = -1 Then
                                    谕组(X, 位谕of周奏丘) = "启DE【DC已CB一】"
                                Else
                                    谕组(X, 位谕of周奏丘) = "启DE【DC已CB〇】"
                                End If
                        '-----------------------------------------------------
                        '筛选：丘启DE劫DC〇
                        Else
                                If 谕组(X, 位谕of周奏数DE叉CB) < -1 Then
