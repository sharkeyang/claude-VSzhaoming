'由于本sub同时涉及两类程序：一是全息跨代码；二是跨期跨周期同代码。所以最好把跨代码的部分全部拿到全息中去。
'========================================================================================
'========================================================================================
'格式化：计分区域
'========================================================================================
'========================================================================================
Function IQQQ跨码据擎_数程生成跨时神谕( _
          ByRef 谕组 As Variant _
        , ByRef 组结算 As Variant _
        , Optional ByVal 基列 As Integer = 花列甲道 _
        , Optional ByVal 是否跨码 As Boolean = True _
        ) As Integer
'========================================================================================
'设置数组
'========================================================================================
    ReDim Preserve 谕组(LBound(谕组, 1) To UBound(谕组, 1), 1 To 位谕列终全部) As Variant
'========================================================================================
'生成跨码信息
'注意：对于跨码展示需要生成；对跨时展示不需要生成
'========================================================================================
'    If 是否跨码 = True Then
'        Call IQQQ跨码据擎_数程生成跨码基础(谕组, 组结算, 基列:=基列)
'    End If
'========================================================================================
'声明变量
'========================================================================================
    '------------------------------------------------------------------------------------
    '设置基位
    '------------------------------------------------------------------------------------
    Dim 基位日类 As Integer
    基位日类 = 基列 - 1
    Dim 基位周类 As Integer
    基位周类 = 基列 - 1 + 花宽单道 * 1
    Dim 基位月类 As Integer
    基位月类 = 基列 - 1 + 花宽单道 * 2
    Dim 基位统类 As Integer
    基位统类 = 基列 - 1 + 花宽单道 * 3
    '------------------------------------------------------------------------------------
    '声明变量
    '------------------------------------------------------------------------------------
    Dim CIDL As String
    Dim 周类JU#, 周类JV#, 周类JW#
    Dim 日类JU#, 日类JV#, 日类JW#, 日射周类JU#
    Dim 基期周类%, 基期日类%
    Dim 仓位周类#, 仓位日类#
    Dim 周类JZ#, 周类JA#, 周类JB#, 周类JC#, 周类JD#, 周类JE#
    Dim 日类JZ#, 日类JA#, 日类JB#, 日类JC#, 日类JD#, 日类JE#, 日类JF#, 日类JG#
    Dim 值月基月局$
    Dim 值周基月局$, 值周基周局$
    Dim 值日基月局$, 值日基周局$, 值日基日局$
    '------------------------------------------------------------------------------------
    Dim 程隔 As String
    程隔 = String(63, "-") & vbCrLf
    Dim 值幅下限 As Double
    Dim 值幅上限 As Double
    Dim X As Integer, Y As Integer
    Dim i As Integer
    Dim countV As Integer, countW As Integer
    Dim 值层地型 As String
'========================================================================================
'遍历
'========================================================================================
For X = LBound(组结算, 1) To UBound(组结算, 1)
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
            '============================================================================
            '清空原有数据，将每个赋值语句设置空值集中于此
            '============================================================================
            For Y = 位谕列始全部 To 位谕列终全部
                谕组(X, Y) = ""
            Next
            CIDL = 组结算(X, 基位日类 + 位os代码)
            If UBCID是代码(CIDL) = True Then
            '============================================================================
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@




'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'########################################################################################
'########################################################################################
'重组：统时
'########################################################################################
'########################################################################################
            '============================================================================
            '统计：日段仨属性
            '待完成：后续须放入跨码程序
            '============================================================================
            If 是否跨码 = True Then
                    '--------------------------------------------------------------------
                    '统计：日段仨属性
                    '--------------------------------------------------------------------
                    谕组(X, 位谕of日段仨停数涨) = 组结算(X, 基位统类 + 位统时列仨停数涨)
                    谕组(X, 位谕of日段仨停数高) = 组结算(X, 基位统类 + 位统时列仨停数高)
                    谕组(X, 位谕of日段仨停数跌) = 组结算(X, 基位统类 + 位统时列仨停数跌)
                    谕组(X, 位谕of日段仨停数低) = 组结算(X, 基位统类 + 位统时列仨停数低)
                    谕组(X, 位谕of日段仨均幅涨) = 组结算(X, 基位统类 + 位统时列仨均幅涨)
                    谕组(X, 位谕of日段仨均幅高) = 组结算(X, 基位统类 + 位统时列仨均幅高)
                    谕组(X, 位谕of日段仨均幅低) = 组结算(X, 基位统类 + 位统时列仨均幅低)
                    谕组(X, 位谕of日段仨高小比) = 组结算(X, 基位统类 + 位统时列仨高小比)
                    谕组(X, 位谕of日段仨重心正比) = 组结算(X, 基位统类 + 位统时列仨重心正比)
                    谕组(X, 位谕of日段仨顶龄) = 组结算(X, 基位统类 + 位统时列仨顶龄)
                    谕组(X, 位谕of日段仨顶价) = 组结算(X, 基位统类 + 位统时列仨顶价)
                    If 组结算(X, 基位统类 + 位统时列仨顶幅) = 0 Then
                        谕组(X, 位谕of日段仨顶幅) = "新顶"
                    ElseIf 组结算(X, 基位统类 + 位统时列仨顶幅) <> -1 Then
                        谕组(X, 位谕of日段仨顶幅) = Round(1 / (1 + 组结算(X, 基位统类 + 位统时列仨顶幅)) - 1, 2)
                    End If
                    谕组(X, 位谕of日段仨底龄) = 组结算(X, 基位统类 + 位统时列仨底龄)
                    谕组(X, 位谕of日段仨底价) = 组结算(X, 基位统类 + 位统时列仨底价)
                    If 组结算(X, 基位统类 + 位统时列仨底幅) = 0 Then
                        谕组(X, 位谕of日段仨底幅) = "新底"
                    ElseIf 组结算(X, 基位统类 + 位统时列仨底幅) <> -1 Then
                        谕组(X, 位谕of日段仨底幅) = Round(1 / (1 + 组结算(X, 基位统类 + 位统时列仨底幅)) - 1, 2)
                    End If
                    谕组(X, 位谕of日段仨计数) = 组结算(X, 基位统类 + 位统时列仨计数)
                    '--------------------------------------------------------------------
                    '统计：日段佰属性
                    '--------------------------------------------------------------------
                    谕组(X, 位谕of日段佰停数涨) = 组结算(X, 基位统类 + 位统时列佰停数涨)
                    谕组(X, 位谕of日段佰停数高) = 组结算(X, 基位统类 + 位统时列佰停数高)
                    谕组(X, 位谕of日段佰停数跌) = 组结算(X, 基位统类 + 位统时列佰停数跌)
                    谕组(X, 位谕of日段佰停数低) = 组结算(X, 基位统类 + 位统时列佰停数低)
                    谕组(X, 位谕of日段佰均幅涨) = 组结算(X, 基位统类 + 位统时列佰均幅涨)
                    谕组(X, 位谕of日段佰均幅高) = 组结算(X, 基位统类 + 位统时列佰均幅高)
                    谕组(X, 位谕of日段佰均幅低) = 组结算(X, 基位统类 + 位统时列佰均幅低)
                    谕组(X, 位谕of日段佰高小比) = 组结算(X, 基位统类 + 位统时列佰高小比)
                    谕组(X, 位谕of日段佰重心正比) = 组结算(X, 基位统类 + 位统时列佰重心正比)
                    谕组(X, 位谕of日段佰顶龄) = 组结算(X, 基位统类 + 位统时列佰顶龄)
                    谕组(X, 位谕of日段佰顶价) = 组结算(X, 基位统类 + 位统时列佰顶价)
                    If 组结算(X, 基位统类 + 位统时列佰顶幅) = 0 Then
                        谕组(X, 位谕of日段佰顶幅) = "新顶"
                    ElseIf 组结算(X, 基位统类 + 位统时列佰顶幅) <> -1 Then
                        谕组(X, 位谕of日段佰顶幅) = Round(1 / (1 + 组结算(X, 基位统类 + 位统时列佰顶幅)) - 1, 2)
                    End If
                    谕组(X, 位谕of日段佰底龄) = 组结算(X, 基位统类 + 位统时列佰底龄)
                    谕组(X, 位谕of日段佰底价) = 组结算(X, 基位统类 + 位统时列佰底价)
                    If 组结算(X, 基位统类 + 位统时列佰底幅) = 0 Then
                        谕组(X, 位谕of日段佰底幅) = "新底"
                    ElseIf 组结算(X, 基位统类 + 位统时列佰底幅) <> -1 Then
