'########################################################################################
            '============================================================================
            '衍生：WXCD护型
            '20260526添加前缀：当WXZC＞0，若WXCD＜0，加前缀“铜”；若WXCD＞0，对（a甲b乙r己），加前缀“金”，其余加前缀“银”。对于WXZC＜0，镜面映射，加前缀“屎尿屁”。
            '注20260612：根据WXCD护型，凡是前缀为“屎尿”，都是下降趋势；前缀为“唏嘘”，都是选择方向区；只有“金银”，是上升趋势。
            '============================================================================
            值WXCD护型 = ""
                    If 周类BTCD > 0 Then
                            If 周类BTZD < 0 Then
                                值WXCD护型 = 值WXCD护型 & "5尿c丙降"
                            ElseIf 周类BTZC < 0 Then
                                值WXCD护型 = 值WXCD护型 & "4嘘b乙待" '属于CD嘴，大概率向上
                            ElseIf 周类BTZC < 周类BTCD Then
                                值WXCD护型 = 值WXCD护型 & "1金b乙升"
                            Else
                                值WXCD护型 = 值WXCD护型 & "1金a甲升"
                            End If
                    Else
                            If 周类BTZD > 0 Then
                                值WXCD护型 = 值WXCD护型 & "2银r己升"
                            ElseIf 周类BTZC > 0 Then
                                值WXCD护型 = 值WXCD护型 & "3唏y戊待" '属于CD嘴，大概率向下'20260611特别注意：根据WXCD护型，选择（甲乙己），所以要舍弃（戊）。以前认为只要大于WJC就有机会，其实当WXCD负交，上破WJC只是降趋势的反弹，不能作为升趋势的开始。
                            ElseIf 周类BTZC > 周类BTCD Then
                                值WXCD护型 = 值WXCD护型 & "6屎y戊降"
                            Else
                                值WXCD护型 = 值WXCD护型 & "6屎z丁降"
                            End If
                    End If
            '============================================================================
            '周层三鳄：构建WXCD/WXAB/DXAB三层防护。“鳄”的含义，张开嘴，且要在嘴外面（大于两条线），而不是在嘴中。
            '对WXCD，要求WXCD＞0或（WXCD＜0，WXZD＞0）。利用WJC作为止损线。
            '对WXAB，要求WXAB＞0或（WXAB＜0，WXZB＞0）。符合条件代表在升势；不符合也只用WJC止损。
            '对DXAB，仅要求DXAB＞0或（DXAB＜0，DXZB＞0）。
            '作用：【周层三鳄】用来排序，分类。【周层大局】用来看，要简化前端区域，细化后端波型。
            '============================================================================
            谕组(X, 位谕of周层三鳄) = ""
                    '--------------------------------------------------------------------
                    '【天时】WXCD
                    '--------------------------------------------------------------------
                    谕组(X, 位谕of周层三鳄) = 谕组(X, 位谕of周层三鳄) & Left$(值WXCD护型, 2)
                    谕组(X, 位谕of周层三鳄) = 谕组(X, 位谕of周层三鳄) & Mid$(值WXCD护型, 5, 1)
                    '--------------------------------------------------------------------
                    '【地利】周层护型
                    '--------------------------------------------------------------------
                    谕组(X, 位谕of周层三鳄) = 谕组(X, 位谕of周层三鳄) & Left$(谕组(X, 位谕of周层护型), 1)
                    谕组(X, 位谕of周层三鳄) = 谕组(X, 位谕of周层三鳄) & Mid$(谕组(X, 位谕of周层护型), 3, 1)
                    '--------------------------------------------------------------------
                    '【人和】针对DXAB
                    '--------------------------------------------------------------------
                    谕组(X, 位谕of周层三鳄) = 谕组(X, 位谕of周层三鳄) & "."
                    谕组(X, 位谕of周层三鳄) = 谕组(X, 位谕of周层三鳄) & Left$(谕组(X, 位谕of日层护型), 1)
                    谕组(X, 位谕of周层三鳄) = 谕组(X, 位谕of周层三鳄) & Mid$(谕组(X, 位谕of日层护型), 3, 1)
            '============================================================================
'########################################################################################
            '============================================================================
            '位谕of周层大局
            '注20260501：重要标识（WXCD→WXAB→波型），逐步锁定主升。
            '============================================================================
                谕组(X, 位谕of周层大局) = ""
                '------------------------------------------------------------------------
                '位1【天时】：利用WJC与WXCD进行判别。正常主升必为WXCD＞0，只有少数形成主升的情况是WXCD＜0（当WXCD＜0很可能是底诱或顶诱）。
                '注20260526：针对WXCD护型（只选取甲乙己），标注好√×，只要是×就不能持有。
                '------------------------------------------------------------------------
                    '--------------------------------------------------------------------
                    'WXCD护型：使用“升降待”指明方向。
                    '--------------------------------------------------------------------
                    谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & Mid$(值WXCD护型, 2, 1)      '不区分【金a/金b】【屎y/屎z】
                    谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & Mid$(值WXCD护型, 5, 1)
                    '--------------------------------------------------------------------
                    'WXAB护型，使用“上下”指明方向，区分于，WXCD护型“升降待”
                    '↑ ↓← →↖↗↘↙?
                    '--------------------------------------------------------------------
                    '谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & "_"
                    谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & Left$(谕组(X, 位谕of周层护型), 1)
                    谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & Mid$(谕组(X, 位谕of周层护型), 3, 1)
                '------------------------------------------------------------------------
                '位2：针对周类层段（a甲b乙r己），提供地型进行参考，包括WJC之下。
                '20260527持仓规则：在WJC之上，a甲b乙c己可主动持有；c丙可被动持有；z丁y戊可被动持有或清仓。
                '------------------------------------------------------------------------
                    If InStr(谕组(X, 位谕of周层护型), "甲") > 0 _
                    Or InStr(谕组(X, 位谕of周层护型), "乙") > 0 _
                    Or InStr(谕组(X, 位谕of周层护型), "己") > 0 Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & "."
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & 谕组(X, 位谕of周层波型)
                    End If
                '------------------------------------------------------------------------
                '位3：融合（WXAB是否正交）与（周类层段），去掉与之重复的（周层）。（WXAB是否正交：MU正交/OZ负交）（周类层段：a甲b乙c丙r己y戊z丁：其中在WJC之上abcx都可取）。需要注意的是，（周层：初主再）与前面有冲突，不要在此处使用。
                '注20260516：只要在WJC之上就可持有，特别是当WXAB正交情况。最重要是寻找在WJA之上升排的前期。
                '------------------------------------------------------------------------
                    '--------------------------------------------------------------------
                    'WJC之上
                    '--------------------------------------------------------------------
                    If 谕组(X, 位谕of周基周局) = "1w" _
                    Or 谕组(X, 位谕of周基周局) = "1b" _
                    Or 谕组(X, 位谕of周基周局) = "2c" _
                    Or 谕组(X, 位谕of周基周局) = "2d" _
                    Or 谕组(X, 位谕of周基周局) = "1e" _
                    Or 谕组(X, 位谕of周基周局) = "2e" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局)        '属于【WXAB正交】可能属于层段(甲乙）
                    ElseIf 谕组(X, 位谕of周基周局) = "3v" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & ".被" & 谕组(X, 位谕of周基周局)             '属于【WXAB正交.M3】“被动持有”。属于【中间态】，不属于【升态】或【跌态】
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of周基周局) = "1v" _
                        Or 谕组(X, 位谕of周基周局) = "2I" _
                        Or 谕组(X, 位谕of周基周局) = "2i" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & ".口" & 谕组(X, 位谕of周基周局)           '属于【WXAB负交.N1】，同时大于WJB与WJC
                    ElseIf 谕组(X, 位谕of周基周局) = "3h" _
                        Or 谕组(X, 位谕of周基周局) = "3w" _
                        Or 谕组(X, 位谕of周基周局) = "3u" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & ".警" & 谕组(X, 位谕of周基周局)             '属于【WXAB负交.N2】“被动持有”。属于【中间态】，不属于【升态】或【跌态】
                    '--------------------------------------------------------------------
                    'WJC之下
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of周基周局) = "4w" _
                        Or 谕组(X, 位谕of周基周局) = "4b" _
                        Or 谕组(X, 位谕of周基周局) = "5c" _
                        Or 谕组(X, 位谕of周基周局) = "5d" _
                        Or 谕组(X, 位谕of周基周局) = "4e" _
                        Or 谕组(X, 位谕of周基周局) = "5e" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局)
                    ElseIf 谕组(X, 位谕of周基周局) = "6v" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & ".魅" & 谕组(X, 位谕of周基周局)
                    '--------------------------------------------------------------------
                    ElseIf 谕组(X, 位谕of周基周局) = "4v" _
                        Or 谕组(X, 位谕of周基周局) = "5I" _
                        Or 谕组(X, 位谕of周基周局) = "5i" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & ".逃" & 谕组(X, 位谕of周基周局)
                    ElseIf 谕组(X, 位谕of周基周局) = "6h" _
                        Or 谕组(X, 位谕of周基周局) = "6w" _
                        Or 谕组(X, 位谕of周基周局) = "6u" Then
                            谕组(X, 位谕of周层大局) = 谕组(X, 位谕of周层大局) & ".魅" & 谕组(X, 位谕of周基周局)
                    End If
