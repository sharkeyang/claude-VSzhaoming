                    月类临高 = 组结算(X, 基位月类 + 位os临高)
                    月类临低 = 组结算(X, 基位月类 + 位os临低)
            '============================================================================
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@




'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'########################################################################################
'########################################################################################
'宏观衍生：族势局
'########################################################################################
'########################################################################################
            '============================================================================
            '月类六局
            '============================================================================
            值月基月局 = 组结算(X, 基位月类 + 位os局ZABC)
            谕组(X, 位谕of月基月局) = 值月基月局
            '============================================================================
            '周类六局
            '============================================================================
            值周基月局 = 组结算(X, 基位周类 + 位os局ZCDE)
            值周基周局 = 组结算(X, 基位周类 + 位os局ZABC)
            谕组(X, 位谕of周基乾局) = "_" & 值周基月局 & "._" & 值周基周局
            谕组(X, 位谕of周基月局) = 值周基月局
            谕组(X, 位谕of周基周局) = 值周基周局
            '============================================================================
            '日类六局
            '日线级别不代表趋势，只代表位置。不存在日线支撑或压制的情况。
            '============================================================================
            值日基月局 = 组结算(X, 基位日类 + 位os局ZEFG)
            值日基周局 = 组结算(X, 基位日类 + 位os局ZCDE)
            值日基日局 = 组结算(X, 基位日类 + 位os局ZABC)
            '醍醐灌顶20230727：将日类六局作为周类六局的展开，只针对符合尊的情况进行展示
            谕组(X, 位谕of日基乾局) = "_" & 值日基月局 & "._" & 值日基周局
            谕组(X, 位谕of日基坤局) = "_" & 值日基周局 & "._" & 值日基日局
            谕组(X, 位谕of日基月局) = 值日基月局
            谕组(X, 位谕of日基周局) = 值日基周局
            谕组(X, 位谕of日基日局) = 值日基日局
            '============================================================================
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@




'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'########################################################################################
'########################################################################################
'重组：波动相关 月类
'########################################################################################
'########################################################################################
            '============================================================================
            '重组：月类波动体系
            '“前”系价格：正式结算的上上月价格
            '“今”系价格：正式结算的上月价格
            '“临”系价格：实时结算的本月价格或每日结算更新后的昨日价格
            '============================================================================
            谕组(X, 位谕of月波今涨幅) = 组结算(X, 基位月类 + 位os结幅PR0)
            谕组(X, 位谕of月波临涨幅) = 组结算(X, 基位月类 + 位os临幅PR)
            谕组(X, 位谕of月波临高幅) = 组结算(X, 基位月类 + 位os临幅HR)
            谕组(X, 位谕of月波临低幅) = 组结算(X, 基位月类 + 位os临幅LR)
            '============================================================================
'########################################################################################
'########################################################################################
'重组：波动相关 周类
'########################################################################################
'########################################################################################
            '============================================================================
            '重组：周类波动体系
            '============================================================================
            谕组(X, 位谕of周波涨幅0) = 组结算(X, 基位周类 + 位os结幅PR0)
            谕组(X, 位谕of周波涨幅1) = 组结算(X, 基位周类 + 位os结幅PR1)
            谕组(X, 位谕of周波涨幅2) = 组结算(X, 基位周类 + 位os结幅PR2)
            谕组(X, 位谕of周波涨幅3) = 组结算(X, 基位周类 + 位os结幅PR3)
            谕组(X, 位谕of周波涨幅4) = 组结算(X, 基位周类 + 位os结幅PR4)
            '============================================================================
            '重组：周类波动体系
            '《前》系价格：正式结算的上上周价格
            '《今》系价格：正式结算的上周价格
            '《临》系价格：实时结算的本周价格或每日结算更新后的昨日价格
            '============================================================================
            谕组(X, 位谕of周波今收) = 周类今收
            谕组(X, 位谕of周波今涨幅) = 组结算(X, 基位周类 + 位os结幅PR0)
            谕组(X, 位谕of周波今高幅) = 组结算(X, 基位周类 + 位os结幅HR0)
            谕组(X, 位谕of周波临涨幅) = 组结算(X, 基位周类 + 位os临幅PR)
            谕组(X, 位谕of周波临高幅) = 组结算(X, 基位周类 + 位os临幅HR)
            '============================================================================
            '平均波动
            '============================================================================
            '衍生：柱组信息
            谕组(X, 位谕of周波均涨幅五) = Round((组结算(X, 基位周类 + 位os结幅PR0) _
                                            + 组结算(X, 基位周类 + 位os结幅PR1) _
                                            + 组结算(X, 基位周类 + 位os结幅PR2) _
                                            + 组结算(X, 基位周类 + 位os结幅PR3) _
                                            + 组结算(X, 基位周类 + 位os结幅PR4)) / 5, 2)
            谕组(X, 位谕of周波均高幅十) = Round((组结算(X, 基位周类 + 位os结幅HR0) _
                                            + 组结算(X, 基位周类 + 位os结幅HR1) _
                                            + 组结算(X, 基位周类 + 位os结幅HR2) _
                                            + 组结算(X, 基位周类 + 位os结幅HR3) _
                                            + 组结算(X, 基位周类 + 位os结幅HR4) _
                                            + 组结算(X, 基位周类 + 位os结幅HR5) _
                                            + 组结算(X, 基位周类 + 位os结幅HR6) _
                                            + 组结算(X, 基位周类 + 位os结幅HR7) _
                                            + 组结算(X, 基位周类 + 位os结幅HR8) _
                                            + 组结算(X, 基位周类 + 位os结幅HR9)) / 10, 2)
            '-------------------------------------------------
            '10柱内是否出现超过20%单柱：进行单列
            If 组结算(X, 基位周类 + 位os结幅HR0) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR1) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR2) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR3) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR4) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR5) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR6) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR7) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR8) > 20 _
            Or 组结算(X, 基位周类 + 位os结幅HR9) > 20 Then
                    谕组(X, 位谕of周波高幅十冲) = "已"
            Else
                    谕组(X, 位谕of周波高幅十冲) = "〇"
            End If
            '-------------------------------------------------
            '10柱内是否出现多个低于2%单柱：进行单列。不再提前排除萎，而是按照此标准进行过滤
            谕组(X, 位谕of周波高幅十败数) = _
                          IIf(组结算(X, 基位周类 + 位os结幅HR0) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR1) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR2) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR3) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR4) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR5) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR6) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR7) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR8) < 3, 1, 0) _
                        + IIf(组结算(X, 基位周类 + 位os结幅HR9) < 3, 1, 0)
            '-------------------------------------------------
            '根据周柱波动情况进行分类
            If 谕组(X, 位谕of周波均高幅十) <= 3 Then    '过滤第一条件：排除低波动
                谕组(X, 位谕of周波类) = "1低均"
            ElseIf 谕组(X, 位谕of周波高幅十败数) >= 6 Then '过滤第二条件：排除可能无法获利情况
                谕组(X, 位谕of周波类) = "2败多"
            ElseIf 谕组(X, 位谕of周波高幅十冲) = "已" Then '过滤第三条件：排除活跃情况
                谕组(X, 位谕of周波类) = "3已冲"
            Else
                谕组(X, 位谕of周波类) = "4常"
            End If
            
    '将以上部分放入结算，提高效率
            '============================================================================
            '叠幅
            '============================================================================
            '叠幅的作用：用于发现上涨曲线由陡到缓的特征，适用于特别光滑的曲线，对于凹凸不平的曲线不适用。
            '止盈点的选择：（最优）巨宽龙；（次优）走缓即本方法（再次）阴阳交错（最差）破WJA
'            谕组(X, 位谕of周波今叠幅) = 组结算(X, 基位周类 + 位os龟叠幅0)
'            谕组(X, 位谕of周波均叠幅五) = (组结算(X, 基位周类 + 位os龟叠幅0) _
'                                        + 组结算(X, 基位周类 + 位os龟叠幅1) _
'                                        + 组结算(X, 基位周类 + 位os龟叠幅2) _
'                                        + 组结算(X, 基位周类 + 位os龟叠幅3) _
'                                        + 组结算(X, 基位周类 + 位os龟叠幅4)) / 5
            '============================================================================
'########################################################################################
'########################################################################################
'重组：波动相关 日类
'########################################################################################
'########################################################################################
            '============================================================================
            '重组：日类波动体系
            '============================================================================
            谕组(X, 位谕of日波叠幅) = 组结算(X, 基位日类 + 位os龟叠幅0)
            '-------------------------------------------------
            '注20240218：上身衡量的是今日冲高后现在还保留的比例。
            谕组(X, 位谕of日波上身) = 0
            If 日类今高 - 日类前收 > 0 Then
                谕组(X, 位谕of日波上身) = 100 * Round((日类今收 - 日类前收) / (日类今高 - 日类前收), 2)
            End If
            '-------------------------------------------------
            If 日类前收 > 0 Then
                谕组(X, 位谕of日波BSPR) = Round((日类今收 / 日类前收 - 1) * 100, 1)
                谕组(X, 位谕of日波BSOR) = Round((日类今开 / 日类前收 - 1) * 100, 1)
                谕组(X, 位谕of日波BSLR) = Round((日类今低 / 日类前收 - 1) * 100, 1)
                谕组(X, 位谕of日波BSHR) = Round((日类今高 / 日类前收 - 1) * 100, 1)
                谕组(X, 位谕of日波BSKR) = Round((日类今高 - 日类今低) / 日类前收 * 100, 1)
            End If
            '-------------------------------------------------
            '价格偏差
            If 日类JZ > 0 Then 谕组(X, 位谕of日波BSPZ) = 1 * Round((日类今收 / 日类JZ - 1) * 100, 1)
            If 日类JA > 0 Then 谕组(X, 位谕of日波BSPA) = 1 * Round((日类今收 / 日类JA - 1) * 100, 1)
            If 日类JB > 0 Then 谕组(X, 位谕of日波BSPB) = 1 * Round((日类今收 / 日类JB - 1) * 100, 1)
            If 日类JC > 0 Then 谕组(X, 位谕of日波BSPC) = 1 * Round((日类今收 / 日类JC - 1) * 100, 1)
            '============================================================================
'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@




'@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'########################################################################################
'########################################################################################
'宏观衍生：月参系
'醍醐灌顶20240208：总体来讲，月线作用不大，变化太慢，可以被周类信息所替代。
'醍醐灌顶20240208：【月德横类】变化过于缓慢，完全没有参考价值，废弃。
'########################################################################################
'########################################################################################
            '============================================================================
            '核心状态
            '============================================================================
            谕组(X, 位谕of月道层类) = 组结算(X, 基位月类 + 位os基层类)
            谕组(X, 位谕of月道横类) = 组结算(X, 基位月类 + 位os基横类)
            谕组(X, 位谕of月道竖态) = 组结算(X, 基位月类 + 位os基竖态)
            '============================================================================
            '工具箱
            '============================================================================
            谕组(X, 位谕of月管上符串) = 组结算(X, 基位月类 + 位os具上符串)
            谕组(X, 位谕of月管中符串) = 组结算(X, 基位月类 + 位os具中符串)
            谕组(X, 位谕of月管并符串) = 组结算(X, 基位月类 + 位os具并符串)
            谕组(X, 位谕of月道尊BTIB) = 组结算(X, 基位月类 + 位os具BTIB)
            谕组(X, 位谕of月道尊比柱) = 组结算(X, 基位月类 + 位os具比柱JB)
            '============================================================================
            '月奏
            '============================================================================
            谕组(X, 位谕of月道奏启) = 组结算(X, 基位月类 + 位os奏丘启XCBA)
            谕组(X, 位谕of月道奏数交BC) = 组结算(X, 基位月类 + 位os奏数交BC总)
            谕组(X, 位谕of月道奏数BC叉BA) = 组结算(X, 基位月类 + 位os奏数BC叉BA)
            '============================================================================
''########################################################################################
''########################################################################################
''宏观衍生：日道奏
''########################################################################################
''########################################################################################
'            '============================================================================
'            '日类丘启
'            '============================================================================
'            谕组(X, 位谕of日道奏启) = 组结算(X, 基位日类 + 位os奏丘启XEDC)
'            If 谕组(X, 位谕of日道奏启) = "DEce" Or 谕组(X, 位谕of日道奏启) = "DEec" Then
'                谕组(X, 位谕of日道奏数DE叉DC) = 组结算(X, 基位日类 + 位os奏数DE叉DC)
'                谕组(X, 位谕of日道奏数DE叉CB) = 组结算(X, 基位日类 + 位os奏数DE叉CB)
'                谕组(X, 位谕of日道奏数DE叉EZ) = 组结算(X, 基位日类 + 位os奏数DE叉EZ)
'                谕组(X, 位谕of日道奏数DE叉DZ) = 组结算(X, 基位日类 + 位os奏数DE叉DZ)
'            ElseIf 谕组(X, 位谕of日道奏启) = "CEde" Then
'                谕组(X, 位谕of日道奏数CE叉DC) = 组结算(X, 基位日类 + 位os奏数CE叉DC)
'                谕组(X, 位谕of日道奏数CE叉CB) = 组结算(X, 基位日类 + 位os奏数CE叉CB)
'                谕组(X, 位谕of日道奏数CE叉EZ) = 组结算(X, 基位日类 + 位os奏数CE叉EZ)
'                谕组(X, 位谕of日道奏数CE叉DZ) = 组结算(X, 基位日类 + 位os奏数CE叉DZ)
'            End If
'            If 日类BTCD > 0 Then
'                谕组(X, 位谕of日道奏数CD叉CB) = 组结算(X, 基位日类 + 位os奏数CD叉CB)
'                谕组(X, 位谕of日道奏数CD叉CZ) = 组结算(X, 基位日类 + 位os奏数CD叉CZ)
'            End If
'            If 日类BTBC > 0 Then
'                谕组(X, 位谕of日道奏数BC叉CA) = 组结算(X, 基位日类 + 位os奏数BC叉CA)
'                谕组(X, 位谕of日道奏数BC叉BA) = 组结算(X, 基位日类 + 位os奏数BC叉BA)
'            End If
'            '============================================================================
'########################################################################################
'########################################################################################
'宏观衍生：周奏系
'########################################################################################
'########################################################################################
            '============================================================================
            '别阴阳分界标志
            '注意：由于M2c持续时间远大于M1bM1w，且确定性更大，所以没有必要为迁就M1b而将分界改为BTCE或其他。
            '============================================================================
            谕组(X, 位谕of周奏数交CD) = 组结算(X, 基位周类 + 位os奏数交CD总)
            '============================================================================
            '丘启：WJEDC环境下ZD交叉情况
            '基于理念：周类tCE+数叉ZD，主要用于识别尾部。反之，也是底部标志。
            '识别顶部：在BTDE>0情况下，WJZ多次下探WJD，就是顶部标示，特别是M2i/M3h/M3u。当ZD多次交叉后，再出现w2e/w3v就要更加注意逃顶。
            '识别底部：月级别M6v只是基本要求，必须多次出现ZD交叉，M5e/M6v才具有意义。
            '============================================================================
            谕组(X, 位谕of周奏启) = 组结算(X, 基位周类 + 位os奏丘启XEDC)
            '----------------------------------------------------------------------------
            '注意20230101：进行赋值，注意不要添加条件
            '----------------------------------------------------------------------------
            谕组(X, 位谕of周奏数DE叉DC) = 组结算(X, 基位周类 + 位os奏数DE叉DC)
            谕组(X, 位谕of周奏数DE叉CB) = 组结算(X, 基位周类 + 位os奏数DE叉CB)
            谕组(X, 位谕of周奏数DE叉EZ) = 组结算(X, 基位周类 + 位os奏数DE叉EZ)
            谕组(X, 位谕of周奏数DE叉DZ) = 组结算(X, 基位周类 + 位os奏数DE叉DZ)
            谕组(X, 位谕of周奏数CE叉DC) = 组结算(X, 基位周类 + 位os奏数CE叉DC)
            谕组(X, 位谕of周奏数CE叉CB) = 组结算(X, 基位周类 + 位os奏数CE叉CB)
            谕组(X, 位谕of周奏数CE叉EZ) = 组结算(X, 基位周类 + 位os奏数CE叉EZ)
            谕组(X, 位谕of周奏数CE叉DZ) = 组结算(X, 基位周类 + 位os奏数CE叉DZ)
            If 周类BTCD > 0 Then
                谕组(X, 位谕of周奏数CD叉CB) = 组结算(X, 基位周类 + 位os奏数CD叉CB)
            End If
            '============================================================================
            '信息部：周奏
            '包含：丘奏。重要均线下探，包括DZ相交、DC相交、EC相交
            '衍生关系：丘奏(月阶为7/6)=>道奏(全部月阶)
            '============================================================================
            谕组(X, 位谕of周奏丘) = ""
            '-----------------------------------------------------------------
            If 周类BTDE > 0 And 周类BTCE > 0 Then   '限制月阶为7/6，包含DEce/CEde
                If 谕组(X, 位谕of周奏启) = "CEde" Then
                        '-----------------------------------------------------
                        '筛选：丘启CE劫DC已
                        If 谕组(X, 位谕of周奏数CE叉DC) < 0 Then
                                If 谕组(X, 位谕of周奏数CD叉CB) < -1 Then
                                    谕组(X, 位谕of周奏丘) = "启CE【DC已CB多】"
                                ElseIf 谕组(X, 位谕of周奏数CD叉CB) = -1 Then
                                    谕组(X, 位谕of周奏丘) = "启CE【DC已CB一】"
                                Else
                                    谕组(X, 位谕of周奏丘) = "启CE【DC已CB〇】"
                                End If
                        '-----------------------------------------------------
                        '筛选：丘启CE劫DC〇
                        Else
                                If 谕组(X, 位谕of周奏数CE叉CB) < -1 Then
                                    谕组(X, 位谕of周奏丘) = "启CE【DC〇CB多】"
                                ElseIf 谕组(X, 位谕of周奏数CE叉CB) = -1 Then
                                    谕组(X, 位谕of周奏丘) = "启CE【DC〇CB一】"
                                Else
                                    谕组(X, 位谕of周奏丘) = "启CE【DC〇CB〇】"
                                End If
                        End If
                        '-----------------------------------------------------
