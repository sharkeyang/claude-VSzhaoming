'########################################################################################
'########################################################################################
'中观衍生：柱排
'[柱排]与[柱型]区别：柱排只考虑柱，未添加均线；柱型添加均线JA，所以更复杂。
'########################################################################################
'########################################################################################
            '============================================================================
            '【位谕of周层柱排】仅适用于【顶JA】管内判断方向，其余区域不适用。
            '思路20240923：在【周层阶段】确定的可操作范围内，根据并符区分【升链】【跌链】【余链】。
            '============================================================================
                    '----------------------------------------------------------------
                    '根据【并符】判断是否为【升链】：主要方向为升
                    '----------------------------------------------------------------
                    If Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符升连 Then
                        谕组(X, 位谕of周层柱排) = "升.尾连" & 常枚并符升连 & 常枚并符升连
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符升连 Then
                        谕组(X, 位谕of周层柱排) = "升.尾连" & 常枚并符升吞 & 常枚并符升连
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符升连 Then
                        谕组(X, 位谕of周层柱排) = "升.尾连" & 常枚并符升孕 & 常枚并符升连
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升吞 Then
                        谕组(X, 位谕of周层柱排) = "升.尾吞" & 常枚并符跌孕 & 常枚并符升吞
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌孕 Then
                        谕组(X, 位谕of周层柱排) = "升.尾反孕" & 常枚并符升连 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕 Then
                        谕组(X, 位谕of周层柱排) = "升.尾反孕" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕
                    '----------------------------------------------------------------
                    '根据【并符】判断是否为【跌链】：主要方向为跌
                    '----------------------------------------------------------------
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符跌连 Then
                        谕组(X, 位谕of周层柱排) = "跌.尾连" & 常枚并符跌连 & 常枚并符跌连
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符跌连 Then
                        谕组(X, 位谕of周层柱排) = "跌.尾连" & 常枚并符跌吞 & 常枚并符跌连
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符跌连 Then  '很可能向上
                        谕组(X, 位谕of周层柱排) = "跌.尾连" & 常枚并符跌孕 & 常枚并符跌连
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌吞 Then
                        谕组(X, 位谕of周层柱排) = "跌.尾吞" & 常枚并符升孕 & 常枚并符跌吞
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升孕 Then
                        谕组(X, 位谕of周层柱排) = "跌.尾反孕" & 常枚并符跌连 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升孕 Then
                        谕组(X, 位谕of周层柱排) = "跌.尾反孕" & 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升孕
                    '----------------------------------------------------------------
                    '人排：需要手动判断方向，一般与均线同向
                    '引入均线分不同情况，给与不同的归类，不要一概而论需要人工判断
                    '----------------------------------------------------------------
                    '特殊情况：升连后吞：/升连跌吞/升连跌吞升孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌吞 Then  '很可能向上
                        谕组(X, 位谕of周层柱排) = "(升)人.连后吞" & 常枚并符升连 & 常枚并符跌吞
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕 Then
                        谕组(X, 位谕of周层柱排) = "(升)人.连后吞" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕
                    '---------------------------------------------
                    '特殊情况：跌连后吞：/跌连升吞/跌连升吞跌孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升吞 Then  '很可能向上
                        谕组(X, 位谕of周层柱排) = "(跌)人.连后吞" & 常枚并符跌连 & 常枚并符升吞
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符跌连 & 常枚并符升吞 & 常枚并符跌孕 Then
                        谕组(X, 位谕of周层柱排) = "(跌)人.连后吞" & 常枚并符跌连 & 常枚并符升吞 & 常枚并符跌孕
                    '---------------------------------------------
                    '特殊情况：升衔吞吞：巨幅上下波动
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞 Then  '无方向
                        谕组(X, 位谕of周层柱排) = "(升)人.吞吞" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞 & 常枚并符升孕 Then     '无方向
                        谕组(X, 位谕of周层柱排) = "(升)人.吞吞" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符跌吞 _
                        Or Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升吞 & 常枚并符跌吞 & 常枚并符升孕 Then   '无方向
                        谕组(X, 位谕of周层柱排) = "(人)人.吞吞" & "* " & 常枚并符升吞 & 常枚并符跌吞
                    '---------------------------------------------
                    '特殊情况：跌衔吞吞：巨幅上下波动
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞 Then  '无方向
                        谕组(X, 位谕of周层柱排) = "(跌)人.吞吞" & 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞 & 常枚并符跌孕 Then  '无方向
                        谕组(X, 位谕of周层柱排) = "(跌)人.吞吞" & 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符升吞 _
                        Or Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符跌吞 & 常枚并符升吞 & 常枚并符跌孕 Then  '无方向
                        谕组(X, 位谕of周层柱排) = "(人)人.吞吞" & "* " & 常枚并符跌吞 & 常枚并符升吞
                    '---------------------------------------------
                    '特殊情况：孕孕：小幅上下波动
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符升孕 Then    '无方向
                        谕组(X, 位谕of周层柱排) = "(升)人.孕孕" & 常枚并符跌孕 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕 & 常枚并符升孕 Then   '无方向
                        谕组(X, 位谕of周层柱排) = "(升)人.孕孕" & 常枚并符跌孕 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符跌连 & 常枚并符升孕 & 常枚并符跌孕 Then   '无方向
                        谕组(X, 位谕of周层柱排) = "(跌)人.孕孕" & 常枚并符升孕 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升孕 & 常枚并符跌孕 Then   '无方向
                        谕组(X, 位谕of周层柱排) = "(跌)人.孕孕" & 常枚并符升孕 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升孕 _
                        Or Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌孕 Then
                        谕组(X, 位谕of周层柱排) = "(人)人.孕孕" & 常枚并符跌孕 & 常枚并符升孕
                    Else
                        谕组(X, 位谕of周层柱排) = "错.未赋值"
                    End If
                '------------------------------------------------------------------------
                '提示：并符
                '------------------------------------------------------------------------
                    If Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符跌连 Then
                        谕组(X, 位谕of周层柱排) = 谕组(X, 位谕of周层柱排) & "." & 常枚并符跌连 & (-1 * 组结算(X, 基位周类 + 位osBTPR0))
                    ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符升连 Then
                        谕组(X, 位谕of周层柱排) = 谕组(X, 位谕of周层柱排) & "." & 常枚并符升连 & 组结算(X, 基位周类 + 位osBTPR0)
                    End If
            '============================================================================
'########################################################################################
            '============================================================================
            '【位谕of日层柱排】仅适用于【顶JA】管内判断方向，其余区域不适用。
            '思路20240923：在【日层阶段】确定的可操作范围内，根据并符区分【升链】【跌链】【余链】。
            '============================================================================
                    '----------------------------------------------------------------
                    '根据【并符】判断是否为【升链】：主要方向为升
                    '----------------------------------------------------------------
                    If Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符升连 Then
                        谕组(X, 位谕of日层柱排) = "升.尾连" & 常枚并符升连 & 常枚并符升连
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符升连 Then
                        谕组(X, 位谕of日层柱排) = "升.尾连" & 常枚并符升吞 & 常枚并符升连
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符升连 Then
                        谕组(X, 位谕of日层柱排) = "升.尾连" & 常枚并符升孕 & 常枚并符升连
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升吞 Then
                        谕组(X, 位谕of日层柱排) = "升.尾吞" & 常枚并符跌孕 & 常枚并符升吞
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌孕 Then
                        谕组(X, 位谕of日层柱排) = "升.尾反孕" & 常枚并符升连 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕 Then
                        谕组(X, 位谕of日层柱排) = "升.尾反孕" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕
                    '----------------------------------------------------------------
                    '根据【并符】判断是否为【跌链】：主要方向为跌
                    '----------------------------------------------------------------
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符跌连 Then
                        谕组(X, 位谕of日层柱排) = "跌.尾连" & 常枚并符跌连 & 常枚并符跌连
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符跌连 Then
                        谕组(X, 位谕of日层柱排) = "跌.尾连" & 常枚并符跌吞 & 常枚并符跌连
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符跌连 Then  '很可能向上
                        谕组(X, 位谕of日层柱排) = "跌.尾连" & 常枚并符跌孕 & 常枚并符跌连
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌吞 Then
                        谕组(X, 位谕of日层柱排) = "跌.尾吞" & 常枚并符升孕 & 常枚并符跌吞
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升孕 Then
                        谕组(X, 位谕of日层柱排) = "跌.尾反孕" & 常枚并符跌连 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升孕 Then
                        谕组(X, 位谕of日层柱排) = "跌.尾反孕" & 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升孕
                    '----------------------------------------------------------------
                    '人排：需要手动判断方向，一般与均线同向
                    '引入均线分不同情况，给与不同的归类，不要一概而论需要人工判断
                    '----------------------------------------------------------------
                    '特殊情况：升连后吞：/升连跌吞/升连跌吞升孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌吞 Then  '很可能向上
                        谕组(X, 位谕of日层柱排) = "(升)人.连后吞" & 常枚并符升连 & 常枚并符跌吞
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕 Then
                        谕组(X, 位谕of日层柱排) = "(升)人.连后吞" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕
                    '---------------------------------------------
                    '特殊情况：跌连后吞：/跌连升吞/跌连升吞跌孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升吞 Then  '很可能向上
                        谕组(X, 位谕of日层柱排) = "(跌)人.连后吞" & 常枚并符跌连 & 常枚并符升吞
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符跌连 & 常枚并符升吞 & 常枚并符跌孕 Then
                        谕组(X, 位谕of日层柱排) = "(跌)人.连后吞" & 常枚并符跌连 & 常枚并符升吞 & 常枚并符跌孕
                    '---------------------------------------------
                    '特殊情况：升衔吞吞：巨幅上下波动
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞 Then  '无方向
                        谕组(X, 位谕of日层柱排) = "(升)人.吞吞" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞 & 常枚并符升孕 Then     '无方向
                        谕组(X, 位谕of日层柱排) = "(升)人.吞吞" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌吞 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符跌吞 _
                        Or Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升吞 & 常枚并符跌吞 & 常枚并符升孕 Then    '无方向
                        谕组(X, 位谕of日层柱排) = "(人)人.吞吞" & "* " & 常枚并符升吞 & 常枚并符跌吞
                    '---------------------------------------------
                    '特殊情况：跌衔吞吞：巨幅上下波动
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞 Then  '无方向
                        谕组(X, 位谕of日层柱排) = "(跌)人.吞吞" & 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞 & 常枚并符跌孕 Then  '无方向
                        谕组(X, 位谕of日层柱排) = "(跌)人.吞吞" & 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升吞 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符升吞 _
                        Or Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符跌吞 & 常枚并符升吞 & 常枚并符跌孕 Then   '无方向
                        谕组(X, 位谕of日层柱排) = "(人)人.吞吞" & "* " & 常枚并符跌吞 & 常枚并符升吞
                    '---------------------------------------------
                    '特殊情况：孕孕：小幅上下波动
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符升孕 Then    '无方向
                        谕组(X, 位谕of日层柱排) = "(升)人.孕孕" & 常枚并符跌孕 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕 & 常枚并符升孕 Then   '无方向
                        谕组(X, 位谕of日层柱排) = "(升)人.孕孕" & 常枚并符跌孕 & 常枚并符升孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符跌连 & 常枚并符升孕 & 常枚并符跌孕 Then   '无方向
                        谕组(X, 位谕of日层柱排) = "(跌)人.孕孕" & 常枚并符升孕 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符升孕 & 常枚并符跌吞 & 常枚并符升孕 & 常枚并符跌孕 Then   '无方向
                        谕组(X, 位谕of日层柱排) = "(跌)人.孕孕" & 常枚并符升孕 & 常枚并符跌孕
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升孕 _
                        Or Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌孕 Then
                        谕组(X, 位谕of日层柱排) = "(人)人.孕孕" & 常枚并符跌孕 & 常枚并符升孕
                    Else
                        谕组(X, 位谕of日层柱排) = "错.未赋值"
                    End If
                '------------------------------------------------------------------------
                '提示：并符
                '------------------------------------------------------------------------
                    If Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符跌连 Then
                        谕组(X, 位谕of日层柱排) = 谕组(X, 位谕of日层柱排) & "." & 常枚并符跌连 & (-1 * 组结算(X, 基位日类 + 位osBTPR0))
                    ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符升连 Then
                        谕组(X, 位谕of日层柱排) = 谕组(X, 位谕of日层柱排) & "." & 常枚并符升连 & 组结算(X, 基位日类 + 位osBTPR0)
                    End If
            '============================================================================
'########################################################################################


'注20260607：遍历日级别与周级别柱型，看哪些（柱型预测与实际情况）符合或不符合。找出其中的规律并修正模型。
'注20260607：一个直觉：柱型不只与DJA相关，也与DXAB/DJC相关（例如，DXAB刚正交或上破DJC的枝更有效）。如果能肯定这个猜测，就要按DXAB+DJC重新对柱型进行分类。
'########################################################################################
'########################################################################################
'中观衍生：柱型
'作用：借助均线JA，筛选本柱形态，使得下柱为连升、单阳柱、冲高柱（可以回落为阴柱）。
'########################################################################################
'########################################################################################
            '============================================================================
            '衍生【位谕of日层柱型】：
            '注20250411：根据【日层联类】制定策略，也就是根据【周类信息】制定策略，不要仅根据【日类信息】制定策略。
            '============================================================================
                    '====================================================================
                    '主要针对以下情况，继续提供参考信息：
                    '（0）剔除：不应提供联动细节；剔除DXZC<0
                    '（1）日护丘：依赖DXBC护丘。以DJB作为在DJC之上，且方向向上的辅助条件。
                    '提供以下信息，辅助判断日柱是否会冲高：
                    '（2）日柱排：是否为升排；
                    '（3）日顶型：是否触顶；
                    '====================================================================
                    '信息：DXBC。作为DXCD的拓展护线。
                    '日类须遵从周类操作要点:
                    '   止损：与周类算法保持一致：破WJB退出（日类可优化为破DJD退出）；破WJA双柱退出。例外，对于冲高情况，可在下破DJB处提前退出，退出理由是基于以下理念，冲高时应卖出而未卖。
                    '   介入：WXAB正交；上破WJA双柱。
                    '周类视角：相信下周冲高。把（DJC,顶）看做周管，在管中波动。在周类视角以WJB为操作底线，可以转化为，在日类视角以DXCD作为辅助工具。
                    '辅助护线的级别与作用:
                    '   WXAB（DXCD）地位：操作规则的核心龙骨。其他辅助护线只可增强信心，不可用作止损线。
                    '   DXBC/DXAB护线作用：坚决不能作为止损依据；满足（DJD-DJC-DJB）多头排列时增强信心；不满足多头排列时仅警示不止损，且仅按照DXCD进行操作。
                    '注20251220：将[位谕of日层柱型]作为基础设施，不再先判断条件再进行输出。
                    '====================================================================
                    值of日层柱型 = ""
                        '----------------------------------------------------------------
                        '时段限制：TZA≤-4。镜面映射
                        '----------------------------------------------------------------
                        If 谕组(X, 位谕of日类BTZA) <= -4 Then
                                        值of日层柱型 = ".99线下四"
                         '----------------------------------------------------------------
                        '时段限制：-3≤TZA≤0。镜面映射
                        '----------------------------------------------------------------
                        ElseIf 谕组(X, 位谕of日类BTZA) <= 0 Then
                                If 谕组(X, 位谕of日类BTZA) = -1 Then
                                    If Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符跌连 Then
                                        值of日层柱型 = ".55根贯连待X"
                                    Else         '很可能是围绕均线贯穿
                                        值of日层柱型 = ".55根贯单待A"
                                    End If
                                ElseIf (Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符升孕) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符升连) Then
                                        '注：要解决包含（单鼎后回踩）情况的识别，如果是跌连后回踩，会被以下（特跌排）（特跌栅）识别。
                                        值of日层柱型 = ".52根启踩警"
                                ElseIf (Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符跌连) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌孕) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符跌孕) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌孕) Then
                                        '注：要解决刚突破WJA后（单鼎后衔接升孕或升连）的启动形态，其他跟随在（升连）后的情况会被以下（特跌排）（特跌栅）识别。
                                        值of日层柱型 = ".51根启跌冲"
                                End If
                        '----------------------------------------------------------------
                        '时段限制：3≥TZA＞0。
                        '----------------------------------------------------------------
                        '以下为：枝（特升突）。注意，（特升突）可能转变为（特升排），也可能只是围绕WJA反复贯穿，要寻找能够形成长期升势的特殊情况。
                        ElseIf 谕组(X, 位谕of日类BTZA) <= 3 Then
                                If 谕组(X, 位谕of日类BTZA) = 1 Then
                                    If Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符升连 Then
                                        值of日层柱型 = ".44枝贯连待X"
                                    Else         '很可能是围绕均线贯穿
                                        值of日层柱型 = ".44枝贯单待A"
                                    End If
                                ElseIf (Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符跌孕) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符跌连) Then
                                        '注：要解决包含（单鼎后回踩）情况的识别，如果是升连后回踩，会被以下（特升排）（特升栅）识别。
                                        值of日层柱型 = ".42枝启踩警"
                                ElseIf (Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符升连) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升孕) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符升孕) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升孕) Then
                                        '注：要解决刚突破WJA后（单鼎后衔接跌孕或跌连）的启动形态，其他跟随在（跌连）后的情况会被以下（特升排）（特升栅）识别。
                                        值of日层柱型 = ".41枝启升冲"
                                End If
                        '----------------------------------------------------------------
                        '时段限制：TZA≥4。
                        '----------------------------------------------------------------
                        Else
                                '以下为：梯（特升排）。
                                '主要目的是：寻找WXAB正交情况下，可延续的不存在（/跌吞/跌连）等终止情况的柱排。注意，包含少数（阴阳阴）等可能为顶部标志的情况，需要特殊情况特殊分析。
                                If Right(组结算(X, 基位日类 + 位os具并符串), 1) = 常枚并符升连 Then
                                        值of日层柱型 = ".01梯升连冲" & 常枚并符升连    '属于升排（连阳），期待下柱为（连阳）
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌孕 Then
                                        值of日层柱型 = ".02梯升孕冲" & 常枚并符升连 & 常枚并符跌孕    '属于升排（连阳跌孕），期待下柱为（单阳）
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符升孕 Then
                                        值of日层柱型 = ".03梯升调待" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符升孕
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升吞 Then
                                        值of日层柱型 = ".04梯交调待" & 常枚并符跌孕 & 常枚并符升吞    '属于升排（跌孕升吞），期待下柱为（连阳）
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕 Then
                                        值of日层柱型 = ".05梯交跌警" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕   '属于升排（跌孕升吞跌孕），期待下柱为（单阳）。注意可能是（阴阳阴）
                                '以下为：栏
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌吞 Then
                                        值of日层柱型 = ".15栏调跌警" & 常枚并符升连 & 常枚并符跌吞    '属于人排（连阳跌吞），期待下柱为（冲高）。
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕 Then
                                        值of日层柱型 = ".12栏调孕待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕    '属于人排（连阳跌吞升孕），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符升吞 Then
                                        值of日层柱型 = ".11栏调吞待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符升吞     '属于人排（连阳跌吞升吞），期待下柱为（连阳）。属于四柱栅变体。
                                '以下为：栅（WJA之上）：需等待出现以上信号再介入。
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 Then
                                        值of日层柱型 = ".25栅调跌警" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 Then
                                        值of日层柱型 = ".25栅调跌警" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升孕 Then
                                        值of日层柱型 = ".22栅调孕待" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升孕    '属于跌排（连阳跌孕跌连升孕），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升孕 Then
                                        值of日层柱型 = ".22栅调孕待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升孕    '属于跌排（连阳跌吞跌连升孕），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升吞 Then
                                        值of日层柱型 = ".21栅调吞待" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升吞    '属于跌排（连阳跌孕跌连升吞），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位日类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升吞 Then
                                        值of日层柱型 = ".21栅调吞待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升吞    '属于跌排（连阳跌吞跌连升吞），期待下柱为（连阳）。属于四柱栅变体。
                                '以下为：杂（WJA之上两柱）
                                '判定原则：需要分析“杂”到底包含哪些情况？哪些代表向上？哪些代表向下？
                                '注20251220：针对“杂”，如果柱排包含“跌”，则代表向下；如果柱排包含“升”，则代表向上；否则，代表需要人工判断。
                                Else
                                    If InStr(谕组(X, 位谕of日层柱排), "跌") > 0 Then
                                        值of日层柱型 = ".37杂调跌待"
                                    ElseIf InStr(谕组(X, 位谕of日层柱排), "升") > 0 Then
                                        值of日层柱型 = ".35杂调升待"
                                    Else
                                        值of日层柱型 = ".36杂调人待"
                                    End If
                                End If
                        End If
                    '====================================================================
                    '赋值
                    '====================================================================
                    谕组(X, 位谕of日层柱型) = 值of日层柱型
                    '====================================================================
                    '提示：对于刚上破WJA，提示初始启动
                    '====================================================================
                    If InStr(谕组(X, 位谕of日层柱型), "梯") > 0 _
                    Or InStr(谕组(X, 位谕of日层柱型), "栏") > 0 _
                    Or InStr(谕组(X, 位谕of日层柱型), "栅") > 0 _
                    Or InStr(谕组(X, 位谕of日层柱型), "枝") > 0 Then
