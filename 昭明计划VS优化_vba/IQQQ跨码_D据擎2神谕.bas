            '============================================================================
            '【卖提示】提供更苛刻条件用于【左侧止盈】
            '（0）【卖顶】是否创新高：/触顶否
            '（1）【卖高】是否单柱涨幅大：/高幅
            '（2）【卖宽】是否（哼JC管）过宽过陡：/管宽（哼JC）/陡（均线拉开距离）
            '（3）【卖叠】是否连续涨幅过大/是否连续阳柱：/叠（连续波幅）/连阳数
            '============================================================================
            谕组(X, 位谕of日层盈提示) = ""
            If 日类BTZC > 0 Then
                    '====================================================================
                    '是否触顶：是否创新高
                    '====================================================================
                    If Right(谕组(X, 位谕of日龟顶触), 1) = "高" Then
                        If 组结算(X, 基位日类 + 位os龟BT顶) >= 0 Then
                                '注20240714：在触哼时提示卖出。
                                谕组(X, 位谕of日层盈提示) = 谕组(X, 位谕of日层盈提示) & "a"
                        Else
                                谕组(X, 位谕of日层盈提示) = 谕组(X, 位谕of日层盈提示) & "雀"
                        End If
                    End If
                    '====================================================================
                    '【卖宽】是否（哼JC管）过宽过陡
                    '====================================================================
                    '注：当【管宽】较大，且回撤未过半的时候进行提示。回撤过多就不要提示了
                    If VBA.IsNumeric(谕组(X, 位谕of日层撤哼JC)) = True Then
                    If 谕组(X, 位谕of日层撤哼JC) <= 谕组(X, 位谕of日层宽哼JC) * 0.5 Then
                        If 谕组(X, 位谕of日层宽哼JC) > 20 Then
                            谕组(X, 位谕of日层盈提示) = 谕组(X, 位谕of日层盈提示) & "宽"
                        End If
                    End If
                    End If
                    '------------------------------------------------------------
                    '待解决【陡】如何建模
                    '【陡】偏BSBC过大代表之前有过一大波涨幅。不要参与顶部或尾部。等待均线距离拉近再次蓄势。
                    '待完成：改为利用BSAC来描述【陡】
                    'If 谕组(X, 位谕of日层BSAC) >= 7 Then
                    '        谕组(X, 位谕of日层盈提示) = 谕组(X, 位谕of日层盈提示) & "陡"
                    'End If
                    '====================================================================
                    '【卖连】是否连续涨幅过大/是否连续阳柱
                    '注202409015：【叠】不需要过度考虑，暂时隐藏该列。
                    '====================================================================
                    If 谕组(X, 位谕of日波龄BTPR0) >= 3 Then
                        谕组(X, 位谕of日层盈提示) = 谕组(X, 位谕of日层盈提示) & "连" & 谕组(X, 位谕of日波龄BTPR0)
                    End If
                    '====================================================================
                    '【卖偏】是否单柱涨幅大。抓住单柱冲高进行卖出。
                    '====================================================================
                    If 谕组(X, 位谕of日波BSHR) >= 5 Then
                            谕组(X, 位谕of日层盈提示) = 谕组(X, 位谕of日层盈提示) & "高"    '高幅3就应止盈
                    ElseIf 谕组(X, 位谕of日层BSHA) >= 6 Then
                            谕组(X, 位谕of日层盈提示) = 谕组(X, 位谕of日层盈提示) & "偏"
                    End If
                    '====================================================================
            End If
            '============================================================================
