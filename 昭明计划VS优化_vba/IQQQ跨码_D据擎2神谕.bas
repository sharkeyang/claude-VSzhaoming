'########################################################################################
            '============================================================================
            '周层类
            '============================================================================
            谕组(X, 位谕of周层类合) = 组结算(X, 基位周类 + 位os基层类)
            If InStr(组结算(X, 基位周类 + 位os基层类), 常枚层别管) > 0 Then
                谕组(X, 位谕of周层类IS管) = VBA.Replace(组结算(X, 基位周类 + 位os基层类), 常枚层别管, "")
            Else
                谕组(X, 位谕of周层类IS粒) = 组结算(X, 基位周类 + 位os基层类)
            End If
            '============================================================================
            '周德状态
            '主要原则：区分【鸡蛋挑骨头】与【沙子里淘金】
