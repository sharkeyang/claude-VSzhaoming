                                End If
                                '代表是否频繁贯穿WJA。
                                If InStr(谕组(X, 位谕of周层护型), "暂") > 0 Then
                                        谕组(X, 位谕of周层下柱冲高提示) = 谕组(X, 位谕of周层下柱冲高提示) & ".暂"
                                End If
                                '----------------------------------------------------------------
                            End If
                    End If
                End If
