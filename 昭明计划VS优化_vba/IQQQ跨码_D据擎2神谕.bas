            '============================================================================
            '【周道月阶】
            '一定要抓住大趋势【月阶7】【月阶3】
            '============================================================================
            谕组(X, 位谕of周道月阶) = IIf(周类JC >= 周类JD, 1, 0) + IIf(周类JC >= 周类JE, 2, 0) + IIf(周类JD >= 周类JE, 4, 0)
            '============================================================================
            '宏观指标【权重】，依靠WJCDE对全时间进行划分，基本要求时WXZC＞0。框定是否能够进行买卖操作的区域
            '注：以均线为基准，以WJC作为是否清仓线，以WJC至上的WJB作为警戒线。
            '【倒逼定理】根据上涨倒逼定理，上涨阶段必然有【WXCD正】【WXBC正】【Ga顶型】，其中【WXBC正】最重要，要躲避底部、顶部，其余皆可以持有。
            '============================================================================
                '------------------------------------------------------------------------
                '基本要求：双向分布
                '注20260321：区分【可看】【可持】【可龙】。在WJC之上都属于【可看】；其中剔除/C6/X4/X0后为【可持】，因为这些状态为WXCD负交；在【可持】中，当处于龙管为【可龙】。
                '注20260526：区分“金银铜屎尿屁”
                '------------------------------------------------------------------------
                If 谕组(X, 位谕of周道月阶) = 7 Then
                        If 周类BTZC > 0 Then
                                If Left$(谕组(X, 位谕of周层界), 1) = "初" Or Left$(谕组(X, 位谕of周层界), 1) = "储" Then
                                    谕组(X, 位谕of周道月势) = "C7顶震"
                                Else
                                    谕组(X, 位谕of周道月势) = "A7升主"
                                End If
                        Else
                                If 周类BTZD < 0 Then
                                    谕组(X, 位谕of周道月势) = "Z7顶震"
                                Else
                                    谕组(X, 位谕of周道月势) = "X7顶震"
                                End If
                        End If
                ElseIf 谕组(X, 位谕of周道月阶) = 0 Then
                        If 周类BTZC > 0 Then
                                If 周类BTZD > 0 Then
                                    谕组(X, 位谕of周道月势) = "A0底震"
                                Else
                                    谕组(X, 位谕of周道月势) = "C0底震"
                                End If
                        Else
                                If Left$(谕组(X, 位谕of周层界), 1) = "初" Or Left$(谕组(X, 位谕of周层界), 1) = "破" Then
                                    谕组(X, 位谕of周道月势) = "X0底震"
                                Else
                                    谕组(X, 位谕of周道月势) = "Z0降主"
                                End If
                        End If
                ElseIf 谕组(X, 位谕of周道月阶) = 6 Then
                        谕组(X, 位谕of周道月势) = IIf(周类BTZC > 0, "C6顶震", "Z6降主")
                ElseIf 谕组(X, 位谕of周道月阶) = 1 Then
                        谕组(X, 位谕of周道月势) = IIf(周类BTZC > 0, "A1升主", "X1底震")
                ElseIf 谕组(X, 位谕of周道月阶) = 4 Then
                        谕组(X, 位谕of周道月势) = IIf(周类BTZC > 0, "C4降震", "Z4降主")
                ElseIf 谕组(X, 位谕of周道月阶) = 3 Then
                        谕组(X, 位谕of周道月势) = IIf(周类BTZC > 0, "A3升主", "X3升震")
                Else
                        谕组(X, 位谕of周道月势) = "ERROR分类错误"
                End If
            '============================================================================
