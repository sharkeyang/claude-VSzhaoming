                        值层界 = "储局1v"
            ElseIf ARROS(位os局ZABC) = "6w" Then
                        值层界 = "储局6w"
            ElseIf ARROS(位os局ZABC) = "6v" Then
                        值层界 = "储局6v"
            ElseIf ARROS(位os局ZABC) = "3v" Then
                        值层界 = "破局3v"
            ElseIf ARROS(位os局ZABC) = "3w" Then
                        值层界 = "破局3w"
            ElseIf ARROS(位os局ZABC) = "4v" Then
                        值层界 = "_破局4v"
            ElseIf ARROS(位os局ZABC) = "4w" Then
                        值层界 = "_破局4w"
            '----------------------------------------------------------------------------
            '针对JC线上
            '----------------------------------------------------------------------------
            ElseIf Left(ARROS(位os基层类), 1) <> "_" Then
                    '--------------------------------------------------------------------
                    '层G：只要是触顶就有可能是主升浪。警：经过回车后触顶有可能是诱多。
                    '--------------------------------------------------------------------
                    If InStr(ARROS(位os基层类), 常枚层类G) > 0 Then
                            If ARROS(位osBTZA) < 0 Then
                                值层界 = "主Ge根"
                            ElseIf ARROS(位os龟BT顶) > 0 Then
                                值层界 = "主Ga顶"          '需要区分是否存在【震荡中a触】【中间是否多处未触顶】
                            ElseIf ARROS(位os龟BT顶) >= -2 Then
                                值层界 = "主Gb〇"
                            ElseIf ARROS(位osBTZA) >= -1 * ARROS(位os龟BT顶) Then
                                值层界 = "主Gc〇"
                            Else
                                值层界 = "主Gd芽"       '虎雀。是否区分【雀】【在WJA上三柱】
                            End If
                    '--------------------------------------------------------------------
                    '层A：主要看均线排列，如果没有回撤站稳步骤很可能是试仓。
                    '--------------------------------------------------------------------
                    ElseIf InStr(ARROS(位os基层类), 常枚层类A) > 0 Then
                            '以下为：/1be/2cde
                            If ARROS(位osBTZA) < 0 Then
                                值层界 = "初Ae根"
                            ElseIf ARROS(位os龟BT顶) > 0 Then
                                值层界 = "初Aa顶"          '需要区分是否存在【震荡中a触】【中间是否多处未触顶】
                            ElseIf ARROS(位os龟BT顶) >= -2 Then
                                值层界 = "初Ab〇"
                            ElseIf ARROS(位osBTZA) >= -1 * ARROS(位os龟BT顶) Then
                                值层界 = "初Ac〇"
                            Else
                                值层界 = "初Ad芽"       '虎雀。是否区分【雀】【在WJA上三柱】
                            End If
                    '--------------------------------------------------------------------
                    '层BCD：主要看均线排列与触哼。
                    '--------------------------------------------------------------------
                    Else
                            值层界 = "再" & Left(ARROS(位os基层类), 1)
                            If ARROS(位osBTZA) < 0 Then
                                值层界 = 值层界 & "e根"
                            ElseIf ARROS(位os龟BT顶) > 0 Then
                                值层界 = 值层界 & "a顶"     '不一定是多头排列
                            ElseIf ARROS(位os龟BT顶) >= -2 Then
                                值层界 = 值层界 & "b〇"
                            Else
                                值层界 = 值层界 & "d芽"
                            End If
                    End If
            '----------------------------------------------------------------------------
            '针对JC线下
            '----------------------------------------------------------------------------
            Else
                    '--------------------------------------------------------------------
                    '层G：只要是触顶就有可能是主升浪。警：经过回车后触顶有可能是诱多。
                    '--------------------------------------------------------------------
                    If InStr(ARROS(位os基层类), 常枚层类G) > 0 Then
                            If ARROS(位os龟BT底) > 0 Then
                                值层界 = "_主Ga底"
                            ElseIf ARROS(位osBTZA) > 0 Then
                                值层界 = "_主Ge根"
                            ElseIf ARROS(位os龟BT底) >= -2 Then
                                值层界 = "_主Gb〇"
                            ElseIf ARROS(位osBTZA) <= -1 * ARROS(位os龟BT底) Then
                                值层界 = "_主Gc〇"
                            Else
                                值层界 = "_主Gd芽"
                            End If
                    '--------------------------------------------------------------------
                    '层A：主要看均线排列，如果没有回撤站稳步骤很可能是试仓。
                    '--------------------------------------------------------------------
                    ElseIf InStr(ARROS(位os基层类), 常枚层类A) > 0 Then
                            '------------------------------------------------------------
                            '以下为：/4be/5cde
                            If ARROS(位os龟BT底) > 0 Then
                                值层界 = "_初Aa底"          '需要区分是否存在【震荡中a触】【中间是否多处未触顶】
                            ElseIf ARROS(位osBTZA) > 0 Then
                                值层界 = "_初Ae根"
                            ElseIf ARROS(位os龟BT底) >= -2 Then
                                值层界 = "_初Ab〇"
                            ElseIf ARROS(位osBTZA) <= -1 * ARROS(位os龟BT底) Then
                                值层界 = "_初Ac〇"
                            Else
                                值层界 = "_初Ad芽"       '虎雀。是否区分【雀】【在WJA上三柱】
                            End If
                    '--------------------------------------------------------------------
                    '层BCD：主要看均线排列与触哼。
                    '--------------------------------------------------------------------
                    Else
                            值层界 = "_再" & Mid(ARROS(位os基层类), 2, 1)
                            If ARROS(位os龟BT底) > 0 Then
                                值层界 = 值层界 & "a底"
                            ElseIf ARROS(位osBTZA) > 0 Then
                                值层界 = 值层界 & "e根"
                            ElseIf ARROS(位os龟BT底) >= -2 Then
                                值层界 = 值层界 & "b〇"
                            Else
                                值层界 = 值层界 & "d芽"
                            End If
                    End If
                    '--------------------------------------------------------------------
            End If
            '----------------------------------------------------------------------------
            ARROS(位os层界) = 值层界
            '============================================================================
            '============================================================================
            '层护型
            '注20240911：【层护型】用于指引大势，所以将WJC与WJB作为核心均线，负责处置在管中行进的节奏。WJA上下都属于可持。
            '             '没有好坏之论，要把不是机会或陷阱的提示放在这个变量
            '             '持有范围是：WBTZC>0或(WBTZB>0且C>WJC)。
            '             '参考范围是：WBTZC>0或WBTZB>0。
            '============================================================================
            '============================================================================
                值层护型 = ""
                '------------------------------------------------------------------------
                '位1：层段
                '正一段：（导致WXAB正交）或（上破WJA且WTZA≥4）
                '正二段：WXZB>0且WTZA≤3
                '正三段：WTZB＜0
                '------------------------------------------------------------------------
                If ARROS(位osBTAB) > 0 Then
                        If ARROS(位osBTZB) < 0 Then
                            值层护型 = 值层护型 & "c丙"
                        ElseIf ARROS(位osBTZA) < 0 Then
                            值层护型 = 值层护型 & "b乙"
                        'ElseIf ARROS(位osBTZA) <= 3 And ARROS(位osBTZA) < ARROS(位osBTAB) Then
                        ElseIf ARROS(位osBTZA) < ARROS(位osBTAB) Then
                            值层护型 = 值层护型 & "b乙"
                        Else
                            值层护型 = 值层护型 & "a甲"
                        End If
                Else
                        If ARROS(位osBTZB) > 0 Then
                            值层护型 = 值层护型 & "r己"
                        ElseIf ARROS(位osBTZA) > 0 Then
                            值层护型 = 值层护型 & "y戊"
                        'ElseIf ARROS(位osBTZA) >= -3 And ARROS(位osBTZA) > ARROS(位osBTAB) Then
                        ElseIf ARROS(位osBTZA) > ARROS(位osBTAB) Then
                            值层护型 = 值层护型 & "y戊"
                        Else
                            值层护型 = 值层护型 & "z丁"
                        End If
                End If
                '------------------------------------------------------------------------
                '位2：方向
                '------------------------------------------------------------------------
                        If InStr(值层护型, "甲") > 0 _
                        Or InStr(值层护型, "乙") > 0 _
                        Or InStr(值层护型, "己") > 0 Then
                            If ARROS(位osBTZA) < 0 Then
                                值层护型 = 值层护型 & "→"
                            Else
                                值层护型 = 值层护型 & "↗"
                            End If
                        Else
                            值层护型 = 值层护型 & "↘"
                        End If
                '------------------------------------------------------------------------
                '位2：WXAB护。依赖WJB与WJA
                '------------------------------------------------------------------------
                If ARROS(位osBTAB) > 0 Then
                        If ARROS(位osBTZA) > 0 Then
                            值层护型 = 值层护型 & "上"
                        ElseIf ARROS(位osBTZB) > 0 Then
                            值层护型 = 值层护型 & "中" '另外设置变量寻找BTZA<0的机会
                        Else
                            值层护型 = 值层护型 & "下" '另外设置变量寻找BTZA<0的机会
                        End If
                        值层护型 = 值层护型 & ARROS(位osBTAB)
                Else
                        If ARROS(位osBTZB) > 0 Then
                            值层护型 = 值层护型 & "忐" '应该仅仅试仓
                        ElseIf ARROS(位osBTZA) > 0 Then
                            值层护型 = 值层护型 & "忠"
                        Else
                            值层护型 = 值层护型 & "忑" '另外设置变量寻找BTZA<0的机会
                        End If
                        值层护型 = 值层护型 & ARROS(位osBTAB)
                End If
                '------------------------------------------------------------------------
                '分割：重要的持仓信息，在前2位已经总结完毕，后续信息都是展开注释。
                '------------------------------------------------------------------------
                值层护型 = 值层护型 & "."
                '------------------------------------------------------------------------
                '位3：与WJA关系
                '可持状态链：WXZC＞0，WXZB＞0，（WXZA≥2或WXZA=-1），只有在冲高情况下可止盈。
                '分为五类：A（WTZA≥2）Y（WTZA=-1）C（WTZA=1，要判定之前在WJA之下存续多少柱）Z（WTZA≤-2，针对前期冲高情况可退出）X（WTZB＜0）
                '------------------------------------------------------------------------
                If ARROS(位osBTZA) >= 4 Then
                    值层护型 = 值层护型 & "A" & ARROS(位osBTZA)
                ElseIf ARROS(位osBTZA) >= 2 Then
                    值层护型 = 值层护型 & "B" & ARROS(位osBTZA)
                ElseIf ARROS(位osBTZA) = 1 Then
                    值层护型 = 值层护型 & "I"
                ElseIf ARROS(位osBTZA) = -1 Then
                    值层护型 = 值层护型 & "Y"
                Else    'If ARROS(位osBTZA) <= -2 Then
                    值层护型 = 值层护型 & "Z" & ARROS(位osBTZA)    '注20251117：按WJB为止损线不需要退出；但下破WJA两柱代表已形成下降趋势，所以仿照“×”写为“X”
                End If
                值层护型 = 值层护型 & ARROS(位osBTZA暂下破)
            '----------------------------------------------------------------------------
            ARROS(位os层护型) = 值层护型
            '============================================================================
            '============================================================================
            '层地型
            '作用：比柱型更有效描述所处环境。
            '============================================================================
            '============================================================================
                值层地型 = ""
                '------------------------------------------------------------------------
                '位1：区分<周地型>，针对WJA。
                '------------------------------------------------------------------------
                        '----------------------------------------------------------------
                        '20260118：分别用顶与WJA的特殊情况，用来修饰层[主]。之所以把WJA的修饰放在此处，而非用来修饰“龙猪”，是因为“层主”已经过滤了很多WXAB相交的异常情况（已放入层再）。
                        '----------------------------------------------------------------
                        '20260221：根据前四位所含柱型进行<周地型>定义。
                        '异无：全为QOov
                        '异栏：只有一个V，其余全为QOov
                        '异栅：只有一个W，其余全为QOovV
                        '异杂
                        '----------------------------------------------------------------
                        If ARROS(位osBTZA) >= 4 Then
                                '--------------------------------------------------------
                                '统计异常
                                '--------------------------------------------------------
                                countV = 0
                                countW = 0
                                ' 遍历前四位，统计数量
                                For i = 2 To 5
                                    Select Case Mid(ARROS(位os具并符串), i, 1)
                                        Case "V"
                                            countV = countV + 1
                                        Case "W"
                                            countW = countW + 1
                                    End Select
                                Next i
                                '--------------------------------------------------------
                                ' 第三步：根据新规则匹配返回结果
                                ' 规则1：全是QOov（无V/W，且无非法字符）
                                If countV = 0 And countW = 0 Then
                                    值层地型 = 值层地型 & "0橅"
                                ' 规则2：仅含一个V，其余为QOov（V=1、W=0，且无非法字符）
                                ElseIf countV = 1 And countW = 0 Then
                                    值层地型 = 值层地型 & "1柜"
                                ' 规则3：仅含一个W(VW或vW)，其余为QOov（W=1、V≤1，且无非法字符）
                                ElseIf countV <= 1 And countW = 1 Then
                                    值层地型 = 值层地型 & "2栅"
                                ' 其他情况保持默认的"含杂"
                                Else
                                    值层地型 = 值层地型 & "3桮"
                                End If
                        '----------------------------------------------------------------
                        '针对：上破JA三柱以内
                        '----------------------------------------------------------------
                        ElseIf ARROS(位osBTZA) >= 0 Then
                            If ARROS(位osBTZA暂下破) = "暂" Then
                                值层地型 = 值层地型 & "4暂"
                            Else
                                值层地型 = 值层地型 & "4蛀"
                            End If
                        ElseIf ARROS(位osBTZA) >= -3 Then
                            If ARROS(位osBTZA暂下破) = "暂" Then
                                值层地型 = 值层地型 & "5暂"
                            Else
                                值层地型 = 值层地型 & "5蛀"       ''重新结算
                            End If
                        '----------------------------------------------------------------
                        Else
                                '--------------------------------------------------------
                                '统计异常
                                '--------------------------------------------------------
                                countO = 0
                                countQ = 0
                                ' 遍历前四位，统计数量
                                For i = 2 To 5
                                    Select Case Mid(ARROS(位os具并符串), i, 1)
                                        Case "O"
                                            countO = countO + 1
                                        Case "Q"
                                            countQ = countQ + 1
                                    End Select
                                Next i
                                '--------------------------------------------------------
                                ' 第三步：根据新规则匹配返回结果
                                ' 规则1：全是QOov（无V/W，且无非法字符）
                                If countO = 0 And countQ = 0 Then
                                    值层地型 = 值层地型 & "9妩"
                                ' 规则2：仅含一个V，其余为QOov（V=1、W=0，且无非法字符）
                                ElseIf countO = 1 And countQ = 0 Then
                                    值层地型 = 值层地型 & "8姖"
                                ' 规则3：仅含一个Q（OQ或oQ）
                                ElseIf countO <= 1 And countQ = 1 Then
                                    值层地型 = 值层地型 & "7姗"
                                ' 其他情况保持默认的"含杂"
                                Else
                                    值层地型 = 值层地型 & "6娝"
                                End If
                                '--------------------------------------------------------
                        End If
            '----------------------------------------------------------------------------
            ARROS(位os层地型) = 值层地型
            '============================================================================
'########################################################################################



'########################################################################################
'##################################     微观衍生     ####################################
'##################################   龟类衍生指标   ####################################
'########################################################################################


'########################################################################################
'##################################     微观衍生     ####################################
'##################################   竖态衍生指标   ####################################
'########################################################################################
            '============================================================================
            '竖态
            '算法目标：突出关键局类的机阱。核心是【中符】研究柱与JA关系【并符】研究柱与柱关系。
            '============================================================================
            值当中符 = ARROS(位os具中符0)
            值当并符 = ARROS(位os具并符0)
            值局类 = ARROS(位os局ZABC)
            '----------------------------------------------------------------------------
            '初始化：常态提供【中符】【并符】并针对所处局类提示机阱。
            '----------------------------------------------------------------------------
            值竖态 = ""
            值竖态 = 值竖态 & 值当中符
            值竖态 = 值竖态 & 值当并符
            '----------------------------------------------------------------------------
            If 值局类 = "2c" Then
                    If ARROS(位osBTZA) = 1 Then
                            值竖态 = 值竖态 & "鼎首"            '靠近JA（须谨慎）
                    ElseIf 值当并符 = 常枚并符升连 Then
                        '连续阳柱情况：前置状态为2c/1b/2i/3h
                        If 值当中符 = 常枚中符鼎正 Then
                            值竖态 = 值竖态 & "升连鼎继"    '靠近JA（须谨慎）
                        Else
                            值竖态 = 值竖态 & "升连"        '注意逃顶（注意逃顶）
                        End If
                    Else
                        '单独阳柱情况：前一柱为阴柱
                        If 值当中符 = 常枚中符鼎正 Then
                            值竖态 = 值竖态 & "升孕鼎继"    '靠近JA（须谨慎）
                        Else
                            值竖态 = 值竖态 & "升孕"        '不触JA（注意逃顶）
                        End If
                    End If
            ElseIf 值局类 = "2d" Then
                    If 值当中符 = 常枚中符薡反 Then
                            值竖态 = 值竖态 & "薡"
                    ElseIf 值当并符 = 常枚并符跌连 Then
                            值竖态 = 值竖态 & "跌连"
                    ElseIf 值当并符 = 常枚并符跌吞 Then
                            值竖态 = 值竖态 & "跌吞"
                    Else
                            值竖态 = 值竖态 & "跌孕"
                    End If
                    '注20231021：【2d.价下破JA】包含在【跌连】【跌单吞前】两种情况中
            '----------------------------------------------------------------------------
            ElseIf 值局类 = "5c" Then
                    If ARROS(位osBTZA) = -1 Then
                            值竖态 = 值竖态 & "薡首"            '靠近JA（须谨慎）
                    ElseIf 值当并符 = 常枚并符跌连 Then
                        '连续阳柱情况：前置状态为2c/1b/2i/3h
                        If 值当中符 = 常枚中符薡反 Then
                            值竖态 = 值竖态 & "跌连鼎继"    '靠近JA（须谨慎）
                        Else
                            值竖态 = 值竖态 & "跌连"        '注意逃顶（注意逃顶）
                        End If
                    Else
                        '单独阳柱情况：前一柱为阴柱
                        If 值当中符 = 常枚中符薡反 Then
                            值竖态 = 值竖态 & "跌孕鼎继"    '靠近JA（须谨慎）
                        Else
                            值竖态 = 值竖态 & "跌孕"        '不触JA（注意逃顶）
                        End If
                    End If
            ElseIf 值局类 = "5d" Then
                    If 值当中符 = 常枚中符鼎正 Then
                            值竖态 = 值竖态 & "鼎正"
                    ElseIf 值当并符 = 常枚并符升连 Then
                            值竖态 = 值竖态 & "升连"
                    ElseIf 值当并符 = 常枚并符升吞 Then
                            值竖态 = 值竖态 & "升吞"
                    Else
                            值竖态 = 值竖态 & "升孕"
                    End If
            '----------------------------------------------------------------------------
            ElseIf 值局类 = "1e" Or 值局类 = "2e" Or 值局类 = "3v" Or 值局类 = "3w" Then
                    If 值当中符 = 常枚中符鼎正 Then
                            值竖态 = 值竖态 & "鼎"
                    ElseIf 值当并符 = 常枚并符升连 Then
                            值竖态 = 值竖态 & "升连"
                    ElseIf 值当并符 = 常枚并符升吞 Then
                            值竖态 = 值竖态 & "升吞"
                    ElseIf 值当并符 = 常枚并符跌连 Then
                            值竖态 = 值竖态 & "跌连"
                    End If
            '----------------------------------------------------------------------------
            ElseIf 值局类 = "1b" _
                Or 值局类 = "1w" _
                Or 值局类 = "6w" _
                Or 值局类 = "1v" _
                Or 值局类 = "6v" _
                Or 值局类 = "2I" _
                Or 值局类 = "3h" _
                Or 值局类 = "2i" _
                Or 值局类 = "3u" _
                Then
                    If 值当中符 = 常枚中符鼎正 Then
                            值竖态 = 值竖态 & "鼎"
                    ElseIf 值当中符 = 常枚中符薡反 Then
                            值竖态 = 值竖态 & "薡"
                    ElseIf 值当并符 = 常枚并符升连 Then
                            值竖态 = 值竖态 & "升连"
                    ElseIf 值当并符 = 常枚并符升吞 Then
                            值竖态 = 值竖态 & "升吞"
                    ElseIf 值当并符 = 常枚并符跌连 Then
                            值竖态 = 值竖态 & "跌连"
                    ElseIf 值当并符 = 常枚并符跌吞 Then
                            值竖态 = 值竖态 & "跌吞"
                    ElseIf 值当并符 = 常枚并符跌孕 Then
                            值竖态 = 值竖态 & "跌孕"
                    End If
            End If
            '----------------------------------------------------------------------------
            ARROS(位os基竖态) = 值竖态
            '============================================================================
'########################################################################################
'##################################     微观衍生     ####################################
'##################################   竖态衍生指标   ####################################
'########################################################################################

'========================================================================================
'返回
'========================================================================================
        STBASE结算引擎_单点衍生核程 = 1
End Function







Function IQQQ跨码展擎_按列神谕区域( _
          ByRef WS As Worksheet _
        , Optional ByVal 基列 As Integer = 1 _
        , Optional ByVal 基行 As Integer = 1 _
        ) As Integer
'========================================================================================
'格式化：全局
'========================================================================================
    '------------------------------------------------------------------------------------
    '列
    '------------------------------------------------------------------------------------
