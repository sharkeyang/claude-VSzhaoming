                            End If
                    End If
            '============================================================================
'########################################################################################
            '============================================================================
            '【位谕of周层柱型】
            '（周层柱型）与（周层柱排）的关系：（柱排）只考虑了柱与柱之间的关系；（柱型）考虑了均线与柱间的关系。
            '思路20240915：在【位谕of周层界】确定的可操作范围内，根据与【WJA柱排列】细分持有位置。前缀为：持、N不主动进入、？待定、s卖出减仓、o机会。
            '注意20240916：对于WJA柱排列，仅关注可能影响丘形状的因素，如/薡/跌连，不要添加其余指示机会或风险的元素。
            '============================================================================
                    '====================================================================
                    '设置【位谕of周层柱型】：只针对有可能下柱冲高的情况，其余情况不进行注释（直接舍弃）。已限制操作范围（√口潜）
                    '提供以下信息：
                    '（1）WXAB正交：WJA在WXAB上的位置
                    '（2）WJA丘：标注突破点
                    '（3）对于WJA之上，提供柱排信息。
                    '（4仅参考）顶型：是否触顶触哼
                    '（5仅参考）是否警告止盈：宽偏连
                    '--------------------------------------------------------
                    '顺柱1：重点是关注是否大阳柱或有可能反复震荡
                    '分情况：
                    '（0）出现暴：大阳柱。大涨或过分偏离WJA，要先卖等回调。
                    '（1）如果是顶部区域：可能是诱多，应止盈。
                    '（2）如果是刚突破：分仓进入或等二柱回踩。
                    '--------------------------------------------------------
                    '顺柱2以上：重点是出管三方式
                    '分情况：
                    '（1）上冲出现暴：大阳柱（忽然放大要先退出）逐步放大（×暴叠/×暴宽）
                    '（2）在管中排列打乱：/反吞/连阴/阴阳交错
                    '（3）未大涨始终贴服于WJA：不应再以异作为退出依据，有两种选择：要么不选择贴服或频繁贯穿WJA情况；要么阳柱就出，等待阴柱再入。
                    '注20240211：【久】不是出管方式，但也需要注意上升乏力或准备冲高。
                    '====================================================================
                    '注20251011：【主】的周期不同于过渡期【储初再】。过渡期一般很短，且典型形态类似，要单独列示；而【主】可长可短，所以要对【主】进行更细致的分类。
                    '       根据柱型分类，【根杂枝】均为与WJA相关，要把WXZA劫单独出来作为防止顶震的情况。
                    '       【根杂枝】均为与WJA打交道，有下落如【杂根】，有围绕震荡如【枝】，要把他们与包含升连的主升情况分离。
                    '注20251125：第四位为方向。【冲】代表向上，下柱为/冲高/阳柱；【待】为不确定方向；【警】为向下。
                    '====================================================================
                    值of周层柱型 = ""
                        '----------------------------------------------------------------
                        '时段限制：TZA≤-4。镜面映射
                        '----------------------------------------------------------------
                        If 谕组(X, 位谕of周类BTZA) <= -4 Then
                                        值of周层柱型 = ".99线下四"
                         '----------------------------------------------------------------
                        '时段限制：-3≤TZA≤0。镜面映射
                        '----------------------------------------------------------------
                        ElseIf 谕组(X, 位谕of周类BTZA) <= 0 Then
                                If 谕组(X, 位谕of周类BTZA) = -1 Then
                                    If Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符跌连 Then
                                        值of周层柱型 = ".55根贯连待X"
                                    Else         '很可能是围绕均线贯穿
                                        值of周层柱型 = ".55根贯单待A"
                                    End If
                                ElseIf (Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符升孕) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符升连) Then
                                        '注：要解决包含（单鼎后回踩）情况的识别，如果是跌连后回踩，会被以下（特跌排）（特跌栅）识别。
                                        值of周层柱型 = ".52根启踩警"
                                ElseIf (Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符跌连) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升孕 & 常枚并符跌孕) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升吞 & 常枚并符跌孕) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌孕) Then
                                        '注：要解决刚突破WJA后（单鼎后衔接升孕或升连）的启动形态，其他跟随在（升连）后的情况会被以下（特跌排）（特跌栅）识别。
                                        值of周层柱型 = ".51根启跌冲"
                                End If
                        '----------------------------------------------------------------
                        '时段限制：3≥TZA＞0。
                        '----------------------------------------------------------------
                        '以下为：枝（特升突）。注意，（特升突）可能转变为（特升排），也可能只是围绕WJA反复贯穿，要寻找能够形成长期升势的特殊情况。
                        ElseIf 谕组(X, 位谕of周类BTZA) <= 3 Then
                                If 谕组(X, 位谕of周类BTZA) = 1 Then
                                    If Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符升连 Then
                                        值of周层柱型 = ".44枝贯连待X"
                                    Else         '很可能是围绕均线贯穿
                                        值of周层柱型 = ".44枝贯单待A"
                                    End If
                                ElseIf (Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符跌孕) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符跌吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符跌连) Then
                                        '注：要解决包含（单鼎后回踩）情况的识别，如果是升连后回踩，会被以下（特升排）（特升栅）识别。
                                        值of周层柱型 = ".42枝启踩警"
                                ElseIf (Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符升连) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升孕) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌吞 & 常枚并符升孕) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升吞) _
                                    Or (Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌连 & 常枚并符升孕) Then
                                        '注：要解决刚突破WJA后（单鼎后衔接跌孕或跌连）的启动形态，其他跟随在（跌连）后的情况会被以下（特升排）（特升栅）识别。
                                        值of周层柱型 = ".41枝启升冲"
                                End If
                        '----------------------------------------------------------------
                        '时段限制：TZA≥4。
                        '----------------------------------------------------------------
                        Else
                                '以下为：梯（特升排）。
                                '主要目的是：寻找WXAB正交情况下，可延续的不存在（/跌吞/跌连）等终止情况的柱排。注意，包含少数（阴阳阴）等可能为顶部标志的情况，需要特殊情况特殊分析。
                                If Right(组结算(X, 基位周类 + 位os具并符串), 1) = 常枚并符升连 Then
                                        值of周层柱型 = ".01梯升连冲" & 常枚并符升连    '属于升排（连阳），期待下柱为（连阳）
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌孕 Then
                                        值of周层柱型 = ".02梯升孕冲" & 常枚并符升连 & 常枚并符跌孕    '属于升排（连阳跌孕），期待下柱为（单阳）
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符升孕 Then
                                        值of周层柱型 = ".03梯升调待" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符升孕
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符跌孕 & 常枚并符升吞 Then
                                        值of周层柱型 = ".04梯交调待" & 常枚并符跌孕 & 常枚并符升吞    '属于升排（跌孕升吞），期待下柱为（连阳）
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕 Then
                                        值of周层柱型 = ".05梯交跌警" & 常枚并符跌孕 & 常枚并符升吞 & 常枚并符跌孕   '属于升排（跌孕升吞跌孕），期待下柱为（单阳）。注意可能是（阴阳阴）
                                '以下为：栏
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 2) = 常枚并符升连 & 常枚并符跌吞 Then
                                        值of周层柱型 = ".15栏调跌警" & 常枚并符升连 & 常枚并符跌吞    '属于人排（连阳跌吞），期待下柱为（冲高）。
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕 Then
                                        值of周层柱型 = ".12栏调孕待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符升孕    '属于人排（连阳跌吞升孕），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符升吞 Then
                                        值of周层柱型 = ".11栏调吞待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符升吞     '属于人排（连阳跌吞升吞），期待下柱为（连阳）。属于四柱栅变体。
                                '以下为：栅（WJA之上）：需等待出现以上信号再介入。
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 Then
                                        值of周层柱型 = ".25栅调跌警" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 3) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 Then
                                        值of周层柱型 = ".25栅调跌警" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升孕 Then
                                        值of周层柱型 = ".22栅调孕待" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升孕    '属于跌排（连阳跌孕跌连升孕），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升孕 Then
                                        值of周层柱型 = ".22栅调孕待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升孕    '属于跌排（连阳跌吞跌连升孕），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升吞 Then
                                        值of周层柱型 = ".21栅调吞待" & 常枚并符升连 & 常枚并符跌孕 & 常枚并符跌连 & 常枚并符升吞    '属于跌排（连阳跌孕跌连升吞），期待下柱为（连阳）。属于四柱栅变体。
                                ElseIf Right(组结算(X, 基位周类 + 位os具并符串), 4) = 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升吞 Then
                                        值of周层柱型 = ".21栅调吞待" & 常枚并符升连 & 常枚并符跌吞 & 常枚并符跌连 & 常枚并符升吞    '属于跌排（连阳跌吞跌连升吞），期待下柱为（连阳）。属于四柱栅变体。
                                '以下为：杂（WJA之上两柱）
                                '判定原则：需要分析“杂”到底包含哪些情况？哪些代表向上？哪些代表向下？
                                '注20251220：针对“杂”，如果柱排包含“跌”，则代表向下；如果柱排包含“升”，则代表向上；否则，代表需要人工判断。
                                Else
                                    If InStr(谕组(X, 位谕of周层柱排), "跌") > 0 Then
                                        值of周层柱型 = ".37杂调跌待"
                                    ElseIf InStr(谕组(X, 位谕of周层柱排), "升") > 0 Then
                                        值of周层柱型 = ".35杂调升待"
                                    Else
                                        值of周层柱型 = ".36杂调人待"
                                    End If
                                End If
                        End If
                        '----------------------------------------------------------------
                    '====================================================================
                    '赋值
                    '====================================================================
                    谕组(X, 位谕of周层柱型) = 值of周层柱型
            '============================================================================
            '顶幅：只针对触a情况，提供顶的增幅，勇于风险参考。
            '============================================================================
                    If InStr(谕组(X, 位谕of周层柱型), "顶a") > 0 Then
                        If 组结算(X, 基位周类 + 位os龟结哼幅) > 0 Then
