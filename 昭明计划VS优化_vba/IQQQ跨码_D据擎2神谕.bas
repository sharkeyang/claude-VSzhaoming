                        '注20260117：对于【震】，需要区分“头”“尾”。“头”为站上WJB，但（还未WXAB正交）或（WXAB已正交，未触顶），包括【储初再】刚上破WJC或WJB的情况；“尾”为（从主升回落，但未下破WJB）。
                        '----------------------------------------------------------------
                        ElseIf 日类BTZB < 0 And 日类BTAB > 0 Then
                                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & "__" & "Df头负"
                        ElseIf 日类BTZB < 0 And 日类BTAB < 0 And (组结算(X, 基位日类 + 位os龟BT底) * -1 < 日类BTZB) Then
                                    If 日类BTZA > 0 Then
                                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & "__" & "De头正根"
                                    Else
                                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & "__" & "Dd头正芽"
                                    End If
                        '----------------------------------------------------------------
                        '注20260117：对于【震】，需要区分“头”“尾”。“头”为站上WJB，但（还未WXAB正交）或（WXAB已正交，未触顶），包括【储初再】刚上破WJC或WJB的情况；“尾”为（从主升回落，但未下破WJC）。
                        '----------------------------------------------------------------
                        Else
                                    If 日类BTAB > 0 Then
                                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & "__" & "Ff震负"
                                    ElseIf 日类BTZA > 0 Then
                                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & "__" & "Fe震正根"
                                    ElseIf 日类BTZA <= -1 * 组结算(X, 基位日类 + 位os龟BT底) Then
                                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & "__" & "Fa震正〇"
                                        '注20260131：要区分柱排，升排（可接受）人排（需谨慎）跌排（应退出）。
                                    Else
                                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & "__" & "Fd震正芽"
                                    End If
                        End If
                        '----------------------------------------------------------------
                End If
                '------------------------------------------------------------------------
                '位3：区分日层界
                '------------------------------------------------------------------------
                If Left$(谕组(X, 位谕of日层界), 1) = "破" Then
                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & Left$(谕组(X, 位谕of日层界), 1)
                        '20260109：由于按WXAB进行操盘，是否区分WXAB＞0（W3v）、WXAB＜0（W3w）。但针对WJB丘，凡下破WJB都应退出。
                ElseIf Left$(谕组(X, 位谕of日层界), 1) = "储" Or Left$(谕组(X, 位谕of日层界), 1) = "初" Then
                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & Left$(谕组(X, 位谕of日层界), 1)
                ElseIf Left$(谕组(X, 位谕of日层界), 1) = "再" Then
                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & Left$(谕组(X, 位谕of日层界), 2)
                ElseIf Left$(谕组(X, 位谕of日层界), 1) = "主" Then
                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & Left$(谕组(X, 位谕of日层界), 1)
                '-----------------------------------------------------
                ElseIf Left$(谕组(X, 位谕of日层界), 2) = "_再" Then
                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & Left$(谕组(X, 位谕of日层界), 3)
                Else
                        谕组(X, 位谕of日层波型) = 谕组(X, 位谕of日层波型) & "." & Left$(谕组(X, 位谕of日层界), 2)
                End If
            '============================================================================
