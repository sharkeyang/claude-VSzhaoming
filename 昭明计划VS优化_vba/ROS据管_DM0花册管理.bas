        .Cells(1, 位列花天在池) = "在池"
        '---------------------------------
        .Cells(1, 位列花天量比) = "量比"
        .Cells(1, 位列花天换手) = "换手"
        .Cells(1, 位列花天交量) = "交量"
        .Cells(1, 位列花天流市) = "流市"
        .Cells(1, 位列花天总市) = "总市"
        .Cells(1, 位列花天停牌) = "停牌"
        '---------------------------------
    End With
    '------------------------------------------------------------------------------------
    '边框
    '------------------------------------------------------------------------------------
    With WS花册.Columns(基列)
            With .Columns(位列花天市日).Borders(xlEdgeRight)
                .Color = 常色主黑
                .Weight = xlThin
            End With
            With .Columns(位列花天市场板类).Borders(xlEdgeRight)
                .Color = 常色主黑
                .Weight = xlThin
            End With
            With .Columns(位列花天仓宝福).Borders(xlEdgeLeft)
                .Color = 常色主黑
                .Weight = xlThin
            End With
            With .Columns(位列花天是否上证50).Borders(xlEdgeLeft)
                .Color = 常色主黑
                .Weight = xlThin
            End With
            With .Columns(位列花天今池).Borders(xlEdgeLeft)
                .Color = 常色主靛
                .Weight = xlThin
            End With
            With .Columns(位列花天在池).Borders(xlEdgeRight)
                .Color = 常色主黑
                .Weight = xlThin
            End With
    End With
    '------------------------------------------------------------------------------------
    '列
    '------------------------------------------------------------------------------------
    With WS花册.Cells(基列, 位列花天CIDL).Resize(1, 花宽主道 - 基列 + 1).EntireColumn
        .HorizontalAlignment = xlRight
        .Interior.Color = 常色七灰
        .ColumnWidth = 2
        .Hidden = True
    End With
    With WS花册.Columns(基列)
        .Columns(位列花天CIDL).HorizontalAlignment = xlLeft
        .Columns(位列花天代称).HorizontalAlignment = xlLeft
        .Columns(位列花天代称).Interior.TintAndShade = 0.2
        
        .Columns(位列花天换手).NumberFormatLocal = 全设格式of一位
        .Columns(位列花天量比).NumberFormatLocal = 全设格式of零位
        .Columns(位列花天流市).NumberFormatLocal = 全设格式of零位
        .Columns(位列花天总市).NumberFormatLocal = 全设格式of零位
    End With
    With WS花册.Columns(基列)
        '---------------------------------
        .Columns(位列花天CIDL).ColumnWidth = 8
        .Columns(位列花天代称).ColumnWidth = 10
        .Columns(位列花天市日).ColumnWidth = 9
        .Columns(位列花天市日).NumberFormatLocal = 全设格式of日期
        .Columns(位列花天交易所码).ColumnWidth = 5
        .Columns(位列花天市场板类).ColumnWidth = 6
        .Columns(位列花天地区新浪).ColumnWidth = 6
        .Columns(位列花天行业新浪).ColumnWidth = 8
        .Columns(位列花天行业益盟).ColumnWidth = 10
        .Columns(位列花天概念益盟).ColumnWidth = 0.1
        .Columns(位列花天CIDS).ColumnWidth = 10
        .Columns(位列花天CIDS).Hidden = True
        .Columns(位列花天CIDS).NumberFormatLocal = 全设格式of代码
        .Columns(位列花天市板).ColumnWidth = 4
        .Columns(位列花天对应大势).ColumnWidth = 8
        '---------------------------------
        .Columns(位列花天是否上证50).ColumnWidth = 2
        .Columns(位列花天是否中股300).ColumnWidth = 2
        .Columns(位列花天是否中证500).ColumnWidth = 2
        .Columns(位列花天是否中证1000).ColumnWidth = 2
        .Columns(位列花天是否中证2000).ColumnWidth = 2
        .Columns(位列花天是否创业板50).ColumnWidth = 2
        .Columns(位列花天是否成分).ColumnWidth = 2
        .Columns(位列花天是否港股通).ColumnWidth = 2
        .Columns(位列花天是否MSCI中国).ColumnWidth = 2
        '---------------------------------
        .Columns(位列花天仓宝福).ColumnWidth = 4
        .Columns(位列花天仓宝彦).ColumnWidth = 4
        .Columns(位列花天仓宝合).ColumnWidth = 4
        .Columns(位列花天仓周).ColumnWidth = 4
        '---------------------------------
        .Columns(位列花天今池).ColumnWidth = 2
        .Columns(位列花天在池).ColumnWidth = 2
        '---------------------------------
        .Columns(位列花天量比).ColumnWidth = 4
        .Columns(位列花天换手).ColumnWidth = 4
        .Columns(位列花天交量).ColumnWidth = 4
        .Columns(位列花天流市).ColumnWidth = 4
        .Columns(位列花天总市).ColumnWidth = 4
        .Columns(位列花天停牌).ColumnWidth = 4
        '---------------------------------
    End With
    '列：隐藏
    With WS花册.Columns(基列)
        .Columns(位列花天对应大势).Hidden = True
        .Columns(位列花天量比).Hidden = True
        .Columns(位列花天换手).Hidden = True
        .Columns(位列花天交量).Hidden = True
        .Columns(位列花天流市).Hidden = True
        .Columns(位列花天总市).Hidden = True
        .Columns(位列花天停牌).Hidden = True
    End With
    '------------------------------------------------------------------------------------
    '排序
    '------------------------------------------------------------------------------------
    If WS花册.Name = 常花美股 Then
        WS花册.Columns("C:Z").Hidden = True
        WS花册.Columns(位列花天代称).ColumnWidth = 20
        WS花册.Columns(位列花天行业新浪).ColumnWidth = 20
    ElseIf WS花册.Name = 常花港股通 Then
        WS花册.Columns("C:Z").Hidden = True
        WS花册.Columns(位列花天代称).ColumnWidth = 16
    End If
'========================================================================================
'排序
'========================================================================================
    With WS花册.Cells
        .Sort _
            key1:=WS花册.Cells(1, 位列花天CIDL), order1:=xlAscending, _
            Header:=xlYes
    End With
'========================================================================================
'罗盘
'========================================================================================
    Call IQQQ跨码展擎_按列OS区域(WS花册, 花列甲道, 基色底:=基色底, 基色调:=0.5)
    Call IQQQ跨码展擎_按列OS区域(WS花册, 花列乙道, 基色底:=基色底, 基色调:=0.4)
    Call IQQQ跨码展擎_按列OS区域(WS花册, 花列丙道, 基色底:=基色底, 基色调:=0.3)
'========================================================================================
'清理
'========================================================================================
    WS花册.Activate
    ActiveWindow.Zoom = 80
End Function





'========================================================================================
'========================================================================================
'导入信息：全部股票列表
'导入文件：Tushare basics文件zdata.TSstock
'========================================================================================
'========================================================================================
Private Function STCALL花册管理_重制花天P1子程导入列表单票(WS花册 As Worksheet) As Integer
'========================================================================================
'TS：导入文件
'========================================================================================
    '------------------------------------------------------------------------------------
    '指定文件
    '------------------------------------------------------------------------------------
    Dim FILEOPEN As String
    FILEOPEN = 全设基夹根 & "\BaseTS中股票.csv"    '注20231231：输入文件必须是tushare列表
'    FILEOPEN = 全设基夹根 & "\PROstockbasic.csv"
    If UTL判断文件存在(FILEOPEN) = False Then
        Exit Function
    End If
'    '------------------------------------------------------------------------------------
'    '对话框选择
'    '------------------------------------------------------------------------------------
'    Dim FILEOPEN
'    FILEOPEN = Application.GetOpenFilename("csv文件,*.csv", , "请选择tushare文件PROstockbasic", , False)
'    If FILEOPEN = False Then
'        Exit Function
'    End If
'========================================================================================
    UTL宏工具_BEGIN
'========================================================================================
    Dim 位列TS代码 As Integer
    Dim 位列TS代称 As Integer
    Dim 位列TS地区新浪 As Integer
    Dim 位列TS行业新浪 As Integer
    Dim 位列TS交易所码 As Integer
    Dim 位列TS市场板类 As Integer
    Dim 位列TS上市状态 As Integer
    Dim 位列TS上市始日 As Integer
    Dim 位列TS是否港通 As Integer
    '------------------------------------------------------------------------------------
    '导入数组
    '------------------------------------------------------------------------------------
    Dim WBTS As Workbook
    Set WBTS = GetObject(FILEOPEN)
    Dim ARRTS  As Variant
    With WBTS.ActiveSheet
        ARRTS = .Range("A1").CurrentRegion
        位列TS代码 = .Rows(1).Find(What:="ts_code").Column
        位列TS代称 = .Rows(1).Find(What:="name").Column
        位列TS地区新浪 = .Rows(1).Find(What:="area").Column
        位列TS行业新浪 = .Rows(1).Find(What:="industry").Column
        位列TS交易所码 = .Rows(1).Find(What:="exchange").Column
        位列TS市场板类 = .Rows(1).Find(What:="market").Column
        位列TS上市状态 = .Rows(1).Find(What:="list_status").Column
        位列TS上市始日 = .Rows(1).Find(What:="list_date").Column
    End With
    WBTS.Close False
    Set WBTS = Nothing
'========================================================================================
'TS：输出中间工作表
'========================================================================================
'    '------------------------------------------------------------------------------------
'    '建立工作簿
'    '------------------------------------------------------------------------------------
'    Dim WSTS As Worksheet
'    Call PBASE格程工具_表操工表新增(WSTS, "IOTS", WB:=ThisWorkbook, 基色底:=常色十红)
'    '------------------------------------------------------------------------------------
'    '输出数组
'    '------------------------------------------------------------------------------------
'    Call UTL数据转换_集ARR2WS(ARRTS, WSTS)
'    '------------------------------------------------------------------------------------
'    '格式化
'    '------------------------------------------------------------------------------------
'    WSTS.Rows(1).Font.Bold = True
'    WSTS.Columns(位列TS代码).NumberFormatLocal = 全设格式of代码
'    WSTS.Columns.AutoFit
'    '------------------------------------------------------------------------------------
'    '按照代码进行排序
'    '------------------------------------------------------------------------------------
'    WSTS.Cells.Sort key1:=WSTS.Cells(1, 位列TS代码), order1:=xlAscending, Header:=xlYes
'    '------------------------------------------------------------------------------------
'    WSTS.Activate
'    ActiveWindow.Zoom = 80
'    Debug.Print WSTS.Cells(65536, 位列TS代码).End(xlUp).Row
'    Set WSTS = Nothing
'========================================================================================
'花册：导入股票列表
'========================================================================================
    Dim sdate As String
    Dim CIDV As Variant
    Dim CIDL As String
    '====================================================================================
    '合并 TSstock
    '====================================================================================
    Dim 计数导入 As Integer
    Dim 主列行号 As Integer
    Dim 遍历序号 As Integer
    
    计数导入 = 0
    For 遍历序号 = LBound(ARRTS, 1) + 1 To UBound(ARRTS, 1)
    If ARRTS(遍历序号, 位列TS交易所码) = "SSE" _
    Or ARRTS(遍历序号, 位列TS交易所码) = "SZSE" _
    Or ARRTS(遍历序号, 位列TS交易所码) = "BSE" _
    Then
    '注释20220806：剔除北交所，仅保留上交所与深交所
        '--------------------------------------------------------------------------------
        计数导入 = 计数导入 + 1
        主列行号 = 计数导入 + 1
        '--------------------------------------------------------------------------------
        '处理代码
        '--------------------------------------------------------------------------------
        CIDV = ARRTS(遍历序号, 位列TS代码)
        CIDL = VBA.LCase(Mid$(CIDV, InStr(CIDV, ".") + 1)) & Left$(CIDV, 6)
        WS花册.Cells(主列行号, 位列花天CIDS) = CIDV
        WS花册.Cells(主列行号, 位列花天CIDL) = CIDL
        '--------------------------------------------------------------------------------
        '市日
        sdate = ARRTS(遍历序号, 位列TS上市始日)
        If sdate Like "########" Then
            WS花册.Cells(主列行号, 位列花天市日) = DateSerial(Left$(sdate, 4), Mid$(sdate, 5, 2), Mid$(sdate, 7, 2))
        End If
        '--------------------------------------------------------------------------------
        WS花册.Cells(主列行号, 位列花天代称) = ARRTS(遍历序号, 位列TS代称)
        WS花册.Cells(主列行号, 位列花天交易所码) = ARRTS(遍历序号, 位列TS交易所码)
        WS花册.Cells(主列行号, 位列花天市场板类) = ARRTS(遍历序号, 位列TS市场板类)
        WS花册.Cells(主列行号, 位列花天地区新浪) = ARRTS(遍历序号, 位列TS地区新浪)
        WS花册.Cells(主列行号, 位列花天行业新浪) = ARRTS(遍历序号, 位列TS行业新浪)
        '--------------------------------------------------------------------------------
        '衍生对应大势
        '待完成：重新划分 上证50 沪深300 中证500 等细分指数
        '--------------------------------------------------------------------------------
        If ARRTS(遍历序号, 位列TS交易所码) = "SSE" Then
            If ARRTS(遍历序号, 位列TS市场板类) = "科创板" Then
                WS花册.Cells(主列行号, 位列花天对应大势) = "科创50"
            ElseIf ARRTS(遍历序号, 位列TS市场板类) = "主板" Then
                WS花册.Cells(主列行号, 位列花天对应大势) = "上证指数"
            Else
                WS花册.Cells(主列行号, 位列花天对应大势) = "上证指数"
            End If
        ElseIf ARRTS(遍历序号, 位列TS交易所码) = "SZSE" Then
            If ARRTS(遍历序号, 位列TS市场板类) = "创业板" Then
                WS花册.Cells(主列行号, 位列花天对应大势) = "创业板指"     '399006
            ElseIf ARRTS(遍历序号, 位列TS市场板类) = "主板" Or ARRTS(遍历序号, 位列TS市场板类) = "中小板" Then
                WS花册.Cells(主列行号, 位列花天对应大势) = "深证成指"
            Else
                WS花册.Cells(主列行号, 位列花天对应大势) = "深证成指"
            End If
        ElseIf ARRTS(遍历序号, 位列TS交易所码) = "BSE" Then
                WS花册.Cells(主列行号, 位列花天对应大势) = "北交50"
        End If
        '--------------------------------------------------------------------------------
        Debug.Print "花册花天单票列表导入>>>"; 遍历序号
        '--------------------------------------------------------------------------------
    End If
    Next
    Erase ARRTS
'========================================================================================
    STCALL花册管理_重制花天P1子程导入列表单票 = 计数导入
    UTL宏工具_END
End Function
'========================================================================================
'========================================================================================
'导入信息：全部指数列表
'导入文件：zdata中指数列表
'========================================================================================
'========================================================================================
Private Function STCALL花册管理_重制花天P1子程导入列表指数(WS花册 As Worksheet) As Integer
'========================================================================================
'zdata：导入列表
'========================================================================================
    Dim FILEOPEN As String
    FILEOPEN = 全设基夹中股
    If UTL判断路径存在(FILEOPEN) = False Then
        MsgBox FILEOPEN & "文件夹不存在！"
        Exit Function
    End If
    '------------------------------------------------------------------------------------
    '导入数组
    '------------------------------------------------------------------------------------
    Dim 典集指码 As New Dictionary
    Dim 原件名称 As String
    Dim 原件代码 As String
    Dim 原件期类 As String
    '------------------------------------------------------------------------------------
    '过滤：指数列表
    '------------------------------------------------------------------------------------
    Dim FSO As New FileSystemObject
    Dim gfile As file
    For Each gfile In FSO.GetFolder(FILEOPEN).Files
        '--------------------------------------------------------------------------------
'        原件名称 = UCase(FSO.GetBaseName(gfile.Path))
'        原件代码 = LCase(Left$(原件名称, 8))
'        原件期类 = UCase(Mid$(原件名称, 9, 1))
'        If 原件期类 = 常期类为日 Then
'            典集指码.Add Item:=原件代码, Key:=原件代码
'        End If
        '--------------------------------------------------------------------------------
        原件名称 = UCase(FSO.GetBaseName(gfile.Path))
        原件代码 = LCase(原件名称)
        典集指码.Add Item:=原件代码, Key:=原件代码
        '--------------------------------------------------------------------------------
    Next
    Set FSO = Nothing
    '------------------------------------------------------------------------------------
    '测试：指数列表
    '------------------------------------------------------------------------------------
'    Dim I As Integer
'    For I = 1 To 典集指码.Count
'        Debug.Print I, 典集指码.Keys(I - 1)
'    Next
'========================================================================================
'花册：指数列表清理
'========================================================================================
    Dim CIDL As String
    Dim 行号遍历 As Integer
    For 行号遍历 = PBASE格程工具_表参末行指定(WS花册, 位列花天CIDL) To 2 Step -1
        CIDL = WS花册.Cells(行号遍历, 位列花天CIDL).Value
        If UBCID是中股指(CIDL) = True Or UBCID是中股基(CIDL) = True Then
            WS花册.Rows(行号遍历).Delete
            Debug.Print "花册花天指数列表 清理>>>"; 行号遍历
        End If
    Next
'========================================================================================
'花册：指数列表导入
'========================================================================================
    Dim 目标行号 As Integer
    目标行号 = PBASE格程工具_表参末行指定(WS花册, 位列花天CIDL)
    '------------------------------------------------------------------------------------
    Dim 计数导入 As Integer
    计数导入 = 0
    Dim i As Integer
    For i = 1 To 典集指码.Count
        '--------------------------------------------------------------------------------
        CIDL = 典集指码.Keys(i - 1)
        CIDV = VBA.UCase(Right(CIDL, 6) & "." & Left$(CIDL, 2))
        '--------------------------------------------------------------------------------
        '处理代码
        '--------------------------------------------------------------------------------
        '处理代码：指数
        If (CIDL Like 常通配全码上指) Then
            计数导入 = 计数导入 + 1
            目标行号 = 目标行号 + 1
            WS花册.Cells(目标行号, 位列花天CIDL) = CIDL
            WS花册.Cells(目标行号, 位列花天CIDS) = CIDV
            WS花册.Cells(目标行号, 位列花天行业新浪) = "上证指数"
            WS花册.Cells(目标行号, 位列花天对应大势) = "上证指数"     '"sh000001"
        ElseIf (CIDL Like 常通配全码深指) Then
            计数导入 = 计数导入 + 1
            目标行号 = 目标行号 + 1
            WS花册.Cells(目标行号, 位列花天CIDL) = CIDL
            WS花册.Cells(目标行号, 位列花天CIDS) = CIDV
            WS花册.Cells(目标行号, 位列花天行业新浪) = "深证指数"
            WS花册.Cells(目标行号, 位列花天对应大势) = "深证成指"     '"sz399001"
        '处理代码：ETF
        ElseIf (CIDL Like 常通配全码上ETF) Then
            计数导入 = 计数导入 + 1
            目标行号 = 目标行号 + 1
            WS花册.Cells(目标行号, 位列花天CIDL) = CIDL
            WS花册.Cells(目标行号, 位列花天CIDS) = CIDV
            WS花册.Cells(目标行号, 位列花天行业新浪) = "上证ETF"
            WS花册.Cells(目标行号, 位列花天对应大势) = "上证指数"     '"sh000001"
        ElseIf (CIDL Like 常通配全码深ETF) Then
            计数导入 = 计数导入 + 1
            目标行号 = 目标行号 + 1
            WS花册.Cells(目标行号, 位列花天CIDL) = CIDL
            WS花册.Cells(目标行号, 位列花天CIDS) = CIDV
            WS花册.Cells(目标行号, 位列花天行业新浪) = "深证ETF"
            WS花册.Cells(目标行号, 位列花天对应大势) = "深证成指"     '"sz399001"
        End If
        '--------------------------------------------------------------------------------
        Debug.Print "花册花天指数列表 导入>>>"; i
    Next
    '------------------------------------------------------------------------------------
    典集指码.RemoveAll
    Set 典集指码 = Nothing
'========================================================================================
    STCALL花册管理_重制花天P1子程导入列表指数 = 计数导入
End Function
