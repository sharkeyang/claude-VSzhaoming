'########################################################################################
'花册花天重整操作顺序:
'（1.1）生成黑表Zn以及金银非索引；
'（1.2）导入tushare列表；
'（1.3）导入金银非今黑信息：需要提前保留池黑信息，否则需要全部从益盟导入；
'（2）导入益盟信息；
'（3）导入持仓；
'（4）全新结算；
'########################################################################################
'========================================================================================
'花册：初始化
'========================================================================================
Sub STCALL花册管理_重制花天P1调程导入列表()
    '预备：导出池信息
    MSG = MSG & STBASE池管理_索引基程(实结类型:="cCCC", 是否索引池金:=True, 是否索引池银:=True, 是否索引池铜:=True)
    '导入：导入tushare列表
    MSG = MSG & STCALL花册管理_重制花天P1正程导入列表
    '导入金银非今黑信息：需要提前保留池黑信息，否则需要全部从益盟导入
    MSG = MSG & STCALL花册管理_重制花天P9正程设置信息(是否更新市板:=True, 是否更新在池:=True, 是否更新停牌:=True, 是否更新代称:=True)
    MsgBox MSG, vbOKOnly, "花册导入列表"
End Sub
Sub STCALL花册管理_重制花天P2调程导入益盟()
    MSG = STCALL花册管理_重制花天P2正程导入益盟
    MsgBox MSG, vbOKOnly, "花册导入益盟"
End Sub
