'========================================================================================
'========================================================================================
'功能：设置基础信息
'========================================================================================
'========================================================================================
Public Function STCALL花册管理_重制花天P9正程设置信息( _
          Optional 是否更新市板 As Boolean = False _
        , Optional 是否更新在池 As Boolean = False _
        , Optional 是否更新停牌 As Boolean = False _
        , Optional 是否更新代称 As Boolean = False _
        ) As String
'========================================================================================
    UTL宏工具_BEGIN
    TT = Timer
'========================================================================================
'输入
'========================================================================================
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then
        UTL宏工具_END
        Exit Function
    End If
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽全道)
'========================================================================================
'设置：信息
'========================================================================================
    '------------------------------------------------------------------------------------
    Dim MSG As String
    MSG = MSG & "【任务】设置花册基本信息" & vbCrLf
    '------------------------------------------------------------------------------------
    If 是否更新市板 = True Then
        Call STCALL花册管理_重制花天P9子程重置信息1市板(组花册)
        MSG = MSG & "1.重置市板"
        MSG = MSG & vbCrLf
    End If
    '------------------------------------------------------------------------------------
    If 是否更新在池 = True Then
        MSG在池 = STCALL花册管理_重制花天P9子程重置信息2在池(组花册)
        MSG = MSG & "2.重置在池  " & MSG在池
        MSG = MSG & vbCrLf
    End If
    '------------------------------------------------------------------------------------
    If 是否更新停牌 = True Then
        MSG停牌 = STCALL花册管理_重制花天P9子程重置信息8停牌(组花册, 法道基列:=花列甲道, 指定花册:=常花中股)
        MSG = MSG & "8.重置停牌  " & MSG停牌
        MSG = MSG & vbCrLf
    End If
    '------------------------------------------------------------------------------------
    '注意20220824：此过程耗时较长，仅在导入指数列表时运行；其余更新代称过程，放在运行行情异常时同步完成。
    If 是否更新代称 = True Then
        Call STCALL花册管理_重制花天P9子程重置信息5代称(组花册)
        MSG = MSG & "9.更新名称"
        MSG = MSG & vbCrLf
    End If
'========================================================================================
'输出：花册
'========================================================================================
    Call UTL数据转换_集ARR2WS(组花册, WS花册, 始行:=2, 始列:=1)
    Erase 组花册
    '------------------------------------------------------------------------------------
    '格式化：花册
    '------------------------------------------------------------------------------------
    Call STCALL花册工具_花册格程(WS花册)
    Call 历研统时引擎5格程按列(WS花册, 始列:=花列统道)
    WS花册.Activate
    Set WS花册 = Nothing
'========================================================================================
'返回
'========================================================================================
    UTL宏工具_END
    MSG = MSG & "【重置信息耗时】" & CInt(Timer - TT) & vbCrLf
    '------------------------------------------------------------------------------------
    STCALL花册管理_重制花天P9正程设置信息 = MSG
End Function




'========================================================================================
'设置信息：停牌
'注20240601：【指定头码】是该代码群中指定【基准日期】的代码
'========================================================================================
Function STCALL花册管理_重制花天P9子程重置信息8停牌( _
          组花册 As Variant _
        , Optional 法道基列 As Integer = 花列甲道 _
        , Optional 指定花册 As String = 常花中股 _
        , Optional 指定头码 As String = 常查询代码中股 _
        ) As String
    '------------------------------------------------------------------------------------
    Dim 基位日类 As Integer
    基位日类 = 法道基列 - 1
    Dim 计数停牌 As Integer
    Dim 基准结期日类 As Date
    Dim 基准结期周类 As Date
    Dim 基准结期月类 As Date
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
                        '----------------------------------------------------------------
                        '获取基准日期：sh000001结算日期作为基准日期
                        If 组花册(X, 1) = 指定头码 Then
                            基准结期日类 = 组花册(X, 基位日类 + 位os结期)
                            基准结期周类 = 组花册(X, 基位日类 + 位os结期 + 花宽单道 * 1)
                            基准结期月类 = 组花册(X, 基位日类 + 位os结期 + 花宽单道 * 2)
                            Exit For
                        End If
                        '----------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    For X = LBound(组花册, 1) To UBound(组花册, 1)
                        '----------------------------------------------------------------
                        '过滤非基准日期
                        组花册(X, 基位日类 + 位os停牌) = ""
                        If 组花册(X, 基位日类 + 位os结期) <> 基准结期日类 Then
                            组花册(X, 基位日类 + 位os停牌) = "S"
                            If 组花册(X, 位列花天市板) <> 常市板指 And 组花册(X, 位列花天市板) <> 常市板基 Then
                                计数停牌 = 计数停牌 + 1
                            End If
                        End If
                        '----------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    STCALL花册管理_重制花天P9子程重置信息8停牌 = 计数停牌 & vbCrLf & "【结算终期日类】" & 基准结期日类 & vbCrLf & "【结算终期周类】" & 基准结期周类 & vbCrLf & "【结算终期月类】" & 基准结期月类
End Function


'========================================================================================
'设置信息：代称
'注意20220824：此过程耗时较长，仅在导入指数列表时运行；其余更新代称过程，放在运行行情异常时同步完成。
'========================================================================================
Function STCALL花册管理_重制花天P9子程重置信息5代称( _
          组花册 As Variant _
        ) As Integer
    Dim CIDL As String
    Dim aRESP As Variant
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
                        '----------------------------------------------------------------
                        CIDL = 组花册(X, 位列花天CIDL)
                        If UBHTTP腾实_查回组(aRESP, CIDL) > 0 Then
                            组花册(X, 位列花天代称) = aRESP(位序腾实代称)
                            组花册(X, 位列花天量比) = aRESP(位序腾实A量比)
                            组花册(X, 位列花天换手) = aRESP(位序腾实A换手)
                            组花册(X, 位列花天交量) = aRESP(位序腾实交量)
                            组花册(X, 位列花天流市) = aRESP(位序腾实流市)
                            组花册(X, 位列花天总市) = aRESP(位序腾实总市)
                            组花册(X, 位列花天停牌) = aRESP(位序腾实停牌)
                            Erase aRESP
                        End If
                        '----------------------------------------------------------------
    Next
    STCALL花册管理_重制花天P9子程重置信息5代称 = UBound(组花册, 1) - LBound(组花册, 1) + 1
End Function




'========================================================================================
'设置信息：市板
'========================================================================================
Function STCALL花册管理_重制花天P9子程重置信息1市板( _
          组花册 As Variant _
        ) As Integer
    Dim CIDL As String
    Dim 值市日 As Date
    Dim 值市板 As String
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
        '----------------------------------------------------------------
        CIDL = 组花册(X, 位列花天CIDL)
        值市日 = 组花册(X, 位列花天市日)
        '----------------------------------------------------------------
        '市板分类
        If UBCID是中股指(CIDL) = True Then
            值市板 = 常市板指        ' Qd = index
        ElseIf UBCID是中股基(CIDL) = True Then
            值市板 = 常市板基        ' Qe = ETF
        ElseIf UBCID是中股票(CIDL) = True Then
            If InStr(组花册(X, 位列花天代称), "ST") > 0 Or InStr(组花册(X, 位列花天代称), "退") > 0 Then
                值市板 = 常市板票Qst
            ElseIf 组花册(X, 位列花天是否中股300) = "Y" Then
                值市板 = 常市板票Qif  ' Qif = 沪深300
            ElseIf 组花册(X, 位列花天是否中证500) = "Y" Then
                值市板 = 常市板票Qic  ' Qic = 中证500
            ElseIf 组花册(X, 位列花天是否中证1000) = "Y" Then
                值市板 = 常市板票Qim  ' Qim = 中证1000
            ElseIf 组花册(X, 位列花天是否中证2000) = "Y" Then
                值市板 = 常市板票Qit  ' Qit = 中证2000
            Else
                值市板 = 常市板票Qin  ' Qin = 中证非
            End If
        Else
            值市板 = ""
        End If
        组花册(X, 位列花天市板) = 值市板
        '----------------------------------------------------------------
        '为指数和ETF设置市日
        '----------------------------------------------------------------
        If UBCID是中股指(CIDL) = True Or UBCID是中股基(CIDL) = True Then
            组花册(X, 位列花天市日) = 组花册(X, 花列甲道 - 1 + 位os基市期)
        End If
        '----------------------------------------------------------------
    Next
    STCALL花册管理_重制花天P9子程重置信息1市板 = UBound(组花册, 1) - LBound(组花册, 1) + 1
End Function


'========================================================================================
'========================================================================================
'设置信息：在池（金银非）
'========================================================================================
'========================================================================================
Function STCALL花册管理_重制花天P9子程重置信息2在池( _
          组花册 As Variant _
        ) As String
'========================================================================================
'制作池列表
'========================================================================================
                        '制作池：池金
                        '用于周线级别长线操作，使用恒定【底仓】持有，不计较每日波动，遇到坑可以适当增加【浮仓】，出坑后平掉【浮仓】
                        Dim 典码已在池金 As New Dictionary
                        计数池金 = UTL数据转换_集WS名2典码(典码已在池金, 常池名金)
                        '----------------------------------------------------------------
                        '制作池：池银
                        '用于备选操作，优先级低于【池金】
                        Dim 典码已在池银 As New Dictionary
                        计数池银 = UTL数据转换_集WS名2典码(典码已在池银, 常池名银)
                        '----------------------------------------------------------------
                        '制作池：池铜
                        '用于备选操作，优先级低于【池金】
                        Dim 典码已在池铜 As New Dictionary
                        计数池铜 = UTL数据转换_集WS名2典码(典码已在池铜, 常池名铜)
                        '----------------------------------------------------------------
                        '制作池：池黑
                        '用于备选操作，每月进行一次甄别，是否从黑名单取出来
                        Dim 典码已在池黑 As New Dictionary
                        计数池黑 = UTL数据转换_集WS名2典码(典码已在池黑, 常池名黑)
                        '----------------------------------------------------------------
                        '----------------------------------------------------------------
                        '制作池：今池
                        '用于备选操作，每周进行一次甄别
                        Dim 典码已在池今 As New Dictionary
                        计数池今 = UTL数据转换_集WS名2典码(典码已在池今, 常池名今)
'========================================================================================
'设置信息：先清理（必须非空）再设置
'========================================================================================
    Dim CIDL As String
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
                        '----------------------------------------------------------------
                        '注意20230101：如有新列表就进行更新，否则保持原有信息。
                        If 计数池金 > 0 And 组花册(X, 位列花天在池) = 常池名金 Then 组花册(X, 位列花天在池) = ""
                        If 计数池银 > 0 And 组花册(X, 位列花天在池) = 常池名银 Then 组花册(X, 位列花天在池) = ""
                        If 计数池铜 > 0 And 组花册(X, 位列花天在池) = 常池名铜 Then 组花册(X, 位列花天在池) = ""
                        If 计数池黑 > 0 And 组花册(X, 位列花天在池) = 常池名黑 Then 组花册(X, 位列花天在池) = ""
                        '----------------------------------------------------------------
                        If 计数池今 > 0 Then 组花册(X, 位列花天今池) = ""
                        '----------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    For X = LBound(组花册, 1) To UBound(组花册, 1)
                        CIDL = 组花册(X, 位列花天CIDL)
                        '----------------------------------------------------------------
                        '标注是否已在池：金银非黑为互斥关系
                        If 典码已在池金.Exists(CIDL) = True Then
                            组花册(X, 位列花天在池) = 常池名金
                        ElseIf 典码已在池银.Exists(CIDL) = True Then
                            组花册(X, 位列花天在池) = 常池名银
                        ElseIf 典码已在池铜.Exists(CIDL) = True Then
                            组花册(X, 位列花天在池) = 常池名铜
                        ElseIf 典码已在池黑.Exists(CIDL) = True Then
                            组花册(X, 位列花天在池) = 常池名黑
                        End If
                        '----------------------------------------------------------------
                        If 典码已在池今.Exists(CIDL) = True Then
                            组花册(X, 位列花天今池) = 常池名今
                        End If
                        '----------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    Set 典码已在池今 = Nothing
    Set 典码已在池金 = Nothing
    Set 典码已在池银 = Nothing
    Set 典码已在池铜 = Nothing
    Set 典码已在池黑 = Nothing
'========================================================================================
'计数
'========================================================================================
    For X = LBound(组花册, 1) To UBound(组花册, 1)
                        CIDL = 组花册(X, 位列花天CIDL)
                        '----------------------------------------------------------------
                        '标注是否已在池：金银非黑为互斥关系
                        If 组花册(X, 位列花天在池) = 常池名金 Then
                            典码已在池金.Add Item:=X, Key:=CIDL
                        ElseIf 组花册(X, 位列花天在池) = 常池名银 Then
                            典码已在池银.Add Item:=X, Key:=CIDL
                        ElseIf 组花册(X, 位列花天在池) = 常池名铜 Then
                            典码已在池铜.Add Item:=X, Key:=CIDL
                        ElseIf 组花册(X, 位列花天在池) = 常池名黑 Then
                            典码已在池黑.Add Item:=X, Key:=CIDL
                        End If
                        '----------------------------------------------------------------
                        If 组花册(X, 位列花天今池) = 常池名今 Then
                            典码已在池今.Add Item:=X, Key:=CIDL
                        End If
                        '----------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    Dim MSG As String
    MSG = "更新在池："
    MSG = MSG & vbCrLf & ">>池今：" & 典码已在池今.Count
'    MSG = MSG & vbCrLf & ">>池金：" & 典码已在池金.Count
'    MSG = MSG & vbCrLf & ">>池银：" & 典码已在池银.Count
'    MSG = MSG & vbCrLf & ">>池铜：" & 典码已在池铜.Count
    MSG = MSG & vbCrLf & ">>池黑：" & 典码已在池黑.Count
    '------------------------------------------------------------------------------------
    Set 典码已在池今 = Nothing
    Set 典码已在池金 = Nothing
    Set 典码已在池银 = Nothing
    Set 典码已在池铜 = Nothing
    Set 典码已在池黑 = Nothing
'========================================================================================
'返回
'========================================================================================
    STCALL花册管理_重制花天P9子程重置信息2在池 = MSG
End Function
