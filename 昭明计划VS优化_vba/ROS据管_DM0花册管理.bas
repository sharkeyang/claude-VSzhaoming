Private Sub 测试_STCALL花册工具_花天查询日基势局()
    Dim CIDL As String
    CIDL = "sh000002"
    Dim 值势局 As String
    值势局 = STCALL花册工具_花天查询日基势局(CIDL)
    Debug.Print "SSS:", 值势局
    值势局 = STCALL花册工具_花天查询神谕字段(CIDL, "cCCC", 位qt代称)
    值日层联类 = STCALL花册工具_花天查询神谕字段(CIDL, "cCCC", 位谕of日层联动)
    Debug.Print "SSS:", 值势局, 值日层联类
End Sub
'========================================================================================
'========================================================================================
'根据代码进行实时结算获取实时势局
'========================================================================================
'========================================================================================
Function STCALL花册工具_花天查询神谕字段(CIDL As String, Optional 实结类型 As String = "cCCC", Optional 位谕of待查字段 As Integer = 位qt代称) As String
        '--------------------------------------------------------------------------------
        '获取变量
        '--------------------------------------------------------------------------------
        Dim 采样典码 As New Dictionary
        采样典码.Add Item:=CIDL, Key:=CIDL
        Dim 谕组 As Variant
        Call IQQQ跨码据擎_数程生成全息(谕组, 常花中股, 实结类型:=实结类型, 采样典码:=采样典码)
        If VBA.IsEmpty(谕组) = True Then Exit Function
        STCALL花册工具_花天查询神谕字段 = 谕组(1, 位谕of待查字段)
        '--------------------------------------------------------------------------------
        Erase 谕组
        Set 采样典码 = Nothing
End Function
Function STCALL花册工具_花天查询日基势局(CIDL As String, Optional 今收 As Double = 0) As String
        '--------------------------------------------------------------------------------
        '获取变量
        '--------------------------------------------------------------------------------
        Dim 提取行元 As Range
        Dim ARROS(1 To 花宽单道) As Variant
        
        Dim WS花册 As Worksheet
        If STBASE外簿工具_花册链接(WS花册, 常花中股) Then
            With WS花册
                Set 提取行元 = .Columns(1).Find(What:=CIDL)
                If 提取行元 Is Nothing Then
                    Exit Function
                End If
                For i = 1 To 花宽单道
                    ARROS(i) = .Cells(提取行元.Row, 花列甲道).Cells(1, i)
                Next
                Set 提取行元 = Nothing
            End With
        End If
        '--------------------------------------------------------------------------------
        '进行实时结算
        '--------------------------------------------------------------------------------
        If 今收 <> 0 Then
            ARROS(位os临期) = Date
            ARROS(位os临收) = 今收
            Call STBASE结算引擎_单点结算核程(ARROS)
        End If
        '--------------------------------------------------------------------------------
        '返回
        '--------------------------------------------------------------------------------
        Dim 值势局 As String
        值势局 = ARROS(位os局势日基)
        STCALL花册工具_花天查询日基势局 = 值势局
End Function


Function STCALL花册工具_花天查询单码名称(CIDL As String) As String
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then Exit Function
    Dim RG As Range
    Set RG = WS花册.Columns(位列花天CIDL).Find(CIDL)
    If Not RG Is Nothing Then
        STCALL花册工具_花天查询单码名称 = WS花册.Cells(RG.Row, 位列花天代称)
    End If
    Set RG = Nothing
End Function
