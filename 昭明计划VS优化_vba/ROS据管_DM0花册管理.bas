'########################################################################################
'########################################################################################
'############################     花册工具_提取典码     #################################
'########################################################################################
'########################################################################################
Function STCALL花册工具_提取典码花天按市池( _
          典码称 As Dictionary _
        , Optional 包含市指 As Boolean = False _
        , Optional 包含市基 As Boolean = False _
        , Optional 包含市票 As Boolean = False _
        , Optional 是否池金 As Boolean = True _
        , Optional 是否池银 As Boolean = True _
        , Optional 是否池铜 As Boolean = True _
        , Optional 是否池黑 As Boolean = True _
        , Optional 是否池外 As Boolean = True _
        , Optional 测试限数 As Integer = -1 _
        ) As Integer
'========================================================================================
    典码称.RemoveAll
'========================================================================================
'验证文件存在
'========================================================================================
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then
        Debug.Print 常花中股 & "不存在"
        Exit Function
    End If
'========================================================================================
'导入数据
'========================================================================================
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽主道)
'========================================================================================
'遍历
'========================================================================================
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
        CIDL = 组花册(X, 位列花天CIDL)
        代称 = 组花册(X, 位列花天代称)
        '--------------------------------------------------------------------------------
        是否提取 = False
        If 组花册(X, 位列花天市板) = 常市板指 Then
            If 包含市指 = True Then 是否提取 = True
        ElseIf 组花册(X, 位列花天市板) = 常市板基 Then
            If 包含市基 = True Then 是否提取 = True
        Else
            If 包含市票 = True Then
                是否提取 = True
            End If
        End If
        If 是否提取 = True Then
            If 组花册(X, 位列花天在池) = 常池名金 Then
                是否提取 = 是否池金
            ElseIf 组花册(X, 位列花天在池) = 常池名银 Then
                是否提取 = 是否池银
            ElseIf 组花册(X, 位列花天在池) = 常池名铜 Then
                是否提取 = 是否池铜
            ElseIf 组花册(X, 位列花天在池) = 常池名黑 Then
                是否提取 = 是否池黑
            Else
                是否提取 = 是否池外
            End If
        End If
        '--------------------------------------------------------------------------------
        If 是否提取 = True Then
            If 典码称.Exists(CIDL) = False Then 典码称.Add Key:=CIDL, Item:=代称
        End If
        '--------------------------------------------------------------------------------
        If 测试限数 > 0 And 典码称.Count > 测试限数 Then Exit For         '测试专用
        Debug.Print X, CIDL
        '--------------------------------------------------------------------------------
    Next
    Erase 组花册
'========================================================================================
'返回
'========================================================================================
    STCALL花册工具_提取典码花天按市池 = 典码称.Count
End Function


Function STCALL花册工具_提取典码花天按采样( _
          典码称 As Dictionary _
        , Optional ByVal 采样列号 As Integer = 0 _
        , Optional ByVal 采样列值 As String = "" _
        ) As Integer
'========================================================================================
'验证文件存在
'========================================================================================
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then
        Debug.Print 常花中股 & "不存在"
        Exit Function
    End If
'========================================================================================
'导入数据
'========================================================================================
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽主道)
'========================================================================================
'遍历
'========================================================================================
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
        CIDL = 组花册(X, 位列花天CIDL)
        代称 = 组花册(X, 位列花天代称)
        '--------------------------------------------------------------------------------
        采样总数 = 0
        If UBCID是中股票(CIDL) = True Or UBCID是中股基(CIDL) = True Or UBCID是中股指(CIDL) = True Then
        If 组花册(X, 采样列号) = 采样列值 Then
            采样总数 = 采样总数 + 1
            If 典码称.Exists(CIDL) = False Then 典码称.Add Key:=CIDL, Item:=代称
        End If
        End If
        '--------------------------------------------------------------------------------
    Next
    Erase 组花册
'========================================================================================
'返回
'========================================================================================
    STCALL花册工具_提取典码花天按采样 = 典码称.Count
End Function
