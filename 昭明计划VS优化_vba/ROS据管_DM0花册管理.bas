'========================================================================================
'========================================================================================
'导入信息：全部股票列表
'导入文件：Tushare basics文件zdata.TSstock
'========================================================================================
'========================================================================================
Private Function STCALL花册管理_重制花天P1正程导入列表() As String
    UTL宏工具_BEGIN
'========================================================================================
'花册：建立
'========================================================================================
    Dim 指定花册 As String
    指定花册 = 常花中股
    Dim WS花册 As Worksheet
    Call PBASE格程工具_表操工表新增(WS花册, 指定花册, wb:=ThisWorkbook, 基色底:=常色四紫)
'========================================================================================
'导入列表：单票
'========================================================================================
    Dim 计数单票 As Integer
    计数单票 = STCALL花册管理_重制花天P1子程导入列表单票(WS花册)
'========================================================================================
'导入列表：指数
'========================================================================================
    Dim 计数指数 As Integer
    计数指数 = STCALL花册管理_重制花天P1子程导入列表指数(WS花册)
'========================================================================================
    UTL宏工具_END
    MSG = MSG & "导入列表" _
            & vbCrLf & "计数单票 >>" & 计数单票 _
            & vbCrLf & "计数指数 >>" & 计数指数 _
            & vbCrLf
    STCALL花册管理_重制花天P1正程导入列表 = MSG
End Function




'========================================================================================
'========================================================================================
'导入信息：益盟行业 益盟概念
'导入文件：益盟信息
'注意：【位列花天概念益盟】删除程序在【STCALL花册工具_控制显示花天】
'========================================================================================
'========================================================================================
Private Function STCALL花册管理_重制花天P2正程导入益盟() As String
'========================================================================================
'验证文件存在
'========================================================================================
'========================================================================================
'益盟：导入文件
'========================================================================================
    Dim FILEOPEN
    'FILEOPEN = Application.GetOpenFilename("益盟信息文件,*.xls", , "请选择益盟信息文件xls", , False)
    '注20260524：从益盟导出文件时，一定要选择csv文件格式，而不要选择xls文件，因为xls会截断字符串（最长为255）。切记！
    FILEOPEN = Application.GetOpenFilename("益盟信息文件,*.csv", , "请选择益盟信息文件csv，不要导出为xls文件（会截断字符串）", , False)
    If FILEOPEN = False Then
        Exit Function
    End If
'========================================================================================
    UTL宏工具_BEGIN
'========================================================================================
    Dim 位列YM代码 As Integer
    Dim 位列YM代称 As Integer
    Dim 位列YM行业益盟 As Integer
    Dim 位列YM概念益盟 As Integer
    '------------------------------------------------------------------------------------
    '导入数组
    '------------------------------------------------------------------------------------
    Dim WBYM As Workbook
    Set WBYM = GetObject(FILEOPEN)
    Dim ARRYM As Variant
    With WBYM.ActiveSheet
        ARRYM = .Range("A1").CurrentRegion
        位列YM代码 = .Rows(1).Find(What:="代码").Column
        位列YM代称 = .Rows(1).Find(What:="A股板块").Column
        位列YM行业益盟 = .Rows(1).Find(What:="行业").Column
        位列YM概念益盟 = .Rows(1).Find(What:="所属概念").Column
    End With
    WBYM.Close False
    Set WBYM = Nothing
'========================================================================================
'益盟：输出中间工作表
'========================================================================================
'    '------------------------------------------------------------------------------------
'    '建立工作簿
'    '------------------------------------------------------------------------------------
'    Dim WSYM As Worksheet
'    Call PBASE格程工具_表操工表新增(WSYM, "IOYM", WB:=ThisWorkbook, 基色底:=常色十红)
'    '------------------------------------------------------------------------------------
'    '输出数组
'    '------------------------------------------------------------------------------------
'    Call UTL数据转换_集ARR2WS(ARRYM, WSYM)
'    '------------------------------------------------------------------------------------
'    '格式化
'    '------------------------------------------------------------------------------------
'    WSYM.Rows(1).Font.Bold = True
'    WSYM.Columns(位列YM代码).NumberFormatLocal = 全设格式of代码
'    WSYM.Columns.AutoFit
'    '------------------------------------------------------------------------------------
'    '按照代码进行排序
'    '------------------------------------------------------------------------------------
'    WSYM.Cells.Sort key1:=WSYM.Cells(1, 位列YM代码), order1:=xlAscending, Header:=xlYes
'    '------------------------------------------------------------------------------------
'    WSYM.Activate
'    ActiveWindow.Zoom = 80
'    Debug.Print WSYM.Cells(65536, 位列YM代码).End(xlUp).Row
'    Set WSYM = Nothing
'========================================================================================
'输入
'========================================================================================
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then
        UTL宏工具_END
        Exit Function
    End If
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽主道)
'========================================================================================
'花册：合并 益盟行业 益盟概念
'========================================================================================
    '------------------------------------------------------------------------------------
    '制作字典
    '------------------------------------------------------------------------------------
    Dim 典集行业益盟 As New Dictionary
    Dim 典集概念益盟 As New Dictionary
    Dim CIDV As Variant
    Dim CIDL As String
    
    Dim R As Integer
    For R = LBound(ARRYM, 1) + 1 To UBound(ARRYM, 1)
        CIDV = ARRYM(R, 位列YM代码)
        CIDL = UBCID规制代码(CIDV)
        典集行业益盟.Add Key:=CIDL, Item:=ARRYM(R, 位列YM行业益盟)
        典集概念益盟.Add Key:=CIDL, Item:=ARRYM(R, 位列YM概念益盟)
    Next R
    Erase ARRYM
    '------------------------------------------------------------------------------------
    '导入
    '------------------------------------------------------------------------------------
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
        '--------------------------------------------------------------------------------
        CIDL = 组花册(X, 位列花天CIDL)
        '--------------------------------------------------------------------------------
        If UBCID是中股票(CIDL) = True Then
                组花册(X, 位列花天行业益盟) = ""
                组花册(X, 位列花天概念益盟) = ""
                If 典集行业益盟.Exists(CIDL) Then
                        组花册(X, 位列花天行业益盟) = 典集行业益盟(CIDL)
                        组花册(X, 位列花天概念益盟) = 典集概念益盟(CIDL)
                End If
                '设置：主要归属
                值概念益盟 = 典集概念益盟(CIDL)
                If Len(值概念益盟) > 0 Then
                        '----------------------------------------------------------------
                        组花册(X, 位列花天是否上证50) = IIf(InStr(值概念益盟, "上证50") > 0, "Y", "")
                        组花册(X, 位列花天是否中股300) = IIf(InStr(值概念益盟, "沪深300") > 0, "Y", "")
                        组花册(X, 位列花天是否中证500) = IIf(InStr(值概念益盟, "中证500") > 0, "Y", "")
                        组花册(X, 位列花天是否中证1000) = IIf(InStr(值概念益盟, "中证1000") > 0, "Y", "")
                        组花册(X, 位列花天是否中证2000) = IIf(InStr(值概念益盟, "中证2000") > 0, "Y", "")
                        组花册(X, 位列花天是否创业板50) = IIf(InStr(值概念益盟, "创业板50") > 0, "Y", "")
                        '----------------------------------------------------------------
                        '注释20240220：由于国家队通过ETF救市，所以对不属于各指数基金的股票进行标注。MSCI中国已经不重要。
                        If InStr(值概念益盟, "上证50") > 0 Then
                            组花册(X, 位列花天是否成分) = "IH"
                        ElseIf InStr(值概念益盟, "沪深300") > 0 Then
                            组花册(X, 位列花天是否成分) = "IF"
                        ElseIf InStr(值概念益盟, "中证500") > 0 Then
                            组花册(X, 位列花天是否成分) = "IC"
                        ElseIf InStr(值概念益盟, "中证1000") > 0 Then
                            组花册(X, 位列花天是否成分) = "Im"
                        ElseIf InStr(值概念益盟, "中证2000") > 0 Then
                            组花册(X, 位列花天是否成分) = "It"
                        Else
                            组花册(X, 位列花天是否成分) = "N"
                        End If
                        '----------------------------------------------------------------
                        If InStr(值概念益盟, "沪股通") > 0 Then
                            组花册(X, 位列花天是否港股通) = "沪"
                        ElseIf InStr(值概念益盟, "深股通") > 0 Then
                            组花册(X, 位列花天是否港股通) = "深"
                        Else
                            组花册(X, 位列花天是否港股通) = ""
                        End If
                         组花册(X, 位列花天是否MSCI中国) = IIf(InStr(值概念益盟, "MSCI中国") > 0, "Y", "")
                       '----------------------------------------------------------------
                End If
        '--------------------------------------------------------------------------------
        ElseIf UBCID是中股指(CIDL) = True Or UBCID是中股基(CIDL) = True Then
                组花册(X, 位列花天行业益盟) = 组花册(X, 位列花天行业新浪)
        End If
        '--------------------------------------------------------------------------------
    Next
    Set 典集行业益盟 = Nothing
    Set 典集概念益盟 = Nothing
'========================================================================================
'输出：花册
'========================================================================================
    Call UTL数据转换_集ARR2WS(组花册, WS花册, 始行:=2, 始列:=1)
    Erase 组花册
    '------------------------------------------------------------------------------------
    '格式化：花册
    '------------------------------------------------------------------------------------
    Call STCALL花册工具_花册格程(WS花册)
    WS花册.Activate
    Set WS花册 = Nothing
'========================================================================================
    UTL宏工具_END
    MSG = "导入益盟信息完成" & vbCrLf
    STCALL花册管理_重制花天P2正程导入益盟 = MSG
End Function




'========================================================================================
'========================================================================================
'功能：1.导入华宝持仓
'========================================================================================
'========================================================================================
Public Function STCALL花册管理_重制花天P3正程导入华宝(Optional 指定列仓 As Integer = 位列花天仓宝福, Optional 是否更新仓周 As Boolean = False) As Integer
'========================================================================================
'注2025061：用于区分是否属于周仓：用于排序。临时仓位排在前面，周仓位排在后面。
'在每周结算日导入周仓，其余交易日导入日仓。在Z陈列时，将日仓放在前面，将周仓放在后面。
'========================================================================================
    '====================================================================================
    '设置：根据仓列确定池
    '====================================================================================
    Dim 值常池名  As String
    If 指定列仓 = 位列花天仓宝福 Then
        值常池名 = 常仓名宝福
    ElseIf 指定列仓 = 位列花天仓宝彦 Then
        值常池名 = 常仓名宝彦
    End If
    '====================================================================================
    '设置：导入验证：周仓只在周五-周日可以导入，其他时间必须人工确认。
    '====================================================================================
    If 是否更新仓周 = True Then
        If Weekday(Date, vbMonday) >= 5 Then
        Else
            是否导入周池 = MsgBox("周池应只在周末进行导入。请确认是否导入？", vbOKCancel, "导入周池" & 值常池名)
            If 是否导入周池 <> vbOK Then Exit Function
        End If
    End If
'========================================================================================
'验证文件存在
'========================================================================================
'========================================================================================
'导入文件：华宝
'========================================================================================
    Dim FILEOPEN
    FILEOPEN = Application.GetOpenFilename("华宝持仓文件,*.xls", , "请选择华宝持仓文件" & 值常池名, , False)
    Debug.Print FILEOPEN
'    Stop
    If FILEOPEN = False Then
        Exit Function
    End If
'========================================================================================
    UTL宏工具_BEGIN
'========================================================================================
'导入数组
'========================================================================================
    Dim 所在区域 As Range
    Dim 位列TS代码 As Integer
    Dim 位列TS代称 As Integer
    Dim 位列TS摊薄成本 As Integer
    Dim 位列TS持仓数量 As Integer
    Dim 位列TS持仓金额 As Integer
    Dim 位列TS交易所名 As Integer
    '-------------------------------
    Application.Calculation = xlCalculationAutomatic
    '注20260610：必须设置这个选项，否则将导致文件导入不正确。
    'Application.Calculation = xlManual（手动计算模式）是导致 ="币种" 显示为 0 的最直接原因：
    '这些 ="..." 在 Excel 里是公式，不是纯文本
    '手动计算模式下，新打开的文件公式不会被自动计算
    '未计算的公式单元格没有缓存值 → 显示为 0
    '-------------------------------
    Dim WBTS As Workbook
    Set WBTS = GetObject(FILEOPEN)
    Dim ARRTS  As Variant
    With WBTS.ActiveSheet
            Set 所在区域 = .Columns(1).Find(What:="证券代码").CurrentRegion
            ARRTS = 所在区域
            位列TS代码 = 所在区域.Rows(1).Find(What:="证券代码").Column
            位列TS代称 = 所在区域.Rows(1).Find(What:="证券名称").Column
            位列TS持仓数量 = 所在区域.Rows(1).Find(What:="证券数量").Column
            位列TS摊薄成本 = 所在区域.Rows(1).Find(What:="摊薄成本").Column
            位列TS持仓金额 = 所在区域.Rows(1).Find(What:="最新市值").Column
            位列TS交易所名 = 所在区域.Rows(1).Find(What:="交易所名称").Column
            Set 所在区域 = Nothing
    End With
    WBTS.Close False
    Set WBTS = Nothing
'========================================================================================
'输入
'========================================================================================
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中股) = False Then
        UTL宏工具_END
        Exit Function
    End If
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽主道)
'========================================================================================
'设置：花册信息
'包括：清除原有持仓信息
'========================================================================================
    '====================================================================================
    '设置
    '====================================================================================
    Dim CIDL As String
    Dim 典集花册行号 As New Dictionary
    For X = LBound(组花册, 1) To UBound(组花册, 1)
        '--------------------------------------------------------------------------------
        CIDL = 组花册(X, 1)
        典集花册行号.Add Item:=X, Key:=CIDL
        '--------------------------------------------------------------------------------
        '清空原有信息：持仓
        '--------------------------------------------------------------------------------
        组花册(X, 指定列仓) = ""
        '--------------------------------------------------------------------------------
        '清空原有信息：仓周。只删除对应仓位的周池记录
        '--------------------------------------------------------------------------------
        If 是否更新仓周 = True Then
            If 组花册(X, 位列花天仓周) = 值常池名 Then 组花册(X, 位列花天仓周) = ""
        End If
        '--------------------------------------------------------------------------------
    Next
'========================================================================================
'常花中股：导入股票列表
'========================================================================================
    Dim CIDV As Variant
    Dim 值持仓数量 As Long
    Dim 值交易所名 As String
    Dim 计数导入 As Integer
    '====================================================================================
    '导入
    '====================================================================================
    计数导入 = 0
    For X = LBound(ARRTS, 1) + 1 To UBound(ARRTS, 1)
        定位花册行号 = 0
        '--------------------------------------------------------------------------------
        '处理代码
        '--------------------------------------------------------------------------------
        CIDV = ARRTS(X, 位列TS代码)
        CIDL = UBCID规制代码(CIDV)
        值持仓数量 = ARRTS(X, 位列TS持仓数量)
        If 值持仓数量 >= 1 Then
            计数导入 = 计数导入 + 1
            值交易所名 = ARRTS(X, 位列TS交易所名)
            If 值交易所名 = "上海A股" Or 值交易所名 = "深圳A股" Or 值交易所名 = "北交所" Then
                If 典集花册行号.Exists(CIDL) = True Then
                    定位花册行号 = 典集花册行号(CIDL)
                    组花册(定位花册行号, 指定列仓) = (ARRTS(X, 位列TS持仓数量)) & "," & (ARRTS(X, 位列TS摊薄成本))
                    '更新周池信息：标注是否为周层以及对应账户
                    If 是否更新仓周 = True Then 组花册(定位花册行号, 位列花天仓周) = 值常池名
                Else
                    定位花册行号 = -1
                End If
            ElseIf 值交易所名 = "沪港" Or 值交易所名 = "深港" Then
                CIDL = "r_hk" & Format(CIDV, "00000")
            End If
        End If
        '--------------------------------------------------------------------------------
        值代称 = ARRTS(X, 位列TS代称)
        Debug.Print "华宝持仓导入>>>"; X; 值代称, CIDL, CIDV, 定位花册行号
        '--------------------------------------------------------------------------------
    Next
    Erase ARRTS
    Set 典集花册行号 = Nothing
'========================================================================================
'输出：花册
'========================================================================================
    Call UTL数据转换_集ARR2WS(组花册, WS花册, 始行:=2, 始列:=1)
    Erase 组花册
    '------------------------------------------------------------------------------------
    '格式化：花册
    '------------------------------------------------------------------------------------
    Call STCALL花册工具_花册格程(WS花册)
    'WS花册.Activate
    Set WS花册 = Nothing
'========================================================================================
'返回
'========================================================================================
    UTL宏工具_END
    MSG = "导入持仓 >>" & 计数导入 & vbCrLf
    STCALL花册管理_重制花天P3正程导入华宝 = 计数导入
End Function





