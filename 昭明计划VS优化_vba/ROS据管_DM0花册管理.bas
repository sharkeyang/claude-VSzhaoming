'========================================================================================
'========================================================================================
'格式化HX
'更新信息：代称、行业、市板
'========================================================================================
'========================================================================================
Function STCALL花册工具_花册格程( _
          WS花册 As Worksheet _
        , Optional ByVal 基列 As Integer = 1 _
        , Optional ByVal 基行 As Integer = 1 _
        , Optional 基色底 As Long = 常色十靛 _
        ) As Integer
'========================================================================================
'全局设置
'========================================================================================
    With WS花册
        .Tab.Color = 基色底
        .Rows.Hidden = False
        .Columns.Hidden = False
        .Cells.ClearFormats
        .Cells.Font.Size = 9
    End With
    '------------------------------------------------------------------------------------
    '调整与冻结
    '------------------------------------------------------------------------------------
    Call PBASE格程工具_表冻结锁定(WS花册, 基列, 2)
'========================================================================================
'花册：格式化
'========================================================================================
    '------------------------------------------------------------------------------------
    '首行
    '------------------------------------------------------------------------------------
    WS花册.Rows(基列).Font.Bold = True
    With WS花册
        '---------------------------------
        .Cells(1, 位列花天CIDL) = "CIDL"
        .Cells(1, 位列花天CIDS) = "CIDS"
        .Cells(1, 位列花天代称) = "代称"
        .Cells(1, 位列花天市板) = "市板"
        .Cells(1, 位列花天市日) = "市日"
        .Cells(1, 位列花天交易所码) = "交易所码"
        .Cells(1, 位列花天市场板类) = "市场板类"
        '---------------------------------
        .Cells(1, 位列花天地区新浪) = "地区新浪"
        .Cells(1, 位列花天行业新浪) = "行业新浪"
        .Cells(1, 位列花天行业益盟) = "行业益盟"
        .Cells(1, 位列花天概念益盟) = "概念益盟"
        .Cells(1, 位列花天对应大势) = "对应大势"
        '---------------------------------
        .Cells(1, 位列花天是否上证50) = "IH"
        .Cells(1, 位列花天是否中股300) = "IF"
        .Cells(1, 位列花天是否中证500) = "IC"
        .Cells(1, 位列花天是否中证1000) = "Im"
        .Cells(1, 位列花天是否中证2000) = "It"
        .Cells(1, 位列花天是否创业板50) = "创业板50"
        .Cells(1, 位列花天是否成分) = "成分"
        .Cells(1, 位列花天是否港股通) = "港股通"
        .Cells(1, 位列花天是否MSCI中国) = "MSCI中国"
        '---------------------------------
        .Cells(1, 位列花天仓宝福) = "福仓"
        .Cells(1, 位列花天仓宝彦) = "彦仓"
