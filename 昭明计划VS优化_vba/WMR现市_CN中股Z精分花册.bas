    Print #1, 符缩进 & "    ) As Boolean"
    '------------------------------------------------------------------------------------
    '输出：页面设置
    '------------------------------------------------------------------------------------
    Print #1, 符隔大
    Print #1, 符缩进 & 符引单 & "页面格式设置"
    Print #1, 符隔大
    Print #1, 符缩进 & "MS.Cells.Font.Size = 10"
