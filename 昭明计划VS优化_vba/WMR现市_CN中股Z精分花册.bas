Private Sub 后台族群精分辅程_准备类组()
'========================================================================================
    Dim WSLIST As Worksheet
    Set WSLIST = ThisWorkbook.ActiveSheet
    If Not WSLIST.Name Like "族*" Then
        Exit Sub
    End If
    '------------------------------------------------------------------------------------
    Dim CL As Range
    Dim 类名 As String
    Dim 类列表 As String
    Dim 始列输出 As Integer
    Dim 始行输出 As Integer
    始列输出 = 3
    始行输出 = 2
    '------------------------------------------------------------------------------------
    Dim 典类名去重 As New Dictionary
    Dim 维纵 As Integer
    Dim 维横 As Integer
    For 维横 = 始列输出 To WSLIST.UsedRange.Columns.Count
        类列表 = "Array(" & Chr(34) & WSLIST.Cells(1, 维横) & Chr(34)
        For 维纵 = 始行输出 To WSLIST.UsedRange.Rows.Count
            Set CL = WSLIST.Cells(维纵, 维横)
            If Len(CL.Value) > 0 Then
                If InStr(CL.Value, "[") > 1 Then
                    类名 = Left$(CL.Value, InStr(CL.Value, "[") - 1)
                Else
                    类名 = CL.Value
                End If
                If 典类名去重.Exists(类名) = False Then
                    类列表 = 类列表 & "," & Chr(34) & 类名 & Chr(34)
                    典类名去重.Add Key:=类名, Item:=类名
                End If
            End If
        Next 维纵
        类列表 = 类列表 & ") _"
        
        '输出时：首行不加逗号
        If 维横 = 始列输出 Then
            Debug.Print "          " & 类列表
        Else
            Debug.Print "        , " & 类列表
        End If
    Next 维横
    Debug.Print vbCrLf
'========================================================================================
    Set 典类名去重 = Nothing
End Sub



