    Print #1, 符缩进 & "当列 = 始行 + 5"
    '------------------------------------------------------------------------------------
    '<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
    
    
    '====================================================================================
    '遍历 组族群 一维：族
