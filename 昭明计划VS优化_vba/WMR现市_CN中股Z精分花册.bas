'########################################################################################
Function 后台族群精分引擎正程( _
      组族群 As Variant _
    , 去簿名 As String _
    , 来簿名 As String _
    , 来列群名 As Integer _
    , Optional 来列群指 As Integer = 0 _
    , Optional 输出族群号始 As Integer = -1 _
    , Optional 输出族群号终 As Integer = 1000 _
    , Optional 是否输出码表 As Boolean = False _
    )
'========================================================================================
'基础设置
'========================================================================================
    '------------------------------------------------------------------------------------
    '来工作簿
    '------------------------------------------------------------------------------------
    Dim 来簿 As Worksheet
    If STBASE外簿工具_花册链接(来簿, 来簿名) = False Then
        MsgBox "外部花册链接失败：" & 来簿名
        Exit Function
    End If
    '------------------------------------------------------------------------------------
    On Error Resume Next
    来簿.ShowAllData
    On Error GoTo 0
    '------------------------------------------------------------------------------------
    Dim i As Integer
    Dim k As Integer
    Dim X As Integer
    Dim Y As Integer
    Dim 群名 As String
'========================================================================================
'设置输出工作簿
'========================================================================================
    Dim 去簿 As Worksheet
    Call PBASE格程工具_表操工表新增(去簿, 去簿名, wb:=ThisWorkbook, 基色底:=常色主黄)
    '------------------------------------------------------------------------------------
    去簿.Rows(1).Font.Bold = True
    去簿.Rows(1).Borders(xlEdgeBottom).Weight = xlThin
    '------------------------------------------------------------------------------------
    '兜底列
    '------------------------------------------------------------------------------------
    Dim 去列偏离 As Integer
    去列偏离 = 2
    With 去簿.Columns(1)
        .ColumnWidth = 6
        .Interior.ColorIndex = 15
        .Cells(1, 1) = "类型"
    End With
    With 去簿.Columns(2)
        .ColumnWidth = 20
        .Interior.ColorIndex = 15
        .Cells(1, 1) = "未归属族群"
    End With
'========================================================================================
'汇总典群
'========================================================================================
    '====================================================================================
    '汇总典群：典群花册
    '====================================================================================
    Dim 典群花册 As New Dictionary
    Dim 来内容串 As String
    Dim 来内容组 As Variant
    '------------------------------------------------------------------------------------
    '对于 花册
    '进行日期过滤用以排除部分新码
    '------------------------------------------------------------------------------------
    Dim 来市日 As Date
    Dim 过滤市日开始 As Date
    Dim 过滤市日结束 As Date
    过滤市日开始 = "1989/1/1"
    过滤市日结束 = "2017/1/1"
    过滤市日结束 = "2020/1/1"
    
    If 来簿名 = 常花中股 Then
        For X = 2 To 来簿.Cells(65536, 来列群名).End(xlUp).Row
            来市日 = 来簿.Cells(X, 位列花天市日)
            
            来内容串 = 来簿.Cells(X, 来列群名)
            来内容组 = Split(来内容串, ";")
            For Y = LBound(来内容组) To UBound(来内容组)
                If (来市日 >= 过滤市日开始 And 来市日 <= 过滤市日结束) Then
                群名 = 来内容组(Y)
                If Not 典群花册.Exists(群名) Then
                    典群花册.Add Item:=群名, Key:=群名
                End If
                End If
            Next Y
            Erase 来内容组
        Next X
    '------------------------------------------------------------------------------------
    '对于 成源
    '------------------------------------------------------------------------------------
    Else
        For X = 2 To 来簿.Cells(65536, 来列群名).End(xlUp).Row
            来内容串 = 来簿.Cells(X, 来列群名)
            来内容组 = Split(来内容串, ";")
            For Y = LBound(来内容组) To UBound(来内容组)
                群名 = 来内容组(k)
                If Not 典群花册.Exists(群名) Then
                    典群花册.Add Item:=群名, Key:=群名
                End If
            Next Y
            Erase 来内容组
        Next X
    End If
    '------------------------------------------------------------------------------------
    On Error GoTo 0
    '====================================================================================
    '汇总典群：典群族群
    '====================================================================================
    Dim 典群族群 As New Dictionary
    
    For X = LBound(组族群, 1) To UBound(组族群, 1)
    For Y = LBound(组族群(X), 1) + 1 To UBound(组族群(X), 1)
        群名 = 组族群(X)(Y)
        If Not 典群族群.Exists(群名) Then
            典群族群.Add Item:=群名, Key:=群名
        End If
    Next Y
    Next X
    '====================================================================================
    '典群比较：检查 典群 包含关系
    '====================================================================================
    Dim 群是否存在 As Boolean
    '------------------------------------------------------------------------------------
    '未归属：典群花册 > 典群族群
    '------------------------------------------------------------------------------------
    For k = 1 To 典群花册.Count
        群名 = 典群花册.Keys(k - 1)
        群是否存在 = 典群族群.Exists(群名)
        
        If 群是否存在 = False Then
            With 去簿.Cells(去簿.Cells(65536, 1).End(xlUp).Row + 1, 1)
                .Value = "[册>族]"
                .Cells(1, 2).Value = 群名
            End With
        End If
    Next k
    '------------------------------------------------------------------------------------
    '未归属：典群族群 > 典群花册
    '------------------------------------------------------------------------------------
    For k = 1 To 典群族群.Count
        群名 = 典群族群.Keys(k - 1)
        群是否存在 = 典群花册.Exists(群名)
        
        If 群是否存在 = False Then
            With 去簿.Cells(去簿.Cells(65536, 1).End(xlUp).Row + 1, 1)
                .Value = "[族>册]"
                .Cells(1, 2).Value = 群名
                .Interior.ColorIndex = 16
            End With
        End If
    Next k
    '------------------------------------------------------------------------------------
    Set 典群花册 = Nothing
    Set 典群族群 = Nothing
'========================================================================================
'运行：输出产出物
'========================================================================================
    Dim 输出开关 As Boolean
    Dim 参数单行代码个数 As Integer
    Dim 参数输出个数阈值 As Integer
    参数输出个数阈值 = 100
    '-------------------------------
    Dim 目行 As Integer
    Dim 目列 As Integer
    Dim 程序名称 As String
    '-------------------------------
    Dim 族名 As String
    Dim 群对应指数 As String
    Dim 群成分个数 As Integer
    Dim 群成分代码 As String
