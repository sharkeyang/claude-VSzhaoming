        '--------------------------------------------------------------------------------
        '设置输出开关：使用前缀【略】作为禁止输出的标志
        '--------------------------------------------------------------------------------
'        输出开关 = (X >= 输出族群号始 And X <= 输出族群号终) And X <> UBound(组族群, 1)
        输出开关 = (X >= 输出族群号始 And X <= 输出族群号终) And Left$(族名, 1) <> "略"
        '--------------------------------------------------------------------------------
        
        '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
        '输出：调用列表
        '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
        If 输出开关 = True Then
            '----------------------------------------------------------------------------
            '调用列表：正常
            '----------------------------------------------------------------------------
            Print #1, 符隔小
            Print #1, 符缩进 & "当列 = " & 程序名称 & "(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1"
            '----------------------------------------------------------------------------
        Else
            '----------------------------------------------------------------------------
            '调用列表：省略
            '----------------------------------------------------------------------------
            Print #1, 符隔小
            Print #1, 符缩进 & 符引单 & "当列 = " & 程序名称 & "(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1"
            '----------------------------------------------------------------------------
        End If
        '<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
    Next X
    
    
    '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
    '输出文件 基程代码
    '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
    '------------------------------------------------------------------------------------
    '输出：页面设置
    '------------------------------------------------------------------------------------
    Print #1, 符隔大
    Print #1, 符缩进 & 符引单 & "页面格式设置"
    Print #1, 符隔大
'    Print #1, 符缩进 & "MS.Rows(始行).Font.Bold = True"
'    Print #1, 符缩进 & "MS.Rows(始行).HorizontalAlignment = xlLeft"
'    Print #1, 符缩进 & "MS.Rows(始行).Borders(xlEdgeBottom).Weight = xlThin"
'    '------------------------------------------
'    Print #1, 符隔小
    Print #1, 符缩进 & "If 是否排序 = xlAscending Or 是否排序 = xlDescending Then"
    Print #1, 符缩进 & "    With MS.Cells(始行 + 1, 始行 + 1)"
    Print #1, 符缩进 & "        .Resize(.Offset(65536, 0).End(xlUp).Row, 3).Sort _"
    Print #1, 符缩进 & "        key1:=.Offset(0, 1), order1:=是否排序, Header:=xlYes"
    Print #1, 符缩进 & "    End With"
    Print #1, 符缩进 & "End If"
    Print #1, 符隔小
    Print #1, 符缩进 & "MS.Activate"
    Print #1, 符缩进 & "Call PBASE格程工具_表冻结锁定(MS, 始行 + 1, 始行 + 3)"
    Print #1, 符隔大
    Print #1, "End Function"
    '------------------------------------------------------------------------------------
    Print #1, 符隔外
    Print #1, 符隔外
    Print #1, 符隔外
    Print #1,
    Print #1,
    '------------------------------------------------------------------------------------
    '<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<


'========================================================================================
'运行：输出调用分程
'========================================================================================
    '====================================================================================
    '遍历 组族群 一维：族
    '====================================================================================
    For X = LBound(组族群, 1) To UBound(组族群, 1)
        '--------------------------------------------------------------------------------
        '级别设置：族
        '--------------------------------------------------------------------------------
        族名 = 组族群(X)(0)
        目列 = 去列偏离 + (X + 1)
        去簿.Cells(1, 目列) = 族名
        程序名称 = "现市分程_" & 去簿名 & "_" & 族名
        '--------------------------------------------------------------------------------
        '设置输出开关
        '--------------------------------------------------------------------------------
'        输出开关 = (X >= 输出族群号始 And X <= 输出族群号终) And X <> UBound(组族群, 1)
        输出开关 = (X >= 输出族群号始 And X <= 输出族群号终) And Left$(族名, 1) <> "略"
        '--------------------------------------------------------------------------------
       
        
        '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
        '输出：调用列表 分程程序头部
        '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
        If 输出开关 = True Then
            '----------------------------------------------------------------------------
            '外部文件：分程程序头部
            '----------------------------------------------------------------------------
            Print #1,
            Print #1,
            Print #1, "Function " & 程序名称 & "( _"
            Print #1, 符缩进 & "      MS As Worksheet _"
            Print #1, 符缩进 & "    , 始行 As Integer, 始列 As Integer _"
            Print #1, 符缩进 & "    , Optional 是否排序 As XlSortOrder = xlDescending _"
            Print #1, 符缩进 & "    , Optional 天组 As Variant _"
            Print #1, 符缩进 & "    , Optional 天典 As Dictionary _"
            Print #1, 符缩进 & "    ) As Integer"
            Print #1, 符隔大
            Print #1, 符缩进 & "MS.Cells(始行, 始列).Cells(1, 位简式名称) = " & 符引双 & 族名 & 符引双
            Print #1, 符隔小
            Print #1, 符缩进 & "Dim 目行 As Integer"
            Print #1, 符缩进 & "Dim 目列 As Integer"
            Print #1, 符缩进 & "目行 = 始行 + 1"
            Print #1, 符缩进 & "目列 = 始列"
            Print #1, 符隔小
            Print #1, 符缩进 & "Dim 码市 As String"
            Print #1, 符缩进 & "码市 = " & 符引双 & "SS" & 符引双
            Print #1, 符缩进 & "Dim 码类 As String"
            Print #1, 符缩进 & "Dim 码指 As String"
            Print #1, 符缩进 & "Dim 码组 As Variant"
            Print #1, 符隔大
            '----------------------------------------------------------------------------
        End If
        '<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
       
        
        '================================================================================
        '遍历 组族群 二维：群
        '================================================================================
        For Y = LBound(组族群(X), 1) + 1 To UBound(组族群(X), 1)
            '----------------------------------------------------------------------------
            '级别设置：群
            '----------------------------------------------------------------------------
            群名 = 组族群(X)(Y)
            '----------------------------------------------------------------------------
            '衍生群名：获取码集
            '----------------------------------------------------------------------------
            For k = 2 To 来簿.Cells(65536, 来列群名).End(xlUp).Row
                If InStr(来簿.Cells(k, 来列群名), 群名) > 0 Then
                    '---------------------------------------------------------------------
                    '获取：群对应的指数
                    '---------------------------------------------------------------------
                    If 来列群指 <> 0 Then 群对应指数 = 来簿.Cells(k, 来列群指)
                    '---------------------------------------------------------------------
                    '获取：成分码集
                    '---------------------------------------------------------------------
                    群成分代码 = 来簿.Cells(k, 位列花天CIDL)
                    If Len(群成分代码) > 0 Then
                        群成分码集.Add Item:=群成分代码, Key:=群成分代码
                    End If
                    '---------------------------------------------------------------------
                End If
            Next k
            群成分个数 = 群成分码集.Count
            '----------------------------------------------------------------------------
            '衍生群名：生成码串
            '----------------------------------------------------------------------------
            If 群成分个数 > 200 Then
                参数单行代码个数 = 20
            Else
                参数单行代码个数 = 10
            End If
            
            群成分码串 = ""
            For i = 1 To Application.Min(参数输出个数阈值, 群成分码集.Count)
                群成分码串 = 群成分码串 & "," & 符引双 & 群成分码集(i) & 符引双
                If i Mod 参数单行代码个数 = 0 Then
                    群成分码串 = 群成分码串 & " _" & vbCrLf & String(8, " ")
                End If
            Next
            群成分码串 = String(10, " ") & Mid$(群成分码串, 2)
            '----------------------------------------------------------------------------
            Set 群成分码集 = Nothing
            '----------------------------------------------------------------------------
            
            
            '#############################################################################
            '输出 族群矩阵 到 结果工作簿
            '#############################################################################
            目行 = 1 + Y
            '----------------------------------------------------------------------------
            去簿.Cells(目行, 目列).Value = 组族群(X)(Y) & "[" & 群成分个数 & "]"
            If 群成分个数 > 200 Then
                去簿.Cells(目行, 目列).Font.Color = 常色十红
            ElseIf 群成分个数 > 参数输出个数阈值 Then
                去簿.Cells(目行, 目列).Font.Color = 常色八紫
            ElseIf 群成分个数 = 0 Then
                去簿.Cells(目行, 目列).Interior.ColorIndex = 3
            End If
            If 输出开关 = False Then
                去簿.Cells(目行, 目列).Interior.ColorIndex = 15
            End If
            '#############################################################################
            
            
            '#############################################################################
            '输出代码列表 到立即窗口
            '#############################################################################
            If 输出开关 = True And 是否输出码表 = True Then
                Debug.Print (群名) & vbCrLf & (群成分码串) & vbCrLf
            End If
            '#############################################################################
           
            
            '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
            '输出分程程序 到外部
            '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
            If 输出开关 = True Then
                Print #1, 符缩进 & "码类 = " & 符引双 & 群名 & 符引双
                Print #1, 符缩进 & "码组 = Array(" & " _"
                Print #1, 群成分码串 & " )"
                If 来列群指 = 0 Then
                    Print #1, 符缩进 & "目列 = 查程同市码组(码市, 码类, 码组, MS, 目行, 目列, 是否排序, 天组:=天组, 天典:=天典)"
                Else
                    Print #1, 符缩进 & "码指 = " & 符引双 & 群对应指数 & 符引双
                    Print #1, 符缩进 & "目列 = 查程同市码组(码市, 码类, 码组, MS, 目行, 目列, 是否排序, 码指:=码指, 天组:=天组, 天典:=天典)"
                End If
                Print #1, 符缩进 & "Erase 码组"
                Print #1, 符隔小
            End If
            '<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
        Next Y
        '================================================================================
        '遍历 组族群 二维：群
        '================================================================================
        
        
        '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
        '输出程序尾部
        '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
        If 输出开关 = True Then
            Print #1, 符隔大
            Print #1, 符缩进 & 程序名称 & "= 目列"
            Print #1, "End Function"
        End If
        '<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
    Next X
    '====================================================================================
    '遍历 组族群 一维：族
    '====================================================================================
    
    
    
    '>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
    Close #1
    '<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
'========================================================================================
'格式化
'========================================================================================
    去簿.Columns.AutoFit
    去簿.Activate
    ActiveWindow.Zoom = 80
    Set 去簿 = Nothing
'========================================================================================
End Function
