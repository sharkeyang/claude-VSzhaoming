'========================================================================================
'理论最近交易日：根据期类推断
'========================================================================================
Function 时程结期推算质程(期类 As String, 期开始查找 As Date) As Date
    Dim 第几日 As Integer
    Dim 期遍历 As Date
    Dim 期锁定 As Date
    '------------------------------------------------------------------------------------
    For 第几日 = 0 To 1000
        期遍历 = DateAdd("D", -1 * 第几日, 期开始查找)
        
        If 期类 = 常期类为日 And 时程结期判断IS类日(期遍历) Then
            期锁定 = 期遍历
            Exit For
        ElseIf 期类 = 常期类为周 And 时程结期判断IS类周(期遍历) Then
            期锁定 = 期遍历
            Exit For
        ElseIf 期类 = 常期类为月 And 时程结期判断IS类月(期遍历) Then
            期锁定 = 期遍历
            Exit For
        End If
    Next 第几日
    '------------------------------------------------------------------------------------
    时程结期推算质程 = 期锁定
End Function
'========================================================================================
'本次交易日
'注意20220828：统一取日类历史，然后进行推算
'========================================================================================
Function 时程结期推算本次藏库(ByVal 期类 As String, 目标日期 As Date) As Date
    '------------------------------------------------------------------------------------
    Dim 日期可得历史 As Date
    日期可得历史 = STBASE取据引擎查时戳由藏库()
    Dim 日期开始查找  As Date
    日期开始查找 = Application.Min(日期可得历史, 目标日期)
    '------------------------------------------------------------------------------------
    时程结期推算本次藏库 = 时程结期推算质程(期类, 日期开始查找)
End Function

Function 时程结期推算本次TH(ByVal 期类 As String, 目标日期 As Date) As Date
    '------------------------------------------------------------------------------------
    Dim 日期可得历史 As Date
    日期可得历史 = STBASE取据引擎查时戳由腾历(常期类为日, CIDL:="sh000001")
    Dim 日期开始查找  As Date
    日期开始查找 = Application.Min(日期可得历史, 目标日期)
    '------------------------------------------------------------------------------------
    时程结期推算本次TH = 时程结期推算质程(期类, 日期开始查找)
End Function
