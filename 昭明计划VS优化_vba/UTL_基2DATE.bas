Function 时程工具衍生期索(今日 As Date, 期类 As String) As String
    Dim 索引日期 As String
    If 期类 = 常期类为日 Then
        索引日期 = Format(今日, "YYYYMMDD")
    ElseIf 期类 = 常期类为周 Then
        索引日期 = Year(今日) & "w" & Format(Format(今日, "ww"), "00")
    ElseIf 期类 = 常期类为月 Then
        索引日期 = Format(今日, "YYYYMM")
    End If
    时程工具衍生期索 = 索引日期
End Function
