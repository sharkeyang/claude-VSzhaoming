'========================================================================================
'判断初始期是否能够进行日结算
'========================================================================================
Function 时程结期判断IS类日(初始期 As Date) As Boolean
    If 典全局交期类日 Is Nothing Then Call 时程结期判断by字典装载(常期类为日)
    时程结期判断IS类日 = 典全局交期类日.Exists(时程工具衍生期索(初始期, 常期类为日))
End Function
Function 时程结期判断IS类周(初始期 As Date) As Boolean
    If 典全局交期类周 Is Nothing Then Call 时程结期判断by字典装载(常期类为周)
    时程结期判断IS类周 = 典全局交期类周.Exists(时程工具衍生期索(初始期, 常期类为日))    '注：一定要按“日”衍生
End Function
Function 时程结期判断IS类月(初始期 As Date) As Boolean
    If 典全局交期类月 Is Nothing Then Call 时程结期判断by字典装载(常期类为月)
    时程结期判断IS类月 = 典全局交期类月.Exists(时程工具衍生期索(初始期, 常期类为日))    '注：一定要按“日”衍生
End Function

'========================================================================================
'从《交日》工表装载具体交易日数据
'========================================================================================
Private Sub 时程结期判断by字典装载(期类 As String)
    Dim 典全局交期 As New Dictionary
    '------------------------------------------------------------------------------------
    Dim 所在列号 As Integer
    Dim i As Integer
    If 期类 = 常期类为日 Then
        所在列号 = 1
    ElseIf 期类 = 常期类为周 Then
        所在列号 = 2
    ElseIf 期类 = 常期类为月 Then
        所在列号 = 3
    End If
    '------------------------------------------------------------------------------------
    Dim WS交期 As Worksheet
    If STBASE外簿工具_花册链接(WS交期, 常花结期) Then
        Dim currentDate As Date
        Dim 值索横期 As String
        With WS交期
            For i = 1 To .Cells(65536, 所在列号).End(xlUp).Row
                If VBA.IsDate(.Cells(i, 所在列号)) = True Then
                    currentDate = .Cells(i, 所在列号)
                    值索横期 = 时程工具衍生期索(currentDate, 常期类为日)
                    典全局交期.Add Item:=currentDate, Key:=值索横期
                End If
            Next
        End With
    End If
    '------------------------------------------------------------------------------------
    If 期类 = 常期类为日 Then
        Set 典全局交期类日 = 典全局交期
    ElseIf 期类 = 常期类为周 Then
        Set 典全局交期类周 = 典全局交期
    ElseIf 期类 = 常期类为月 Then
        Set 典全局交期类月 = 典全局交期
    End If
    Set 典全局交期 = Nothing
End Sub
