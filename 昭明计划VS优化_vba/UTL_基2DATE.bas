Private Sub 时程后台加工_生成交易日工表()
    '------------------------------------------------------------------------------------
    '导入文件：创建交易日期集合
    '------------------------------------------------------------------------------------
    ' 设置交易日历文件路径
    Dim tradeDatesFilePath As String
    tradeDatesFilePath = "D:\zdata\交易日.csv"

'    Dim tradeDatesFilePath
'    tradeDatesFilePath = Application.GetOpenFilename("*.csv,*.xls", , "请选择trade_dates.csv", , False)
'    If tradeDatesFilePath = False Then
'        Exit Function
'    End If
    '------------------------------------------------------------------------------------
    ' 创建交易日期集合
    Dim 典交易日  As New Dictionary

    ' 打开交易日历文件
    Dim tradeDatesFile As Object
    Set tradeDatesFile = CreateObject("Scripting.FileSystemObject").OpenTextFile(tradeDatesFilePath, 1)

    ' 跳过文件头
    tradeDatesFile.ReadLine

    ' 读取交易日期并添加到集合中
    Dim tradeDate As Date
    Dim tradeDate串 As String
    Do While Not tradeDatesFile.AtEndOfStream
        tradeDate串 = tradeDatesFile.ReadLine
        If tradeDate串 Like "########" Then
            tradeDate = DateSerial(Left$(tradeDate串, 4), Mid$(tradeDate串, 5, 2), Mid$(tradeDate串, 7, 2))
            典交易日.Add Item:=tradeDate, Key:=tradeDate串
        End If
    Loop
    tradeDatesFile.Close
    '------------------------------------------------------------------------------------
    '输出到外部花册
    '------------------------------------------------------------------------------------
    Dim WS交期 As Worksheet
    Dim 花册簿 As Workbook
    Dim i As Integer
    If STBASE外簿工具_花册链接(WS交期, 常花结期) = False Then
        If STBASE外簿工具_花册定位(花册簿) = False Then
            MsgBox "无法打开外部花册，交易日工表生成失败。", vbExclamation
            Set 典交易日 = Nothing
            Exit Sub
        End If
    Else
        Set 花册簿 = WS交期.Parent
    End If
    Call PBASE格程工具_表操工表新增(WS交期, 常花结期, wb:=花册簿, 基色底:=常色主黑)
    With WS交期
        .Cells(1, 1) = "结日"
        For i = 1 To 典交易日.Count
            .Cells(1 + i, 1) = 典交易日.Items(i - 1)
        Next
    End With
    '====================================================================================
    Dim DATEatROW As Date
    Dim ROWID As Integer
    '====================================================================================
    '衍生：周类结算日、月类结算日
    '====================================================================================
    '重新装载交易日数据
    Call 时程结期判断by字典装载(常期类为日)
    '衍生
    With WS交期
        For ROWID = 2 To .Cells(65536, 1).End(xlUp).Row
            DATEatROW = .Cells(ROWID, 1)
            '----------------------------------------------------------------------------
            If 时程结期判断by手工IS类周(DATEatROW) = True Then .Cells(ROWID, 2) = DATEatROW
            '----------------------------------------------------------------------------
            If 时程结期判断by手工IS类月(DATEatROW) = True Then .Cells(ROWID, 3) = DATEatROW
            '----------------------------------------------------------------------------
            .Cells(ROWID, 4) = Weekday(DATEatROW, vbMonday)
            .Cells(ROWID, 5) = 时程结期判断IS类日(DATEatROW)
            .Cells(ROWID, 6) = 时程结期判断by手工IS类周(DATEatROW)
            .Cells(ROWID, 7) = 时程结期判断by手工IS类月(DATEatROW)
            '----------------------------------------------------------------------------
        Next
    '------------------------------------------------------------------------------------
        .Cells(1, 1) = "结日"
        .Cells(1, 2) = "结周"
        .Cells(1, 3) = "结月"
        .Columns(1).NumberFormatLocal = 全设格式of日期
        .Columns(2).NumberFormatLocal = 全设格式of日期
        .Columns(3).NumberFormatLocal = 全设格式of日期
        .Cells(1, 4) = "周几"
        .Cells(1, 5) = "IS日"
        .Cells(1, 6) = "IS周"
        .Cells(1, 7) = "IS月"
        .Rows(1).Font.Bold = True
        .Columns.AutoFit
    End With
    '====================================================================================
    '验证算法正确性
    '====================================================================================
    With WS交期
        For ROWID = 2 To .Cells(65536, 1).End(xlUp).Row
            DATEatROW = .Cells(ROWID, 1)
            '----------------------------------------------------------------------------
            If 时程结期判断IS类周(DATEatROW) = 时程结期判断by手工IS类周(DATEatROW) Then
                .Cells(ROWID, 8) = "周算法正确"
            Else
                .Cells(ROWID, 8) = "周错误" & 时程结期判断IS类周(DATEatROW) & 时程结期判断by手工IS类周(DATEatROW)
                .Cells(ROWID, 8).Interior.Color = 常色十红
                Stop
            End If
            '----------------------------------------------------------------------------
            If 时程结期判断IS类月(DATEatROW) = 时程结期判断by手工IS类月(DATEatROW) Then
                .Cells(ROWID, 9) = "月算法正确"
            Else
                .Cells(ROWID, 9) = "月错误" & 时程结期判断IS类月(DATEatROW) & 时程结期判断by手工IS类月(DATEatROW)
                .Cells(ROWID, 9).Interior.Color = 常色十红
                Stop
            End If
            '----------------------------------------------------------------------------
        Next
    '------------------------------------------------------------------------------------
        .Cells(1, 1) = "结日"
        .Cells(1, 2) = "结周"
        .Cells(1, 3) = "结月"
        .Columns(1).NumberFormatLocal = 全设格式of日期
        .Columns(2).NumberFormatLocal = 全设格式of日期
        .Columns(3).NumberFormatLocal = 全设格式of日期
        .Cells(1, 4) = "周几"
        .Cells(1, 5) = "IS日"
        .Cells(1, 6) = "IS周"
        .Cells(1, 7) = "IS月"
        .Cells(1, 8) = "验正周（新旧）"
        .Cells(1, 9) = "验正月（新旧）"
        .Rows(1).Font.Bold = True
        .Columns.AutoFit
        .Activate
        .Range("A2").Select
        ActiveWindow.FreezePanes = True
    End With
    '====================================================================================
    Set 典交易日 = Nothing
    Set WS交期 = Nothing
    '------------------------------------------------------------------------------------
End Sub

