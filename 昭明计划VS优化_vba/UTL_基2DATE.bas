'========================================================================================
'判断初始期是否能够进行周结算
'========================================================================================
Function 时程结期判断by手工IS类周(初始期 As Date) As Boolean
    '------------------------------------------------------------------------------------
    Dim 是否可结算 As Boolean
    Dim 当日 As Date
    Dim 下一日 As Date
    Dim 本期终日 As Date
    '------------------------------------------------------------------------------------
    下一日 = DateAdd("D", 1, 初始期)
    本期终日 = DateAdd("ww", 1, 初始期) - Weekday(DateAdd("ww", 1, 初始期), vbMonday)
    '------------------------------------------------------------------------------------
    是否可结算 = True
    If 时程结期判断IS类日(初始期) = False Then
        是否可结算 = False
    Else
        For 当日 = 下一日 To 本期终日
            If 时程结期判断IS类日(当日) = True Then
                是否可结算 = False
                Exit For
            End If
        Next
    End If
    '------------------------------------------------------------------------------------
    时程结期判断by手工IS类周 = 是否可结算
End Function
'========================================================================================
'判断初始期是否能够进行月结算
'========================================================================================
Function 时程结期判断by手工IS类月(初始期 As Date) As Boolean
    '------------------------------------------------------------------------------------
    Dim 是否月可结算 As Boolean
    Dim 当日 As Date
    Dim 本期终日 As Date
    Dim 下一日 As Date
    '------------------------------------------------------------------------------------
    下一日 = DateAdd("D", 1, 初始期)
    本期终日 = DateAdd("m", 1, 初始期) - Day(DateAdd("m", 1, 初始期))
    '------------------------------------------------------------------------------------
    是否月可结算 = True
    If 时程结期判断IS类日(初始期) = False Then
        是否月可结算 = False
    Else
        For 当日 = 下一日 To 本期终日
            If 时程结期判断IS类日(当日) = True Then
                是否月可结算 = False
                Exit For
            End If
        Next
    End If
    '------------------------------------------------------------------------------------
    时程结期判断by手工IS类月 = 是否月可结算
End Function
