    Dim 排序顺序 As XlSortOrder
    排序列号 = Selection.Column
    排序顺序 = xlDescending
    
    Call PSOP排序引擎( _
      排序列号:=排序列号 _
    , 排序顺序:=排序顺序 _
    )
End Sub
Sub PSOP排序单块调程_按这列升序()
    Dim 排序列号 As Integer
    Dim 排序顺序 As XlSortOrder
    排序列号 = Selection.Column
    排序顺序 = xlAscending
    
    Call PSOP排序引擎( _
      排序列号:=排序列号 _
    , 排序顺序:=排序顺序 _
    )
End Sub

Function PSOP排序引擎( _
          排序列号 As Integer _
        , Optional 排序顺序 As XlSortOrder = xlDescending _
        ) As Boolean
'========================================================================================
'验明正身
'========================================================================================
    If PSOP格整理质程_是否适用首列(ActiveSheet.Name) = False And Left$(ActiveSheet.Name, 2) <> "历统" Then
        Exit Function
    End If
'========================================================================================
'探索区块
'========================================================================================
    Dim 排序区块 As Range
    Dim 本行 As Integer
    本行 = Selection.Row
    If PSOP排序基程_探索区块(排序区块, ActiveSheet, 本行) = False Then
        PSOP排序引擎 = False
        Exit Function
    End If
'========================================================================================
'排序
'========================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    '排序
    '------------------------------------------------------------------------------------
    If PSOP格整理质程_是否适用首列(ActiveSheet.Name) = True Then
        With 排序区块
            .Cells.Sort key1:=.Cells(1, 排序列号), order1:=排序顺序, Header:=xlNo
        End With
    ElseIf Left$(ActiveSheet.Name, 2) = "历统" Then
        With 排序区块
            .Cells.Sort key1:=.Cells(1, 排序列号), order1:=排序顺序, Header:=xlYes
        End With
    End If
    Set 排序区块 = Nothing
    PSOP排序引擎 = True
    '------------------------------------------------------------------------------------
    UTL宏工具_END
'========================================================================================
End Function




'========================================================================================
'========================================================================================
'功能：探索排序区域
'区别：对适用首列工表，视非代码行为区域分界线；其余，视空行为区域分界线
'========================================================================================
'========================================================================================
Function PSOP排序基程_探索区块( _
          排序区块 As Range _
        , WSAS As Worksheet _
        , 本行 As Integer _
        , Optional 本列 As Integer = 1 _
        ) As Boolean
    '====================================================================================
    '工表：适用首列
    '====================================================================================
    If PSOP格整理质程_是否适用首列(WSAS.Name) = True Then
        '------------------------------------------------------------------------------------
        '验证区域
        '------------------------------------------------------------------------------------
        Dim 末行 As Integer
        末行 = PBASE格程工具_表参末行指定(WSAS, 1)
        If 本行 > 末行 Or UBCID是代码(WSAS.Cells(本行, 位qt代码)) = False Then
            PSOP排序基程_探索区块 = False
            Exit Function
        End If
        '------------------------------------------------------------------------------------
        '确定区域
        '------------------------------------------------------------------------------------
        Dim 区域上沿 As Integer
        Dim 行号遍历 As Integer
        For 行号遍历 = 本行 To 2 Step -1
            If UBCID是代码(WSAS.Cells(行号遍历, 位qt代码)) = True Then
                区域上沿 = 行号遍历
            Else
                Exit For
            End If
        Next 行号遍历
        Dim 区域下沿 As Integer
        For 行号遍历 = 本行 To 末行
            If UBCID是代码(WSAS.Cells(行号遍历, 位qt代码)) = True Then
                区域下沿 = 行号遍历
            Else
                Exit For
            End If
        Next 行号遍历
        '------------------------------------------------------------------------------------
        '确定区域
        '------------------------------------------------------------------------------------
        Dim 末列 As Integer
        末列 = PBASE格程工具_表参末列指定(WSAS, 本行)
        If 区域下沿 >= 区域上沿 Then
            Set 排序区块 = WSAS.Cells(区域上沿, 1).Resize(区域下沿 - 区域上沿 + 1, 末列)
            PSOP排序基程_探索区块 = True
        End If
    '====================================================================================
    '工表：历统
    '====================================================================================
    ElseIf Left$(WSAS.Name, 2) = "历统" Then
            Set 排序区块 = WSAS.Cells(本行, 本列).CurrentRegion
            PSOP排序基程_探索区块 = True
    '====================================================================================
    '工表：其他
    '====================================================================================
    Else
            PSOP排序基程_探索区块 = False
            Exit Function
    End If
    '====================================================================================
End Function
'########################################################################################
'########################################################################################
'##################################     单块排序     #####################################
'########################################################################################
'########################################################################################




'########################################################################################
'########################################################################################
'##################################     全表排序     #####################################
'########################################################################################
'########################################################################################
Function PSOP排序全表分块基程(WS As Worksheet, 排序列号 As Integer, Optional 排序顺序 As XlSortOrder = xlDescending) As Boolean
'    UTL宏工具_BEGIN
'========================================================================================
'验明正身
'========================================================================================
    If PSOP格整理质程_是否适用首列(ActiveSheet.Name) = False Then
        Exit Function
    End If
'========================================================================================
    Dim 末行 As Integer
    末行 = PBASE格程工具_表参末行指定(WS, 1)
    '------------------------------------------------------------------------------------
    Dim 排序区块 As Range
    Dim 本行 As Integer
    本行 = 2
    
    Do While 本行 <= 末行
        If PSOP排序基程_探索区块(排序区块, WS, 本行) = False Then
            本行 = 本行 + 1
        Else
            With 排序区块
                .Cells.Sort key1:=.Cells(1, 排序列号), order1:=排序顺序, Header:=xlNo
            End With
            本行 = 本行 + 排序区块.Rows.Count
        End If
    Loop
    Set 排序区块 = Nothing
'========================================================================================
'    UTL宏工具_END
End Function

