'========================================================================================
'========================================================================================
'功能：获取特征值所在的行号前一行，否则为最后一行
'========================================================================================
'========================================================================================
Function PBASE格程工具_表参定位特征行号( _
      WS As Worksheet _
    , Optional 特征值 As String = "核心指数" _
    , Optional 特征列 As Integer = 1 _
    ) As Integer
    '------------------------------------------------------------------------------------
    If WS Is Nothing Then Exit Function
    '------------------------------------------------------------------------------------
    Dim 定位终行 As Integer
    Dim 定位终元 As Range
    Set 定位终元 = WS.Columns(特征列).Find(What:=特征值)
    If Not 定位终元 Is Nothing Then
        定位终行 = 定位终元.Row - 1
    Else
        定位终行 = WS.Cells(65536, 特征列).End(xlUp).Row
        Set 定位终元 = Nothing
    End If
    '------------------------------------------------------------------------------------
    PBASE格程工具_表参定位特征行号 = 定位终行
End Function

