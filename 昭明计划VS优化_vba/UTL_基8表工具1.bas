'========================================================================================
'========================================================================================
'操作：圈选代码集合
'========================================================================================
'========================================================================================
Function UGSOP拣选引擎圈选(典被研代码 As Dictionary) As Integer
'========================================================================================
    Dim 当前表名  As String
    当前表名 = ActiveSheet.Name
    Dim WSAS As Worksheet
    Set WSAS = ActiveSheet
    '------------------------------------------------------------------------------------
    Dim CIDL As String
    Dim 名称 As String
'========================================================================================
'圈选：从首列
'========================================================================================
    If PSOP格整理质程_是否适用首列(当前表名) _
    Or Left$(当前表名, 1) = 常簿缀结算 _
    Or 当前表名 = "统算比" _
    Or 当前表名 = "统算展" _
    Then
        '--------------------------------------------------------------------------------
        '遍历获取代码列表
        '--------------------------------------------------------------------------------
        Dim 行号遍历 As Integer
        For 行号遍历 = 2 To PBASE格程工具_表参末行指定(WSAS, 1)
            If Intersect(WSAS.Rows(行号遍历), Selection) Is Nothing Then
            Else
                CIDL = WSAS.Cells(行号遍历, 位qt代码).Value
                名称 = WSAS.Cells(行号遍历, 位qt代称).Value
                '针对代码
                If UBCID是中股票(CIDL) = True Or UBCID是中股基(CIDL) = True Or UBCID是中股指(CIDL) = True Then
                    If 典被研代码.Exists(CIDL) = False Then 典被研代码.Add Item:=名称, Key:=CIDL
                End If
            End If
        Next
'========================================================================================
'圈选：从频谱
'========================================================================================
    ElseIf 当前表名 Like (常簿缀频谱 & "*" & 常簿缀频谱) _
    Then
        If Selection.Column Mod 常频块目列宽数 = 1 Then
            CIDL = Selection.Cells(1, 常频块目列宽数)
            名称 = Selection.Cells(1, 1)
            If UBCID是代码(CIDL) = True And 典被研代码.Exists(CIDL) = False Then
                典被研代码.Add Item:=名称, Key:=CIDL
            End If
        End If
'========================================================================================
    End If
    Set WSAS = Nothing
    '------------------------------------------------------------------------------------
    UGSOP拣选引擎圈选 = 典被研代码.Count
End Function





'========================================================================================
'========================================================================================
'操作：归集总标记
'========================================================================================
'========================================================================================
Sub UGSOP拣选引擎标记()
    UTL宏工具_BEGIN
'========================================================================================
    Dim WS As Worksheet
    Set WS = ActiveSheet
    Dim 当前表名  As String
    当前表名 = WS.Name
    Dim RG As Range
    '====================================================================================
    '归集：从首列【底色与字色不同】加入Z
    '====================================================================================
    If (PSOP格整理质程_是否适用首列(当前表名) = True) _
    Then
        For 行号遍历 = 2 To PBASE格程工具_表参末行指定(WS, 1)
            If Intersect(WS.Rows(行号遍历), Selection) Is Nothing Then
            Else
                WS.Cells(行号遍历, 1).Resize(1, 2).Font.ColorIndex = 3
            End If
        Next
    '====================================================================================
    '归集：从市况【底色与章色相同+字色不是黑色】加入ZZ
    '====================================================================================
    ElseIf 当前表名 = "概念" _
        Or 当前表名 = "地区" _
        Or 当前表名 = "行业" _
        Or 当前表名 = "行益" _
        Or 当前表名 = "W" _
    Then
        For Each RG In Selection
            RG.Font.ColorIndex = 3
        Next
    '====================================================================================
    '归集：从历史/异常【字色不是黑色】加入ZZ
    '====================================================================================
    ElseIf Left$(当前表名, 1) = 常簿缀历统 _
        Or 当前表名 = "异常" _
    Then
        For Each RG In Selection
            RG.Font.ColorIndex = 3
        Next
    '====================================================================================
    '归集：从频谱【字色不是黑色】加入ZZ
    '====================================================================================
    ElseIf 当前表名 Like 常簿缀频谱 & "*" & 常簿缀频谱 _
    Then
        For Each RG In Selection
            If RG.Column Mod 常频块目列宽数 = 1 Then RG.Font.ColorIndex = 3
        Next
    '====================================================================================
    End If
    '====================================================================================
    Set RG = Nothing
'========================================================================================
    UTL宏工具_END
End Sub






