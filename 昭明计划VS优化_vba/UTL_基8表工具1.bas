Sub UGSOP全局统一正程_更新()
    '------------------------------------------------------------------------------------
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Dim WS As Worksheet
    Set WS = ActiveSheet
'----------------------------------------------------------------------------------------
    If PSOP格整理质程_是否适用首列(WS.Name) = True Then
        Call IQQQ展擎瓜页前调更新排否S___
    ElseIf WS.Name = "G" Then
        Call 现市单程_全局全球
    ElseIf WS.Name = "W" Then
        Call 现市单程_全局监视
    '------------------------------------------------------------------------------------
    ElseIf Left$(WS.Name, 2) = "历统" Then
        Call 历研统码工具点灯
    '------------------------------------------------------------------------------------
    ElseIf WS.Name = "异常" Then
        Call 现市单程_中股异常
    ElseIf WS.Name = "美国" Then
        Call 现市单程降序_市场美国
    ElseIf WS.Name = "香港" Then
        Call 现市单程降序_市场香港
    ElseIf WS.Name = "概念" Then
        Call 现市单程降序_中股精分概念益盟
    ElseIf WS.Name = "行益" Then
        Call 现市单程降序_中股精分行业益盟
    '------------------------------------------------------------------------------------
    ElseIf WS.Name = 常花中股 Then
        Call STCALL花册管理_重制花天P9调程设置信息
    End If
'----------------------------------------------------------------------------------------
    Set WS = Nothing
    '------------------------------------------------------------------------------------
    UTL宏工具_END
    '------------------------------------------------------------------------------------
End Sub

