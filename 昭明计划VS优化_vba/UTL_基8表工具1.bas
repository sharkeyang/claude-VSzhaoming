'========================================================================================
'CREATE WORKSHEET sWS IN WORKBOOK WB
'========================================================================================
Function PBASE格程工具_表操工表新增( _
          WS As Worksheet _
        , sWS As String _
        , Optional wb As Workbook _
        , Optional 基色底 As Long = 常色十红 _
        ) As Boolean
    PBASE格程工具_表操工表新增 = False
    If wb Is Nothing Then Set wb = ThisWorkbook
    ' 删除旧表（如有）
    If UTL判断工表存在(sWS, wb) Then
        Dim bSave As Boolean
        bSave = Application.DisplayAlerts
        Application.DisplayAlerts = False
        wb.Sheets(sWS).Delete
        Application.DisplayAlerts = bSave
    End If
    ' 新建表
    Dim WSNEW As Worksheet
    Set WSNEW = wb.Sheets.Add(after:=wb.Sheets(wb.Sheets.Count))
    WSNEW.Name = sWS
    WSNEW.Tab.Color = 基色底
    Set WS = WSNEW
    PBASE格程工具_表操工表新增 = True
End Function
Function PBASE格程工具_表操工表删除( _
          sWS As String _
        , Optional wb As Workbook _
        ) As Boolean
    PBASE格程工具_表操工表删除 = False
    If wb Is Nothing Then Set wb = ThisWorkbook
    If UTL判断工表存在(sWS, wb) Then
        Dim bSave As Boolean
        bSave = Application.DisplayAlerts
        Application.DisplayAlerts = False
        wb.Sheets(sWS).Delete
        Application.DisplayAlerts = bSave
        PBASE格程工具_表操工表删除 = True
    End If
End Function







Function PBASE格程工具_表操保存外簿(wb As Excel.Workbook, 工簿简称 As String, Optional 物理地址 As String = "") As String
    '------------------------------------------------------------------------------------
    Dim 工簿路径 As String
    If (InStr(物理地址, "\") > 0 And UTL判断路径存在(物理地址) = False) Or 物理地址 = "" Then
        物理地址 = ThisWorkbook.Path
    End If
    工簿路径 = 物理地址 & IIf(InStr(物理地址, "/"), "/", "\") & 工簿简称 & ".xlsx"
    
    Debug.Print 工簿路径
    '------------------------------------------------------------------------------------
    If UTL判断工表存在("Sheet1", wb) Then Call PBASE格程工具_表操工表删除("Sheet1", wb)
    '------------------------------------------------------------------------------------
    On Error Resume Next
    If UTL判断工簿打开(工簿简称) Then Workbooks(工簿简称).Close True
    Kill 工簿路径
    wb.SaveAs 工簿路径
    'WB.Close
    On Error GoTo 0
    '------------------------------------------------------------------------------------
    PBASE格程工具_表操保存外簿 = "存档路径： " & 工簿路径
End Function




'========================================================================================
'检查工作簿是否存在
'========================================================================================
Public Function UTL判断工表存在( _
          sWS As String _
        , Optional wb As Workbook _
        ) As Boolean
    '------------------------------------------------------------------------------------
    If wb Is Nothing Then Set wb = ThisWorkbook
    
    Dim X As Object
    On Error Resume Next
    Set X = wb.Sheets(sWS)
    
    If X Is Nothing Then
        UTL判断工表存在 = False
    Else
        UTL判断工表存在 = True
    End If
    On Error GoTo 0
    '------------------------------------------------------------------------------------
End Function


Public Function UTL判断工簿打开(wbNAME As String) As Boolean
    Dim X As Workbook
    On Error Resume Next
    Set X = Workbooks(wbNAME)
    If Err = 0 Then
        UTL判断工簿打开 = True
    Else
        UTL判断工簿打开 = False
    End If
    On Error GoTo 0
End Function

Public Function UTL判断文件存在(fNAME As String) As Boolean
    Dim X As String
    X = Dir(fNAME)
    If fNAME <> "" And X <> "" Then
        UTL判断文件存在 = True
    Else
        UTL判断文件存在 = False
    End If
End Function

Public Function UTL判断路径存在(pNAME As String) As Boolean
    Dim X As String
    On Error Resume Next
    X = GetAttr(pNAME) And 0
    If Err = 0 Then
        UTL判断路径存在 = True
    Else
        UTL判断路径存在 = False
    End If
    On Error GoTo 0
End Function

Public Function UTL判断名字存在(sNAME As String) As Boolean
    Dim X As Object
    On Error Resume Next
    Set X = ThisWorkbook.Names(sNAME)
    If Err = 0 Then
        UTL判断名字存在 = True
    Else
        UTL判断名字存在 = False
    End If
    On Error GoTo 0
End Function




