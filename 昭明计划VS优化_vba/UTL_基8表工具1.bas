'========================================================================================
'操作：归集总调用
'========================================================================================
'========================================================================================
Function UGSOP拣选引擎归集子程(表名归集 As String, Optional 是否归集入池 As Boolean = True) As Integer
'========================================================================================
'验证归集表名
'========================================================================================
    If PSOP格整理质程_是否适用池类(表名归集) = False Then
        MsgBox "归集表名错误", vbOKOnly, "归集"
        Exit Function
    End If
    '------------------------------------------------------------------------------------
    UTL宏工具_BEGIN
'========================================================================================
'归集
'========================================================================================
    Dim WSIN As Worksheet
    Set WSIN = ActiveSheet
    '因为引用了ActiveSheet，所以必须放到下面建页的前面
    Dim 当前表名 As String
    当前表名 = WSIN.Name
    '------------------------------------------------------------------------------------
    Dim 集合归集代码 As New Dictionary
    Dim 计数归集 As Integer
    If 是否归集入池 = True And 表名归集 = 当前表名 Then
        '入池不能归集自身
        '出池可以归集自身
    Else
        计数归集 = UGSOP拣选质程_归集代码从通用(集合归集代码, WSIN)
    End If
'========================================================================================
'设置工表
'========================================================================================
    Dim WSTO As Worksheet
    If Not UTL判断工表存在(表名归集) Then
        Call PBASE格程工具_表操工表新增(WSTO, 表名归集)
    End If
    Set WSTO = ThisWorkbook.Sheets(表名归集)
'========================================================================================
'将集合元素归集到WSTO
'========================================================================================
    Dim 集合注释 As String
    Dim 参数标注 As String: 参数标注 = ""
    Dim MSG As String
    集合注释 = "from " & WSIN.Name & "【" & 计数归集 & "】  " & 参数标注
    If 计数归集 = 0 Then
    ElseIf 是否归集入池 = True Then
        MSG = "入池总数：" & UGSOP拣选质程_归集典集入池(集合归集代码, WSTO, 集合注释)
        MSG = "归集入池：" & 当前表名 & "  >>  " & 表名归集 & "  " & MSG
        Debug.Print MSG
    Else
        MSG = "出池总数：" & UGSOP拣选质程_归集典集出池(集合归集代码, WSTO, 集合注释)
        MSG = "归集出池：" & 当前表名 & "  >>  " & 表名归集 & "  " & MSG
        Debug.Print MSG
    End If
'========================================================================================
    Set WSIN = Nothing
    Set WSTO = Nothing
    '------------------------------------------------------------------------------------
    UTL宏工具_END
End Function




Function UGSOP拣选质程_归集代码从通用(集合归集代码 As Dictionary, WSIN As Worksheet) As Integer
    Dim 计数归集 As Integer
    Dim 当前表名 As String
    当前表名 = WSIN.Name
    '====================================================================================
    '归集：从首列【底色与字色不同】加入Z
    '====================================================================================
    If (PSOP格整理质程_是否适用首列(当前表名) = True) Then
        计数归集 = UGSOP拣选质程_归集代码从首列(集合归集代码, WSIN)
    '====================================================================================
    '归集：从市况【底色与章色相同+字色不是黑色】加入ZZ
    '====================================================================================
    ElseIf 当前表名 = "概念" _
        Or 当前表名 = "地区" _
        Or 当前表名 = "行业" _
        Or 当前表名 = "行益" _
        Or 当前表名 = "W" _
    Then
        计数归集 = UGSOP拣选质程_归集代码从市况(集合归集代码, WSIN)
    '====================================================================================
    '归集：从代称+花册【字色不是黑色】加入ZZ
    '====================================================================================
    ElseIf 当前表名 Like 常簿缀历统 & "*" _
        Or 当前表名 = "异常" _
    Then
        计数归集 = UGSOP拣选质程_归集代码从代称(集合归集代码, WSIN)
    End If
    '====================================================================================
    UGSOP拣选质程_归集代码从通用 = 计数归集
End Function
'========================================================================================
'========================================================================================
'操作：归集自选【Z?】中【底色与字色不同】加入Z
'========================================================================================
'========================================================================================
Function UGSOP拣选质程_归集代码从首列(集合归集代码 As Dictionary, WSIN As Worksheet) As Integer
    '------------------------------------------------------------------------------------
    '将选定的代码放入集合：底色与字色不同
    '------------------------------------------------------------------------------------
    Dim CIDL As String
    Dim 行号遍历 As Integer
    For 行号遍历 = 2 To WSIN.[a65536].End(xlUp).Row
        With WSIN.Cells(行号遍历, 位qt代码)
        If UBCID是代码(.Value) = True Then
            CIDL = .Value
                       
            If (.Font.ColorIndex = 3) _
            Or (Not Intersect(WSIN.Rows(行号遍历), Selection) Is Nothing) _
            Then
                If 集合归集代码.Exists(CIDL) = False Then
                    集合归集代码.Add Item:=CIDL, Key:=CIDL
                End If
                .Resize(1, 2).Font.ColorIndex = 4
            End If
        End If
        End With
    Next
    '------------------------------------------------------------------------------------
    UGSOP拣选质程_归集代码从首列 = 集合归集代码.Count
    '------------------------------------------------------------------------------------
End Function
'========================================================================================
'========================================================================================
'操作：归集市场【底色与章色相同+字色不是黑色】加入ZZ
'========================================================================================
'========================================================================================
Function UGSOP拣选质程_归集代码从市况(集合归集代码 As Dictionary, WSIN As Worksheet) As Integer
    '------------------------------------------------------------------------------------
    '将选定的代码放入集合：底色与章色相通+字色不是黑色
    '------------------------------------------------------------------------------------
    Dim 颜色背景 As Long
    颜色背景 = WSIN.Cells(1, 1).Interior.Color
    
    Dim CIDL As String
    Dim CL As Range
    For Each CL In WSIN.UsedRange
        If CL.Interior.Color = 颜色背景 And CL.Font.ColorIndex <> 1 Then
        Dim 左偏列数 As Integer
        For 左偏列数 = 0 To 2
            CIDL = CL.Offset(0, -1 * 左偏列数)
            If CIDL Like 常通配全码代码 Then
                If 集合归集代码.Exists(CIDL) = False Then
                    集合归集代码.Add Item:=CIDL, Key:=CIDL
                End If
                CL.Font.ColorIndex = 1
            End If
        Next 左偏列数
        End If
    Next CL
    '------------------------------------------------------------------------------------
    UGSOP拣选质程_归集代码从首列 = 集合归集代码.Count
    '------------------------------------------------------------------------------------
End Function
'========================================================================================
'========================================================================================
'操作：归集历调【字色不是黑色】加入ZZ
'========================================================================================
'========================================================================================
Function UGSOP拣选质程_归集代码从代称(集合归集代码 As Dictionary, WSIN As Worksheet) As Integer
    '------------------------------------------------------------------------------------
    '利用花册制作字典
    '------------------------------------------------------------------------------------
    Dim 典代称 As New Dictionary
    Dim 值代称 As String
    Dim CIDL As String
    
    Dim WS花天 As Worksheet
    If STBASE外簿工具_花册链接(WS花天, 常花中股) = False Then Exit Function
    Dim i As Integer
    For i = 2 To WS花天.Cells(65536, 1).End(xlUp).Row
        CIDL = WS花天.Cells(i, 位qt代码)
        值代称 = WS花天.Cells(i, 位qt代称)
        If 典代称.Exists(值代称) = False And Len(CIDL) > 0 Then
            典代称.Add Item:=CIDL, Key:=值代称
        End If
    Next i
    '------------------------------------------------------------------------------------
    '变量声明
    '------------------------------------------------------------------------------------
    Dim 集合归集代称 As New Dictionary
    'Dim 集合归集代码 As New Dictionary
    '------------------------------------------------------------------------------------
    '将选定的名称放入集合：字色不是黑色
    '------------------------------------------------------------------------------------
    Dim CL As Range
    For Each CL In WSIN.UsedRange
        If CL.Font.ColorIndex <> 1 And Len(CL.Value) > 0 Then
            If 集合归集代称.Exists(CL.Value) = False Then
                集合归集代称.Add Item:=CL.Value, Key:=CL.Value
            End If
            CL.Font.ColorIndex = 1
        End If
    Next CL
    '------------------------------------------------------------------------------------
    '将选定的代码放入集合：字色不是黑色
    '------------------------------------------------------------------------------------
    For i = 1 To 集合归集代称.Count
        值代称 = 集合归集代称.Keys(i - 1)
        If 典代称.Exists(值代称) = True Then
            CIDL = 典代称(值代称)
            集合归集代码.Add Item:=CIDL, Key:=CIDL
        End If
    Next i
    
    Set 集合归集代称 = Nothing
    典代称.RemoveAll
    Set 典代称 = Nothing
    '------------------------------------------------------------------------------------
    UGSOP拣选质程_归集代码从代称 = 集合归集代码.Count
    '------------------------------------------------------------------------------------
End Function





'========================================================================================
'========================================================================================
'功能：归集 入池已有集合
'========================================================================================
'========================================================================================
Function UGSOP拣选质程_归集典集入池(集合归集代码 As Dictionary, WSTO As Worksheet, Optional 集合注释 As String = "") As Integer
    If 集合归集代码.Count = 0 Then Exit Function
    '------------------------------------------------------------------------------------
    Dim 集合总数 As Integer
    集合总数 = 集合归集代码.Count
'========================================================================================
'将集合元素归集到Z
'========================================================================================
    Dim 目行 As Integer
    目行 = WSTO.[a65536].End(xlUp).Row + 1
    '------------------------------------------------------------------------------------
    '输出注释
    '------------------------------------------------------------------------------------
    WSTO.Cells(目行, 位qt代码) = 集合注释
    WSTO.Cells(目行, 位qt行业) = "@" & Format(Now(), "MMDDHHMM")
    '------------------------------------------------------------------------------------
    '输出代码集合（标注为黄色）
    '------------------------------------------------------------------------------------
    Dim i As Integer
    For i = 1 To 集合总数
        With WSTO.Cells(目行 + i, 位qt代码)
            .Value = 集合归集代码.Keys(i - 1)
            .Interior.Color = 常色主黄
            .Resize(1, 2).Font.ColorIndex = 3
        End With
    Next
    '------------------------------------------------------------------------------------
    Set 集合归集代码 = Nothing
'========================================================================================
'返回
'========================================================================================
    UGSOP拣选质程_归集典集入池 = 集合总数
End Function
'========================================================================================
'========================================================================================
'功能：归集 出池已有集合
'========================================================================================
'========================================================================================
Function UGSOP拣选质程_归集典集出池(集合归集代码 As Dictionary, WSTO As Worksheet, Optional 集合注释 As String = "") As Integer
    If 集合归集代码.Count = 0 Then Exit Function
    '------------------------------------------------------------------------------------
    Dim 集合总数 As Integer
    集合总数 = 集合归集代码.Count
'========================================================================================
'遍历文件删除详细信息
'========================================================================================
    Dim CIDL As String
    Dim 出池总数 As Integer
    出池总数 = 0
    Dim 行号遍历 As Integer
    For 行号遍历 = WSTO.[a65536].End(xlUp).Row To 2 Step -1
        CIDL = WSTO.Cells(行号遍历, 位qt代码)
        If 集合归集代码.Exists(CIDL) And Len(CIDL) > 0 Then
            WSTO.Rows(行号遍历).Delete
            出池总数 = 出池总数 + 1
        End If
    Next
    '------------------------------------------------------------------------------------
    Set 集合归集代码 = Nothing
'========================================================================================
'返回
'========================================================================================
    UGSOP拣选质程_归集典集出池 = 出池总数
End Function
