Private UTL宏工具_DEPTH As Long
'========================================================================================











'########################################################################################
'##################################    程序状态控制     ##################################
'########################################################################################
'========================================================================================
'状态控制 — 引用计数嵌套模式
'========================================================================================
'  每调用一次 BEGIN，计数器 +1；每调用一次 END，计数器 -1。
'  只有第一层 BEGIN 真正关闭状态，只有最外层 END（计数器归零）才恢复。
'  内层 END 不恢复 —— 因此"中间绝不交出控制权"。
'========================================================================================
'  恢复策略：
'    ScreenUpdating / DisplayAlerts / Calculation → 恢复 BEGIN 时保存的旧值。
'      这三项用户可能在宏运行前手动设置过（如永久使用手动计算），必须尊重原状。
'    Interactive / EnableEvents → 强制设为 True。
'      这两项控制"前台能否操作 Excel"。正常情况下总是 True，不存在用户故意关闭的场景。
'      强制 True 保证：只要最外层 END 执行到，控制权必然归还，不受嵌套配对错误影响。
'========================================================================================
'  注意：
'    1. BEGIN 必须放在异常检测之后（避免 Exit 跳过 END 导致计数器永不归零）。
'    2. 每个 Exit Sub / Exit Function 前必须调用 END。
'    3. END 硬编码恢复至正常状态（不依赖保存值），嵌套调用由 DEPTH 计数器保护。
'========================================================================================
'========================================================================================
Public Sub UTL宏工具_BEGIN()
    If UTL宏工具_DEPTH = 0 Then
        Application.ScreenUpdating = False
        Application.DisplayAlerts = False
        On Error Resume Next
        Application.Calculation = xlCalculationManual
        On Error GoTo 0
        Application.Interactive = False
        Application.EnableEvents = False
    End If
    UTL宏工具_DEPTH = UTL宏工具_DEPTH + 1
End Sub
Public Sub UTL宏工具_END()
    If UTL宏工具_DEPTH <= 0 Then Exit Sub
    UTL宏工具_DEPTH = UTL宏工具_DEPTH - 1
    If UTL宏工具_DEPTH = 0 Then
        Application.ScreenUpdating = True
        Application.DisplayAlerts = True
        Application.Calculation = xlCalculationAutomatic
        Application.Interactive = True
        Application.EnableEvents = True
    End If
End Sub
Public Sub UTL宏工具_检测失效()
    Debug.Print "Depth:", UTL宏工具_DEPTH
    Debug.Print "ScreenUpdating=False:", Application.ScreenUpdating = False
    Debug.Print "DisplayAlerts=False:", Application.DisplayAlerts = False
    Debug.Print "Calculation=Manual:", Application.Calculation = xlCalculationManual
    Debug.Print "Interactive=False:", Application.Interactive = False
    Debug.Print "EnableEvents=False:", Application.EnableEvents = False
End Sub
Public Sub UTL宏工具_显示工作簿()
    '强制显示当前工作簿窗口
    On Error Resume Next
    Application.Visible = True
    ThisWorkbook.Windows(1).Visible = True
    ThisWorkbook.Windows(1).WindowState = xlNormal
    ThisWorkbook.Activate
    On Error GoTo 0
End Sub
'========================================================================================
'功能：根据文件名打开/显示已打开的工作簿
'========================================================================================
Public Sub UTL宏工具_显示指定工作簿(文件名 As String)
    '按文件名查找已打开的工作簿，如果找到则激活显示
    On Error Resume Next
    Dim wb As Workbook
    Set wb = Workbooks(文件名)
    If Not wb Is Nothing Then
        Application.Visible = True
        wb.Windows(1).Visible = True
        wb.Windows(1).WindowState = xlNormal
        wb.Activate
    End If
    Set wb = Nothing
    On Error GoTo 0
End Sub
