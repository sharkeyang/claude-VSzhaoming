Sub UGSOP全局清理工表_昭明全部()
    UTL宏工具_BEGIN
'========================================================================================
    Dim 是否保留 As Boolean
    
    On Error Resume Next
    Dim WS As Worksheet
    For Each WS In ThisWorkbook.Sheets
        '--------------------------------------------------------------------------------
        '排除删除：ZX HX 类源 G
        '--------------------------------------------------------------------------------
        是否保留 = Left$(WS.Name, 1) = 常簿缀选自 _
                    Or WS.Name Like 常簿缀结算 & "?" _
                    Or WS.Name = "G" _
                    Or WS.Name = "统算比" _
                    Or WS.Name = 常花中股

        If 是否保留 = False Then
            WS.Tab.ColorIndex = 2
            WS.Delete
        End If
        '--------------------------------------------------------------------------------
    Next WS
    On Error GoTo 0
    Set WS = Nothing
'========================================================================================
    If UTL判断工表存在("G") Then ThisWorkbook.Sheets("G").Activate
    ThisWorkbook.Save
'========================================================================================
    UTL宏工具_END
End Sub
