'########################################################################################
'########################################################################################
'################################       藏库更新      ###################################
'########################################################################################
'########################################################################################
Function STBASE藏库引擎_更新主程( _
          Optional ByVal 指定期类 As String = 常期类为日 _
        , Optional ByVal 是否新建藏库 As Boolean = False _
        , Optional ByVal 是否更新全量 As Boolean = False _
        , Optional ByVal 是否更新源AK As Boolean = False _
        , Optional ByVal 是否更新源TR As Boolean = False _
        , Optional ByVal 指定结期下限 As Date = 常结期下限历短 _
        ) As String
'========================================================================================
'声明变量
'========================================================================================
    Dim 藏库令 As Workbook
    Dim WS藏库 As Worksheet
    If 是否新建藏库 = True Then
        Set 藏库令 = Workbooks.Add
        Call PBASE格程工具_表操工表新增(WS藏库, 指定期类, wb:=藏库令, 基色底:=常色主黑)
        Call PBASE格程工具_表操保存外簿(藏库令, "昭明藏库" & 指定期类, 全设基夹根)
        Set WS藏库 = Nothing
        Set 藏库令 = Nothing
    End If
'========================================================================================
    UTL宏工具_BEGIN
    Dim MSG As String
    TT = Timer
'========================================================================================
'按期类进行入库
'========================================================================================
    Dim 典码称 As New Dictionary
    Call STCALL花册工具_提取典码花天按市池(典码称, 包含市指:=True, 包含市基:=True, 包含市票:=True, 测试限数:=-1)
    '====================================================================================
    Dim ARRDATA As Variant
    If STBASE外簿工具_藏库获取组库(ARRDATA, 指定期类) = 0 Then
        MSG = "【藏库空】从CSV重新构建"
        'ARRDATA保持空Variant，更新数程内部会ReDim创建
    End If
    '------------------------------------------------------------------------------------
    If 是否更新源AK = True Then
        MSG = MSG & STBASE藏库引擎_更新数程(ARRDATA, 典码称, 常据源AK, 指定期类, 是否更新全量:=是否更新全量, 指定结期下限:=指定结期下限)
    End If
    '------------------------------------------------------------------------------------
    If 是否更新源TR = True And 指定期类 = 常期类为日 Then
        MSG = MSG & STBASE藏库引擎_更新数程(ARRDATA, 典码称, 常据源TR, 指定期类)
    End If
    '诊断：更新后ARRDATA维度
    On Error Resume Next
    Debug.Print "【诊断】更新后ARRDATA: " & UBound(ARRDATA, 1) & "行 × " & UBound(ARRDATA, 2) & "列"
    If UBound(ARRDATA, 2) <= 2 Then Debug.Print "【诊断】无数据列，更新数程可能未填充"
    On Error GoTo 0
'========================================================================================
'输出（先定位已打开工簿→避免双链接冲突。@@@2026-07-15 fix）
'========================================================================================
    Dim 定位簿令 As Workbook
    If STBASE外簿引擎_定位(定位簿令, 常外簿藏库) Then
        Set WS藏库 = 定位簿令.Sheets(指定期类)
    ElseIf STBASE外簿工具_藏库链接(WS藏库, 指定期类) = False Then
        MSG = "藏库链接失败：" & 指定期类
        STBASE藏库引擎_更新主程 = MSG
        Exit Function
    End If
    WS藏库.Cells.Clear
    Call UTL数据转换_集ARR2WS(ARRDATA, WS藏库, 1, 1)
    'Erase ARRDATA  '@@@ 2026-07-15 去掉Erase，函数结束自动释放，避免数组状态异常
    '------------------------------------------------------------------------------------
    '格式化
    '------------------------------------------------------------------------------------
    Call STBASE藏库引擎_工具格程(WS藏库)
    WS藏库.Parent.Save
    Set WS藏库 = Nothing
'========================================================================================
'返回
'========================================================================================
    MSG = MSG & "【藏库更新耗时】" & CInt(Timer - TT) & vbCrLf
    UTL宏工具_END
    '------------------------------------------------------------------------------------
    Debug.Print MSG
    STBASE藏库引擎_更新主程 = MSG
End Function




