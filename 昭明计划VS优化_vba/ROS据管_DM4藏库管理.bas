'========================================================================================
'========================================================================================
'功能：藏库 格式化
'========================================================================================
'========================================================================================
Function STBASE藏库引擎_工具设置头部( _
          ByRef ARRDATA As Variant _
        , ByVal 指定期类 As String _
        ) As Integer
    '====================================================================================
    '初始赋值
    '====================================================================================
    ARRDATA(位行TT交日, 位列TT代码) = "交日"
    ARRDATA(位行TT交索, 位列TT代码) = "交索"
    ARRDATA(位行TT更源, 位列TT代码) = "更源"
    ARRDATA(位行TT交日, 位列TT代称) = 指定期类
    ARRDATA(位行TT交索, 位列TT代称) = UBound(ARRDATA, 2) - 位列TT头部
    ARRDATA(位行TT更源, 位列TT代称) = UBound(ARRDATA, 1) - 位行TT头部
    '====================================================================================
    '返回
    '====================================================================================
    STBASE藏库引擎_工具设置头部 = UBound(ARRDATA, 2) - 位列TT头部
End Function
'========================================================================================
'========================================================================================
'功能：藏库 格式化
'========================================================================================
'========================================================================================
Function STBASE藏库引擎_工具格程( _
          WSDATA As Worksheet _
        ) As Boolean
    '====================================================================================
    '格式化
    '====================================================================================
    '    WSDATA.Rows(位行TT交日).Font.Bold = True
    '    WSDATA.Columns(位列TT代码).Font.Bold = True
    '------------------------------------------------------------------------------------
    WSDATA.Cells.Font.Size = 9
    WSDATA.Cells.NumberFormatLocal = 全设格式of零位
    WSDATA.Rows(位行TT交日).NumberFormatLocal = 全设格式of日期
    WSDATA.Columns.ColumnWidth = 8
    WSDATA.Columns(位列TT代码).ColumnWidth = 8
    WSDATA.Columns(位列TT代称).ColumnWidth = 8
    '------------------------------------------------------------------------------------
    '缩放
    '------------------------------------------------------------------------------------
    WSDATA.Activate
    Call PBASE格程工具_表冻结锁定(WSDATA, 基行:=位行TT更源, 基列:=位列TT代称)
    ActiveWindow.Zoom = 80
    '====================================================================================
End Function
