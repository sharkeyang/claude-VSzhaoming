'========================================================================================
'========================================================================================
'通用调用程序：更新基程
'注意：模式【常据源AK】需要设置是否更新全量，【常据源TR】必然全量。全量只在第一轮循环进行。
'========================================================================================
'========================================================================================
Function STBASE藏库引擎_更新数程( _
          ByRef ARRDATA As Variant _
        , ByRef 典码称 As Dictionary _
        , ByVal 指定据源 As String _
        , Optional ByVal 指定期类 As String = 常期类为日 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        , Optional ByVal 是否更新全量 As Boolean = True _
        ) As String
'========================================================================================
    If 典码称 Is Nothing Then Debug.Print "[更新数程退出] 典码称 Is Nothing": Exit Function
    If 典码称.Count = 0 Then Debug.Print "[更新数程退出] 典码称.Count=0（花册可能为空）": Exit Function
'========================================================================================
'设置可更新交日更新：从花册结期表构建交易日轴（替代原sh000001.csv）
'========================================================================================
    Dim CIDL As String
    Dim WS交期 As Worksheet
    If STBASE外簿工具_花册链接(WS交期, 常花结期) = False Then
        Debug.Print "[更新数程退出] 花册结期表链接失败"
        Exit Function
    End If
    Dim 典期序本源 As New Dictionary
    Dim 当期 As Date
    Dim 值索横期 As String
    Dim i As Integer
    With WS交期
        For i = 2 To .Cells(65536, 1).End(xlUp).Row
            If VBA.IsDate(.Cells(i, 1)) = True Then
                当期 = .Cells(i, 1)
                值索横期 = 时程工具衍生期索(当期, 指定期类)
                典期序本源.Add Item:=当期, Key:=值索横期
            End If
        Next
    End With
    Set WS交期 = Nothing
    If 典期序本源.Count = 0 Then
        Debug.Print "[更新数程退出] 结期表无有效日期"
        Exit Function
    End If
    Dim 更期最始本源 As Date
    更期最始本源 = 典期序本源.Items(0)
    Dim 更期最终本源 As Date
    更期最终本源 = 典期序本源.Items(典期序本源.Count - 1)
'========================================================================================
'制作原始字典：删除本次应更新数据列
'逻辑：先检查不是日期的行，删除TR列，删除超过本源最终更期列，然后把更新列添在磨列最后。
'========================================================================================
    '------------------------------------------------------------------------------------
    '输入更新前数组
    '逻辑：如果ARRDATA为空，则利用藏库；否则利用上次结果。
    '------------------------------------------------------------------------------------
    If VBA.IsEmpty(ARRDATA) = True Then
        ReDim ARRDATA(1 To 位行TT头部, 1 To 位列TT头部) As Variant
        Call STBASE藏库引擎_工具设置头部(ARRDATA, 指定期类)
    End If
    Dim ARR前 As Variant
    ARR前 = ARRDATA
    Erase ARRDATA
    '------------------------------------------------------------------------------------
    '步骤一：获取库期典
    '------------------------------------------------------------------------------------
    Dim 典横索序  As New Dictionary
    Dim Y As Integer
    For Y = 位列TT头部 + 1 To UBound(ARR前, 2)
        当期 = ARR前(位行TT交日, Y)
        值索横期 = ARR前(位行TT交索, Y)
        If VBA.IsDate(当期) = False Then
            Stop    '异常：出现非日期列 需要外部进行检查
        ElseIf 当期 > 指定结期下限 Then
            If ARR前(位行TT更源, Y) = 常据源AK Then
                '------------------------------------------------------------------------
                If 指定据源 = 常据源AK Then      '【是否更新全量】仅对AK生效
                    If 是否更新全量 = True Then                 '全量模式：删除所有能更新的日期
                        If 当期 < 更期最始本源 Then 典横索序.Add Item:=Y, Key:=值索横期
                    ElseIf 当期 <= 更期最终本源 Then
                        If 典期序本源.Exists(值索横期) = False Then
                            典横索序.Add Item:=Y, Key:=值索横期
                        ElseIf 当期 = 典期序本源(值索横期) Then
                            典横索序.Add Item:=Y, Key:=值索横期
                        End If
                    End If
                ElseIf 指定据源 = 常据源TR Then
                        If 当期 <= 更期最终本源 Then 典横索序.Add Item:=Y, Key:=值索横期
                End If
                '------------------------------------------------------------------------
            End If
        End If
    Next
    '------------------------------------------------------------------------------------
    '步骤二：获取库典
    '------------------------------------------------------------------------------------
    Dim 典码行库 As New Dictionary
    Dim X As Integer
    For X = LBound(ARR前, 1) To UBound(ARR前, 1)
        If UBCID是中股(ARR前(X, 位列TT代码)) = True Then
            典码行库.Add Key:=ARR前(X, 位列TT代码), Item:=X
        End If
    Next
    Dim 典期列库 As New Dictionary
    For Y = LBound(ARR前, 2) To UBound(ARR前, 2)
        If VBA.IsDate(ARR前(位行TT交日, Y)) = True Then
            典期列库.Add Key:=ARR前(位行TT交日, Y), Item:=Y
        End If
    Next
    '------------------------------------------------------------------------------------
    '步骤三：制作更新前数据组
    '------------------------------------------------------------------------------------
    ReDim ARRDATA(1 To 位行TT头部 + 典码称.Count, 1 To 位列TT头部 + 典横索序.Count) As Variant
    Call STBASE藏库引擎_工具设置头部(ARRDATA, 指定期类)
    '-----------------------------------------------
    '横向首行
    Dim 定位行库 As Integer, 定位列库 As Integer
    For Y = 1 To 典横索序.Count
        定位列库 = 典横索序.Items(Y - 1)
        ARRDATA(位行TT交日, 位列TT头部 + Y) = ARR前(位行TT交日, 定位列库)
        ARRDATA(位行TT交索, 位列TT头部 + Y) = ARR前(位行TT交索, 定位列库)
        ARRDATA(位行TT更源, 位列TT头部 + Y) = ARR前(位行TT更源, 定位列库)
    Next
    '-----------------------------------------------
    '纵向首列 单元格
    For X = 1 To 典码称.Count
        CIDL = 典码称.Keys(X - 1)
        ARRDATA(位行TT头部 + X, 位列TT代码) = CIDL
        ARRDATA(位行TT头部 + X, 位列TT代称) = 典码称.Items(X - 1)
        If 典码行库.Exists(CIDL) Then
            定位行库 = 典码行库(CIDL)
            For Y = 1 To 典横索序.Count
                定位列库 = 典横索序.Items(Y - 1)
                ARRDATA(位行TT头部 + X, 位列TT头部 + Y) = ARR前(定位行库, 定位列库)
            Next
        End If
    Next
    Erase ARR前
    Dim 更期最终前次 As Date
    If UBound(ARRDATA, 2) > 2 Then
        更期最终前次 = ARRDATA(位行TT交日, UBound(ARRDATA, 2))
    End If
'    '------------------------------------------------------------------------------------
'    '测试输出
'    '------------------------------------------------------------------------------------
'    Dim WSTO As Worksheet
'    Call PBASE格程工具_表操工表新增(WSTO, "DDD")
'    WSTO.Cells.Font.Size = 8
'    Call UTL数据转换_集ARR2WS(ARRDATA, WSTO, 1, 1)
'    Exit Function
'Stop
'========================================================================================
'更新：横向 更期
'========================================================================================
    '------------------------------------------------------------------------------------
    '新增：纵向 日期
    '------------------------------------------------------------------------------------
    Dim 典期序新增 As New Dictionary
    For i = 1 To 典期序本源.Count
        当期 = 典期序本源.Items(i - 1)
        值索横期 = 典期序本源.Keys(i - 1)
        If 当期 > 更期最终前次 Then
            If 典横索序.Exists(值索横期) = False Then 典期序新增.Add Item:=当期, Key:=值索横期
        End If
    Next
    Set 典期序本源 = Nothing
    'If 典期序新增.Count = 0 Then Exit Function '注意20220906：不要此句退出，以下可以更新某些空单元格
    '------------------------------------------------------------------------------------
    '扩展
    '------------------------------------------------------------------------------------
    Dim 更期计数本次 As Integer
    Dim 更期最始本次 As Date
    Dim 更期最终本次 As Date
    更期计数本次 = 典期序新增.Count
    If 典期序新增.Count > 0 Then
            '----------------------------------------------------------------------------
            更期最始本次 = 典期序新增.Items(0)
            更期最终本次 = 典期序新增.Items(典期序新增.Count - 1)
            Dim 末列 As Integer
            末列 = UBound(ARRDATA, 2)
            '----------------------------------------------------------------------------
            ReDim Preserve ARRDATA(LBound(ARRDATA, 1) To UBound(ARRDATA, 1), LBound(ARRDATA, 2) To UBound(ARRDATA, 2) + 典期序新增.Count) As Variant
            Call STBASE藏库引擎_工具设置头部(ARRDATA, 指定期类)
            '----------------------------------------------------------------------------
            Dim 计数新增 As Integer
            计数新增 = 0
            For i = 1 To 典期序新增.Count
                当期 = 典期序新增.Items(i - 1)
                值索横期 = 典期序新增.Keys(i - 1)
                计数新增 = 计数新增 + 1
                ARRDATA(位行TT交日, 末列 + 计数新增) = 当期
                ARRDATA(位行TT交索, 末列 + 计数新增) = 值索横期
                ARRDATA(位行TT更源, 末列 + 计数新增) = 指定据源
            Next
            Set 典期序新增 = Nothing
            '----------------------------------------------------------------------------
    End If
'    '------------------------------------------------------------------------------------
'    '测试输出
'    '------------------------------------------------------------------------------------
'    Dim WSTO As Worksheet
'    Call PBASE格程工具_表操工表新增(WSTO, "DDF")
'    WSTO.Cells.Font.Size = 8
'    Call UTL数据转换_集ARR2WS(ARRDATA, WSTO, 1, 1)
'Stop
'========================================================================================
'运行：进行更新
'========================================================================================
    '------------------------------------------------------------------------------------
    '更新 典横索序
    '------------------------------------------------------------------------------------
    典横索序.RemoveAll
    For Y = 位列TT头部 + 1 To UBound(ARRDATA, 2)
        值索横期 = ARRDATA(位行TT交索, Y)
        典横索序.Add Key:=值索横期, Item:=Y
    Next
    '------------------------------------------------------------------------------------
    '读取数组：
    '------------------------------------------------------------------------------------
    Dim 更码总数本库 As Integer
    更码总数本库 = UBound(ARRDATA, 1) - 位行TT头部
    Dim 更期最始本库 As Date
    '更期最始本库 = ARRDATA(位行TT交日, 位列TT头部 + 1)
    '------------------------------------------------------------------------------------
    '变量声明
    '------------------------------------------------------------------------------------
    Dim ARRCSV As Variant
    Dim 指定代码 As String
    Dim 指定列号 As Integer
    Dim 更期最始本码 As Date
    Dim 更期最终本码 As Date
    Dim 计数更新本码 As Integer
    Dim 计数更新本次 As Long
    计数更新本次 = 0
    '-----------------------------------
    Dim 是否应更新本码 As Boolean
    Dim 计码未更新到位 As Long
    Dim 计行导入 As Integer      '计行导入：用于AK/TR数据循环
'========================================================================================
'运行：多轮遍历更新数据
'========================================================================================
    Dim 全局更新轮数 As Integer, 遍历行号 As Integer
    For 全局更新轮数 = 0 To 9
        计码未更新到位 = 0

        '================================================================================
        'TR：批量 HTTP 查询 — 先收集本轮需更新代码，一次批量拉取，再分发写入
        '   复用 STBASE取据引擎取据由腾实批 → UBHTTP腾实_查回典批量（常HTTP批大小个/次）
        '================================================================================
        If 指定据源 = 常据源TR Then

            '--- 收集本轮待更新代码（末列为空即需更新）---
            Dim 代码串 As String
            代码串 = ""
            For 遍历行号 = 位行TT头部 + 1 To UBound(ARRDATA, 1)
                指定代码 = ARRDATA(遍历行号, 位列TT代码)
                If Len(ARRDATA(遍历行号, UBound(ARRDATA, 2))) = 0 Then
                    代码串 = 代码串 & "," & 指定代码
                End If
            Next
            If Len(代码串) = 0 Then Exit For   '全部到位，提前结束轮循
            代码串 = Mid$(代码串, 2)            '去前导逗号

            '--- 一次性批量 HTTP 拉取 ---
            Dim 批典 As Dictionary
            Set 批典 = STBASE取据引擎取据由腾实批(代码串)

            '--- 分发：逐码从批典取结果，写入 ARRDATA ---
            For 遍历行号 = 位行TT头部 + 1 To UBound(ARRDATA, 1)
                指定代码 = ARRDATA(遍历行号, 位列TT代码)
                If Len(ARRDATA(遍历行号, UBound(ARRDATA, 2))) = 0 Then
                    If 批典.Exists(指定代码) Then
                        ARRCSV = 批典(指定代码)
                        计行导入 = 1
                    Else
                        计行导入 = 0
                    End If
                    If 计行导入 > 0 Then
                        计数更新本码 = 0
                        For i = LBound(ARRCSV, 1) To UBound(ARRCSV, 1)
                            当期 = ARRCSV(i, 位列TS结期)
                            值索横期 = 时程工具衍生期索(当期, 指定期类)
                            If 典横索序.Exists(值索横期) = True Then
                                指定列号 = 典横索序(值索横期)
                                If Len(ARRDATA(遍历行号, 指定列号)) = 0 Then
                                    ReDim ARRLINE(位列TS下限 To 位列TS上限单期) As Variant
                                    ARRLINE(位列TS结高) = ARRCSV(i, 位列TS结高)
                                    ARRLINE(位列TS结低) = ARRCSV(i, 位列TS结低)
                                    ARRLINE(位列TS结收) = ARRCSV(i, 位列TS结收)
                                    ARRDATA(遍历行号, 指定列号) = Join(ARRLINE, ",")
                                    Erase ARRLINE

                                    计数更新本次 = 计数更新本次 + 1
                                    计数更新本码 = 计数更新本码 + 1
                                    If 计数更新本码 = 1 Then 更期最始本码 = 当期
                                    更期最终本码 = 当期
                                End If
                            End If
                        Next
                    End If
                    计码未更新到位 = 计码未更新到位 + IIf(更期最终本码 = 更期最终本次, 0, 1)
                    Debug.Print "藏库更新>>" & 指定据源 & ">>" & 指定期类 & ">>" & 遍历行号 & ">>" & 指定代码 & ">>" & " [" & 更期最始本码 & ">>" & 更期最终本码 & "]=" & 计数更新本码 & "  累未到位=" & 计码未更新到位 & "  全局更新轮数=" & 全局更新轮数
                End If
            Next
            Set 批典 = Nothing

        '================================================================================
        'AK：逐码 HTTP 查询（保持原有逻辑不变）
        '================================================================================
        Else
            For 遍历行号 = 位行TT头部 + 1 To UBound(ARRDATA, 1)
                指定代码 = ARRDATA(遍历行号, 位列TT代码)
                '--- 判断是否应更新本码：末列为空，或全量第一轮 ---
                是否应更新本码 = False
                If Len(ARRDATA(遍历行号, UBound(ARRDATA, 2))) = 0 Then
                        是否应更新本码 = True
                ElseIf 是否更新全量 = True Then
                    If 指定据源 = 常据源AK Then
                        是否应更新本码 = IIf(全局更新轮数 = 0, True, False)
                    End If
                End If
                If 是否应更新本码 = True Then
                        计行导入 = 0
                        计行导入 = STBASE取据引擎取据由外库(ARRCSV, 指定代码, 指定期类:=指定期类, 指定结期下限:=指定结期下限)
                        If 计行导入 > 0 Then
                            计数更新本码 = 0
                            For i = LBound(ARRCSV, 1) To UBound(ARRCSV, 1)
                                当期 = ARRCSV(i, 位列TS结期)
                                值索横期 = 时程工具衍生期索(当期, 指定期类)
                                If 典横索序.Exists(值索横期) = True Then
                                    指定列号 = 典横索序(值索横期)
                                    If Len(ARRDATA(遍历行号, 指定列号)) = 0 Then
                                        ReDim ARRLINE(位列TS下限 To 位列TS上限单期) As Variant
                                        ARRLINE(位列TS结高) = ARRCSV(i, 位列TS结高)
                                        ARRLINE(位列TS结低) = ARRCSV(i, 位列TS结低)
                                        ARRLINE(位列TS结收) = ARRCSV(i, 位列TS结收)
                                        ARRDATA(遍历行号, 指定列号) = Join(ARRLINE, ",")
                                        Erase ARRLINE

                                        计数更新本次 = 计数更新本次 + 1
                                        计数更新本码 = 计数更新本码 + 1
                                        If 计数更新本码 = 1 Then 更期最始本码 = 当期
                                        更期最终本码 = 当期
                                    End If
                                End If
                            Next
                            Erase ARRCSV
                        End If
                        计码未更新到位 = 计码未更新到位 + IIf(更期最终本码 = 更期最终本次, 0, 1)
                        Debug.Print "藏库更新>>" & 指定据源 & ">>" & 指定期类 & ">>" & 遍历行号 & ">>" & 指定代码 & ">>" & " [" & 更期最始本码 & ">>" & 更期最终本码 & "]=" & 计数更新本码 & "  累未到位=" & 计码未更新到位 & "  全局更新轮数=" & 全局更新轮数
                End If
            Next
        End If

        全局更新轮数 = 全局更新轮数 + 1
    Next
    '------------------------------------------------------------------------------------
    典横索序.RemoveAll
    Set 典横索序 = Nothing
'========================================================================================
'返回
'========================================================================================
    Dim MSG As String
    MSG = "【任务】藏库数据引擎_更新全码" & vbCrLf
'    MSG = MSG & "【更期最始本库】" & 更期最始本库 & vbCrLf
    MSG = MSG & "【来源数据类型】" & 指定据源 & vbCrLf
    MSG = MSG & "【本源最始更期】" & 更期最始本源 & vbCrLf
    MSG = MSG & "【本源最终更期】" & 更期最终本源 & vbCrLf
    MSG = MSG & "【本次更期计数】" & 更期计数本次 & vbCrLf
    If 更期计数本次 > 0 Then
    MSG = MSG & "【本次最始更期】" & 更期最始本次 & vbCrLf
    MSG = MSG & "【本次最终更期】" & 更期最终本次 & vbCrLf
    End If
    MSG = MSG & "【计码总数本库】" & 更码总数本库 & vbCrLf
    MSG = MSG & "【计码未更到位】" & 计码未更新到位 & vbCrLf
'    MSG = MSG & "【计数更新本次】" & 计数更新本次 & vbCrLf
    '------------------------------------------------------------------------------------
'    藏库令.Save
    STBASE藏库引擎_更新数程 = MSG
End Function

