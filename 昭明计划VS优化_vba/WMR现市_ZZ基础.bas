'编写 查程同市码典

Function 查程同市码组( _
          码市 As String _
        , 码类 As String _
        , 码组 As Variant _
        , MS As Worksheet _
        , 始行 As Integer _
        , 始列 As Integer _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 是否返列 As Boolean = True _
        , Optional 码指 As String _
        , Optional 天组 As Variant, Optional 天典 As Dictionary _
        ) As Integer
'========================================================================================
'查询
'========================================================================================
    Dim 展示列数 As Integer
    展示列数 = 位简式宽三式
    '------------------------------------------------------------------------------------
    '获取数据
    '------------------------------------------------------------------------------------
    Dim 查组 As Variant
    Call 查程同市批处理(查组, 码市, 码类, 码组, 码指:=码指, 天组:=天组, 天典:=天典)
    '------------------------------------------------------------------------------------
    '测试输出
    '------------------------------------------------------------------------------------
'    MS.Cells.Clear
'    Call UTL数据转换_集ARR2WS(查组, MS, 1, 1)
'========================================================================================
'输出数组
'========================================================================================
    Dim 基元 As Range
    Set 基元 = MS.Cells(始行, 始列)
    '------------------------------------------------------------------------------------
    '输出到表
    '------------------------------------------------------------------------------------
    Dim 计数查组行 As Integer
    Dim 计数查组列 As Integer
    计数查组行 = UBound(查组, 1) - LBound(查组, 1) + 1
    计数查组列 = UBound(查组, 2) - LBound(查组, 2) + 1
    基元.Resize(计数查组行, 计数查组列) = 查组
    '------------------------------------------------------------------------------------
    '是否排序
    '------------------------------------------------------------------------------------
    If (是否排序 = xlDescending Or 是否排序 = xlAscending) And 计数查组行 > 1 Then
        With 基元.Resize(计数查组行, 计数查组列)
            .Sort key1:=.Cells(1, 位简式涨幅), order1:=是否排序, Header:=xlYes
        End With
    End If
'========================================================================================
'格式化
'========================================================================================
    '------------------------------------------------------------------------------------
    '列格式化
    '------------------------------------------------------------------------------------
    MS.Columns(始列).Columns(位简式名称).HorizontalAlignment = xlLeft
    MS.Columns(始列).Columns(位简式涨幅).HorizontalAlignment = xlRight
    MS.Columns(始列).Columns(位简式涨幅).NumberFormatLocal = 全设格式of一位
    MS.Columns(始列).Columns(位简式代码).ColumnWidth = 9
    MS.Columns(始列).Columns(位简式名称).ColumnWidth = IIf(码市 = "SS", 8, 12)
    MS.Columns(始列).Columns(位简式涨幅).ColumnWidth = 6
    MS.Columns(始列).Columns(位简式代码).Hidden = True
    '------------------------------------------------------------------------------------
    '边框
    '------------------------------------------------------------------------------------
    With 基元.Resize(计数查组行, 计数查组列)
        With .Borders(xlEdgeBottom)
            .LineStyle = xlContinuous
            .Color = 常色八灰
            .Weight = xlThin
        End With
        With .Borders(xlEdgeRight)
            .LineStyle = xlContinuous
            .Color = 常色八灰
            .Weight = xlThin
        End With
    End With
    '列代称：左边框
    With 基元.Offset(0, 1).Resize(计数查组行, 1)
        With .Borders(xlEdgeLeft)
            .LineStyle = xlContinuous
            .Color = 常色八灰
            .Weight = xlThin
        End With
    End With
    '------------------------------------------------------------------------------------
    '首行格式
    '------------------------------------------------------------------------------------
    With 基元.Resize(1, 展示列数)
        .Interior.Color = 常色一灰
        .Font.Color = 常色八靛
    End With
    '------------------------------------------------------------------------------------
    '首行数据：涨幅颜色
    '------------------------------------------------------------------------------------
    With 基元.Cells(1, 位简式涨幅)
        Select Case .Value
        Case Is > 0.5
          .Font.Color = 常色八红
        Case Is < -0.5
          .Font.Color = 常色八绿
        Case Else
          .Font.Color = 常色八灰
        End Select
    End With
'========================================================================================
'制作本页目录
'========================================================================================
    If 是否返列 = True Then
        Dim 目元 As Range
        Set 目元 = MS.Cells(65536, 始行).End(xlUp).Offset(1, 0)
        With 目元
            .Cells(1, 1) = 基元.Cells(1, 位简式名称)
            .Cells(1, 2) = 基元.Cells(1, 位简式名称).Offset(0, 1)
            .Cells(1, 3) = 基元.Cells(1, 位简式代码)
            .Cells(1, 1).HorizontalAlignment = xlRight
            .Cells(1, 2).NumberFormatLocal = 全设格式of一位
            .Cells(1, 3).HorizontalAlignment = xlRight
            With .Resize(1, 3)
                .Interior.ColorIndex = 37
            End With
            .Cells(1, 2).Interior.TintAndShade = -0.1
            .Cells(1, 3).Interior.TintAndShade = -0.2
        End With
        MS.Hyperlinks.Add _
              Anchor:=目元.Cells(1, 3) _
            , Address:="" _
            , SubAddress:=MS.Name & "!" & 基元.Cells(1, 位简式涨幅).Address(0, 0)
        Set 目元 = Nothing
    End If
'========================================================================================
'返回列号或行号
'========================================================================================
    If 是否返列 = True Then
        查程同市码组 = 始列 + 展示列数
    Else
        查程同市码组 = 始行 + 计数查组行
    End If
'========================================================================================
End Function






'========================================================================================
'20260613改：码市<>"SS" 时走新浪批量预取（UBHTTP新浪_查回典批量），一次 HTTP 拉取全部非沪深代码
'查程同市批处理 — 对同市场代码组批量取行情并写入数组
'  码市="SS" 使用天典/天组缓存（腾讯接口）；码市<>"SS" 自动走新浪批量预取
'========================================================================================
Function 查程同市批处理( _
          查组 As Variant _
        , 码市 As String _
        , 码类 As String _
        , 码组 As Variant _
        , Optional 码指 As String _
        , Optional 天组 As Variant, Optional 天典 As Dictionary _
        ) As Integer
'========================================================================================
'衍生代码
'========================================================================================
    '------------------------------------------------------------------------------------
    '设置数组
    '------------------------------------------------------------------------------------
    Dim 展示列数 As Integer
    展示列数 = 位简式宽三式
    ReDim 查组(0 To UBound(码组) - LBound(码组) + 1, 1 To 展示列数) As Variant
    '------------------------------------------------------------------------------------
    '衍生代码
    '------------------------------------------------------------------------------------
    Dim 代码 As String
    Dim 码组元素 As Variant
    
    Dim X As Integer
    For X = LBound(码组) To UBound(码组)
        码组元素 = 码组(X)
        If Not VBA.IsMissing(码组元素) Then
            If 码市 = "SS" Then
                查组(X + 1, 位简式代码) = LCase(码组元素)
            ElseIf 码市 = "HK" Then
                查组(X + 1, 位简式代码) = LCase(码组元素)
            ElseIf 码市 = "US" Then
                查组(X + 1, 位简式代码) = "gb_" & LCase(码组元素)
            End If
        Else
            查组(X + 1, 位简式代码) = ""
        End If
    Next
    
    '码类
    查组(0, 位简式代码) = 码类
'========================================================================================
'变量声明
'========================================================================================
    Dim 查组元素 As Variant
    Dim 是否查典 As Boolean
    Dim 天典定位 As Integer
    Dim ARRQ As Variant
    '------------------------------------------------------------------------------------
    Dim 值涨幅今 As Double
    Dim 值涨幅和 As Double
    Dim 值码总数 As Integer
    Dim 值码停数 As Integer
    值涨幅今 = 0
    值涨幅和 = 0
    值码总数 = 0
    值码停数 = 0
'========================================================================================
'新浪批量预取（非沪深代码）：收集所有代码 → 一次/数次 HTTP 拉取全部，存入 新浪典
'  后续主循环中 查基程单码ZZ查询 命中缓存则跳过 HTTP，避免逐只查询导致的数百次网络往返
'========================================================================================
    Dim 新浪典 As Dictionary
    If 码市 <> "SS" Then
        Dim 代码串预 As String
        Dim I预 As Long
        For I预 = 1 To UBound(查组)
            If Len(查组(I预, 位简式代码)) > 0 Then
                代码串预 = 代码串预 & 查组(I预, 位简式代码) & ","
            End If
        Next
        If Len(代码串预) > 0 Then
            代码串预 = Left$(代码串预, Len(代码串预) - 1)
            Set 新浪典 = UBHTTP新浪_查回典批量(代码串预)
        End If
    End If
'========================================================================================
'遍历数组
'========================================================================================
    For X = LBound(查组) To UBound(查组)
        查组元素 = 查组(X, 位简式代码)
        '--------------------------------------------------------------------------------
        '判断是否需要查询天典
        '--------------------------------------------------------------------------------
        是否查典 = False
        If 码市 = "SS" And Not 天典 Is Nothing Then
            If 天典.Exists(查组元素) Then
                是否查典 = True
            End If
        End If
        '--------------------------------------------------------------------------------
        '查询天典
        '--------------------------------------------------------------------------------
        If 是否查典 = True Then
            天典定位 = 天典(查组元素)
            
            查组(X, 位简式名称) = 天组(天典定位, 位列天组代称)
            '过滤停牌代码
            If Len(天组(天典定位, 位列天组停牌)) = 0 Then
                值涨幅今 = 天组(天典定位, 位列天组今涨)
                值涨幅和 = 值涨幅和 + 值涨幅今
                值码总数 = 值码总数 + 1
                值码停数 = 值码停数 + IIf(值涨幅今 >= 8, 1, 0)
                
                查组(X, 位简式涨幅) = 值涨幅今
                '查组(X, 位简式价格) = 天组(天典定位, 位列天组今收)
            End If
        '--------------------------------------------------------------------------------
        '查询实时
        '--------------------------------------------------------------------------------
        ElseIf Len(查组元素) > 0 Then
                值涨幅今 = 查基程单码ZZ查询(查组元素, ARRQ, 新浪典:=新浪典)
                值涨幅和 = 值涨幅和 + 值涨幅今
                值码总数 = IIf(X > 0, 值码总数 + 1, 值码总数)
                值码停数 = 值码停数 + IIf(值涨幅今 >= 8, 1, 0)
    
                查组(X, 位简式名称) = ARRQ(位简式名称)
                查组(X, 位简式涨幅) = 值涨幅今
                '查组(X, 位简式价格) = ARRQ(位简式价格)
        '--------------------------------------------------------------------------------
        End If
        '--------------------------------------------------------------------------------
        'Debug.Print 码类 & ">"; 查组元素, X
        '--------------------------------------------------------------------------------
    Next X
'========================================================================================
'汇总数组
'========================================================================================
    '查组(位简式查组首行, 位简式代码) = 值码总数
    查组(位简式查组首行, 位简式代码) = 值码停数 '  & " , " & 值码总数 '统计【大涨数】替代【码总数】
    '------------------------------------------------------------------------------------
    If Len(查组(位简式查组首行, 位简式名称)) = 0 Then
        查组(位简式查组首行, 位简式名称) = 码类
    End If
    '------------------------------------------------------------------------------------
    If 查组(位简式查组首行, 位简式涨幅) = 0 And 值码总数 > 0 Then
        查组(位简式查组首行, 位简式涨幅) = Round(值涨幅和 / 值码总数, 2)
    End If
'========================================================================================
End Function







'========================================================================================
'20260613改：新增 新浪典 参数，命中批量预取缓存则跳过逐只 HTTP
'查基程单码ZZ查询 — 单只代码取行情（返回涨幅），优先命中缓存
'  沪深代码：优先从 腾讯典（批量预查）取；未命中则逐只腾讯 HTTP
'  非沪深：  优先从 新浪典（批量预查）取；未命中则逐只新浪 HTTP
'========================================================================================
Function 查基程单码ZZ查询( _
          代码 As Variant _
        , ARRQ As Variant _
        , Optional 腾讯典 As Dictionary _
        , Optional 新浪典 As Dictionary _
        ) As Double    '返回涨幅
'========================================================================================
    Dim sURL As String
    Dim sSEP As String
    Dim sRESP As String
    Dim aRESP As Variant
    '------------------------------------------------------------------------------------
    Dim 值名称 As String
    Dim 值涨幅 As Double
    Dim 值今收 As Double
    Dim 是否归类 As Boolean
    Dim 批查 As Boolean
    '========================================================================================
    '针对 沪深
    '========================================================================================
    If LCase(代码) Like 常通配全码代码 Then
        ' 批量命中：直接用预查数据，跳过 HTTP
        If Not 腾讯典 Is Nothing Then
            If 腾讯典.Exists(代码) Then
                aRESP = 腾讯典(代码)
                批查 = True
                GoTo 腾讯解析
            End If
        End If
        值涨幅 = 查基程单码SS查询腾讯(代码, ARRQ)
        GoTo 完成

腾讯解析:
        ReDim ARRQ(1 To 7) As Variant
        If UBound(aRESP) >= 32 Then
            值涨幅 = aRESP(32)
            ARRQ(位简式涨幅) = 值涨幅
            ARRQ(位简式名称) = aRESP(1)
            ARRQ(位简式价格) = CDbl(aRESP(3))
            ARRQ(位简式振幅) = aRESP(43)
            ARRQ(位简式量比) = aRESP(49)
        End If
        ARRQ(位简式代码) = 代码
        GoTo 完成
'========================================================================================
'针对 非沪深代码
'========================================================================================
    Else
        ReDim ARRQ(1 To 4) As Variant
        是否归类 = True
        '--------------------------------------------------------------------------------
        '批量命中：直接用预查数据，跳过 HTTP
        '--------------------------------------------------------------------------------
        If Not 新浪典 Is Nothing Then
            If 新浪典.Exists(代码) Then
                aRESP = 新浪典(代码)
                GoTo 新浪解析
            End If
        End If
        '--------------------------------------------------------------------------------
        '查询信息
        '--------------------------------------------------------------------------------
        sURL = "http://hq.sinajs.cn/list=" & 代码
        sSEP = ","
        sRESP = UBHTTP通用_查程回引(sURL)
        If InStr(sRESP, sSEP) > 0 Then
            aRESP = Split(sRESP, sSEP)
新浪解析:
            '----------------------------------------------------------------------------
            '港股
            If Left$(代码, 2) = "hk" Then
                值名称 = aRESP(1)
                If VBA.IsNumeric(aRESP(8)) Then
                If aRESP(8) > -100 Then
                    值涨幅 = aRESP(8)
                End If
                End If
                值今收 = aRESP(6)
            '----------------------------------------------------------------------------
            '美股
            ElseIf Left$(代码, 3) = "gb_" Then
                值名称 = aRESP(0)
                值涨幅 = aRESP(2)
                If VBA.IsNumeric(aRESP(1)) Then 值今收 = aRESP(1)
            '----------------------------------------------------------------------------
            '国内金融期货
            ElseIf Left$(代码, 7) = "CFF_RE_" Then
                值名称 = Mid$(代码, 8)
                值涨幅 = Round(100 * (aRESP(3) - aRESP(13)) / aRESP(13), 2)
                值今收 = aRESP(3)
            '----------------------------------------------------------------------------
            '国际股指
            ElseIf Left$(代码, 4) = "int_" Or Left$(代码, 2) = "b_" Then
                值名称 = aRESP(0)
                值涨幅 = aRESP(3)
                值今收 = aRESP(1)
            '----------------------------------------------------------------------------
            '国内商品期货
            ElseIf Len(代码) <= 3 And Right(代码, 1) = "0" Then
                值名称 = Left$(aRESP(0), Len(aRESP(0)) - 2)
                值涨幅 = Round(100 * (aRESP(8) - aRESP(5)) / aRESP(5), 2)
                值今收 = aRESP(8)
            '----------------------------------------------------------------------------
            '国际商品期货
            ElseIf Left$(代码, 3) = "hf_" Then
                值名称 = aRESP(13)
                If CLng(aRESP(5)) > 0 Then
                    值涨幅 = Round(100 * (aRESP(0) / aRESP(5) - 1), 2)
                End If
                值今收 = aRESP(0)
            '----------------------------------------------------------------------------
            '新浪美元指数
            ElseIf 代码 = "DINIW" Then
                值名称 = aRESP(9)
                值涨幅 = Round(100 * (aRESP(1) - aRESP(3)) / aRESP(3), 2)
                值今收 = aRESP(1)
            '----------------------------------------------------------------------------
            '新浪外汇
            ElseIf Left$(代码, 3) = "fx_" Then
                值名称 = aRESP(9)
                值涨幅 = aRESP(10)
                值今收 = aRESP(1)
            '----------------------------------------------------------------------------
            Else
                是否归类 = False
                ARRQ = aRESP
            End If
            '----------------------------------------------------------------------------
            '填写单元格
            '----------------------------------------------------------------------------
            If 是否归类 = True Then
                ARRQ(位简式代码) = 代码
                ARRQ(位简式名称) = 值名称
                ARRQ(位简式涨幅) = 值涨幅
                ARRQ(位简式价格) = 值今收
            End If
            '----------------------------------------------------------------------------
            Erase aRESP
        '--------------------------------------------------------------------------------
        Else
                ARRQ(位简式代码) = 代码
                ARRQ(位简式名称) = 代码
                ARRQ(位简式涨幅) = "N"
                ARRQ(位简式价格) = "N"
        '--------------------------------------------------------------------------------
        End If
    End If
'========================================================================================
完成:
    查基程单码ZZ查询 = 值涨幅
End Function




Function 查基程单码SS查询腾讯( _
          代码 As Variant _
        , ARRQ As Variant _
        ) As Double    '返回涨幅
'========================================================================================
    Dim nRESP As Integer
    Dim aRESP As Variant
    Dim 值涨幅 As Double
'========================================================================================
    '------------------------------------------------------------------------------------
    '重定义数组
    '------------------------------------------------------------------------------------
    ReDim ARRQ(1 To 7) As Variant
    '------------------------------------------------------------------------------------
    '查询信息
    '------------------------------------------------------------------------------------
    nRESP = UBHTTP腾实_查回组(aRESP, CStr(代码))
    '------------------------------------------------------------------------------------
    '处理信息
    '------------------------------------------------------------------------------------
    If nRESP > 0 Then
        值涨幅 = aRESP(32)
        ARRQ(位简式涨幅) = 值涨幅
        ARRQ(位简式名称) = aRESP(1)
        ARRQ(位简式价格) = CDbl(aRESP(3))
        ARRQ(位简式振幅) = aRESP(43)
        ARRQ(位简式量比) = aRESP(49)
        'ARRQ( 位简式交额) = Int(aRESP(37) / 10000)
        '--------------------------------------------------------------------------------
        Erase aRESP
        '--------------------------------------------------------------------------------
    End If
    ARRQ(位简式代码) = 代码
'========================================================================================
    查基程单码SS查询腾讯 = 值涨幅
End Function










