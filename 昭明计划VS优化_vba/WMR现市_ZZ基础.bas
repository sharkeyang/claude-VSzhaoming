Function 市调预程引擎数程(天组 As Variant, 天典 As Dictionary) As Boolean
    Dim CIDL As String
    Dim nRESP As Integer
    Dim aRESP As Variant
    '====================================================================================
    '重置数组
    '====================================================================================
    ReDim 天组(1 To 天典.Count, 1 To 位列天组维度) As Variant
    '====================================================================================
    '批量预查询（100只/批，每批最多3次重试）
    '====================================================================================
    Dim 批量典 As Dictionary, 代码串 As String
    代码串 = Join(天典.Keys, ",")
    Set 批量典 = UBHTTP腾实_查回典批量(代码串)
    '====================================================================================
    '查询信息
    '====================================================================================
    Dim X As Integer, 批查 As Boolean
    For X = 1 To 天典.Count
        CIDL = 天典.Keys(X - 1)
        批查 = False
        '--------------------------------------------------------------------------------
        '查询信息：优先批量命中，未命中才逐只兜底
        '--------------------------------------------------------------------------------
        If 批量典.Exists(CIDL) Then
            aRESP = 批量典(CIDL)
            nRESP = UBound(aRESP) + 1
            批查 = True
        Else
            nRESP = UBHTTP腾实_查回组(aRESP, CIDL)
        End If
        '--------------------------------------------------------------------------------
        '处理信息
        '--------------------------------------------------------------------------------
        天组(X, 位列天组代码) = CIDL
        If nRESP > 0 Then
                '------------------------------------------------------------------------
                '天组(X, 位列天组代码) = UBCID规制代码(aRESP(位序腾实代码))
                天组(X, 位列天组代称) = aRESP(位序腾实代称)
                天组(X, 位列天组今涨) = aRESP(位序腾实今涨)
                '------------------------------------------------------------------------
                天组(X, 位列天组今收) = aRESP(位序腾实今收)
                天组(X, 位列天组前收) = aRESP(位序腾实前收)
                天组(X, 位列天组今开) = aRESP(位序腾实今开)
                天组(X, 位列天组振幅) = aRESP(位序腾实振幅)
                天组(X, 位列天组今高) = aRESP(位序腾实今高)
                天组(X, 位列天组今低) = aRESP(位序腾实今低)
                天组(X, 位列天组涨停) = aRESP(位序腾实A涨停)
                天组(X, 位列天组跌停) = aRESP(位序腾实A跌停)
                天组(X, 位列天组量比) = aRESP(位序腾实A量比)
                天组(X, 位列天组换手) = aRESP(位序腾实A换手)
                '天组(X, 位列天组今量) = aRESP(位序腾实交量)
                天组(X, 位列天组外盘) = aRESP(位序腾实外盘)
                天组(X, 位列天组内盘) = aRESP(位序腾实内盘)
                天组(X, 位列天组今额) = aRESP(位序腾实交额) / 10000
                '天组(X, 位列天组流市) = aRESP(位序腾实流市)
                '天组(X, 位列天组总市) = aRESP(位序腾实总市)
                天组(X, 位列天组市盈) = aRESP(位序腾实市盈静态)
                天组(X, 位列天组市净) = aRESP(位序腾实A市净)
                '天组(X, 位列天组时间) = aRESP(位序腾实时间)
                天组(X, 位列天组停牌) = aRESP(位序腾实停牌)
                If Not 批查 Then Erase aRESP
        End If
    Next X
'========================================================================================
'检查专用
'========================================================================================
'    For X = LBound(天组, 1) To UBound(天组, 1)
'        For Y = LBound(天组, 2) To UBound(天组, 2)
'            Cells(X + 1, Y + 1) = 天组(X, Y)
'        Next Y
'    Next X
'========================================================================================
End Function
