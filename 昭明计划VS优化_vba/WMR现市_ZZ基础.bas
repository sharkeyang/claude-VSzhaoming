'========================================================================================
'查程混市码组：根据代码数组输出行情信息
'供包含多种市场产品的程序调用
'========================================================================================
'========================================================================================
Function 查程混市码组( _
          码组 As Variant _
        , MS As Worksheet _
        , 始行 As Integer _
        , 始列 As Integer _
        , Optional 是否扩展 As Boolean = False _
        , Optional 是否返列 As Boolean = True _
        ) As Integer
'========================================================================================
'初始设置
'========================================================================================
    Dim 展示列数 As Integer
    展示列数 = IIf(是否扩展, 位简式宽六式, 位简式宽四式)
    '------------------------------------------------------------------------------------
    Dim 基色 As Long
    '基色 = MS.Cells(1, 1).Interior.Color
    基色 = 常色二灰
'========================================================================================
'列格式化
'========================================================================================
    MS.Columns(始列).Columns(位简式名称).HorizontalAlignment = xlRight
    MS.Columns(始列).Columns(位简式涨幅).NumberFormatLocal = 全设格式of一位
    MS.Columns(始列).Columns(位简式振幅).NumberFormatLocal = 全设格式of一位
    MS.Columns(始列).Columns(位简式量比).NumberFormatLocal = 全设格式of一位
    '------------------------------------------------------------------------------------
    MS.Columns(始列).Columns(位简式代码).ColumnWidth = 10
    'MS.Columns(始列).Columns(位简式名称).AutoFit
    MS.Columns(始列).Columns(位简式名称).ColumnWidth = 10
    MS.Columns(始列).Columns(位简式涨幅).ColumnWidth = 5.5
    MS.Columns(始列).Columns(位简式价格).ColumnWidth = 7
    MS.Columns(始列).Columns(位简式振幅).ColumnWidth = 4
    MS.Columns(始列).Columns(位简式量比).ColumnWidth = 4
    MS.Columns(始列).Columns(位简式交额).ColumnWidth = 4
    '------------------------------------------------------------------------------------
    MS.Columns(始列).Columns(位简式代码).Hidden = True
'========================================================================================
'变量声明
'========================================================================================
    Dim 码组元素 As Variant
    Dim 是否空值 As Boolean
    '-----------------------------
    Dim 基元 As Range
    Set 基元 = MS.Cells(始行, 始列)
    Dim 目元 As Range
    Set 目元 = 基元
    '-----------------------------
    Dim 遍历计数 As Integer
    遍历计数 = 0
'========================================================================================
'批量预查询：收集沪深代码一次性查腾讯
'========================================================================================
    Dim 腾讯码串 As String
    Dim 腾讯典 As Dictionary
    Dim 码预 As Variant, X预 As Integer
    For X预 = 1 To UBound(码组, 1)
        码预 = 码组(X预)
        If Not VBA.IsMissing(码预) Then
            If Len(码预) > 0 Then
                If LCase(码预) Like 常通配全码代码 Then
                    腾讯码串 = 腾讯码串 & 码预 & ","
                End If
            End If
        End If
    Next X预
    If Len(腾讯码串) > 0 Then
        腾讯码串 = Left$(腾讯码串, Len(腾讯码串) - 1)
        Set 腾讯典 = UBHTTP腾实_查回典批量(腾讯码串)
    End If
'========================================================================================
'遍历数组
'========================================================================================
    Dim X As Integer
    For X = 1 To UBound(码组, 1)
        码组元素 = 码组(X)
        '--------------------------------------------------------------------------------
        '判断数组元素是否为空
        '--------------------------------------------------------------------------------
        是否空值 = True
        If Not VBA.IsMissing(码组元素) Then
            If Len(码组元素) > 0 Then
                是否空值 = False
            End If
        End If
        '--------------------------------------------------------------------------------
        If 是否空值 = True Then                 '如果元素为空
            With 目元.Resize(1, 展示列数).Borders(xlEdgeBottom)
                .LineStyle = xlContinuous
                .Color = 基色
                .TintAndShade = -0.3
                .Weight = xlThin
            End With
        Else                                    '如果元素非空
            '----------------------------------------------------------------------------
            '遍历计数
            '----------------------------------------------------------------------------
            遍历计数 = 遍历计数 + 1
            Set 目元 = 基元.Cells(遍历计数, 1)
            '----------------------------------------------------------------------------
            '单行格式化
            '----------------------------------------------------------------------------
            目元.Borders(xlEdgeLeft).Weight = xlThin
            
            目元.Cells(1, 位简式名称).Font.Bold = True
            If 是否扩展 = True Then
                With 目元.Cells(1, 位简式名称)
                    .Interior.ThemeColor = xlThemeColorAccent1
                    .Interior.TintAndShade = 0
                End With
                With 目元.Cells(1, 位简式涨幅)
                    .Interior.Color = 常色主碧
                    .Interior.TintAndShade = IIf(.Value >= 0, 0.3, 0.7)
                End With
            End If
            '----------------------------------------------------------------------------
            '原始进行查询输出
            '----------------------------------------------------------------------------
            Dim ARRQ As Variant
            Call 查基程单码ZZ查询(码组元素, ARRQ, 腾讯典)
            
            目元.Cells(1, 位简式代码) = ARRQ(位简式代码)
            目元.Cells(1, 位简式名称) = ARRQ(位简式名称)
            目元.Cells(1, 位简式涨幅) = ARRQ(位简式涨幅)
            目元.Cells(1, 位简式价格) = ARRQ(位简式价格)
            If 是否扩展 = True Then
                目元.Cells(1, 位简式振幅) = ARRQ(位简式振幅)
                目元.Cells(1, 位简式量比) = ARRQ(位简式量比)
            End If
            Erase ARRQ
            '----------------------------------------------------------------------------
            '小数点格式化
            '----------------------------------------------------------------------------
            With 目元.Cells(1, 位简式价格)       '价格格式
                Select Case .Value
                Case Is > 120
                    .NumberFormatLocal = "0"
                Case Is > 10
                    .NumberFormatLocal = "0.0"
                Case Is > 0
                    .NumberFormatLocal = "0.00"
                End Select
            End With
            '----------------------------------------------------------------------------
            Debug.Print MS.Name & ">" & 目元.Address & ">" & X
            '----------------------------------------------------------------------------
        End If
        '================================================================================
    Next X
'========================================================================================
'边框
'========================================================================================
    '------------------------------------------------------------------------------------
    '末行边框
    '------------------------------------------------------------------------------------
    With 目元.Resize(1, 展示列数).Borders(xlEdgeBottom)
            .LineStyle = xlContinuous
            .Color = 基色
            .TintAndShade = -0.3
            .Weight = xlThin
    End With
    Set 目元 = Nothing
    '------------------------------------------------------------------------------------
    '首行边框
    '------------------------------------------------------------------------------------
    With MS.Cells(始行, 始列).Resize(1, 展示列数)
        With .Borders(xlEdgeTop)
            .LineStyle = xlContinuous
            .Color = 基色
            .TintAndShade = -0.3
            .Weight = xlThin
        End With
    End With
    '------------------------------------------------------------------------------------
    '列宽
    '------------------------------------------------------------------------------------
    MS.Columns(始列).Columns(位简式名称).AutoFit
'========================================================================================
'返回列号或行号
'========================================================================================
    If 是否返列 = True Then
        查程混市码组 = 始列 + 展示列数
    Else
        查程混市码组 = 始行 + 遍历计数   '+ 1
    End If
'========================================================================================
End Function
'========================================================================================
'========================================================================================
'查程混市码集：根据代码集合输出行情信息
'供包含多种市场产品的程序调用
'========================================================================================
'========================================================================================
Function 查程混市码典( _
          码典 As Dictionary _
        , MS As Worksheet _
        , 始行 As Integer _
        , 始列 As Integer _
        , Optional 是否扩展 As Boolean = False _
        , Optional 是否返列 As Boolean = True _
        ) As Integer
    '------------------------------------------------------------------------------------
    ReDim 码组(0 To 码典.Count)
    
    Dim X As Integer
    For X = 1 To 码典.Count
        码组(X) = 码典.Items(X - 1)
    Next X
    '------------------------------------------------------------------------------------
    查程混市码典 = 查程混市码组(码组, MS, 始行, 始列, 是否扩展:=是否扩展, 是否返列:=是否返列)
    '------------------------------------------------------------------------------------
    Erase 码组
    '------------------------------------------------------------------------------------
End Function





