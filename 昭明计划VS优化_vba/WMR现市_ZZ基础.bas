Function 市调预程引擎销毁(天组 As Variant, 天典 As Dictionary) As Boolean
    市调预程引擎销毁 = False
    '------------------------------------------------------------------------------------
    '前置检查
    '------------------------------------------------------------------------------------
    If 天典 Is Nothing Or 天典.Count = 0 Then
        市调预程引擎销毁 = True
        Exit Function
    End If
    Erase 天组
    天典.RemoveAll
    Set 天典 = Nothing
    '------------------------------------------------------------------------------------
    市调预程引擎销毁 = True
End Function

