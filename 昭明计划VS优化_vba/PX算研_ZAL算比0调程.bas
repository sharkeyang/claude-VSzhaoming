Function XL算比模板前调精比( _
          被研期类 As String _
        , Optional 是否外簿 As Boolean = True _
        )
    '------------------------------------------------------------------------------------
    Dim 被研算法冠版  As String
    Dim 被研算法挑版  As String
    被研算法冠版 = "s@阶丑加强"
    被研算法挑版 = "s@阶丑"
    '------------------------------------------------------------------------------------
    Dim 组被研算法 As Variant
    组被研算法 = Array("", 被研算法冠版, 被研算法挑版)
    '------------------------------------------------------------------------------------
    Call XL算比模板前调基程( _
          被研期类:=被研期类 _
        , 组被研算法:=组被研算法 _
        , 是否外簿:=是否外簿 _
        )
    '------------------------------------------------------------------------------------
End Function
