'########################################################################################
'########################################################################################
'##################################     算比模板基程   ###################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：算比引擎正程批处理后台
'========================================================================================
'========================================================================================
Function XL算比模板前调基程( _
          被研期类 As String _
        , 组被研算法 As Variant _
        , Optional 是否外簿 As Boolean = False _
        , Optional 基色底 As Long = 常色研究 _
        ) As Integer
'----------------------------------------------------------------------------------------
    TT = Timer
'========================================================================================
'基础设置
'========================================================================================
    Dim 是否明细 As Boolean
    是否明细 = 是否外簿
'========================================================================================
'获取代码列表
'========================================================================================
    Dim 典被研代码 As New Dictionary
    Dim 运行次数 As Integer
    运行次数 = UGSOP拣选引擎圈选(典被研代码)
    '------------------------------------------------------------------------------------
    If 运行次数 = 0 Then
        MsgBox "NP"
        Exit Function
    End If
'========================================================================================
'遍历调用
'========================================================================================
    '------------------------------------------------------------------------------------
    '遍历代码
    '------------------------------------------------------------------------------------
    MSG = XL算比模板后调基程( _
          典被研代码:=典被研代码 _
        , 被研期类:=被研期类 _
        , 组被研算法:=组被研算法 _
            , 是否外簿:=是否外簿 _
            , 是否明细:=是否明细 _
            , 基色底:=基色底 _
        )
    '------------------------------------------------------------------------------------
    典被研代码.RemoveAll
    Set 典被研代码 = Nothing
'========================================================================================
'返回
'========================================================================================
    ThisWorkbook.Save
    '------------------------------------------------------------------------------------
    MSG = "算法对比引擎批处理" _
         & vbCrLf & "运行用时：" & CInt(Timer - TT) _
         & vbCrLf & "运行次数：" & 运行次数 _
         & vbCrLf & "运行列表：" _
         & vbCrLf & MSG
    '------------------------------------------------------------------------------------
    Debug.Print MSG
    MsgBox MSG, Title:="算法对比引擎批处理"
    '------------------------------------------------------------------------------------
End Function



'========================================================================================
'========================================================================================
'功能：算比引擎正程批处理后台
'输入：被研代码集合
'========================================================================================
'========================================================================================
Function XL算比模板后调基程( _
          典被研代码 As Dictionary _
        , 被研期类 As String _
        , 组被研算法 As Variant _
        , 是否外簿 As Boolean _
        , 是否明细 As Boolean _
        , Optional 基色底 As Long = 常色研究 _
        , Optional 运行次数 As Integer = 0 _
        ) As String
'========================================================================================
'确定运行次数
'允许设置参数限制运行次数
'========================================================================================
    If 典被研代码.Count = 0 Then
        Exit Function
    ElseIf 运行次数 = 0 Then
        运行次数 = 典被研代码.Count
    End If
'========================================================================================
'遍历调用
'========================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    Dim 被研代码 As String
    Dim 被研代称 As String
    '------------------------------------------------------------------------------------
    Dim k As Integer
    For k = 1 To 运行次数
        '--------------------------------------------------------------------------------
        被研代码 = 典被研代码.Keys(k - 1)
        被研代称 = 典被研代码.Items(k - 1)
        '--------------------------------------------------------------------------------
        Call XL算比引擎正程( _
              被研代码:=被研代码 _
            , 被研期类:=被研期类 _
            , 组被研算法:=组被研算法 _
            , 是否明细:=是否明细 _
            , 是否外簿:=是否外簿 _
            , 基色底:=基色底 _
            )
        '--------------------------------------------------------------------------------
        MSG = MSG & "【" & k & "】" & 被研代码 & " " & 被研代称 & " " & vbCrLf
        Debug.Print "算法比较批处理>> ", k, 被研代码, 被研代称
        '--------------------------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    UTL宏工具_END
'========================================================================================
'返回
'========================================================================================
    XL算比模板后调基程 = MSG
End Function
