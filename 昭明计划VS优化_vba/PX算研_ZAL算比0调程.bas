'########################################################################################





'========================================================================================
'========================================================================================
'调程后台调用：批处理正程
'========================================================================================
'========================================================================================
Sub XL算比后台调程研究()
    '------------------------------------------------------------------------------------
    Dim 被研期类 As String
    被研期类 = 常期类为乾
    '------------------------------------------------------------------------------------
    Dim 组被研算法 As Variant
    组被研算法 = Array(常算比类型为粗比, _
          "T@乾坤", "T@乾坤B" _
        , "s@均<ZA>", "s@均<ZB>", "s@均<ZC>" _
        , "s@均<AB>", "s@均<AC>" _
        , "s@均<BC>" _
        , "s@阶鑫<IA>", "s@阶鑫<IAB>" _
    )
    '------------------------------------------------------------------------------------
    Dim 典被研代码 As New Dictionary
    Dim WS花天 As Worksheet
    Dim i As Integer, CIDL As String
    If STBASE外簿工具_花册链接(WS花天, 常花中股) = False Then Exit Sub
    For i = 601 To 605
        CIDL = WS花天.Cells(i, 1)
        典被研代码.Add CIDL, CIDL
    Next
    '------------------------------------------------------------------------------------
    Debug.Print XL算比模板后调基程( _
          典被研代码:=典被研代码 _
        , 被研期类:=被研期类 _
        , 组被研算法:=组被研算法 _
        , 是否外簿:=True _
        , 是否明细:=True _
        )
    '------------------------------------------------------------------------------------
End Sub





