'########################################################################################
'#################################   结算管理  历统时      ##############################
'########################################################################################
'########################################################################################











'########################################################################################
'########################################################################################
'#################################  结算管理  基腾实时结算  #############################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：实时结算
'因为用实时日线数据进行结算，所以无法正确更新周类与月类的K线数据
'注意20230101：包含两部分，一部分是更新临时数据，一部分是结算。前一部分必须做，后一部分根据实结模式进行处理。
'注意20230201：增加外部控制，只有实结类型日类为S时，才进行以下结算，为了保证SCC能够得到正确结果。
'========================================================================================
'========================================================================================
Function STBASE结算引擎_实时结算数程基腾( _
          ByRef 组结算 As Variant _
        , ByVal 法道基列 As Integer _
        , Optional ByRef 组行情 As Variant _
        , Optional ByVal 是否结算 As Boolean = True _
        ) As Integer
'========================================================================================
'验证非空
'========================================================================================
    If VBA.IsEmpty(组结算) = True Then Exit Function
'========================================================================================
'获取行情
'========================================================================================
    Dim 是否退出清理  As Boolean
    If VBA.IsMissing(组行情) Then
        组行情 = 组结算
        是否退出清理 = True
    End If
'========================================================================================
'变量声明
'========================================================================================
    Dim 法道基位 As Integer
    法道基位 = 法道基列 - 1
    '====================================
    Dim 当日 As Date, 临日 As Date
    Dim 当收#, 当开#, 当高#, 当低#
    Dim 今量 As Double
    '====================================
    Dim ARROS(1 To 花宽单道) As Variant
    Dim 指定期类 As String
    Dim 结日记录 As Date
    Dim 是否停牌 As Boolean
    Dim 计数已结算  As Integer
    计期已结算 = 0
'========================================================================================
'遍历
'========================================================================================
    Dim 遍历序号 As Integer
    For 遍历序号 = LBound(组结算, 1) To UBound(组结算, 1)
        '================================================================================
        '查询当天行情信息
        '================================================================================
        CIDL = 组行情(遍历序号, 位qt代码)
        是否停牌 = IIf(组行情(遍历序号, 位qt停牌) = "S", True, False)
        
        If UBCID是代码(CIDL) And 是否停牌 = False Then
            '----------------------------------------------------------------------------
            '获取结算向量
            '----------------------------------------------------------------------------
            For i = 1 To 花宽单道
                ARROS(i) = 组结算(遍历序号, 法道基位 + i)
            Next i
            结日记录 = ARROS(位os结期)
            指定期类 = ARROS(位os期类)
            临日 = ARROS(位os临期)
            '----------------------------------------------------------------------------
            '读取数据
            '----------------------------------------------------------------------------
            当日 = 组行情(遍历序号, 位qt今期)
            当收 = 组行情(遍历序号, 位qt今收)
            当开 = 组行情(遍历序号, 位qt今开)
            当高 = 组行情(遍历序号, 位qt今高)
            当低 = 组行情(遍历序号, 位qt今低)
            '----------------------------------------------------------------------------
            '步骤：更新【临】
            '注意20220829：可以不区分期类，直接用周类逻辑进行更新，因为只要结算过临信息就被清零。
            '----------------------------------------------------------------------------
            If 当日 > 临日 Then
                    '---------------------------------------------------------------------
                    If 指定期类 = 常期类为日 Then
                            ARROS(位os临期) = 当日
                            ARROS(位os临收) = 当收
                            ARROS(位os临开) = 当开
                            ARROS(位os临高) = 当高
                            ARROS(位os临低) = 当低
                    Else
                        If 当日 - STBASE取据引擎_工具期类第几日(当日, 指定期类) = 临日 - STBASE取据引擎_工具期类第几日(临日, 指定期类) Then
                            '属于同一期，本期非首个交易日
                            ARROS(位os临期) = 当日
                            ARROS(位os临收) = 当收
                            If 当高 > ARROS(位os临高) Then ARROS(位os临高) = 当高
                            If 当低 < ARROS(位os临低) Then ARROS(位os临低) = 当低
                        Else
                            If ARROS(位os临收) > 0 Then
                                '前期信息未清零，有可能前结算时已停牌，应先结算再更新
                                计期已结算 = 计期已结算 + STBASE结算引擎_单点结算核程(ARROS)
                                'If 是否统时 = True Then Call STBASE结算引擎_单点统时核程(ARROS)
                            End If
                            '本期首个交易日 (所有临时价格已经在上期正式结算中清零)
                            ARROS(位os临期) = 当日
                            ARROS(位os临收) = 当收
                            ARROS(位os临开) = 当开
                            ARROS(位os临高) = 当高
                            ARROS(位os临低) = 当低
                        End If
                    End If
                    '---------------------------------------------------------------------
                    '计算：值临PR
                    '注20241020：因为不会进入正式结算，所以必须放在外面，与临数据共同赋值。
                    '---------------------------------------------------------------------
                    If ARROS(位os结收) <> 0 Then
                        ARROS(位os临幅PR) = Round((ARROS(位os临收) / ARROS(位os结收) - 1) * 100, 2)
                        ARROS(位os临幅HR) = Round((ARROS(位os临高) / ARROS(位os结收) - 1) * 100, 2)
                        ARROS(位os临幅LR) = Round((ARROS(位os临低) / ARROS(位os结收) - 1) * 100, 2)
                    End If
                    '---------------------------------------------------------------------
            End If
            '----------------------------------------------------------------------------
            '步骤：进行结算（与区间结算不同）
            '----------------------------------------------------------------------------
            If 当日 > ARROS(位os结期) Then
                    If 是否结算 = True Then 计数已结算 = 计数已结算 + STBASE结算引擎_单点结算核程(ARROS)
            End If
            '----------------------------------------------------------------------------
            '回写结算向量
            '----------------------------------------------------------------------------
            '补丁：如果没有及时进行【每日结算】，会导致今涨不正确（用了不正确的前收）
            If ARROS(位os期类) = 常期类为日 Then
                ARROS(位os结幅PR0) = 组行情(遍历序号, 位qt今涨幅)
            End If
            '衍生
            Call STBASE结算引擎_单点衍生核程(ARROS)
            '回写
            For i = LBound(ARROS) To UBound(ARROS)
                组结算(遍历序号, 法道基位 + i) = ARROS(i)
            Next i
            Erase ARROS
            '----------------------------------------------------------------------------
            Debug.Print "结算管理_实时结算由腾实>>" & 遍历序号 & ">>" & CIDL & "  [" & 结日记录 & ">>" & 当日 & "]=" & 计数已结算
            '----------------------------------------------------------------------------
        End If
    Next 遍历序号
'========================================================================================
'清理
'========================================================================================
    If 是否退出清理 = True Then
        Erase 组行情
    End If
'========================================================================================
'返回
'========================================================================================
    STBASE结算引擎_实时结算数程基腾 = 计数已结算
End Function
'########################################################################################
'########################################################################################
'#################################  结算管理  基腾实时结算  #############################
'########################################################################################
'########################################################################################













