'========================================================================================
'========================================================================================
'功能：对花册OS进行历统跨时
'========================================================================================
'========================================================================================
Sub STBASE结算引擎_历统时正程调程()
    MSG = STBASE结算引擎_历统时正程(常花中股, 指定结期上限:=Date)
    MsgBox MSG
End Sub
Function STBASE结算引擎_历统时正程( _
          Optional ByVal 指定花册 As String = 常花中股 _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        ) As String
'========================================================================================
'制作字典
'========================================================================================
    Dim WS花册 As Worksheet
    If 指定花册 = 常花中期 Or 指定花册 = 常花港股指 Or 指定花册 = 常花港股通 Or 指定花册 = 常花美股 Or 指定花册 = 常花中股 Then
        If STBASE外簿工具_花册链接(WS花册, 指定花册) = False Then
            MsgBox "对应花册不存在"
            Exit Function
        End If
    Else
        If UTL判断工表存在(指定花册) = False Then
            MsgBox "对应花册不存在"
            Exit Function
        End If
        Set WS花册 = ThisWorkbook.Sheets(指定花册)
    End If
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽主道)
    '------------------------------------------------------------------------------------
    '制作字典
    '------------------------------------------------------------------------------------
    Dim 典码称 As New Dictionary
    Dim 典码行 As New Dictionary
    Dim X As Integer
    For X = LBound(组花册, 1) To UBound(组花册, 1)
        CIDL = 组花册(X, 位列花天CIDL)
        代称 = 组花册(X, 位列花天代称)
        If UBCID是中股(CIDL) = True Then
            典码称.Add Key:=CIDL, Item:=代称
            典码行.Add Key:=CIDL, Item:=X
        End If
        'If 典码称.Count > 50 Then Exit For
    Next
    Dim 码数 As Integer
    码数 = 典码称.Count
'========================================================================================
    UTL宏工具_BEGIN
    Dim MSG As String
    TT = Timer
'========================================================================================
'加工数据
'========================================================================================
    Dim 组历统时 As Variant
    Call 历研统时引擎2数程(组历统时, 典码称, 指定结期上限:=指定结期上限)
    '------------------------------------------------------------------------------------
    ReDim 组历统时花册(LBound(组花册, 1) To UBound(组花册, 1), 位统时列总始 To 位统时列总终) As Variant
    '------------------------------------------------------------------------------------
    For X = LBound(组历统时, 1) To UBound(组历统时, 1)
        CIDL = 组历统时(X, 位统时列CIDL)
        If 典码行.Exists(CIDL) = True Then
            定行花册 = 典码行(CIDL)
            For Y = 位统时列总始 To 位统时列总终
                组历统时花册(定行花册, Y) = 组历统时(X, Y)
            Next
        End If
    Next
    Set 典码称 = Nothing
    Set 典码行 = Nothing
'========================================================================================
'输出到花册
'========================================================================================
    Dim 结期统终 As Date
    结期统终 = 组历统时花册(1, 位统时列结期)
    '------------------------------------------------------------------------------------
    Call STCALL花册工具_花册格程(WS花册, 基色底:=常色主靛)
    Call 历研统时引擎5格程按列(WS花册, 始列:=花列统道)
    '------------------------------------------------------------------------------------
    Call UTL数据转换_集ARR2WS(组历统时花册, WS花册, 始行:=2, 始列:=花列统道)
    Erase 组历统时花册
    Set WS花册 = Nothing
'========================================================================================
'返回
'========================================================================================
    UTL宏工具_END
    '------------------------------------------------------------------------------------
    MSG = MSG & "【任务】历统跨时" & vbCrLf
    MSG = MSG & "【历统码数】" & 码数 & vbCrLf
    MSG = MSG & "【历统终期】" & 结期统终 & vbCrLf
    MSG = MSG & "【历统跨时耗时】" & CLng(Timer - TT) & vbCrLf
    '------------------------------------------------------------------------------------
    STBASE结算引擎_历统时正程 = MSG
End Function
