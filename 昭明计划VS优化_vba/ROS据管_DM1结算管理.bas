'========================================================================================
'========================================================================================
'通用调用程序：导入结算
'========================================================================================
'========================================================================================
Function STBASE结算引擎_全新结算正程( _
          ByVal 指定花册 As String _
        , ByVal 指定文夹 As String _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        , Optional ByVal 基色底 As Long _
        , Optional ByVal 指定头码 As String = 常查询代码中股 _
        ) As String
'========================================================================================
'前置验证
'========================================================================================
    Dim MSG As String
    '------------------------------------------------------------------------------------
    '验证容积
    '------------------------------------------------------------------------------------
'    If 位os容积 > 花宽单道 Then
'        MSG = "OS容积不足：" & 位os容积 & " > " & 花宽单道
'        TCALL结算引擎_全新结算正程 = MSG
'        Exit Function
'    End If
    '------------------------------------------------------------------------------------
    '前置验证：文件夹
    '------------------------------------------------------------------------------------
    If UTL判断路径存在(指定文夹) = False Then
        MSG = "CSV文件夹不存在：" & 指定文夹
        STBASE结算引擎_全新结算正程 = MSG
        Exit Function
    End If
    '------------------------------------------------------------------------------------
    '前置验证：花册
    '------------------------------------------------------------------------------------
    Dim WS花册 As Worksheet
    If 指定花册 = 常花中期 Or 指定花册 = 常花港股指 Or 指定花册 = 常花港股通 Or 指定花册 = 常花美股 Or 指定花册 = 常花中股 Then
        If STBASE外簿工具_花册链接(WS花册, 指定花册) = False Then
            MSG = "外部花册链接失败：" & 指定花册
            STBASE结算引擎_全新结算正程 = MSG
            Exit Function
        End If
    Else
        If UTL判断工表存在(指定花册) = False Then
            MSG = "对应花册不存在：" & 指定花册
            STBASE结算引擎_全新结算正程 = MSG
            Exit Function
        End If
        Set WS花册 = ThisWorkbook.Sheets(指定花册)
    End If
'========================================================================================
    UTL宏工具_BEGIN
    TTT = Timer
'========================================================================================
'数据处理
'========================================================================================
    '====================================================================================
    '进行结算
    '====================================================================================
    '推断结算日：保证其是库中能够确切取到的最大结期
    指定结期上限 = STBASE取据引擎查时戳由外库(指定结期上限:=指定结期上限)
    '------------------------------------------------------------------------------------
    Dim 组结算 As Variant
    Dim 计数导入 As Integer
    计数导入 = STBASE结算引擎_全新结算数程由外库(组结算, WS花册, 指定结期上限:=指定结期上限, 指定结期下限:=指定结期下限)
    '====================================================================================
    '输出数据
    '====================================================================================
    '设置停牌
    Dim MSG停牌 As String
    MSG停牌 = STCALL花册管理_重制花天P9子程重置信息8停牌(组结算, 法道基列:=1, 指定花册:=指定花册, 指定头码:=指定头码)
    Call UTL数据转换_集ARR2WS(组结算, WS花册, 始行:=2, 始列:=花列甲道)
    Erase 组结算
    '====================================================================================
    '格式化
    '====================================================================================
    Call STCALL花册工具_花册格程(WS花册, 基色底:=基色底)
    Set WS花册 = Nothing
'========================================================================================
'清理
'========================================================================================
    MSG = MSG & vbCrLf & "【任务】导入花册"
    MSG = MSG & vbCrLf & "【花册】" & 指定花册
    MSG = MSG & vbCrLf & "【文夹】" & 指定文夹
    MSG = MSG & vbCrLf & "【计数导入】" & 计数导入
    MSG = MSG & vbCrLf & "【计数停牌】" & MSG停牌
    MSG = MSG & vbCrLf & "【全新结算耗时】" & CInt(Timer - TTT) & vbCrLf
'========================================================================================
'返回
'========================================================================================
    ThisWorkbook.Save
    UTL宏工具_END
    '------------------------------------------------------------------------------------
    STBASE结算引擎_全新结算正程 = MSG
End Function
Function STBASE结算引擎_全新结算数程由外库( _
          ByRef 组结算 As Variant _
        , ByRef WS花册 As Worksheet _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        ) As Integer
'========================================================================================
'读取类源信息
'========================================================================================
    '------------------------------------------------------------------------------------
    '获取信组
    '------------------------------------------------------------------------------------
    Dim 组花册 As Variant
    Call UTL数据转换_集WS2ARR(组花册, WS花册, 总列:=花宽主道)
'========================================================================================
'变量声明
'========================================================================================
    '数组：到点结算
    ReDim 组结算(LBound(组花册, 1) To UBound(组花册, 1), 1 To 花宽单道 * 3) As Variant
    '数组：单点结算
    Dim ARRCSVD As Variant
    Dim ARROSD(1 To 花宽单道) As Variant
    Dim ARROSW(1 To 花宽单道) As Variant
    Dim ARROSM(1 To 花宽单道) As Variant
    '====================================
    Dim CIDL As String
    Dim 计期已结算本码 As Integer
    Dim 计数已结算到位  As Integer
    Dim 计数未结算到位  As Integer
    Dim 结日更新 As Date
    Dim 结日记录 As Date
    Dim i As Integer
    Dim 导入代称 As String
'========================================================================================
'循环导入
'========================================================================================
    Dim 遍历序号 As Integer
    For 遍历序号 = LBound(组花册, 1) To UBound(组花册, 1)
        '-----------------------------------------------------------------------------
        CIDL = 组花册(遍历序号, 位列花天CIDL)
        导入代称 = 组花册(遍历序号, 位列花天代称)
        '================================================================================
        '进行结算
        '================================================================================
        If UBCID是代码(CIDL) Then
            '============================================================================
            ARROSD(位os代码) = CIDL
            ARROSD(位os期类) = 常期类为日
            ARROSW(位os代码) = CIDL
            ARROSW(位os期类) = 常期类为周
            ARROSM(位os代码) = CIDL
            ARROSM(位os期类) = 常期类为月
            '----------------------------------------------------------------------------
            计数日类 = STBASE取据引擎_工具取据由外库(ARRCSVD, CIDL, 指定结期上限:=指定结期上限, 指定结期下限:=指定结期下限)
            If 计数日类 > 0 Then
                计期已结算本码 = STBASE结算引擎_区间基码数程(ARRCSVD, ARROSD, ARROSW, ARROSM, 指定结期上限:=指定结期上限, 指定结期下限:=指定结期下限)
            End If
            '----------------------------------------------------------------------------
            For i = 1 To 花宽单道
                组结算(遍历序号, i) = ARROSD(i)
                组结算(遍历序号, 花宽单道 * 1 + i) = ARROSW(i)
                组结算(遍历序号, 花宽单道 * 2 + i) = ARROSM(i)
            Next i
            Erase ARROSD
            Erase ARROSW
            Erase ARROSM
            '============================================================================
            结日记录 = 组结算(遍历序号, 位os基市期)
            结日更新 = 组结算(遍历序号, 位os结期)
            If 结日更新 = 指定结期上限 Then
                计数已结算到位 = 计数已结算到位 + 1
            Else
                计数未结算到位 = (遍历序号 - LBound(组结算, 1) + 1) - 计数已结算到位
            End If
            Debug.Print "结算管理_全新结算由外库>>" & UBound(组花册, 1) & "/" & 遍历序号 & " 已到位:" & 计数已结算到位 & " 未到位:" & 计数未结算到位 & ">>" _
                & "[" & Format(结日记录, "yyyy/mm/dd") & "--" & Format(结日更新, "yyyy/mm/dd") & "]= " & Format(计期已结算本码, "@@@@") _
                & "  " & CIDL & "  " & 导入代称
            '----------------------------------------------------------------------------
            'If 遍历序号 > 20 Then Exit For
            '============================================================================
        End If
        '================================================================================
    Next 遍历序号
'========================================================================================
'返回
'========================================================================================
    Erase 组花册
    STBASE结算引擎_全新结算数程由外库 = 计数已结算到位
End Function
'########################################################################################
'########################################################################################
'#################################   结算管理  全新结算    ##############################
'########################################################################################
'########################################################################################




