'#################################   结算管理  全新结算    ##############################
'########################################################################################
'########################################################################################
'========================================================================================
'统一进行导入结算
'========================================================================================
Sub STBASE结算管理_全新结算调程花天()
    TTT = Timer
    '------------------------------------------------------------------------------------
    '------------------------------------------------------------------------------------
    Dim 指定花册 As String
    指定花册 = 常花中股
    Dim 指定文夹 As String
    指定文夹 = 全设基夹中股
    Dim 指定头码 As String
    指定头码 = 常查询代码中股
    Dim 基色底 As Long
    基色底 = 常色主靛
    '------------------------------------------------------------------------------------
    Dim 指定结期上限 As Date
    指定结期上限 = Date   '"2022/8/17" '
    Dim 指定结期下限 As Date
    '注20240215：为测试节约时间，在非交易日缩短结算时间
    If 时程结期判断IS类日(Date) = True Then
        指定结期下限 = 常结期下限市场
    Else
        指定结期下限 = "2010/1/1"
    End If
    指定结期下限 = 常结期下限市场
    '------------------------------------------------------------------------------------
    '------------------------------------------------------------------------------------
    Dim MSG As String
    MSG = MSG & "【调始时刻】" & Format(Time, "Long Time") & vbCrLf
    '------------------------------------------------------------------------------------
    '结算区域：罗盘
    '------------------------------------------------------------------------------------
    MSG = MSG & STBASE结算引擎_全新结算正程(指定花册, 指定文夹, 基色底:=基色底, 指定结期下限:=指定结期下限, 指定结期上限:=指定结期上限, 指定头码:=指定头码)
    '结算区域：主道基本信息
    MSG = MSG & vbCrLf
    MSG = MSG & STCALL花册管理_重制花天P9正程设置信息(是否更新市板:=True, 是否更新在池:=True, 是否更新停牌:=True, 是否更新代称:=True)
    '------------------------------------------------------------------------------------
    '结算区域：藏库
    '------------------------------------------------------------------------------------
    MSG = MSG & vbCrLf
    MSG = MSG & STBASE藏库引擎_更新主程(指定期类:=常期类为日, 是否新建藏库:=True, 是否更新全量:=True, 是否更新源AK:=True)
    '------------------------------------------------------------------------------------
    '结算区域：历统时
    '------------------------------------------------------------------------------------
    MSG = MSG & vbCrLf
    MSG = MSG & STBASE结算引擎_历统时正程(指定花册, 指定结期上限:=指定结期上限)
    '------------------------------------------------------------------------------------
    '------------------------------------------------------------------------------------
    MSG = MSG & vbCrLf
    MSG = MSG & "【调终时刻】" & Format(Time, "Long Time") & vbCrLf
    MSG = MSG & "【总计耗时】" & CLng(Timer - TTT) & vbCrLf
    Debug.Print MSG
    ThisWorkbook.Activate
    MsgBox MSG, vbOKOnly, "结算中枢 全新结算"
    '------------------------------------------------------------------------------------
End Sub




