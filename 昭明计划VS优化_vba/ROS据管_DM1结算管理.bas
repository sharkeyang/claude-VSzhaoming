Sub STBASE结算管理_全新结算调程花中期()
    UTL宏工具_BEGIN
'========================================================================================
'花册：建立（外部花册）
'========================================================================================
    Dim WS花册 As Worksheet
    If STBASE外簿工具_花册链接(WS花册, 常花中期) = False Then
        UTL宏工具_END
        Exit Sub
    End If
    Dim 花册簿 As Workbook
    Set 花册簿 = WS花册.Parent
    Call PBASE格程工具_表操工表新增(WS花册, 常花中期, wb:=花册簿, 基色底:=常色四紫)
'========================================================================================
'TS：导入文件
'========================================================================================
    Dim FILEOPEN
'    FILEOPEN = Application.GetOpenFilename("csv文件,*.csv", , "请选择由python下载的文件", , False)
'    If FILEOPEN = False Then
'        UTL宏工具_END
'        Exit Sub
'    End If
    '------------------------------------------------------------------------------------
    '设置原始列号
    '------------------------------------------------------------------------------------
    Dim 位列TS代码 As Integer
    Dim 位列TS代称 As Integer
    Dim 位列TS交所 As Integer
    '------------------------------------------------------------------------------------
    '导入数组
    '------------------------------------------------------------------------------------
    FILEOPEN = 全设基夹根 & "\BaseAS中期.csv"
    Dim WBTS As Workbook
    Set WBTS = GetObject(FILEOPEN)
    Dim ARRTS  As Variant
    With WBTS.ActiveSheet
        ARRTS = .Range("A1").CurrentRegion
        位列TS代码 = .Rows(1).Find(What:="symbol").Column
        位列TS代称 = .Rows(1).Find(What:="name").Column
        位列TS交所 = .Rows(1).Find(What:="exchange").Column
    End With
    WBTS.Close False
    Set WBTS = Nothing
'========================================================================================
'花册：导入股票列表
'========================================================================================
    Dim sdate As String
    Dim 市日 As Date
    Dim CIDV As Variant
    Dim CIDL As String
    '====================================================================================
    '合并 TSstock
    '====================================================================================
    Dim 计数导入 As Integer
    Dim 主列行号 As Integer
    Dim 遍历序号 As Integer
    
    计数导入 = 0
    For 遍历序号 = LBound(ARRTS, 1) + 1 To UBound(ARRTS, 1)
        '--------------------------------------------------------------------------------
        计数导入 = 计数导入 + 1
        主列行号 = 计数导入 + 1
        '--------------------------------------------------------------------------------
        '处理代码
        '--------------------------------------------------------------------------------
        CIDV = ARRTS(遍历序号, 位列TS代码)
        CIDL = "fx" & CIDV
        WS花册.Cells(主列行号, 位列花天CIDS) = CIDV
        WS花册.Cells(主列行号, 位列花天CIDL) = CIDL
        '--------------------------------------------------------------------------------
        WS花册.Cells(主列行号, 位列花天代称) = ARRTS(遍历序号, 位列TS代称)
        WS花册.Cells(主列行号, 位列花天交易所码) = ARRTS(遍历序号, 位列TS交所)
        '--------------------------------------------------------------------------------
        Debug.Print "花册单票列表导入>>>"; 遍历序号
        '--------------------------------------------------------------------------------
    Next
    Erase ARRTS
'========================================================================================
'花册：格式化
'========================================================================================
    Call STCALL花册工具_花册格程(WS花册)
'========================================================================================
'清理
'========================================================================================
    STBASE外簿工具_花册关闭 花册簿, 常花中期, 是否保存修改:=True
    Set WS花册 = Nothing
    '------------------------------------------------------------------------------------
    UTL宏工具_END
'========================================================================================
''    MsgBox "导入" _
''            & vbCrLf & "计数单票 >>" & 计数导入 _
''            , vbOKOnly _
''            , "导入花册"
''========================================================================================
    '------------------------------------------------------------------------------------
    Dim 指定花册 As String
    指定花册 = 常花中期
    Dim 指定文夹 As String
    指定文夹 = 全设基夹中期
    Dim 指定头码 As String
    指定头码 = "fxIH0"
    Dim 指定结期上限 As Date
    指定结期上限 = Date
    Dim 基色底 As Long
    基色底 = 常色六青
    '------------------------------------------------------------------------------------
    Dim MSG As String
    MSG = STBASE结算引擎_全新结算正程(指定花册, 指定文夹, 基色底:=基色底, 指定结期上限:=指定结期上限, 指定头码:=指定头码)
    Dim WS花册尾 As Worksheet
    If STBASE外簿工具_花册链接(WS花册尾, 指定花册) Then
        WS花册尾.Columns("C:Z").Hidden = True
        WS花册尾.Columns(位列花天CIDL).ColumnWidth = 8
        WS花册尾.Columns(位列花天交易所码).ColumnWidth = 5
        WS花册尾.Columns(位列花天CIDS).ColumnWidth = 4
    End If
    STBASE外簿工具_花册保存 指定花册
    '------------------------------------------------------------------------------------
    Debug.Print MSG
    'MsgBox MSG, vbOKOnly, "结算中枢 全新结算"
End Sub
