'========================================================================================
'========================================================================================
'功能：区块操作
'========================================================================================
'========================================================================================
Sub IQQQ展擎频谱工具展开()
    '------------------------------------------------------------------------------------
    Dim 全页头部列数 As Integer
    全页头部列数 = ActiveSheet.Cells(常频头行再类之名, 1)
    '------------------------------------------------------------------------------------
    Dim i As Integer
    For Each Column In Selection.Columns
        本列 = Column.Column
        If (本列 - 全页头部列数) Mod 常频块目列宽数 = 1 Then
            '非空则展开所有列
            If ActiveSheet.Cells(常频头行再类之数, 本列) > 0 Then
                ActiveSheet.Cells(常频头行总数, 本列).Resize(1, 常频块目列宽数).EntireColumn.Hidden = False
            '空则只展开第一列
            Else
                ActiveSheet.Columns(本列).Hidden = False
            End If
        End If
    Next
    '------------------------------------------------------------------------------------
End Sub
Sub IQQQ展擎频谱工具折叠()
    '------------------------------------------------------------------------------------
    Dim 全页头部列数 As Integer
    全页头部列数 = ActiveSheet.Cells(常频头行再类之名, 1)
    '------------------------------------------------------------------------------------
    Dim i As Integer
    For Each Column In Selection.Columns
        本列 = Column.Column
        If (本列 - 全页头部列数) Mod 常频块目列宽数 = 1 Then
            ActiveSheet.Cells(常频头行总数, 本列).Resize(1, 常频块目列宽数).EntireColumn.Hidden = True
            ActiveSheet.Columns(本列).Hidden = False
        End If
    Next
    '------------------------------------------------------------------------------------
End Sub
'========================================================================================
'========================================================================================
'功能：本页着色
'能够代表活跃的指标：一是当天涨幅代表当天的活跃程度；一是势局，特别是日类，代表一段时间的活跃程度。
'========================================================================================
'========================================================================================
Sub IQQQ展擎频谱工具着色按日基势局()
    '------------------------------------------------------------------------------------
    Dim WSAS As Worksheet
    Set WSAS = ActiveSheet
    If Not WSAS.Name Like 常簿缀频谱 & "*" & 常簿缀频谱 Then
        Exit Sub
    End If
    '------------------------------------------------------------------------------------
    Dim 全页头部列数 As Integer
    全页头部列数 = WSAS.Cells(常频头行再类之名, 1)
    Dim 总列数本页 As Integer
    总列数本页 = PBASE格程工具_表参末列指定(WSAS, 常频头行再类之名)
    Dim 节色彩 As Long
    Dim 值仓日类 As String
    Dim 值日类涨幅 As Double
    '------------------------------------------------------------------------------------
    Dim 遍历行号 As Integer
    Dim 本列 As Integer
    For 本列 = 全页头部列数 + 1 To 总列数本页
        If (本列 - 全页头部列数) Mod 常频块目列宽数 = 1 Then
        For 遍历行号 = 常频头行总数 + 1 To PBASE格程工具_表参末行指定(WSAS, 本列)
            With WSAS.Cells(遍历行号, 本列)
                值仓日类 = .Cells(1, 常频块目列定色变量)
                节色彩 = STBASE结算工具_衍生色度按仓日类(值仓日类)
                .Resize(1, 常频块目列宽数).Interior.Color = 节色彩
            End With
            '---------------------------------------------
            'Debug.Print 本列; 遍历行号
            '---------------------------------------------
        Next
        End If
    Next
    '------------------------------------------------------------------------------------
End Sub
Sub IQQQ展擎频谱工具着色按日类涨幅()
    '------------------------------------------------------------------------------------
    Dim WSAS As Worksheet
    Set WSAS = ActiveSheet
    If Not WSAS.Name Like 常簿缀频谱 & "*" & 常簿缀频谱 Then
        Exit Sub
    End If
    '------------------------------------------------------------------------------------
    Dim 全页头部列数 As Integer
