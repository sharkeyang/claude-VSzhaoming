    计数导入 = XL算展数程单期(ARRLA, 被研代码, 被研期类)
    
    If 计数导入 < 1 Then Exit Function
    '====================================================================================
    '算法灌入：挑版
    '====================================================================================
    Call XL算灌引擎单期(ARRLA, 规则算法:=被研算法挑版)
    '====================================================================================
    '算法灌入：冠版
    '====================================================================================
    Dim ARRLB As Variant
    ARRLB = ARRLA
    Call XL算灌引擎单期(ARRLB, 规则算法:=被研算法冠版)
    '====================================================================================
    '数程合并
    '====================================================================================
    Dim ARRLL As Variant
    ARRLL = ARRLA
    Call STBASE罗盘数程_OS按日墨汁数程基程(ARRLL, ARRLB)
'========================================================================================
'明细输出：整合输出
'========================================================================================
    '====================================================================================
    '建表
    '====================================================================================
    Dim WS As Worksheet
    Call PBASE格程工具_表操工表新增(WS, 被研表名, wb:=wb, 基色底:=基色底)
    '====================================================================================
    '输出算法明细
    '====================================================================================
    Call UTL数据转换_集ARR2WS(ARRLL, WS, 2, 基列)
    Erase ARRLL
    '====================================================================================
    '格式化：基础
    '====================================================================================
    Call PBASE格程工具_表冻结锁定(WS, 1)
    '------------------------------------------------------------------------------------
    Dim 列定位 As Integer
    列定位 = 基列
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0)
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0.6)
    
    WS.Cells(1, 基列).Resize(1, 花宽单道 * 3).EntireColumn.Hidden = True
'========================================================================================
'重组
'========================================================================================
    Dim 重输始列数组 As Variant
    Dim 重输指标数组 As Variant
    '------------------------------------------------------------------------------------
    '重组：索引
    '------------------------------------------------------------------------------------
    重输始列数组 = Array(基列)
    重输指标数组 = Array( _
            Array(位os基累龄, 6), Array(位os结期, 9) _
        )
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
    '------------------------------------------------------------------------------------
    '重组：持仓对比
    '------------------------------------------------------------------------------------
    重输始列数组 = Array(基列, 基列 + 花宽单道)
    重输指标数组 = Array( _
            Array(位os算法名, 12) _
        , , Array(位os算累持, 4), Array(位os算累赚, 7), Array(位os算今赚, 6), Array(位os算今手, 5), Array(位os算今仓, 4) _
        )
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
'========================================================================================
'统计分析
'========================================================================================
    Dim 列统算展 As Integer
    列统算展 = PBASE格程工具_表参末列指定(WSTO, 1)
    列统算展 = IIf(列统算展 = 1, 1, 列统算展 + 1)
    '====================================================================================
    '算法分析：算法对比
    '====================================================================================
    列统算展 = XL算展统算展基程(ARRLA, 花偏甲道, WSTO, 1, 列统算展, WSIN:=WS)
    列统算展 = XL算展统算展基程(ARRLB, 花偏甲道, WSTO, 1, 列统算展, WSIN:=WS)
'========================================================================================
'返回
'========================================================================================
    Set WS = Nothing
    Erase ARRLA
    Erase ARRLB
'========================================================================================
End Function



    
    
'将返回值设置为优胜者 的名称
'========================================================================================
'========================================================================================
'算法对比：单期算法
'========================================================================================
'========================================================================================
Function XL算比质程乾期精比( _
          被研代码 As String _
        , 被研期类 As String _
        , 被研算法挑版 As String _
        , 被研算法冠版 As String _
        , WSTO As Worksheet _
        , Optional 被研表名 As String _
        , Optional wb As Workbook _
        , Optional 基色底 As Long = 常色研究 _
        ) As Integer
'----------------------------------------------------------------------------------------
    Dim 基列 As Integer
    基列 = 1
'========================================================================================
'数据准备
'========================================================================================
    '====================================================================================
    '数据导入
    '====================================================================================
    Dim ARRLLLX As Variant
    Dim 计数导入 As Integer
    计数导入 = XL算展数程跨期(ARRLLLX, 被研代码)
    If 计数导入 < 1 Then Exit Function
    '====================================================================================
    '算法灌入：挑版
    '====================================================================================
    Call XL算灌引擎跨期(ARRLLLX, 规则算法:=被研算法挑版)
    '====================================================================================
    '算法灌入：冠版
    '====================================================================================
    Dim ARRLLLY As Variant
    ARRLLLY = ARRLLLX
    Call XL算灌引擎跨期(ARRLLLY, 规则算法:=被研算法冠版)
    '====================================================================================
    '数程合并
    '====================================================================================
    Dim ARRLLLLLL As Variant
    ARRLLLLLL = ARRLLLX
    Call STBASE罗盘数程_OS按日墨汁数程基程(ARRLLLLLL, ARRLLLY)
'========================================================================================
'明细输出：整合输出
'========================================================================================
    '====================================================================================
    '建表
    '====================================================================================
    Dim WS As Worksheet
    Call PBASE格程工具_表操工表新增(WS, 被研表名, wb:=wb, 基色底:=基色底)
    '====================================================================================
    '输出算法明细
    '====================================================================================
    Call UTL数据转换_集ARR2WS(ARRLLLLLL, WS, 2, 基列)
    Erase ARRLLLLLL
    '====================================================================================
    '格式化：基础
    '====================================================================================
    Call PBASE格程工具_表冻结锁定(WS, 1)
    '------------------------------------------------------------------------------------
    Dim 列定位 As Integer
    列定位 = 基列
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0.6)
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0.5)
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0)
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0.6)
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0.5)
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0)
    
    WS.Cells(1, 基列).Resize(1, 花宽单道 * 6).EntireColumn.Hidden = True
    '====================================================================================
    Dim 基列一期 As Integer
    Dim 基列二期 As Integer
    Dim 基列三期 As Integer
    基列一期 = 基列
    基列二期 = 基列 + 花宽单道 * 1
    基列三期 = 基列 + 花宽单道 * 2
    Dim 基列四期 As Integer
    Dim 基列五期 As Integer
    Dim 基列六期 As Integer
    基列四期 = 基列 + 花宽单道 * 3
    基列五期 = 基列 + 花宽单道 * 4
    基列六期 = 基列 + 花宽单道 * 5
'========================================================================================
'格式化：重组
'========================================================================================
    Dim 重输始列数组 As Variant
    Dim 重输指标数组 As Variant
    '------------------------------------------------------------------------------------
    '重组：基本信息
    '------------------------------------------------------------------------------------
    重输指标数组 = Array( _
            Array(位os基累龄, 6), Array(位os结期, 10) _
        )
    重输始列数组 = Array(基列)
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
    '------------------------------------------------------------
    重输指标数组 = Array( _
            Array(位os结收, 6) _
        , , Array(位os结幅PR0, 6) _
        )
    重输始列数组 = Array( _
          基列三期 _
        , 基列二期 _
        , 基列一期 _
        )
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
    '------------------------------------------------------------------------------------
    '重组：持仓对比
    '------------------------------------------------------------------------------------
    重输指标数组 = Array( _
            Array(位os算法名, 10) _
        )
    重输始列数组 = Array( _
          基列三期 _
        , 基列六期 _
        )
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
    '------------------------------------------------------------
    重输始列数组 = Array( _
          基列三期, 基列六期 _
        , 基列二期, 基列五期 _
        , 基列一期, 基列四期 _
        )
    重输指标数组 = Array( _
        Array(位os算累持, 4), Array(位os算累赚, 7), Array(位os算今赚, 6), Array(位os算今手, 5), Array(位os算今仓, 4) _
        )
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
    '------------------------------------------------------------------------------------
    '重组：BT
    '------------------------------------------------------------------------------------
    重输指标数组 = Array( _
              Array(位osBTZA, 3), Array(位osBTZB, 3), Array(位osBTZC, 3), Array(位osBTAB, 3), Array(位osBTAC, 3), Array(位osBTBC, 3), Array(位osBTAG, 4), Array(位osBTAD, 4), Array(位osBTCG, 4) _
              )
    重输始列数组 = Array(基列三期)
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    重输始列数组 = Array(基列二期)
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    重输始列数组 = Array(基列一期)
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
    '------------------------------------------------------------------------------------
    '重组：基本信息
    '------------------------------------------------------------------------------------
    重输指标数组 = Array( _
            Array(位os结幅PR0, 6) _
        , , Array(位os结收, 6) _
        , , Array(位os期类, 2), Array(位os基累龄, 6), Array(位os结期, 10) _
        )
    重输始列数组 = Array( _
          基列三期 _
        , 基列二期 _
        , 基列一期 _
        )
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
'========================================================================================
'统计分析
'========================================================================================
    Dim 列统算展 As Integer
    列统算展 = PBASE格程工具_表参末列指定(WSTO, 1)
    列统算展 = IIf(列统算展 = 1, 1, 列统算展 + 1)
    '====================================================================================
    '算法分析：算法对比
    '====================================================================================
    Dim 被研法偏 As Integer
    If 被研期类 = 常期类为周 Then
        被研法偏 = 花偏乙道
    ElseIf 被研期类 = 常期类为日 Then
        被研法偏 = 花偏甲道
    End If
    
    列统算展 = XL算展统算展基程(ARRLLLX, 被研法偏, WSTO, 1, 列统算展, WSIN:=WS)
    列统算展 = XL算展统算展基程(ARRLLLY, 被研法偏, WSTO, 1, 列统算展, WSIN:=WS)
'    '====================================================================================
'    '算法分析：算法对比
'    '====================================================================================
'    列统算展 = XL算展统算展基程(ARRLLLX, 花偏丙道, WSTO, 1, 列统算展, WSIN:=WS)
'    列统算展 = XL算展统算展基程(ARRLLLY, 花偏丙道, WSTO, 1, 列统算展, WSIN:=WS)
'    列统算展 = XL算展统算展基程(ARRLLLX, 花偏乙道, WSTO, 1, 列统算展, WSIN:=WS)
'    列统算展 = XL算展统算展基程(ARRLLLY, 花偏乙道, WSTO, 1, 列统算展, WSIN:=WS)
'    列统算展 = XL算展统算展基程(ARRLLLX, 花偏甲道, WSTO, 1, 列统算展, WSIN:=WS)
'    列统算展 = XL算展统算展基程(ARRLLLY, 花偏甲道, WSTO, 1, 列统算展, WSIN:=WS)
'========================================================================================
'返回
'========================================================================================
    Set WS = Nothing
    Erase ARRLLLX
    Erase ARRLLLY
'========================================================================================
End Function
