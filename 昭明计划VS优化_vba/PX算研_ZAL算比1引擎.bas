'数据准备
'========================================================================================
    '====================================================================================
    '数据导入
    '====================================================================================
    Dim ARRLA As Variant
    Dim 计数导入 As Integer
    计数导入 = XL算展数程单期(ARRLA, 被研代码, 被研期类)
    If 计数导入 < 1 Then Exit Function
    '====================================================================================
