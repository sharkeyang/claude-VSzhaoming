        Call PBASE格程工具_表操工表新增(工表统算比, 常表名统算比, 基色底:=基色底)
        工表统算比.Cells.Interior.ColorIndex = 1
    Else
        Set 工表统算比 = ThisWorkbook.Sheets(常表名统算比)
    End If
'========================================================================================
'格式化
'========================================================================================
    Dim 当行 As Integer
    '------------------------------------------------------------------------------------
    '合并行标题
    '------------------------------------------------------------------------------------
    当行 = 1
    With 工表统算比.Cells(当行, 1).Resize(1, 位统算比全部列数)
        .VerticalAlignment = xlTop
        .HorizontalAlignment = xlCenter
        .Interior.Color = 基色底
