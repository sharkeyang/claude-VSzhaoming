Attribute VB_Name = "PX算研_ZAL算比1引擎"
Option Explicit
Public Const 常算比类型为粗比 = "M"
Public Const 常表名统算比 = "统算比"
Public Const 常表名统算展 = "统算展"
'========================================================================================
Public Const 位统算比基础列始 = 1
Public Const 位统算比基础列数 = 3
Public Const 位统算比次门列始 = 位统算比基础列始 + 位统算比基础列数
Public Const 位统算比次门列数 = 8
Public Const 位统算比持门列始 = 位统算比基础列始 + 位统算比基础列数 + 位统算比次门列数
Public Const 位统算比持门列数 = 8
Public Const 位统算比龄门列始 = 位统算比基础列始 + 位统算比基础列数 + 位统算比次门列数 + 位统算比持门列数
Public Const 位统算比龄门列数 = 10
Public Const 位统算比全部列数 = 位统算比基础列始 + 位统算比基础列数 + 位统算比次门列数 + 位统算比持门列数 + 位统算比龄门列数
'========================================================================================

'模块级共享变量
Dim TT As Double
Dim MSG As String
Public Const 位统算比基础代码 = 位统算比基础列始 + 0
Public Const 位统算比基础代称 = 位统算比基础列始 + 1
Public Const 位统算比基础期类 = 位统算比基础列始 + 2
'-------------------------------------------
Public Const 位统算比次门算法名称 = 位统算比次门列始 + 0
Public Const 位统算比次门累赚均次最大 = 位统算比次门列始 + 1
Public Const 位统算比次门累赚合计最大 = 位统算比次门列始 + 2
Public Const 位统算比次门累涨合计最大 = 位统算比次门列始 + 3
Public Const 位统算比次门总持 = 位统算比次门列始 + 4
Public Const 位统算比次门总次 = 位统算比次门列始 + 5
Public Const 位统算比次门算法胜率 = 位统算比次门列始 + 6
Public Const 位统算比次门次年比率 = 位统算比次门列始 + 7
'-------------------------------------------
Public Const 位统算比持门算法名称 = 位统算比持门列始 + 0
Public Const 位统算比持门累赚均持最大 = 位统算比持门列始 + 1
Public Const 位统算比持门累赚合计最大 = 位统算比持门列始 + 2
Public Const 位统算比持门累涨合计最大 = 位统算比持门列始 + 3
Public Const 位统算比持门总持 = 位统算比持门列始 + 4
Public Const 位统算比持门总次 = 位统算比持门列始 + 5
Public Const 位统算比持门算法胜率 = 位统算比持门列始 + 6
Public Const 位统算比持门持年比率 = 位统算比持门列始 + 7
'-------------------------------------------
Public Const 位统算比龄门算法名称 = 位统算比龄门列始 + 0
Public Const 位统算比龄门累赚均年最大 = 位统算比龄门列始 + 1
Public Const 位统算比总年 = 位统算比龄门列始 + 2
Public Const 位统算比龄门累赚均龄最大 = 位统算比龄门列始 + 3
Public Const 位统算比总龄 = 位统算比龄门列始 + 4
Public Const 位统算比龄门累赚合计最大 = 位统算比龄门列始 + 5
Public Const 位统算比龄门累涨合计最大 = 位统算比龄门列始 + 6
Public Const 位统算比龄门总持 = 位统算比龄门列始 + 7
Public Const 位统算比龄门总次 = 位统算比龄门列始 + 8
Public Const 位统算比龄门算法胜率 = 位统算比龄门列始 + 9
'========================================================================================






Function XL算比引擎正程测试()
'========================================================================================
'参数设置
'========================================================================================
    Dim 被研代码 As String
    Dim 被研期类 As String
    Dim 组被研算法 As Variant
    '------------------------------------------------------------------------------------
    被研代码 = "sh600150"
    '------------------------------------------------------------------------------------
    被研期类 = 常期类为月
    '------------------------------------------------------------------------------------
    组被研算法 = Array(常算比类型为粗比, _
         "s@均<ZB>" _
        , "T@均<JB>", "T@均<JB>2" _
        , "s@阶鑫<IA>", "s@阶鑫<IAB>", "s@阶鑫<IABC>" _
        )
    组被研算法 = Array(常算比类型为粗比, _
        "s@均<ZB>" _
        , "s@阶鑫<IA>", "s@阶鑫<IAB>", "s@阶鑫<IABC>" _
        )
'========================================================================================
    Call XL算比引擎正程( _
          被研代码:=被研代码 _
        , 被研期类:=被研期类 _
        , 组被研算法:=组被研算法 _
        , 是否外簿:=False _
        , 是否明细:=True _
        )
'========================================================================================
End Function






'########################################################################################
'########################################################################################
'##################################   算比引擎正程   #####################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'正程：对单一代码进行分析
'========================================================================================
'========================================================================================
Function XL算比引擎正程( _
          被研代码 As String _
        , 被研期类 As String _
        , 组被研算法 As Variant _
        , Optional 是否外簿 As Boolean = False _
        , Optional 是否明细 As Boolean = False _
        , Optional 基色底 As Long = 常色研究 _
        ) As Integer
'----------------------------------------------------------------------------------------
    TT = Timer
'========================================================================================
'准备工作簿
'========================================================================================
    Dim wb As Workbook
    If 是否外簿 = False Then
        Set wb = ThisWorkbook
    Else
        Set wb = Workbooks.Add
    End If
'========================================================================================
'统计分析：统算比 统算展
'========================================================================================
    '------------------------------------------------------------------------------------
    '统算比：指定工表
    '------------------------------------------------------------------------------------
    Dim 工表统算比  As Worksheet
    If UTL判断工表存在(常表名统算比) = False Then
        Call PBASE格程工具_表操工表新增(工表统算比, 常表名统算比, 基色底:=基色底)
        工表统算比.Cells.Interior.ColorIndex = 1
    Else
        Set 工表统算比 = ThisWorkbook.Sheets(常表名统算比)
    End If
    
    '格式化
    Call XL算比引擎格程统算比
    '------------------------------------------------------------------------------------
    '统算展：指定工表
    '------------------------------------------------------------------------------------
    Dim 工表统算展  As Worksheet
    If UTL判断工表存在(常表名统算展) = False Then
        Call PBASE格程工具_表操工表新增(工表统算展, 常表名统算展, 基色底:=常色研究)
        工表统算展.Cells.Interior.ColorIndex = 1
    Else
        Set 工表统算展 = ThisWorkbook.Sheets(常表名统算展)
    End If
    
    '统算展：设置隔离边框
    Dim 统算展行始 As Integer
    统算展行始 = PBASE格程工具_表参末行指定(工表统算展, 1) + 1
'========================================================================================
'统算：算法比较
'========================================================================================
    '------------------------------------------------------------------------------------
    '设置工作簿：算法汇总
    '------------------------------------------------------------------------------------
    Dim 表名统算 As String
    表名统算 = 常表名统算比 & "." & 被研期类 & "." & 被研代码
    
    Dim WSTO As Worksheet
    Call PBASE格程工具_表操工表新增(WSTO, 表名统算, wb:=wb, 基色底:=基色底)
    WSTO.Cells.Interior.ColorIndex = 1
    '------------------------------------------------------------------------------------
    '算法比较
    '------------------------------------------------------------------------------------
    Dim 算比类型 As String
    算比类型 = 组被研算法(0)
    Dim 被研表名 As String
    
    '算比类型为粗比：仅进行展示
    If 算比类型 = 常算比类型为粗比 Then
        '--------------------------------------------------------------------------------
        '算法粗比
        '--------------------------------------------------------------------------------
        Dim 被研算法 As String
        
        Dim i As Integer
        For i = LBound(组被研算法) + 1 To UBound(组被研算法)
            被研算法 = 组被研算法(i)
            被研表名 = ""
            
            '根据算法前缀调用(单期/跨期)
            If XL算灌引擎判断算法类型(被研算法) = 常算法类型为单期 Then
                If 是否明细 = True Then 被研表名 = 常簿缀研究 & "1." & 被研期类 & i
                
                Call XL算比质程单期粗比( _
                      被研代码:=被研代码 _
                    , 被研期类:=被研期类 _
                    , 被研算法:=被研算法 _
                    , WSTO:=WSTO, 被研表名:=被研表名, wb:=wb, 基色底:=基色底 _
                    )
            ElseIf XL算灌引擎判断算法类型(被研算法) = 常算法类型为跨期 Then
                If 是否明细 = True Then 被研表名 = 常簿缀研究 & "3." & 被研期类 & i
                
                Call XL算比质程乾期粗比( _
                      被研代码:=被研代码 _
                    , 被研期类:=被研期类 _
                    , 被研算法:=被研算法 _
                    , WSTO:=WSTO, 被研表名:=被研表名, wb:=wb, 基色底:=基色底 _
                    )
            End If
        Next
        '--------------------------------------------------------------------------------
    Else
        '--------------------------------------------------------------------------------
        '算法精比
        '--------------------------------------------------------------------------------
        Dim 被研算法挑版 As String
        Dim 被研算法冠版 As String
        被研算法挑版 = 组被研算法(1)
        被研算法冠版 = 组被研算法(2)
       
        If XL算灌引擎判断算法类型(被研算法挑版) = 常算法类型为单期 _
        And XL算灌引擎判断算法类型(被研算法冠版) = 常算法类型为单期 _
        Then
            If 是否明细 = True Then
                被研表名 = 常簿缀研究 & "2." & 被研期类 & "." & 被研代码
            Else
                被研表名 = 常簿缀研究 & "2." & 被研期类 & "." & 被研代码
            End If
            Call XL算比质程单期精比( _
                  被研代码:=被研代码 _
                , 被研期类:=被研期类 _
                , 被研算法挑版:=被研算法挑版 _
                , 被研算法冠版:=被研算法冠版 _
                , WSTO:=WSTO, 被研表名:=被研表名, wb:=wb, 基色底:=基色底 _
                )
        ElseIf XL算灌引擎判断算法类型(被研算法挑版) = 常算法类型为跨期 _
        And XL算灌引擎判断算法类型(被研算法冠版) = 常算法类型为跨期 _
        Then
            If 是否明细 = True Then
                被研表名 = 常簿缀研究 & "6." & 被研期类 & "." & 被研代码
            Else
                被研表名 = 常簿缀研究 & "6." & 被研期类 & "." & 被研代码
            End If
            Call XL算比质程乾期精比( _
                  被研代码:=被研代码 _
                , 被研期类:=被研期类 _
                , 被研算法挑版:=被研算法挑版 _
                , 被研算法冠版:=被研算法冠版 _
                , WSTO:=WSTO, 被研表名:=被研表名, wb:=wb, 基色底:=基色底 _
                )
        Else
            Debug.Print "提供同类算法类型用于精比！"
        End If
        '--------------------------------------------------------------------------------
    End If
    '------------------------------------------------------------------------------------
    '清理
    '------------------------------------------------------------------------------------
    WSTO.Columns.AutoFit
    Call PBASE格程工具_表冻结锁定(WSTO, 2)
'========================================================================================
'统计分析汇总
'========================================================================================
    '------------------------------------------------------------------------------------
    '统算展：格式化
    '------------------------------------------------------------------------------------
    Dim 统算展行终 As Integer
    统算展行终 = PBASE格程工具_表参末行指定(工表统算展, 1)
    
    With 工表统算展.Cells(统算展行始, 1).Resize(1, 位统算展列数汇总)
        With .Borders(xlTop)
            .LineStyle = xlContinuous
            .ColorIndex = 56
            .Weight = xlMedium
        End With
    End With
    With 工表统算展.Cells(统算展行终, 1).Resize(1, 位统算展列数汇总)
        With .Borders(xlBottom)
            .LineStyle = xlContinuous
            .ColorIndex = 56
            .Weight = xlMedium
        End With
    End With
    
    Dim 被研代称 As String
    被研代称 = 工表统算展.Cells(统算展行终, 位统算展基础代称)
    '------------------------------------------------------------------------------------
    '统算展：获取最值
    '------------------------------------------------------------------------------------
    Dim 值累赚合计最大 As Long
    Dim 值累赚均次最大 As Long
    Dim 值累赚均持最大 As Long
    值累赚合计最大 = 工表统算展.Cells(统算展行始, 位统算展累赚合计)
    值累赚均次最大 = 工表统算展.Cells(统算展行始, 位统算展累赚均次)
    值累赚均持最大 = 工表统算展.Cells(统算展行始, 位统算展累赚均持)
    Dim k As Integer
    For k = 统算展行始 To 统算展行终
        If 工表统算展.Cells(k, 位统算展累赚合计) > 值累赚合计最大 Then
            值累赚合计最大 = 工表统算展.Cells(k, 位统算展累赚合计)
        End If
        If 工表统算展.Cells(k, 位统算展累赚均次) > 值累赚均次最大 Then
            值累赚均次最大 = 工表统算展.Cells(k, 位统算展累赚均次)
        End If
        If 工表统算展.Cells(k, 位统算展累赚均持) > 值累赚均持最大 Then
            值累赚均持最大 = 工表统算展.Cells(k, 位统算展累赚均持)
        End If
    Next k
    
    Dim 定位行累赚合计最大 As Integer
    Dim 定位行累赚均次最大 As Integer
    Dim 定位行累赚均持最大 As Integer
    Dim 定位行累赚合计最大 As Integer
    Dim 定位行累赚均次最大 As Integer
    Dim 定位行累赚均持最大 As Integer
    For k = 统算展行始 To 统算展行终
        If 工表统算展.Cells(k, 位统算展累赚合计) = 值累赚合计最大 Then
            工表统算展.Cells(k, 位统算展累涨合计).Font.ColorIndex = 3
            工表统算展.Cells(k, 位统算展累赚合计).Font.ColorIndex = 3
            定位行累赚合计最大 = k
        End If
        If 工表统算展.Cells(k, 位统算展累赚均次) = 值累赚均次最大 Then
            工表统算展.Cells(k, 位统算展累赚均次).Font.ColorIndex = 3
            定位行累赚均次最大 = k
        End If
        If 工表统算展.Cells(k, 位统算展累赚均持) = 值累赚均持最大 Then
            工表统算展.Cells(k, 位统算展累赚均持).Font.ColorIndex = 3
            定位行累赚均持最大 = k
        End If
    Next k
    '------------------------------------------------------------------------------------
    '统算比：输出
    '------------------------------------------------------------------------------------
    Dim 统算比目行 As Integer
    统算比目行 = PBASE格程工具_表参末行指定(工表统算比, 1) + 1
    '------------------------------------------------------------------------------------
    工表统算比.Rows(统算比目行).Font.ColorIndex = 44
    
    工表统算比.Cells(统算比目行, 位统算比基础代码) = 工表统算展.Cells(统算展行终, 位统算展基础代码)
    工表统算比.Cells(统算比目行, 位统算比基础代码).Font.ColorIndex = 43
    工表统算比.Cells(统算比目行, 位统算比基础代称) = 工表统算展.Cells(统算展行终, 位统算展基础代称)
    工表统算比.Cells(统算比目行, 位统算比基础代称).Font.ColorIndex = 43
    工表统算比.Cells(统算比目行, 位统算比基础期类) = 工表统算展.Cells(统算展行终, 位统算展基础期类)
    工表统算比.Cells(统算比目行, 位统算比基础期类).Font.ColorIndex = 43
    '------------------------------------------------------------------------------------
    '统算比：记录最值
    '------------------------------------------------------------------------------------
    k = 定位行累赚均次最大
        工表统算比.Cells(统算比目行, 位统算比次门算法名称) = 工表统算展.Cells(k, 位统算展算法名称)
        工表统算比.Cells(统算比目行, 位统算比次门累赚均次最大) = 工表统算展.Cells(k, 位统算展累赚均次)
        工表统算比.Cells(统算比目行, 位统算比次门累赚均次最大).Font.Bold = True
        工表统算比.Cells(统算比目行, 位统算比次门累赚合计最大) = 工表统算展.Cells(k, 位统算展累赚合计)
        工表统算比.Cells(统算比目行, 位统算比次门累涨合计最大) = 工表统算展.Cells(k, 位统算展累涨合计)
        工表统算比.Cells(统算比目行, 位统算比次门累涨合计最大).Font.ColorIndex = 35
        工表统算比.Cells(统算比目行, 位统算比次门总持) = 工表统算展.Cells(k, 位统算展总持)
        工表统算比.Cells(统算比目行, 位统算比次门总持).Font.ColorIndex = 35
        工表统算比.Cells(统算比目行, 位统算比次门总次) = 工表统算展.Cells(k, 位统算展总次)
        工表统算比.Cells(统算比目行, 位统算比次门算法胜率) = 工表统算展.Cells(k, 位统算展算法胜率)
        工表统算比.Cells(统算比目行, 位统算比次门算法胜率).Font.ColorIndex = 37
        工表统算比.Cells(统算比目行, 位统算比次门次年比率) = 工表统算展.Cells(k, 位统算展总次) / 工表统算展.Cells(k, 位统算展龄年)
        工表统算比.Cells(统算比目行, 位统算比次门次年比率).Font.ColorIndex = 15
    
    k = 定位行累赚均持最大
        工表统算比.Cells(统算比目行, 位统算比持门算法名称) = 工表统算展.Cells(k, 位统算展算法名称)
        工表统算比.Cells(统算比目行, 位统算比持门累赚均持最大) = 工表统算展.Cells(k, 位统算展累赚均持)
        工表统算比.Cells(统算比目行, 位统算比持门累赚均持最大).Font.Bold = True
        工表统算比.Cells(统算比目行, 位统算比持门累赚合计最大) = 工表统算展.Cells(k, 位统算展累赚合计)
        工表统算比.Cells(统算比目行, 位统算比持门累涨合计最大) = 工表统算展.Cells(k, 位统算展累涨合计)
        工表统算比.Cells(统算比目行, 位统算比持门累涨合计最大).Font.ColorIndex = 35
        工表统算比.Cells(统算比目行, 位统算比持门总持) = 工表统算展.Cells(k, 位统算展总持)
        工表统算比.Cells(统算比目行, 位统算比持门总次) = 工表统算展.Cells(k, 位统算展总次)
        工表统算比.Cells(统算比目行, 位统算比持门总次).Font.ColorIndex = 37
        工表统算比.Cells(统算比目行, 位统算比持门算法胜率) = 工表统算展.Cells(k, 位统算展算法胜率)
        工表统算比.Cells(统算比目行, 位统算比持门算法胜率).Font.ColorIndex = 37
        工表统算比.Cells(统算比目行, 位统算比持门持年比率) = 工表统算展.Cells(k, 位统算展总持) / 工表统算展.Cells(k, 位统算展龄年)
        工表统算比.Cells(统算比目行, 位统算比持门持年比率).Font.ColorIndex = 15
    
    k = 定位行累赚合计最大
        工表统算比.Cells(统算比目行, 位统算比龄门算法名称) = 工表统算展.Cells(k, 位统算展算法名称)
        工表统算比.Cells(统算比目行, 位统算比龄门累赚均年最大) = CInt(工表统算展.Cells(k, 位统算展累赚合计) / 工表统算展.Cells(统算展行终, 位统算展龄年))
        工表统算比.Cells(统算比目行, 位统算比龄门累赚均年最大).Font.ColorIndex = 43
        工表统算比.Cells(统算比目行, 位统算比龄门累赚均年最大).Font.Bold = True
        工表统算比.Cells(统算比目行, 位统算比总年) = 工表统算展.Cells(统算展行终, 位统算展龄年)
        工表统算比.Cells(统算比目行, 位统算比总年).Font.ColorIndex = 43
        工表统算比.Cells(统算比目行, 位统算比龄门累赚均龄最大) = CInt(工表统算展.Cells(k, 位统算展累赚合计) / 工表统算展.Cells(统算展行终, 位统算展龄日))
        工表统算比.Cells(统算比目行, 位统算比龄门累赚均龄最大).Font.Bold = True
        工表统算比.Cells(统算比目行, 位统算比总龄) = 工表统算展.Cells(统算展行终, 位统算展龄日)
        工表统算比.Cells(统算比目行, 位统算比龄门累赚合计最大) = 工表统算展.Cells(k, 位统算展累赚合计)
        工表统算比.Cells(统算比目行, 位统算比龄门累涨合计最大) = 工表统算展.Cells(k, 位统算展累涨合计)
        工表统算比.Cells(统算比目行, 位统算比龄门累涨合计最大).Font.ColorIndex = 35
        工表统算比.Cells(统算比目行, 位统算比龄门总持) = 工表统算展.Cells(k, 位统算展总持)
        工表统算比.Cells(统算比目行, 位统算比龄门总持).Font.ColorIndex = 35
        工表统算比.Cells(统算比目行, 位统算比龄门总次) = 工表统算展.Cells(k, 位统算展总次)
        工表统算比.Cells(统算比目行, 位统算比龄门总次).Font.ColorIndex = 37
        工表统算比.Cells(统算比目行, 位统算比龄门算法胜率) = 工表统算展.Cells(k, 位统算展算法胜率)
        工表统算比.Cells(统算比目行, 位统算比龄门算法胜率).Font.ColorIndex = 37
    '------------------------------------------------------------------------------------
    工表统算展.Columns.AutoFit
    Call PBASE格程工具_表冻结锁定(工表统算展, 1)
    Set 工表统算展 = Nothing
    '------------------------------------------------------------------------------------
    工表统算比.Activate
    工表统算比.Columns.AutoFit
    Call PBASE格程工具_表冻结锁定(工表统算比, 2)
    Set 工表统算比 = Nothing
'========================================================================================
'保存：外部存档
'========================================================================================
    Dim 工簿简称 As String
    工簿简称 = 表名统算
    工簿简称 = 工簿简称 & "." & 被研代称
    工簿简称 = VBA.Replace(工簿简称, "*", "")
    '------------------------------------------------------------------------------------
    '进行保存
    '------------------------------------------------------------------------------------
    If wb.Name <> ThisWorkbook.Name Then
        MSG = MSG & vbCrLf & PBASE格程工具_表操保存外簿(wb, 工簿简称)
        'WB.Close
    End If
    '------------------------------------------------------------------------------------
    Set wb = Nothing
'========================================================================================
'返回
'========================================================================================
    XL算比引擎正程 = CInt(Timer - TT)
'========================================================================================
End Function





