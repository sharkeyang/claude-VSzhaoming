        '------------------------------------------------------------------------------------
        '输出算法明细
        '------------------------------------------------------------------------------------
        Call XL算展格程单期(ARRLA, WS, 基色底:=基色底)
        '------------------------------------------------------------------------------------
    End If
'========================================================================================
