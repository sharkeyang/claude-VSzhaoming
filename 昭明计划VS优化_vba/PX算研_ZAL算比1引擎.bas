    '------------------------------------------------------------------------------------
    列统算展 = XL算展统算展基程(ARRLA, 花偏甲道, WSTO, 1, 列统算展, WSIN:=WS)
'========================================================================================
'返回
'========================================================================================
    Set WS = Nothing
    Erase ARRLA
End Function


    
