        '------------------------------------------------------------------------------------
        Dim WS As Worksheet
        Call PBASE格程工具_表操工表新增(WS, 被研表名, wb:=wb, 基色底:=基色底)
        '------------------------------------------------------------------------------------
        '输出算法明细
        '------------------------------------------------------------------------------------
        Call XL算展格程跨期(ARRLLLX, WS, 基色底:=基色底)
        '------------------------------------------------------------------------------------
    End If
'========================================================================================
'统计分析
'========================================================================================
    Dim 列统算展 As Integer
    列统算展 = PBASE格程工具_表参末列指定(WSTO, 1)
    列统算展 = IIf(列统算展 = 1, 1, 列统算展 + 1)
    '====================================================================================
    '算法分析：算法对比
    '====================================================================================
    Dim 被研法偏 As Integer
    If 被研期类 = 常期类为周 Then
        被研法偏 = 花偏乙道
    ElseIf 被研期类 = 常期类为日 Then
