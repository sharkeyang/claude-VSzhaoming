Function XL算比质程单期粗比( _
          被研代码 As String _
        , 被研期类 As String _
        , 被研算法 As String _
        , WSTO As Worksheet _
        , Optional 被研表名 As String _
        , Optional wb As Workbook _
        , Optional 基色底 As Long = 常色研究 _
        ) As Integer
