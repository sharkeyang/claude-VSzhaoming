'========================================================================================
'========================================================================================
'功能：统算展中【同代码】【同期类】算法进行精比
'========================================================================================
'========================================================================================
Sub XL算比引擎特程统算展精比()
'========================================================================================
'基础设置
'========================================================================================
    Dim 是否外簿 As Boolean
    是否外簿 = False
    Dim 是否明细 As Boolean
    是否明细 = Not 是否外簿
'========================================================================================
'获取信息
'========================================================================================
    '------------------------------------------------------------------------------------
    '鉴别宿主
    '------------------------------------------------------------------------------------
    With ActiveSheet
        If .Name <> "统算展" Then
            MsgBox "NP"
            Exit Sub
        End If
    End With
    
    Dim WSAS As Worksheet
    Set WSAS = ActiveSheet
    '------------------------------------------------------------------------------------
    '遍历文件获取代码列表
    '------------------------------------------------------------------------------------
    Dim 代码 As String
    Dim 期类 As String
    Dim 算法 As String
    Dim 集选定代码 As New Collection
    Dim 集选定期类 As New Collection
    Dim 集选定算法 As New Collection
    
    On Error Resume Next
    Dim 行号遍历 As Integer
    For 行号遍历 = 2 To PBASE格程工具_表参末行指定(WSAS, 1)
        If Intersect(WSAS.Rows(行号遍历), Selection) Is Nothing Then
        Else
            代码 = WSAS.Cells(行号遍历, 位统算展基础代码).Value
            期类 = WSAS.Cells(行号遍历, 位统算展基础期类).Value
            算法 = WSAS.Cells(行号遍历, 位统算展算法名称).Value
            '针对代码
            If UBCID是代码(代码) = True Then
                集选定代码.Add Item:=代码, Key:=代码
                集选定期类.Add Item:=期类, Key:=期类
                集选定算法.Add Item:=算法, Key:=算法
            End If
        End If
    Next
    On Error GoTo 0
    '------------------------------------------------------------------------------------
    Set WSAS = Nothing
'========================================================================================
'进行分析
'========================================================================================
    If 集选定算法.Count >= 2 _
    Or 集选定代码.Count = 1 _
    Or 集选定期类.Count = 1 _
    Then
        Dim 被研代码 As String
        被研代码 = 集选定代码(1)
        Dim 被研期类 As String
        被研期类 = 集选定期类(1)
        Dim 组被研算法 As Variant
        组被研算法 = Array("二次精选", 集选定算法(1), 集选定算法(2))
    
        Call XL算比引擎正程( _
              被研代码 _
            , 被研期类 _
            , 组被研算法 _
            , 是否外簿:=是否外簿 _
            , 是否明细:=是否明细 _
        )
    End If
'========================================================================================
End Sub
