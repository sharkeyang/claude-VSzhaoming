'========================================================================================
'查询信息
'========================================================================================
    Dim 元素计数 As Integer
    Dim aQUO() As Variant
    ReDim aQUO(COLLAH.Count, 3) As Variant
    '------------------------------------------------------------------------------------
    Dim CIDL As String
    Dim nRESP As Integer
    Dim aRESP As Variant
    '------------------------------------------------------------------------------------
    On Error Resume Next
    For 元素计数 = 1 To COLLAH.Count
        '--------------------------------------------------------------------------------
        '查询信息
        '--------------------------------------------------------------------------------
        CIDL = COLLAH(元素计数)
        nRESP = UBHTTP腾实_查回组(aRESP, CIDL)
        If nRESP > 0 Then
            aQUO(元素计数, 0) = aRESP(位序腾实代码)
            aQUO(元素计数, 1) = aRESP(位序腾实代称)
            aQUO(元素计数, 2) = aRESP(位序腾实今涨)
            aQUO(元素计数, 3) = aRESP(位序腾实今收)
            Erase aRESP
       End If
        '--------------------------------------------------------------------------------
    Next
'========================================================================================
'列设置
'========================================================================================
    Dim 列AH对H股代码 As Integer
    Dim 列AH对H股代称 As Integer
    Dim 列AH对H股涨幅 As Integer
    Dim 列AH对H股价格 As Integer
    Dim 列AH对A股溢价 As Integer
    Dim 列AH对A股异步 As Integer
    Dim 列AH对A股价格 As Integer
    Dim 列AH对A股涨幅 As Integer
    Dim 列AH对A股代称 As Integer
    Dim 列AH对A股代码 As Integer
    Dim 列AH对总列数 As Integer
    列AH对H股代码 = 0
    列AH对H股代称 = 1
    列AH对H股涨幅 = 2
    列AH对H股价格 = 3
    列AH对A股溢价 = 4
    列AH对A股异步 = 5
    列AH对A股价格 = 6
    列AH对A股涨幅 = 7
    列AH对A股代称 = 8
    列AH对A股代码 = 9
    列AH对总列数 = 9
'========================================================================================
'填写信息
'========================================================================================
    Dim 代码对计数 As Integer
    Dim IDSS As Integer
    Dim IDHK As Integer
    Dim ROWID As Integer
    ROWID = 1
            
    For 代码对计数 = 1 To COLLAH.Count / 2
        '--------------------------------------------------------------------------------
        '提取信息
        '--------------------------------------------------------------------------------
        ROWID = 始行 + 代码对计数
        IDSS = 2 * 代码对计数 - 1
        IDHK = 2 * 代码对计数
        '--------------------------------------------------------------------------------
        With MS.Cells(ROWID, 始列)
                '------------------------------------------------------------------------
                .Offset(0, 列AH对H股代码) = "HK" & Format(aQUO(IDHK, 0), "0000")
                .Offset(0, 列AH对H股代称) = aQUO(IDHK, 1)
                .Offset(0, 列AH对H股涨幅) = CDbl(aQUO(IDHK, 2))
                .Offset(0, 列AH对H股价格) = CDbl(aQUO(IDHK, 3))
                
                .Offset(0, 列AH对A股价格) = CDbl(aQUO(IDSS, 3))
                .Offset(0, 列AH对A股涨幅) = CDbl(aQUO(IDSS, 2))
                .Offset(0, 列AH对A股代称) = aQUO(IDSS, 1)
                .Offset(0, 列AH对A股代码) = UBCID规制代码(aQUO(IDSS, 0))
                '------------------------------------------------------------------------
                .Offset(0, 列AH对A股溢价) = 100 * (.Offset(0, 列AH对H股价格) * 常汇率港币) / .Offset(0, 列AH对A股价格) - 100
                If .Offset(0, 列AH对H股涨幅) >= 0 Then
                    If .Offset(0, 列AH对A股涨幅) >= 0 Then
                        .Offset(0, 列AH对A股异步) = "同涨"
                    Else
                        .Offset(0, 列AH对A股异步) = "H涨A跌"
                    End If
                Else
                    If .Offset(0, 列AH对A股涨幅) >= 0 Then
                        .Offset(0, 列AH对A股异步) = "H跌A涨"
                    Else
                        .Offset(0, 列AH对A股异步) = "同跌"
                    End If
                End If
                '------------------------------------------------------------------------
                With .Offset(0, 列AH对H股代码)
                    .Interior.TintAndShade = -0.8
                    .Font.Color = .Interior.Color
                End With
                With .Offset(0, 列AH对A股代码)
                    .Interior.TintAndShade = -0.8
                    .Font.Color = .Interior.Color
                End With
                With .Offset(0, 列AH对H股代称)
                    .Interior.TintAndShade = -0.3
                End With
                With .Offset(0, 列AH对A股代称)
                    .Interior.TintAndShade = -0.3
                End With
                With .Offset(0, 列AH对H股涨幅)
                    .Interior.TintAndShade = IIf(.Value >= 0, 0.2, -0.1)
                End With
                With .Offset(0, 列AH对A股涨幅)
                    .Interior.TintAndShade = IIf(.Value >= 0, 0.2, -0.1)
                End With
'                With .Offset(0, 列AH对H股价格)
'                    .Interior.TintAndShade = -0.6
'                    .Font.Color = .Interior.Color
'                End With
'                With .Offset(0, 列AH对A股价格)
'                    .Interior.TintAndShade = -0.6
'                    .Font.Color = .Interior.Color
'                End With
                With .Offset(0, 列AH对A股溢价)
                    .Interior.TintAndShade = -0.2
                End With
                '------------------------------------------------------------------------
                With .Offset(0, 列AH对A股异步)
                    If .Value = "H涨A跌" Then
                        .Interior.ColorIndex = 43
                    ElseIf .Value = "H跌A涨" Then
                        .Interior.ColorIndex = 44
                    ElseIf .Value = "同涨" Then
                        .Interior.ColorIndex = 36
                    Else
                        .Interior.ColorIndex = 35
                    End If
                End With
                '------------------------------------------------------------------------
        End With
        '--------------------------------------------------------------------------------
    Next
    '------------------------------------------------------------------------------------
    Set COLLAH = Nothing
    Erase aQUO
    On Error GoTo 0
'========================================================================================
'格式化
'========================================================================================
    With MS
        '--------------------------------------------------------------------------------
        '列格式
        .Columns(始列 + 列AH对H股代码).ColumnWidth = 6
        .Columns(始列 + 列AH对A股代码).ColumnWidth = 10
        .Columns(始列 + 列AH对H股代称).ColumnWidth = 16
        .Columns(始列 + 列AH对H股代称).HorizontalAlignment = xlRight
        .Columns(始列 + 列AH对A股代称).ColumnWidth = 9
        .Columns(始列 + 列AH对H股涨幅).NumberFormatLocal = 全设格式of一位
        .Columns(始列 + 列AH对H股涨幅).ColumnWidth = 6
        .Columns(始列 + 列AH对A股涨幅).NumberFormatLocal = 全设格式of一位
        .Columns(始列 + 列AH对A股涨幅).ColumnWidth = 6
        .Columns(始列 + 列AH对H股价格).NumberFormatLocal = 全设格式of零位
        .Columns(始列 + 列AH对H股价格).ColumnWidth = 5
        .Columns(始列 + 列AH对A股价格).NumberFormatLocal = 全设格式of零位
        .Columns(始列 + 列AH对A股价格).ColumnWidth = 5
        .Columns(始列 + 列AH对A股溢价).NumberFormatLocal = 全设格式of零位
        .Columns(始列 + 列AH对A股溢价).ColumnWidth = 5
        .Columns(始列 + 列AH对A股溢价).HorizontalAlignment = xlCenter
        .Columns(始列 + 列AH对A股异步).ColumnWidth = 7
        .Columns(始列 + 列AH对A股异步).HorizontalAlignment = xlCenter
        '--------------------------------------------------------------------------------
        '首行
        .Cells(始行, 始列).Cells(1, 1 + 列AH对H股代码) = "H代码"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对H股代称) = "H名称"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对H股涨幅) = "H涨幅"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对H股价格) = "H价"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对A股价格) = "A价"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对A股涨幅) = "A涨幅"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对A股代称) = "A名称"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对A股代码) = "A代码"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对A股溢价) = "溢[A-H]%"
        .Cells(始行, 始列).Cells(1, 1 + 列AH对A股异步) = "异步"
        With .Cells(始行, 始列).Resize(1, 列AH对总列数)
            .Font.Bold = True
            .Font.Color = 常色主黑
        End With
'        .Cells(始行, 始列).Resize(1, 列AH对A股溢价).HorizontalAlignment = xlRight
        '--------------------------------------------------------------------------------
        '列显示
        .Columns(始列 + 列AH对H股代码).Hidden = True
        .Columns(始列 + 列AH对A股代码).Hidden = True
        .Columns(始列 + 列AH对H股价格).Hidden = True
        .Columns(始列 + 列AH对A股价格).Hidden = True
        '--------------------------------------------------------------------------------
    End With
'========================================================================================
    现市特程_HK_中港AH对比 = 始列 + 列AH对总列数 + 1
'========================================================================================
End Function






