Attribute VB_Name = "WMR现市_F1港股"
'========================================================================================
'========================================================================================
'调用：港股
'========================================================================================
'========================================================================================
Function 现市基程_市场香港( _
          MS As Worksheet _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 始行 As Integer = 3 _
        , Optional 始列 As Integer = 3 _
        ) As Boolean
'========================================================================================
'页面格式设置
'========================================================================================
    MS.Cells.Font.Size = 10
    MS.Columns.ColumnWidth = 2
    '------------------------------------------------------------------------------------
    MS.Cells(始行, 始行 + 1) = "芥蓝"
    MS.Columns(始行 + 1).ColumnWidth = 16
    MS.Columns(始行 + 2).ColumnWidth = 6
    MS.Columns(始行 + 3).ColumnWidth = 5
    MS.Columns(始行 + 3).Hidden = True
    '------------------------------------------------------------------------------------
    Dim 当列 As Integer
    当列 = 始行 + 5
'========================================================================================
'AH对比
'========================================================================================
    当列 = 现市特程_HK_中港AH对比(MS, 始行, 当列)
'========================================================================================
'指数系列
'========================================================================================
    当列 = 当列 + 2
    '------------------------------------------------------------------------------------
    当列 = 现市分程HK_成分_恒生系列(MS, 始行, 当列, 是否排序) + 1
    '------------------------------------------------------------------------------------
    当列 = 现市分程HK_成分_香港300系列(MS, 始行, 当列, 是否排序) + 1
    '------------------------------------------------------------------------------------
    当列 = 现市分程HK_成分_香港大盘系列(MS, 始行, 当列, 是否排序) + 1
    '------------------------------------------------------------------------------------
    当列 = 现市分程HK_成分_港股通系列(MS, 始行, 当列, 是否排序) + 1
'========================================================================================
'行业系列
'========================================================================================
    当列 = 当列 + 2
    当列 = 现市分程_类系列中证_香港消费类群(MS, 始行, 当列, 是否排序)
'========================================================================================
'页面格式设置
'========================================================================================
    With MS.Rows(始行)
        .Font.Bold = True
        .HorizontalAlignment = xlLeft
        .Borders(xlEdgeBottom).Weight = xlThin
    End With
    '------------------------------------------------------------------------------------
    MS.Activate
    Call PBASE格程工具_表冻结锁定(MS, 始行)
'========================================================================================
End Function





