'########################################################################################
'########################################################################################
'#####################################  QQQ 引擎数程   ###################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：全部代码的全部信息
'类型：即期
'CCC:实结即时 现有数据
'SCC-实结更日 只更新行情 用于看什么情况下会导致现有行情
'SSC-实结日时 更新行情+日OS
'SSS-实结乾时 更新行情+月周日OS
'MMM-实结某时
'========================================================================================
'========================================================================================
Function IQQQ跨码据擎_数程生成全息( _
          ByRef 谕组 As Variant _
        , ByVal 指定花册 As String _
        , Optional ByVal 研究日期 As Date _
        , Optional ByVal 实结类型 As String = "cCCC" _
        , Optional ByRef 采样典码 As Dictionary _
        , Optional ByVal 采样列号 As Integer = 0 _
        , Optional ByVal 采样列值 As String = "" _
        , Optional ByVal 仓日类型 As String = 常仓名宝福 _
        ) As Integer
'========================================================================================
'前置验证
'========================================================================================
        Dim WS花册 As Worksheet
        If 指定花册 = 常花中期 Or 指定花册 = 常花港股指 Or 指定花册 = 常花港股通 Or 指定花册 = 常花美股 Or 指定花册 = 常花中股 Then
            If STBASE外簿工具_花册链接(WS花册, 指定花册) = False Then
                Debug.Print "外部花册链接失败：" & 指定花册
                Exit Function
            End If
        Else
            If UTL判断工表存在(指定花册) = False Then
                Debug.Print "对应花册不存在：" & 指定花册
                Exit Function
            End If
            Set WS花册 = ThisWorkbook.Sheets(指定花册)
        End If
'========================================================================================
'主备：罗盘
'========================================================================================
        '--------------------------------------------------------------------------------
        '制作：花册数组
        '--------------------------------------------------------------------------------
        Dim 组花册 As Variant
        If 研究日期 = 0 Then
            Call UTL数据转换_集WS2ARR(组花册, WS花册, 始行:=2, 始列:=1, 总列:=花宽全道 + 位统时列总终)
    '    Else
    '        Dim ARRHX As Variant
    '        Call STBASE结算引擎_全新结算数程由外库(组花册, WS花册,  研究日期)
    '        Erase ARRHX
        End If
        If VBA.IsEmpty(组花册) Then Exit Function
        '--------------------------------------------------------------------------------
        '制作：花册行号字典
        '--------------------------------------------------------------------------------
        Dim 典码位花册 As New Dictionary
        For X = LBound(组花册, 1) To UBound(组花册, 1)
            CIDL = 组花册(X, 1)
            典码位花册.Add Item:=X, Key:=CIDL
        Next
'========================================================================================
'制作：谕组
'思路：如果谕组原来不是空数组，就保留；如果是空数组，但给出采样条件，就采样；否则就是全部花册。
'========================================================================================
        Dim 位列花天标志 As Integer
        位列花天标志 = 位列花天CIDS
        Dim 采样总数 As Integer
        '--------------------------------------------------------------------------------
        '设置标志位
        '如果谕组不为空，就使用原来的谕组
        '--------------------------------------------------------------------------------
        If VBA.IsEmpty(谕组) = False Then
        Else
                '------------------------------------------------------------------------
                '情况：采样典码 不为空，按照采样典码
                '------------------------------------------------------------------------
                If Not 采样典码 Is Nothing Then
                        采样总数 = 0
                        For X = LBound(组花册, 1) To UBound(组花册, 1)
                            CIDL = 组花册(X, 1)
                            If 采样典码.Exists(CIDL) = True Then
                                采样总数 = 采样总数 + 1
                                组花册(X, 位列花天标志) = True
                            End If
                        Next
                '------------------------------------------------------------------------
                '情况：空数组，全部花册
                '------------------------------------------------------------------------
                ElseIf 采样列号 = 0 Then
                        采样总数 = 0
                        For X = LBound(组花册, 1) To UBound(组花册, 1)
                            采样总数 = 采样总数 + 1
                            组花册(X, 位列花天标志) = True
                        Next
                '------------------------------------------------------------------------
                '情况：空数组，只提取决策所用代码
                '注：将不参与【决策】的放入【池黑】，减少运行时间
                '------------------------------------------------------------------------
                ElseIf 采样列号 = -1 Then
                        采样总数 = 0
                        For X = LBound(组花册, 1) To UBound(组花册, 1)
                            CIDL = 组花册(X, 1)
                            If UBCID是中股票(CIDL) = True Or UBCID是中股基(CIDL) = True Then
                            If 组花册(X, 位列花天在池) <> 常池名黑 Then
                                采样总数 = 采样总数 + 1
                                组花册(X, 位列花天标志) = True
                            End If
                            End If
                        Next
                '------------------------------------------------------------------------
                '情况：空数组，提取仓
                '------------------------------------------------------------------------
                ElseIf 采样列值 = "仓" Then
                        采样总数 = 0
                        For X = LBound(组花册, 1) To UBound(组花册, 1)
                            CIDL = 组花册(X, 1)
                            If UBCID是中股票(CIDL) = True Or UBCID是中股基(CIDL) = True Or UBCID是中股指(CIDL) = True Then
                            If Len(组花册(X, 采样列号)) > 0 Then
                                采样总数 = 采样总数 + 1
                                组花册(X, 位列花天标志) = True
                                'Debug.Print 采样总数, CIDL
                            End If
                            End If
                        Next
                '------------------------------------------------------------------------
                '情况：空数组，给出采样条件
                '------------------------------------------------------------------------
                ElseIf 采样列号 <> 0 Then
                        采样总数 = 0
                        For X = LBound(组花册, 1) To UBound(组花册, 1)
                            CIDL = 组花册(X, 1)
                            If UBCID是中股票(CIDL) = True Or UBCID是中股基(CIDL) = True Or UBCID是中股指(CIDL) = True Then
                            If 组花册(X, 采样列号) = 采样列值 Then
                                采样总数 = 采样总数 + 1
                                组花册(X, 位列花天标志) = True
                                'Debug.Print 采样总数, CIDL
                            End If
                            End If
                        Next
                End If
                '------------------------------------------------------------------------
                '------------------------------------------------------------------------
                '集中输出
                '------------------------------------------------------------------------
                '------------------------------------------------------------------------
                If 采样总数 = 0 Then Exit Function
                ReDim 谕组(1 To 采样总数, 1 To 花宽主道) As Variant
                Dim 采样计数 As Integer
                采样计数 = 0
                For X = LBound(组花册, 1) To UBound(组花册, 1)
                    If 组花册(X, 位列花天标志) = True Then
                        采样计数 = 采样计数 + 1
                        谕组(采样计数, 位qt代码) = 组花册(X, 位列花天CIDL)
                    End If
                Next
                '------------------------------------------------------------------------
        End If
'========================================================================================
'区域：行情
'========================================================================================
        '================================================================================
        '行情：非实时更新
        '================================================================================
        Dim 组结算 As Variant
        ReDim 组结算(LBound(谕组, 1) To UBound(谕组, 1), LBound(组花册, 2) To UBound(组花册, 2)) As Variant
        Dim 值合仓总数 As Long
        Dim 值合仓总额 As Long
        Dim 值合仓成本 As Double
        '--------------------------------------------------------------------------------
        For X = LBound(谕组, 1) To UBound(谕组, 1)
                CIDL = 谕组(X, 1)
                If 典码位花册.Exists(CIDL) = True Then
                        定位花册行号 = 典码位花册(CIDL)
                        '----------------------------------------------------------------
                        谕组(X, 位qt代称) = 组花册(定位花册行号, 位列花天代称)
                        谕组(X, 位qt市板) = 组花册(定位花册行号, 位列花天市板)
                        谕组(X, 位qt行业) = 组花册(定位花册行号, 位列花天行业新浪)
                        谕组(X, 位qt行益) = 组花册(定位花册行号, 位列花天行业益盟)
                        谕组(X, 位qt今池) = 组花册(定位花册行号, 位列花天今池)
                        谕组(X, 位qt在池) = 组花册(定位花册行号, 位列花天在池)
                        谕组(X, 位qt仓周) = 组花册(定位花册行号, 位列花天仓周)
                        '谕组(X, 位qt仓主) = 组花册(定位花册行号, 位列花天仓宝合) '在下面逻辑中处理
                        谕组(X, 位qt量比) = 组花册(定位花册行号, 位列花天量比)
                        谕组(X, 位qt换手) = 组花册(定位花册行号, 位列花天换手)
                        '----------------------------------------------------------------
                        谕组(X, 位qt停牌) = 组花册(定位花册行号, 花宽主道 + 位os停牌)
                        谕组(X, 位qt今期) = 组花册(定位花册行号, 花宽主道 + 位os结期)
                        谕组(X, 位qt今收) = 组花册(定位花册行号, 花宽主道 + 位os结收)
                        谕组(X, 位qt今开) = 组花册(定位花册行号, 花宽主道 + 位os结开)
                        谕组(X, 位qt今高) = 组花册(定位花册行号, 花宽主道 + 位os结高)
                        谕组(X, 位qt今低) = 组花册(定位花册行号, 花宽主道 + 位os结低)
                        谕组(X, 位qt前收) = 组花册(定位花册行号, 花宽主道 + 位os前收)
                        谕组(X, 位qt今涨幅) = 组花册(定位花册行号, 花宽主道 + 位os结幅PR0)
                        '----------------------------------------------------------------
                        For i = LBound(组花册, 2) To UBound(组花册, 2)
                            组结算(X, i) = 组花册(定位花册行号, i)
                        Next
                        '----------------------------------------------------------------
                        '适用于：采样操作，把【仓彦】信息放入【仓福】
                        If 采样列值 = "仓" Then
                                If 采样列号 = 位列花天仓宝福 Then
                                    谕组(X, 位qt仓主) = Right(常仓名宝福, 1)
                                ElseIf 采样列号 = 位列花天仓宝彦 Then
                                    谕组(X, 位qt仓主) = Right(常仓名宝彦, 1)
                                    组结算(X, 位列花天仓宝福) = 组结算(X, 位列花天仓宝彦)
                                End If
                                '注2025061：用于区分是否属于周仓：用于排序。临时仓位排在前面，周仓位排在后面。
                                '在每周结算日导入周仓，其余交易日导入日仓。在Z陈列时，将日仓放在前面，将周仓放在后面。
                                If 谕组(X, 位qt仓周) = 常仓名宝福 Or 谕组(X, 位qt仓周) = 常仓名宝彦 Then
                                    谕组(X, 位qt仓主) = 谕组(X, 位qt仓主) & "W"
                                Else
                                    谕组(X, 位qt仓主) = 谕组(X, 位qt仓主) & "X"
                                End If
                        End If
                        '----------------------------------------------------------------
                        '适用于：更新引擎
                        If 仓日类型 = 常仓名宝福 Then
                        ElseIf 仓日类型 = 常仓名宝彦 Then
                                组结算(X, 位列花天仓宝福) = 组结算(X, 位列花天仓宝彦)
                        ElseIf 仓日类型 = 常仓名宝合 Then
                                值合仓总数 = 0
                                值合仓总额 = 0
                                If Len(组结算(X, 位列花天仓宝彦)) > 0 Then
                                    值合仓总数 = 值合仓总数 + Left$(组结算(X, 位列花天仓宝彦), InStr(组结算(X, 位列花天仓宝彦), ",") - 1)
                                    值合仓总额 = 值合仓总额 + Left$(组结算(X, 位列花天仓宝彦), InStr(组结算(X, 位列花天仓宝彦), ",") - 1) * Mid$(组结算(X, 位列花天仓宝彦), InStr(组结算(X, 位列花天仓宝彦), ",") + 1)
                                End If
                                If Len(组结算(X, 位列花天仓宝福)) > 0 Then
                                    值合仓总数 = 值合仓总数 + Left$(组结算(X, 位列花天仓宝福), InStr(组结算(X, 位列花天仓宝福), ",") - 1)
                                    值合仓总额 = 值合仓总额 + Left$(组结算(X, 位列花天仓宝福), InStr(组结算(X, 位列花天仓宝福), ",") - 1) * Mid$(组结算(X, 位列花天仓宝福), InStr(组结算(X, 位列花天仓宝福), ",") + 1)
                                End If
                                If 值合仓总额 > 0 Then
                                    组结算(X, 位列花天仓宝福) = 值合仓总数 & "," & Round(值合仓总额 / 值合仓总数, 1)
                                End If
                        End If
                        '----------------------------------------------------------------
                End If
        Next
        Erase 组花册
'========================================================================================
'实时更新
'========================================================================================
        '================================================================================
        '实时更新：行情
        '================================================================================
        If Left$(实结类型, 1) = "S" Or Left$(实结类型, 1) = "s" Then
            计数未停牌 = IQQQ跨码据擎_数程查询行情(谕组, 组宽:=位qt主宽)
        End If
        '================================================================================
        '实时更新：结算
        '================================================================================
        Dim 是否实结期日 As Boolean
        Dim 是否实结期周 As Boolean
        Dim 是否实结期月 As Boolean
        是否实结期日 = IIf(Mid$(实结类型, 2, 1) = "S", True, False)
        是否实结期周 = IIf(Mid$(实结类型, 3, 1) = "S", True, False)
        是否实结期月 = IIf(Mid$(实结类型, 4, 1) = "S", True, False)
        '注意20230201：增加外部控制，只有实结类型日类为S时，才进行以下结算，为了保证SCC能够得到正确结果。
        If 是否实结期日 = True Then
            Call STBASE结算引擎_实时结算数程基腾(组结算, 花列甲道, 谕组, 是否结算:=是否实结期日)
            Call STBASE结算引擎_实时结算数程基腾(组结算, 花列乙道, 谕组, 是否结算:=是否实结期周)
            Call STBASE结算引擎_实时结算数程基腾(组结算, 花列丙道, 谕组, 是否结算:=是否实结期月)
            '设置停牌
            Call STCALL花册管理_重制花天P9子程重置信息8停牌(组结算, 花列甲道, 指定花册:=指定花册)
        End If
'========================================================================================
'衍生：谕组
'========================================================================================
        Call IQQQ跨码据擎_数程生成跨时神谕(谕组, 组结算, 花列甲道, 是否跨码:=True)
        Erase 组结算
'========================================================================================
'返回
'========================================================================================
        If Left$(实结类型, 1) = "S" Or Left$(实结类型, 1) = "s" Then
            IQQQ跨码据擎_数程生成全息 = 计数未停牌
        Else
            IQQQ跨码据擎_数程生成全息 = UBound(谕组, 1) - LBound(谕组, 1) + 1
        End If
End Function
