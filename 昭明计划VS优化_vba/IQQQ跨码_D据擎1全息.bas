'########################################################################################
'#####################################  QQQ 引擎数程   ###################################
'########################################################################################
'########################################################################################






'========================================================================================
'========================================================================================
'功能：根据组码中代码列表，更新组去信息
'========================================================================================
'========================================================================================
Function IQQQ跨码据擎_数程查询行情( _
          组去 As Variant _
        , Optional 组码 As Variant _
        , Optional 组宽 As Integer = 位qt主宽 _
        , Optional 使用批量 As Boolean = True _
        ) As Integer
'========================================================================================
'变量声明
'========================================================================================
    '------------------------------------------------------------------------------------
    '未提供组码情况
    '------------------------------------------------------------------------------------
    If VBA.IsMissing(组码) = True Then
        组码 = 组去
    End If
    '------------------------------------------------------------------------------------
    '重设组去：如果维度增加
    '------------------------------------------------------------------------------------
    If 组宽 > UBound(组码, 2) - LBound(组码, 2) + 1 Then
        ReDim Preserve 组去(LBound(组码, 1) To UBound(组码, 1), 1 To 组宽) As Variant
    End If
'========================================================================================
'变量声明
'========================================================================================
    Dim CIDL As String
    '------------------------------------
    Dim nRESP As Integer
    Dim aRESP As Variant
    '------------------------------------
    Dim 是否停牌 As Boolean
    Dim sdate As String
    Dim qdate As Date
    Dim qtime As Date
'========================================================================================
'批量模式：先一次HTTP查全部，未命中再逐只重试
'========================================================================================
    Dim 查回典 As Dictionary
    If 使用批量 Then
        Dim s代码串 As String
        Dim 预号 As Integer
        For 预号 = LBound(组码, 1) To UBound(组码, 1)
            CIDL = 组去(预号, 位qt代码)
            If UBCID是代码(CIDL) = True Then
                s代码串 = s代码串 & "," & CIDL
            End If
        Next
        If Len(s代码串) > 1 Then
            Set 查回典 = UBHTTP腾实_查回典批量(Mid$(s代码串, 2))
        Else
            Set 查回典 = New Dictionary
        End If
    End If
'========================================================================================
'遍历：查询
'========================================================================================
    Dim 计数未停牌 As Integer
    计数未停牌 = 0
    '------------------------------------
    Dim 遍历序号 As Integer
    For 遍历序号 = LBound(组码, 1) To UBound(组码, 1)
        '================================================================================
        '如果数组元素为 代码
        '================================================================================
        CIDL = 组去(遍历序号, 位qt代码)
        If UBCID是代码(CIDL) = True Then
            '----------------------------------------------------------------------------
            '查询信息：批量优先，逐只兜底
            '----------------------------------------------------------------------------
            If 使用批量 Then
                If 查回典.Exists(CIDL) Then
                    aRESP = 查回典(CIDL)
                Else
                    nRESP = UBHTTP腾实_查回组(aRESP, CIDL)
                    If nRESP <= 0 Then
                        计数未停牌 = 计数未停牌 + 1
                        GoTo 跳过本只
                    End If
                End If
            Else
                nRESP = UBHTTP腾实_查回组(aRESP, CIDL)
                If nRESP <= 0 Then
                    计数未停牌 = 计数未停牌 + 1
                    GoTo 跳过本只
                End If
            End If
            '----------------------------------------------------------------------------
            '查询信息
            '----------------------------------------------------------------------------
            If True Then
                '------------------------------------------------------------------------
                '处理信息：美股
                '------------------------------------------------------------------------
                If aRESP(位序腾实市场) = 200 Then '美股
                    组去(遍历序号, 位qt代称) = aRESP(位序腾实代称)
                    组去(遍历序号, 位qt今收) = aRESP(3)
                    组去(遍历序号, 位qt今涨幅) = aRESP(5)
                    组去(遍历序号, 位qt今量) = aRESP(6)
                    组去(遍历序号, 位qt今额) = aRESP(7)
                    If Len(aRESP(8)) > 0 Then 组去(遍历序号, 位qt市值) = CLng(aRESP(8))
                    组去(遍历序号, 位qt今期) = DateValue(Now - 1)
                '------------------------------------------------------------------------
                '处理信息：A股 港股
                '------------------------------------------------------------------------
                Else
                    '---------------------------------------------------------------------
                    '更新：基本信息
                    '---------------------------------------------------------------------
                    组去(遍历序号, 位qt代称) = aRESP(位序腾实代称)
                    组去(遍历序号, 位qt前收) = aRESP(位序腾实前收)
                    If Len(aRESP(位序腾实流市)) > 0 Then 组去(遍历序号, 位qt市值) = CLng(aRESP(位序腾实流市))
                    
                    '港股
                    If aRESP(位序腾实市场) = 100 Then
                        组去(遍历序号, 位qt今期) = DateValue(aRESP(位序腾实时间))
                        组去(遍历序号, 位qt今时) = TimeValue(aRESP(位序腾实时间))
                    'A股
                    Else
                        sdate = aRESP(位序腾实时间)
                        qdate = DateSerial(Left$(sdate, 4), Mid$(sdate, 5, 2), Mid$(sdate, 7, 2))
                        组去(遍历序号, 位qt今期) = qdate
                        qtime = TimeSerial(Mid$(sdate, 9, 2), Mid$(sdate, 11, 2), Mid$(sdate, 13, 2))
                        组去(遍历序号, 位qt今时) = qtime
                    End If
                    '---------------------------------------------------------------------
                    '更新：行情信息
                    '---------------------------------------------------------------------
                    是否停牌 = IIf(Len(aRESP(位序腾实停牌)) > 0, True, False)
                    If 是否停牌 = True Then
                        组去(遍历序号, 位qt停牌) = "S"
                        组去(遍历序号, 位qt今涨幅) = "S"
                        组去(遍历序号, 位qt今收) = aRESP(位序腾实今收)
                    Else
                        '----------------------------------------------------------------
                        '计数未停牌代码
                        计数未停牌 = 计数未停牌 + 1
                        组去(遍历序号, 位qt停牌) = ""
                        组去(遍历序号, 位qt今涨幅) = ""
                        '----------------------------------------------------------------
                        组去(遍历序号, 位qt今涨幅) = aRESP(位序腾实今涨)
                        If aRESP(位序腾实前收) > 0 Then 组去(遍历序号, 位qt今高幅) = Round(100 * (aRESP(位序腾实今高) / aRESP(位序腾实前收) - 1), 2)
                        组去(遍历序号, 位qt今收) = aRESP(位序腾实今收)
                        组去(遍历序号, 位qt今开) = aRESP(位序腾实今开)
                        组去(遍历序号, 位qt今高) = aRESP(位序腾实今高)
                        组去(遍历序号, 位qt今低) = aRESP(位序腾实今低)
                        '组去(遍历序号, 位qt今量) = aRESP(位序腾实交量)
                        组去(遍历序号, 位qt今额) = aRESP(位序腾实交额)
    
                        组去(遍历序号, 位qt量比) = IIf(aRESP(位序腾实市场) = 100, aRESP(位序腾实H量比) * 10, aRESP(位序腾实A量比) * 10)
                        组去(遍历序号, 位qt换手) = IIf(aRESP(位序腾实市场) = 100, aRESP(位序腾实H换手), aRESP(位序腾实A换手))
                        '----------------------------------------------------------------
                    End If
                    '---------------------------------------------------------------------
                End If
                '------------------------------------------------------------------------
            End If
跳过本只:
        End If
        '================================================================================
        'Debug.Print "QT>>"; 遍历序号
        '================================================================================
    Next 遍历序号
'========================================================================================
'返回
'========================================================================================
    IQQQ跨码据擎_数程查询行情 = 计数未停牌
'========================================================================================
End Function




