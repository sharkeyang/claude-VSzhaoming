'#############################     外盘管理_IQQQ乾坤分布调程     #########################
'########################################################################################
'########################################################################################
Private Function IQQQ乾坤分布调程通用( _
          Optional ByVal 指定表名 As String _
        , Optional ByVal 指定花册 As String = 常花港股通 _
        , Optional ByVal 实结类型 As String = "cCCC" _
        , Optional ByRef 采样典码 As Dictionary _
        , Optional ByVal 采样列号 As Integer = 0 _
        , Optional ByVal 采样列值 As String = "" _
        , Optional ByVal 出章模式 As String = "周仓" _
        , Optional ByVal 出节模式 As String = "周层" _
        , Optional ByVal 出全是否 As Boolean = True _
        , Optional ByVal 是否建表 As Boolean = True _
        , Optional ByVal 基色底 As Long = 常色主靛 _
        )
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    If 指定花册 = 常花中期 Then
        指定表名 = ".III" & Right(指定花册, 2) & 实结类型
        'Call STBASE结算管理_全新结算调程花中期
        Call IQQQ乾坤分布质程(指定表名, 指定花册, 实结类型:=实结类型, 基色底:=基色底, 出章模式:=出章模式, 出节模式:=出节模式, 出全是否:=出全是否)
        If UTL判断工表存在(指定表名) = True Then
            ThisWorkbook.Sheets(指定表名).Columns(位qt代称).ColumnWidth = 20
        End If
    '------------------------------------------------------------------------------------
    ElseIf 指定花册 = 常花港股指 Then
        指定表名 = ".III" & Right(指定花册, 2) & 实结类型
        'Call STBASE结算管理_全新结算调程花港股指
        Call IQQQ乾坤分布质程(指定表名, 指定花册, 实结类型:=实结类型, 基色底:=基色底, 出章模式:=出章模式, 出节模式:=出节模式, 出全是否:=出全是否)
        If UTL判断工表存在(指定表名) = True Then
            ThisWorkbook.Sheets(指定表名).Columns(位qt代称).ColumnWidth = 30
        End If
    '------------------------------------------------------------------------------------
    ElseIf 指定花册 = 常花港股通 Then
        指定表名 = ".III" & Right(指定花册, 2) & 实结类型
        'Call STBASE结算管理_全新结算调程花港股通
        Call IQQQ乾坤分布质程(指定表名, 指定花册, 实结类型:=实结类型, 基色底:=基色底, 出章模式:=出章模式, 出节模式:=出节模式, 出全是否:=出全是否)
        If UTL判断工表存在(指定表名) = True Then
            ThisWorkbook.Sheets(指定表名).Columns(位qt代称).ColumnWidth = 16
        End If
    '------------------------------------------------------------------------------------
    ElseIf 指定花册 = 常花美股 Then
        指定表名 = ".III" & Right(指定花册, 2) & 实结类型
        'Call STBASE结算管理_全新结算调程花美股票
        Call IQQQ乾坤分布质程(指定表名, 指定花册, 实结类型:=实结类型, 基色底:=基色底, 出章模式:=出章模式, 出节模式:=出节模式, 出全是否:=出全是否)
        If UTL判断工表存在(指定表名) = True Then
            ThisWorkbook.Sheets(指定表名).Columns(位qt代称).ColumnWidth = 16
        End If
    End If
    '--------------------------------------------------------------------------------
    UTL宏工具_END
End Function
