Public Sub UTL组排序(ByRef lngArray As Variant)
    Dim iOuter As Long
    Dim iInner As Long
    Dim iLBound As Long
    Dim iUBound As Long
    Dim iTemp1 As Variant
    Dim iTemp2 As Variant
    Dim iMax As Long
    '------------------------------------------------------------------------------------
    iLBound = LBound(lngArray, 1)
    iUBound = UBound(lngArray, 1)
    '------------------------------------------------------------------------------------
    '选择排序
    For iOuter = iUBound To iLBound + 1 Step -1
        iMax = iLBound
    
        '得到最大值得索引
        For iInner = iLBound To iOuter
            If lngArray(iInner, 2) > lngArray(iMax, 2) Then iMax = iInner
        Next iInner
    
        '值交换
        iTemp1 = lngArray(iMax, 1)
        iTemp2 = lngArray(iMax, 2)
        lngArray(iMax, 1) = lngArray(iOuter, 1)
        lngArray(iMax, 2) = lngArray(iOuter, 2)
        lngArray(iOuter, 1) = iTemp1
        lngArray(iOuter, 2) = iTemp2
    Next iOuter
    '------------------------------------------------------------------------------------
End Sub
