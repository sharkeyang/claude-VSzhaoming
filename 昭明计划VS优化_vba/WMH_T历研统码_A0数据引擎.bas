'########################################################################################
'########################################################################################
'###################################  历调  基础数据  ####################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：按照三维（码/时/幅）准备数据
'注意20220903：开始去除非代码
'========================================================================================
'========================================================================================
Function 历研数据引擎_基础数据准备( _
          矩历码期值 As Variant _
        , 典码称 As Dictionary _
        , Optional ByVal 指定期类 As String = 常期类为日 _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限历短 _
        , Optional ByVal 是否全新源AK As Boolean = False _
        , Optional ByVal 是否更新源TR As Boolean = True _
        , Optional ByVal 是否神谕指标 As Boolean = False _
        )
'========================================================================================
'制作码典
'注意：典去除非代码
'========================================================================================
    If 典码称 Is Nothing Then Exit Function
    If 典码称.Count = 0 Then Exit Function
    '------------------------------------------------------------------------------------
    '加工典：去除非代码
    '------------------------------------------------------------------------------------
    Dim CIDL As String
    Dim i As Integer
    For i = 典码称.Count To 1 Step -1
        CIDL = 典码称.Keys(i - 1)
        If UBCID是中股(CIDL) = False Then 典码称.Remove (CIDL)
    Next
    '------------------------------------------------------------------------------------
    If 典码称.Count = 0 Then Exit Function
    Dim 码数 As Integer
    码数 = 典码称.Count
'========================================================================================
'获取交易数据
'========================================================================================
    Dim ARRDATA As Variant
    '------------------------------------------------------------------------------------
    '获取数据：历史数据
    '------------------------------------------------------------------------------------
    If 是否全新源AK = True Then
        Call STBASE藏库引擎_更新数程(ARRDATA, 典码称, 常据源AK, 指定期类, 指定结期下限:=指定结期下限, 是否更新全量:=True)
    Else
        Call STBASE外簿工具_藏库获取组库(ARRDATA, 指定期类)
    End If
    '------------------------------------------------------------------------------------
    '获取数据：实时数据
    '------------------------------------------------------------------------------------
    If 是否更新源TR = True Then
        Call STBASE藏库引擎_更新数程(ARRDATA, 典码称, 常据源TR, 指定结期下限:=指定结期下限)
    End If
    If VBA.IsEmpty(ARRDATA) = True Then Exit Function
'    '------------------------------------------------------------------------------------
'    '测试
'    '------------------------------------------------------------------------------------
'    Dim WSLX As Worksheet
'    Call PBASE格程工具_表操工表新增(WSLX, "KK")
'    Call UTL数据转换_集ARR2WS(ARRDATA, WSLX, 2, 1)
'========================================================================================
'制作典
'========================================================================================
    '------------------------------------------------------------------------------------
    '制作典：典期序 '倒序：从现在向最早
    '------------------------------------------------------------------------------------
    Dim 典期序 As New Dictionary
    Dim 值当期 As Date
    Dim 值索横期  As String
    Dim 日期上限实 As Date
    If 是否神谕指标 Then
        日期上限实 = Date   '神谕依赖CSV文件，以今天为上限，避免TR实时列超出CSV数据范围
    Else
        日期上限实 = 指定结期上限
    End If
    Dim Y As Integer
    For Y = UBound(ARRDATA, 2) To 位列TT头部 + 1 Step -1
        值当期 = ARRDATA(位行TT交日, Y)
        值索横期 = 时程工具衍生期索(值当期, 指定期类)
        If 指定结期下限 < 值当期 And 值当期 <= 日期上限实 Then
            典期序.Add Item:=值当期, Key:=值索横期
        End If
    Next
    '------------------------------------------------------------------------------------
    '制作典：典码行
    '------------------------------------------------------------------------------------
    Dim 典码行 As New Dictionary
    Dim X As Integer
    For X = 位行TT头部 + 1 To UBound(ARRDATA, 1)
        CIDL = ARRDATA(X, 位列TT代码)
        If UBCID是中股(CIDL) = True Then
            典码行.Add Key:=CIDL, Item:=X
        End If
    Next
    '------------------------------------------------------------------------------------
'    '测试输出
'    Dim WSTO As Worksheet
'    Call PBASE格程工具_表操工表新增(WSTO, "XC")
'    Call UTL数据转换_集ARR2WS(ARRDATA, WSTO, 1, 1)
'    Stop
'    Exit Function
'========================================================================================
'加工数据
'========================================================================================
    ReDim 矩历码期值(位矩历一维下限 To 典码称.Count, 位矩历二维下限 To 典期序.Count, 位矩历三维下限 To 位矩历三维上限) As Variant
    '------------------------------------------------------------------------------------
    '头部标志
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维幅涨) = "涨幅"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维幅高) = "高幅"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维幅低) = "低幅"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维幅中) = "中幅"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维幅比) = "涨身比"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维价收) = "价收"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维价高) = "价高"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维价低) = "价低"
    '矩历码期值：横轴为日期
    Dim M As Integer
    For M = 1 To 典期序.Count
        值当期 = CDate(典期序.Items(M - 1))
        For Y = 位矩历三维下限 To 位矩历三维上限
            矩历码期值(位矩历一维下限, M, Y) = 值当期
        Next
    Next
    '------------------------------------------------------------------------------------
    '矩历码期值：纵轴为日期
    '矩历码期值：元素为涨幅
    'P2：预建典索期（日期key → 3D数组列号m），替代per-code字典中转
    Dim 典索期 As New Dictionary
    For M = 1 To 典期序.Count
        典索期.Add Key:=典期序.Keys(M - 1), Item:=M
    Next
    '====================================================================
    'P1：预建典码列索 — 每个代码→该行有数据的列索引数组，一次扫描替代重复全量扫描
    '日期范围用 常结期下限市场/常结期上限市场，与原 STBASE取据引擎取据由藏库按行 默认参数一致
    '====================================================================
    Dim 典码列索 As New Dictionary  'Key: CIDL, Item: Variant(0 To N-1) of column indices
    Dim 列索组 As Variant
    Dim 列索数 As Integer
    Dim 代称 As String
    Dim 值期数 As Integer
    Dim ARRSTOCK As Variant
    Dim j As Integer
    Dim 值正序 As Integer
    Dim aLINE As Variant
    Dim 索码串 As String
    Dim vKey As Variant
    Dim 当期 As Date
    For Each vKey In 典码称.Keys
        典码列索.Add Key:=vKey, Item:=Array()
    Next
    Dim 索行 As Integer
    For 索行 = 位行TT头部 + 1 To UBound(ARRDATA, 1)
        CIDL = ARRDATA(索行, 位列TT代码)
        If 典码列索.Exists(CIDL) Then
            列索数 = 0
            ReDim 列索组(0 To UBound(ARRDATA, 2) - 位列TT头部 - 1)
            For j = 位列TT头部 + 1 To UBound(ARRDATA, 2)
                索码串 = ARRDATA(索行, j)
                当期 = ARRDATA(位行TT交日, j)
                If (InStr(索码串, ",") > 0) And (常结期下限市场 < 当期) And (当期 <= 常结期上限市场) Then
                    列索组(列索数) = j
                    列索数 = 列索数 + 1
                End If
            Next
            If 列索数 > 0 Then
                ReDim Preserve 列索组(0 To 列索数 - 1)
                典码列索(CIDL) = 列索组
            End If
        End If
    Next
    '------------------------------------------------------------------------------------
    For X = 1 To 典码称.Count
        CIDL = 典码称.Keys(X - 1)
        If 典码行.Exists(CIDL) = True Then
                '------------------------------------------------------------------------
                '规范化表头：由于【典码称】中代称不标准，需要用【藏库】中代称进行标准化
                '------------------------------------------------------------------------
                代称 = ARRDATA(典码行(CIDL), 位列TT代称)
                '整理代称：把行业放到前缀
                If Left$(代称, 2) = "国证" Or Left$(代称, 2) = "中证" Or Left$(代称, 2) = "上证" Or Left$(代称, 2) = "深证" Then
                    If Mid$(代称, 3) <> "指数" Then 代称 = Mid$(代称, 3) & Left$(代称, 2)
                ElseIf Left$(代称, 2) = "恒生" Then
                    代称 = "恒" & Mid$(代称, 3)
                ElseIf Left$(代称, 4) = "1000" Or Left$(代称, 4) = "300 " Then
                    代称 = Mid$(代称, 5) & Left$(代称, 4)
                ElseIf Left$(代称, 3) = "300" Or Left$(代称, 3) = "500 " Then
                    代称 = Mid$(代称, 4) & Left$(代称, 3)
                ElseIf Left$(代称, 2) = "中韩" Then
                    代称 = Mid$(代称, 2)
                ElseIf Left$(代称, 5) = "港股通金融" Then
                    代称 = "港金"
                End If
                If InStr(代称, "ETF") > 0 Then
                    代称 = VBA.Replace(代称, "ETF", "") & "e"
                End If
                矩历码期值(X, 位矩历二维下限, 位矩历三维指标仓日类) = 代称
                矩历码期值(X, 位矩历二维下限, 位矩历三维指标仓周类) = 代称
                矩历码期值(X, 位矩历二维下限, 位矩历三维幅涨) = 代称
                矩历码期值(X, 位矩历二维下限, 位矩历三维幅高) = 代称
                矩历码期值(X, 位矩历二维下限, 位矩历三维幅低) = 代称
                矩历码期值(X, 位矩历二维下限, 位矩历三维幅中) = 代称
                矩历码期值(X, 位矩历二维下限, 位矩历三维幅比) = 代称
                矩历码期值(X, 位矩历二维下限, 位矩历三维价收) = CIDL             '用来储存CIDL
                矩历码期值(X, 位矩历二维下限, 位矩历三维价高) = CIDL             '用来储存CIDL
                矩历码期值(X, 位矩历二维下限, 位矩历三维价低) = CIDL             '用来储存CIDL
                '------------------------------------------------------------------------
                '获取特定数据
                '------------------------------------------------------------------------
                'P1：用预建列索引直接取值，不再全量扫描ARRDATA
                列索组 = 典码列索(CIDL)
                列索数 = UBound(列索组) - LBound(列索组) + 1
                If 列索数 > 0 And IsArray(列索组) Then
                    If LBound(列索组) > UBound(列索组) Then 列索数 = 0
                End If
                If 列索数 <= 0 Then 值期数 = 0: GoTo SkipExtract
                ReDim ARRSTOCK(1 To 列索数, 1 To 位列TS上限单期)
                值正序 = 0
                For j = 0 To 列索数 - 1
                    索码串 = ARRDATA(典码行(CIDL), 列索组(j))
                    If UTL数据转换_串2组4CSV(aLINE, 索码串) > 0 Then
                        值正序 = 值正序 + 1
                        ARRSTOCK(值正序, 位列TS结龄) = 值正序
                        ARRSTOCK(值正序, 位列TS结期) = ARRDATA(位行TT交日, 列索组(j))
                        ARRSTOCK(值正序, 位列TS结收) = aLINE(位列TS结收)
                        ARRSTOCK(值正序, 位列TS结开) = 0
                        ARRSTOCK(值正序, 位列TS结高) = aLINE(位列TS结高)
                        ARRSTOCK(值正序, 位列TS结低) = aLINE(位列TS结低)
                        Erase aLINE
                    End If
                Next
                值期数 = 值正序
                If 值期数 = 0 Then Erase ARRSTOCK
SkipExtract:
                '------------------------------------------------------------------------
                '填充
                '------------------------------------------------------------------------
                'If X Mod 100 = 1 Then Debug.Print "历研数据引擎_基础数据准备>> 共" & 典码称.Count & " 第" & X & " " & CIDL & " 期数" & 值期数
                'P2：预填本行默认值"S"，再直接写入3D数组（消去per-code字典中转）
                For M = 1 To 典期序.Count
                    矩历码期值(X, M, 位矩历三维幅涨) = "S"
                    矩历码期值(X, M, 位矩历三维幅高) = "S"
                    矩历码期值(X, M, 位矩历三维幅低) = "S"
                    矩历码期值(X, M, 位矩历三维幅中) = "S"
                    矩历码期值(X, M, 位矩历三维幅比) = "S"
                    矩历码期值(X, M, 位矩历三维价收) = "S"
                    矩历码期值(X, M, 位矩历三维价高) = "S"
                    矩历码期值(X, M, 位矩历三维价低) = "S"
                Next
                If 值期数 > 0 Then
                    值期数 = STBASE结算基程_数据衍生(ARRSTOCK, 是否倒序:=True)
                    For M = LBound(ARRSTOCK, 1) To UBound(ARRSTOCK, 1)        '从现在向最早
                        值当期 = ARRSTOCK(M, 位列TS结期)
                        值索横期 = 时程工具衍生期索(值当期, 指定期类)
                        If 典索期.Exists(值索横期) Then
                            Dim 定位索横期 As Integer: 定位索横期 = 典索期(值索横期)
                            矩历码期值(X, 定位索横期, 位矩历三维幅涨) = ARRSTOCK(M, 位列TS涨幅)
                            矩历码期值(X, 定位索横期, 位矩历三维幅高) = ARRSTOCK(M, 位列TS高幅)
                            矩历码期值(X, 定位索横期, 位矩历三维幅低) = ARRSTOCK(M, 位列TS低幅)
                            矩历码期值(X, 定位索横期, 位矩历三维幅中) = Round((ARRSTOCK(M, 位列TS高幅) + ARRSTOCK(M, 位列TS低幅)) / 2, 1)
                            If ARRSTOCK(M, 位列TS高幅) - ARRSTOCK(M, 位列TS低幅) <> 0 Then
                                矩历码期值(X, 定位索横期, 位矩历三维幅比) = 20 * (Round((ARRSTOCK(M, 位列TS涨幅) - ARRSTOCK(M, 位列TS低幅)) / (ARRSTOCK(M, 位列TS高幅) - ARRSTOCK(M, 位列TS低幅)), 1) - 0.5)
                            Else
                                矩历码期值(X, 定位索横期, 位矩历三维幅比) = 0
                            End If
                            矩历码期值(X, 定位索横期, 位矩历三维价收) = ARRSTOCK(M, 位列TS结收)
                            矩历码期值(X, 定位索横期, 位矩历三维价高) = ARRSTOCK(M, 位列TS结高)
                            矩历码期值(X, 定位索横期, 位矩历三维价低) = ARRSTOCK(M, 位列TS结低)
                        End If
                    Next
                    Erase ARRSTOCK
                End If
                '------------------------------------------------------------------------
        End If
    Next
'========================================================================================
'按码结算
'========================================================================================
'批量拉取TR数据供逐码结算补充（神谕模式：若CSV缺最新日，TR数据追加到CSV末尾再结算）
Dim 典腾实 As Dictionary
Set 典腾实 = Nothing
If 是否神谕指标 Then
    Dim s代码串 As String
    For Each vKey In 典码称.Keys()
        s代码串 = s代码串 & CStr(vKey) & ","
    Next
    If Len(s代码串) > 0 Then
        s代码串 = Left$(s代码串, Len(s代码串) - 1)
        Set 典腾实 = STBASE取据引擎取据由腾实批(s代码串)
    End If
End If
If 是否神谕指标 = True Then
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维指标仓日类) = "谕仓日类"
    矩历码期值(位矩历一维下限, 位矩历二维下限, 位矩历三维指标仓周类) = "谕仓周类"
    Dim 典期位谕of仓日类 As New Dictionary
    Dim 典期位谕of仓周类 As New Dictionary
    Dim ARRLLL As Variant
    Dim 谕组 As Variant
    For X = 1 To 典码称.Count
        CIDL = 典码称.Keys(X - 1)
        If 典码行.Exists(CIDL) = True Then
                '------------------------------------------------------------------------
                '输出数据
                '------------------------------------------------------------------------
                值期数 = XL算展数程跨期(ARRLLL, CIDL, 指定结期上限:=指定结期上限, 典腾实:=典腾实)
                If 值期数 > 0 Then
                    ReDim 谕组(LBound(ARRLLL, 1) To UBound(ARRLLL, 1), 1 To 位qt主宽) As Variant
                    Call IQQQ跨码据擎_数程生成跨时神谕(谕组, ARRLLL, 基列:=1, 是否跨码:=False)
                    For M = LBound(ARRLLL, 1) To UBound(ARRLLL, 1)        '从现在向最早
                        值当期 = ARRLLL(M, 位os结期)
                        值索横期 = 时程工具衍生期索(值当期, 指定期类)
                        典期位谕of仓日类.Add Key:=值索横期, Item:=谕组(M, 位谕of仓日类)
                        典期位谕of仓周类.Add Key:=值索横期, Item:=谕组(M, 位谕of仓周类)
                    Next
'                    '--- DEBUG: 诊断典期位谕of仓日类与典期序不匹配 ---
'                    Dim 期钥 As Variant, 期钥Max As String
'                    期钥Max = ""
'                    For Each 期钥 In 典期位谕of仓日类.Keys
'                        If 期钥 > 期钥Max Then 期钥Max = 期钥
'                    Next
'                    Debug.Print "神谕DEBUG>> " & CIDL _
'                        & " | ARRLLL末行=" & ARRLLL(UBound(ARRLLL, 1), 位os结期) _
'                        & " | 谕组末行仓日类=" & 谕组(UBound(谕组, 1), 位谕of仓日类) _
'                        & " | 典期位谕最大=" & 期钥Max _
'                        & " | 典期序首=" & 典期序.Keys(0) & "(新) " _
'                        & " | 典期序末=" & 典期序.Keys(典期序.Count - 1) & "(旧)"
'                    '--- DEBUG END ---
                    Erase ARRLLL
                    Erase 谕组
                    'If X Mod 100 = 1 Then Debug.Print "历研数据引擎_按码结算准备>> 共" & 典码称.Count & " 第" & X & " " & CIDL & " 期数" & 值期数
                End If
                '------------------------------------------------------------------------
                '输出数据
                '------------------------------------------------------------------------
                For M = 1 To 典期序.Count
                    值索横期 = 典期序.Keys(M - 1)
                    If 典期位谕of仓日类.Exists(值索横期) = True Then
                        矩历码期值(X, M, 位矩历三维指标仓日类) = 典期位谕of仓日类(值索横期)
                    Else
                        矩历码期值(X, M, 位矩历三维指标仓日类) = "S"
                    End If
                Next
                典期位谕of仓日类.RemoveAll
                '------------------------------------------------------------------------
                '仓周类
                For M = 1 To 典期序.Count
                    值索横期 = 典期序.Keys(M - 1)
                    If 典期位谕of仓周类.Exists(值索横期) = True Then
                        矩历码期值(X, M, 位矩历三维指标仓周类) = 典期位谕of仓周类(值索横期)
                    Else
                        矩历码期值(X, M, 位矩历三维指标仓周类) = "S"
                    End If
                Next
                典期位谕of仓周类.RemoveAll
                '------------------------------------------------------------------------
        End If
    Next
End If
'========================================================================================
'返回
'========================================================================================
    历研数据引擎_基础数据准备 = 码数
End Function






'========================================================================================
'========================================================================================
'功能：对每日按幅进行排序
'注：第一列是股票名称，单元格内容是【第一列第几行占据该序位】
'========================================================================================
'========================================================================================
Function 历研数据引擎_基础数据排序( _
          ByRef 矩历码期序 As Variant _
        , ByRef 矩历码期值 As Variant _
        )
'========================================================================================
'加工数据
'========================================================================================
    ReDim 矩历码期序(LBound(矩历码期值, 1) To UBound(矩历码期值, 1), LBound(矩历码期值, 2) To UBound(矩历码期值, 2), 1 To 3) As Variant
    '------------------------------------------------------------------------------------
    '头部标志
    矩历码期序(位矩历一维下限, 位矩历二维下限, 位矩历三维幅涨) = "排序涨幅"
    矩历码期序(位矩历一维下限, 位矩历二维下限, 位矩历三维幅高) = "排序高幅"
    矩历码期序(位矩历一维下限, 位矩历二维下限, 位矩历三维幅低) = "排序低幅"
    '矩历码期序：横轴为日期
    Dim Y As Integer
    For Y = 1 To UBound(矩历码期值, 2)
        矩历码期序(位矩历一维下限, Y, 位矩历三维幅涨) = 矩历码期值(位矩历一维下限, Y, 位矩历三维幅涨)
        矩历码期序(位矩历一维下限, Y, 位矩历三维幅高) = 矩历码期值(位矩历一维下限, Y, 位矩历三维幅高)
        矩历码期序(位矩历一维下限, Y, 位矩历三维幅低) = 矩历码期值(位矩历一维下限, Y, 位矩历三维幅低)
    Next
    Dim X As Integer
    For X = 1 To UBound(矩历码期值, 1)
        矩历码期序(X, 位矩历二维下限, 位矩历三维幅涨) = 矩历码期值(X, 位矩历二维下限, 位矩历三维幅涨)
        矩历码期序(X, 位矩历二维下限, 位矩历三维幅高) = 矩历码期值(X, 位矩历二维下限, 位矩历三维幅高)
        矩历码期序(X, 位矩历二维下限, 位矩历三维幅低) = 矩历码期值(X, 位矩历二维下限, 位矩历三维幅低)
    Next
    Dim 码数 As Integer
    码数 = UBound(矩历码期值, 1)
    '------------------------------------------------------------------------------------
    '遍历日期排序
    '------------------------------------------------------------------------------------
    Dim 计数 As Integer
    For Y = 1 To UBound(矩历码期值, 2)
            '----------------------------------------------------------------------------
            '排序：幅涨（从大到小）
            '----------------------------------------------------------------------------
            ReDim 组排名(1 To 码数, 1 To 2) As Variant
            For X = 1 To 码数
                    组排名(X, 1) = X '& "_" & 矩历码期值(X, 0, 位矩历三维幅涨)
                    组排名(X, 2) = 矩历码期值(X, Y, 位矩历三维幅涨)
            Next
            '排序数组
            Call UTL组排序(组排名)
            计数 = 0
            For X = 码数 To 1 Step -1
                If 组排名(X, 2) <> "S" Then
                    计数 = 计数 + 1
                    矩历码期序(计数, Y, 位矩历三维幅涨) = 组排名(X, 1) '& "  " & 组排名(X, 2)
                End If
            Next
            '----------------------------------------------------------------------------
            '排序：幅高（从大到小）
            '----------------------------------------------------------------------------
            ReDim 组排名(1 To 码数, 1 To 2) As Variant
            For X = 1 To 码数
                    组排名(X, 1) = X ' 矩历码期值(X, 0, 位矩历三维幅高)
                    组排名(X, 2) = 矩历码期值(X, Y, 位矩历三维幅高)
            Next
            '排序数组
            Call UTL组排序(组排名)
            计数 = 0
            For X = 码数 To 1 Step -1
                If 组排名(X, 2) <> "S" Then
                    计数 = 计数 + 1
                    矩历码期序(计数, Y, 位矩历三维幅高) = 组排名(X, 1)  '& "  " & 组排名(X, 2)
                End If
            Next
            '----------------------------------------------------------------------------
            '排序：幅低（从小到大）
            '----------------------------------------------------------------------------
            ReDim 组排名(1 To 码数, 1 To 2) As Variant
            For X = 1 To 码数
                    组排名(X, 1) = X '& "_" & 矩历码期值(X, 0, 位矩历三维幅低)
                    组排名(X, 2) = 矩历码期值(X, Y, 位矩历三维幅低)
            Next
            '排序数组
            Call UTL组排序(组排名)
            计数 = 0
            For X = 1 To 码数
                If 组排名(X, 2) <> "S" Then
                    计数 = 计数 + 1
                    矩历码期序(计数, Y, 位矩历三维幅低) = 组排名(X, 1) '& "  " & 组排名(X, 2)
                End If
            Next
            '----------------------------------------------------------------------------
    Next
'========================================================================================
'返回
'========================================================================================
    历研数据引擎_基础数据排序 = 码数
End Function

