End Function






Function XLSOP统时全码_标析引擎( _
          ARRJSL As Variant _
        , ARRJSR As Variant _
        , AMMJJ As Variant _
        , AMMJF As Variant _
        , 典阶标 As Dictionary _
        , 典阶涨 As Dictionary _
        , 提取代码 As String _
        , 指定期类 As String _
        , Optional 阶标左型 As String = "月局" _
        , Optional 阶标右型 As String = "周局" _
        , Optional 指定结算日 As Date = "2050/1/1" _
        ) As Integer
'========================================================================================
'设置基础信息
'========================================================================================
    Dim 典数阶标 As Integer
    典数阶标 = 典阶标.Count
    Dim 典数阶涨 As Integer
    典数阶涨 = 典阶涨.Count
'========================================================================================
'获取行情数据
'========================================================================================
    Dim 指定结日 As Date
    指定结日 = Date
    Dim ARRCSV As Variant
    Dim 计数行情 As Integer
    计数行情 = STBASE取据引擎取据由外库(ARRCSV, 提取代码, 指定期类, 指定结日)
    If 计数行情 < 1 Then Exit Function
    '------------------------------------------------------------------------------------
    Dim 遍历下限 As Integer
    Dim 遍历上限 As Integer
    遍历下限 = LBound(ARRCSV, 1)
    遍历上限 = UBound(ARRCSV, 1)
    '====================================================================================
    '设置数据：OS信息
    '====================================================================================
    ARRJSL(位阶码矩列代码) = 提取代码
    ARRJSL(位阶码矩列期类) = 指定期类
    '累龄 记载 经过交易的期数
    ARRJSL(位阶码矩列累龄) = 计数行情
    '市日 记载 行情开始日期
    ARRJSL(位阶码矩列始日) = ARRCSV(遍历下限, 位列TS结期)
    '今日 记载 行情结束日期
    ARRJSL(位阶码矩列终日) = ARRCSV(遍历上限, 位列TS结期)
    '-------------------------------
    ARRJSR(位阶码矩列代码) = 提取代码
    ARRJSR(位阶码矩列期类) = 指定期类
    '累龄 记载 经过交易的期数
    ARRJSR(位阶码矩列累龄) = 计数行情
    '市日 记载 行情开始日期
    ARRJSR(位阶码矩列始日) = ARRCSV(遍历下限, 位列TS结期)
    '今日 记载 行情结束日期
    ARRJSR(位阶码矩列终日) = ARRCSV(遍历上限, 位列TS结期)
'========================================================================================
'变量声明    -----------------------------------------------------------------------------
'========================================================================================
    Dim 纵阶标 As String, 横阶标 As String
    '------------------------------------------------------------------------------------
    Dim 今收 As Double
    '------------------
    Dim 今涨 As Double
    Dim 前收 As Double
    Dim 前JZ#, 前JA#, 前JB#, 前JC#, 前JD#, 前JE#, 前JF#, 前JG#
    '------------------
    Dim 均基#
    Dim JZ#, JA#, JB#, JC#, JD#, JE#, JF#, JG#
    Dim BTZA%
    Dim BTZB%, BTAB%
    Dim BTZC%, BTAC%, BTBC%
    Dim BTAG%, BTAD%, BTCG%, BTCD%
    Dim BTEG%, BTAE%, BTFG%, BTCE%, BTDE%
    Dim BTAF%, BTCF%, BTDF%, BTEF%
    Dim 值局ZEFG$, 值局ZCDE$, 值局ZABC$
    '------------------------------------------------------------------------------------
    Dim 今仓 As Double, 前仓 As Double
    Dim 今资 As Long
    Dim 今手 As Double, 前手 As Double
'========================================================================================
'遍历文件    -----------------------------------------------------------------------------
'========================================================================================
    Dim 遍历序号 As Integer
    For 遍历序号 = 遍历下限 To 遍历上限
        '--------------------------------------------------------------------------------
        '迭代保存上一条信息
        前收 = 今收
        '--------------------------------------------------------------------------------
        '读取今日信息
        今收 = ARRCSV(遍历序号, 位列TS结收)
        '--------------------------------------------------------------------------------
        '计算：今涨
        If 前收 > 0 And 今收 > 0 Then 今涨 = (今收 / 前收 - 1) * 100
        今涨 = Round(今涨, 1)
        '--------------------------------------------------------------------------------
        
        
        
        
        '================================================================================
        '处理首行以后  -------------------------------------------------------------------
        '================================================================================
        If 遍历序号 > 遍历下限 Then
        

'########################################################################################
'########################################################################################
'##################################     统计核心     #####################################
'########################################################################################
'########################################################################################
'========================================================================================
'设置阶标
'========================================================================================
            If 指定期类 = 常期类为周 Then
                If 阶标左型 = "月局" Then
                    纵阶标 = 值局ZCDE
                ElseIf 阶标左型 = "周局" Then
                    纵阶标 = 值局ZABC
                End If
                If 阶标右型 = "月局" Then
                    横阶标 = 值局ZCDE
                ElseIf 阶标右型 = "周局" Then
                    横阶标 = 值局ZABC
                End If
            ElseIf 指定期类 = 常期类为日 Then
                If 阶标左型 = "月局" Then
                    纵阶标 = 值局ZEFG
                ElseIf 阶标左型 = "周局" Then
                    纵阶标 = 值局ZCDE
                ElseIf 阶标左型 = "日局" Then
                    纵阶标 = 值局ZABC
                End If
                If 阶标右型 = "月局" Then
                    横阶标 = 值局ZEFG
                ElseIf 阶标右型 = "周局" Then
                    横阶标 = 值局ZCDE
                ElseIf 阶标右型 = "日局" Then
                    横阶标 = 值局ZABC
                End If
            End If
'========================================================================================
'统计阶标
'========================================================================================
'    If 值局ZCDE = "2c" Or 值局ZCDE = "1b" Or 值局ZCDE = "1w" Then
            '============================================================================
            '设置矩阵：阶标分布
            '============================================================================
            '分析：纵坐标
            Dim 定阶码矩一维 As Integer
            Dim 定阶阶矩一维 As Integer
            Dim 定阶阶矩二维 As Integer
            Dim 阶阶一维 As Integer
            Dim 阶阶二维 As Integer
            Dim 定阶涨矩一维 As Integer
            Dim 定阶涨矩二维 As Integer
            Dim 阶涨一维 As Integer
            Dim 阶涨二维 As Integer
            '分析：纵坐标
            定阶码矩一维 = 典阶标(纵阶标) + 位阶码矩列展始 - 1
            ARRJSL(定阶码矩一维) = ARRJSL(定阶码矩一维) + 1
            '分析：横坐标
            定阶码矩一维 = 典阶标(横阶标) + 位阶码矩列展始 - 1
            ARRJSR(定阶码矩一维) = ARRJSR(定阶码矩一维) + 1
            '============================================================================
            '设置矩阵：标标
            '============================================================================
            定阶阶矩一维 = 典阶标(纵阶标)
            定阶阶矩二维 = 典阶标(横阶标)
            阶阶一维 = 典数阶标
            阶阶二维 = 典数阶标
            '----------------------------------------------------------------------------
            AMMJJ(定阶阶矩一维, 定阶阶矩二维, 位阶阶矩三维数和) = AMMJJ(定阶阶矩一维, 定阶阶矩二维, 位阶阶矩三维数和) + 1
            AMMJJ(定阶阶矩一维, 阶阶二维 + 1, 位阶阶矩三维数和) = AMMJJ(定阶阶矩一维, 阶阶二维 + 1, 位阶阶矩三维数和) + 1
            AMMJJ(阶阶一维 + 1, 定阶阶矩二维, 位阶阶矩三维数和) = AMMJJ(阶阶一维 + 1, 定阶阶矩二维, 位阶阶矩三维数和) + 1
            AMMJJ(阶阶一维 + 1, 阶阶二维 + 1, 位阶阶矩三维数和) = AMMJJ(阶阶一维 + 1, 阶阶二维 + 1, 位阶阶矩三维数和) + 1
            '----------------------------------------------------------------------------
            AMMJJ(定阶阶矩一维, 定阶阶矩二维, 位阶阶矩三维涨数) = AMMJJ(定阶阶矩一维, 定阶阶矩二维, 位阶阶矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            AMMJJ(定阶阶矩一维, 阶阶二维 + 1, 位阶阶矩三维涨数) = AMMJJ(定阶阶矩一维, 阶阶二维 + 1, 位阶阶矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            AMMJJ(阶阶一维 + 1, 定阶阶矩二维, 位阶阶矩三维涨数) = AMMJJ(阶阶一维 + 1, 定阶阶矩二维, 位阶阶矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            AMMJJ(阶阶一维 + 1, 阶阶二维 + 1, 位阶阶矩三维涨数) = AMMJJ(阶阶一维 + 1, 阶阶二维 + 1, 位阶阶矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            '----------------------------------------------------------------------------
            AMMJJ(定阶阶矩一维, 定阶阶矩二维, 位阶阶矩三维涨和) = AMMJJ(定阶阶矩一维, 定阶阶矩二维, 位阶阶矩三维涨和) + 今涨
            AMMJJ(定阶阶矩一维, 阶阶二维 + 1, 位阶阶矩三维涨和) = AMMJJ(定阶阶矩一维, 阶阶二维 + 1, 位阶阶矩三维涨和) + 今涨
            AMMJJ(阶阶一维 + 1, 定阶阶矩二维, 位阶阶矩三维涨和) = AMMJJ(阶阶一维 + 1, 定阶阶矩二维, 位阶阶矩三维涨和) + 今涨
            AMMJJ(阶阶一维 + 1, 阶阶二维 + 1, 位阶阶矩三维涨和) = AMMJJ(阶阶一维 + 1, 阶阶二维 + 1, 位阶阶矩三维涨和) + 今涨
            '============================================================================
            '设置矩阵：标涨
            '针对周类：要对月类进行限制2c
            '针对日类：要对月类、周类进行限制2c_2c
            '要划分形态：更细的形态
            '============================================================================
            定阶涨矩一维 = 典阶标(纵阶标)
            定阶涨矩二维 = 1
            For i = 1 To 典阶涨.Count
                If 今涨 >= CInt(典阶涨.Items(i - 1)) Then
                    定阶涨矩二维 = i
                    'Debug.Print I, CInt(典阶涨.Items(I - 1)), 今涨, 今涨 >= CInt(典阶涨.Items(I - 1))
                End If
            Next
            阶涨一维 = 典数阶标
            阶涨二维 = 典数阶涨
            '----------------------------------------------------------------------------
            AMMJF(定阶涨矩一维, 定阶涨矩二维, 位阶涨矩三维数和) = AMMJF(定阶涨矩一维, 定阶涨矩二维, 位阶涨矩三维数和) + 1
            AMMJF(定阶涨矩一维, 阶涨二维 + 1, 位阶涨矩三维数和) = AMMJF(定阶涨矩一维, 阶涨二维 + 1, 位阶涨矩三维数和) + 1
            AMMJF(阶涨一维 + 1, 定阶涨矩二维, 位阶涨矩三维数和) = AMMJF(阶涨一维 + 1, 定阶涨矩二维, 位阶涨矩三维数和) + 1
            AMMJF(阶涨一维 + 1, 阶涨二维 + 1, 位阶涨矩三维数和) = AMMJF(阶涨一维 + 1, 阶涨二维 + 1, 位阶涨矩三维数和) + 1
            '----------------------------------------------------------------------------
            AMMJF(定阶涨矩一维, 定阶涨矩二维, 位阶涨矩三维涨数) = AMMJF(定阶涨矩一维, 定阶涨矩二维, 位阶涨矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            AMMJF(定阶涨矩一维, 阶涨二维 + 1, 位阶涨矩三维涨数) = AMMJF(定阶涨矩一维, 阶涨二维 + 1, 位阶涨矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            AMMJF(阶涨一维 + 1, 定阶涨矩二维, 位阶涨矩三维涨数) = AMMJF(阶涨一维 + 1, 定阶涨矩二维, 位阶涨矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            AMMJF(阶涨一维 + 1, 阶涨二维 + 1, 位阶涨矩三维涨数) = AMMJF(阶涨一维 + 1, 阶涨二维 + 1, 位阶涨矩三维涨数) + IIf(今涨 >= 0, 1, 0)
            '----------------------------------------------------------------------------
            AMMJF(定阶涨矩一维, 定阶涨矩二维, 位阶涨矩三维涨和) = AMMJF(定阶涨矩一维, 定阶涨矩二维, 位阶涨矩三维涨和) + 今涨
            AMMJF(定阶涨矩一维, 阶涨二维 + 1, 位阶涨矩三维涨和) = AMMJF(定阶涨矩一维, 阶涨二维 + 1, 位阶涨矩三维涨和) + 今涨
            AMMJF(阶涨一维 + 1, 定阶涨矩二维, 位阶涨矩三维涨和) = AMMJF(阶涨一维 + 1, 定阶涨矩二维, 位阶涨矩三维涨和) + 今涨
            AMMJF(阶涨一维 + 1, 阶涨二维 + 1, 位阶涨矩三维涨和) = AMMJF(阶涨一维 + 1, 阶涨二维 + 1, 位阶涨矩三维涨和) + 今涨
            '============================================================================
'        End If
'########################################################################################
'########################################################################################
'##################################     统计核心     #####################################
'########################################################################################
'########################################################################################
'========================================================================================
'########################################################################################
'########################################################################################
'##################################      OS核心      #####################################
'##################################   内容整体复制   #####################################
'########################################################################################
'########################################################################################
'========================================================================================
'计算：基础信息
'因为需要统计【昨天指标】对应的【今天涨幅】，所以需要将此部分放到【统计】的后面
'========================================================================================
            前JZ = JZ
            前JA = JA
            前JB = JB
            前JC = JC
            前JD = JD
            前JE = JE
            前JF = JF
            前JG = JG
            '----------------------------------------------------------------------------
            JZ = (1 / 3) * JZ + (2 / 3) * 今收
            均基 = JZ
            JA = (4 / 6) * JA + (2 / 6) * 均基
            JB = (11 / 13) * JB + (2 / 13) * 均基
            JC = (25 / 27) * JC + (2 / 27) * 均基
            JD = (59 / 61) * JD + (2 / 61) * 均基
            JE = (119 / 121) * JE + (2 / 121) * 均基
            JF = (239 / 241) * JF + (2 / 241) * 均基
            JG = (479 / 481) * JG + (2 / 481) * 均基
            JZ = Round(JZ, 3)
            JA = Round(JA, 3)
            JB = Round(JB, 3)
            JC = Round(JC, 3)
            JD = Round(JD, 3)
            JE = Round(JE, 3)
            JF = Round(JF, 3)
            JG = Round(JG, 3)
            '----------------------------------------------------------------------------
            BTZA = STBASE结算工具_衍生交叉天数(BTZA, JZ, JA)
            BTZB = STBASE结算工具_衍生交叉天数(BTZB, JZ, JB)
            BTAB = STBASE结算工具_衍生交叉天数(BTAB, JA, JB)
            BTZC = STBASE结算工具_衍生交叉天数(BTZC, JZ, JC)
            BTAC = STBASE结算工具_衍生交叉天数(BTAC, JA, JC)
            BTBC = STBASE结算工具_衍生交叉天数(BTBC, JB, JC)
            BTAG = STBASE结算工具_衍生交叉天数(BTAG, JZ, JD)
            BTAD = STBASE结算工具_衍生交叉天数(BTAD, JA, JD)
            BTCG = STBASE结算工具_衍生交叉天数(BTCG, JB, JD)
            BTCD = STBASE结算工具_衍生交叉天数(BTCD, JC, JD)
            BTEG = STBASE结算工具_衍生交叉天数(BTEG, JZ, JE)
            BTAE = STBASE结算工具_衍生交叉天数(BTAE, JA, JE)
            BTFG = STBASE结算工具_衍生交叉天数(BTFG, JB, JE)
            BTCE = STBASE结算工具_衍生交叉天数(BTCE, JC, JE)
            BTDE = STBASE结算工具_衍生交叉天数(BTDE, JD, JE)
            BTAF = STBASE结算工具_衍生交叉天数(BTAF, JA, JF)
            BTCF = STBASE结算工具_衍生交叉天数(BTCF, JC, JF)
            BTDF = STBASE结算工具_衍生交叉天数(BTDF, JD, JF)
            BTEF = STBASE结算工具_衍生交叉天数(BTEF, JE, JF)
            '===============================================================================
            '衍生：局系统
            '===============================================================================
            值局ZEFG = STBASE结算工具_衍生局(JZ, JE, JF, JG)
            值局ZCDE = STBASE结算工具_衍生局(JZ, JC, JD, JE)
            值局ZABC = STBASE结算工具_衍生局(JZ, JA, JB, JC)
'            If 值局ZABC = "2c" And 结收 < 前收 Then 值局ZABC = "2d"
'========================================================================================
'########################################################################################
'########################################################################################
'##################################      OS核心      #####################################
'##################################   内容整体复制   #####################################
'########################################################################################
'########################################################################################





        '================================================================================
        '处理首行  -----------------------------------------------------------------------
        '================================================================================
        ElseIf 遍历序号 = 遍历下限 Then
            今涨 = 0
            
            JZ = 今收
            JA = 今收
            JB = 今收
            JC = 今收
            JD = 今收
            JE = 今收
            JF = 今收
            
            值局ZEFG = "2c"
            值局ZCDE = "2c"
            值局ZABC = "2c"
        End If
        '================================================================================
    Next 遍历序号
'========================================================================================
'返回
'========================================================================================
    Erase ARRCSV
    '------------------------------------------------------------------------------------
    XLSOP统时全码_标析引擎 = 计数行情
'========================================================================================
End Function
