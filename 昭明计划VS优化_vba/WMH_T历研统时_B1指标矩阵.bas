'待完成：期类为周，K线低点与均线的交叉情况
'研究的目的是：虽然选择交叉的均线十分有效，但是在持有过程中，K线的低点会与均线交叉，造成心理因素退出持有
'研究结果：找到安全（低点不会达到）、有效（均线相交具有重要性）。对于每只股票，找到对应的重要性均线，以及适用于持仓的均线组合
'########################################################################################
'########################################################################################
'#################################  统时全码  遍历分析  ################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：针对市板进行分析
'========================================================================================
'========================================================================================
Function XL历研阶析前调模板( _
          Optional 被研市板 As String = "" _
        , Optional 阶标左型 As String = "阶纬" _
        , Optional 是否外簿 As Boolean = True _
        , Optional 阈值市日 As Date = #1/1/2013# _
        )
'========================================================================================
'确定码集
'========================================================================================
    Dim MSG As String
    '------------------------------------------------------------------------------------
    '确定来源工表
    '------------------------------------------------------------------------------------
    Dim MSFM As Worksheet
    If STBASE外簿工具_花册链接(MSFM, 常花中股) = False Then Exit Function
    '------------------------------------------------------------------------------------
    '确定码集
    '------------------------------------------------------------------------------------
    Dim 被研码集 As New Dictionary
    Dim CIDL As String
    Dim 代称 As String
    Dim 市日 As Date
    
    Dim 行号遍历 As Integer
    For 行号遍历 = 2 To MSFM.[a65536].End(xlUp).Row
        CIDL = MSFM.Cells(行号遍历, 位列花天CIDL).Value
        代称 = MSFM.Cells(行号遍历, 位列花天代称).Value
        市日 = MSFM.Cells(行号遍历, 位列花天市日).Value
        
        If UBCID是代码(CIDL) _
        And 被研码集.Exists(CIDL) = False _
        And (Len(市日) > 0 And 市日 < 阈值市日) _
        Then
            If Len(被研市板) = 0 Then
                被研码集.Add Key:=CIDL, Item:=代称
            ElseIf MSFM.Cells(行号遍历, 位列花天市板) = 被研市板 Then
                被研码集.Add Key:=CIDL, Item:=代称
            End If
        End If
    Next
    Set MSFM = Nothing
'========================================================================================
'设置工簿
'========================================================================================
    Dim wb As Workbook
    If 是否外簿 = False Then
        Set wb = ThisWorkbook
    Else
        Set wb = Workbooks.Add
    End If
'========================================================================================
'分析：交叉表
'========================================================================================
    Call XLSOP统时全码_标析正程(常期类为周, 被研码集, wb, 阶标左型:="月局", 阶标右型:="周局", 被研主题:="周类局局交叉分布情况", 基色底:=常色主黄)
    '------------------------------------------------------------------------------------
    Call XLSOP统时全码_标析正程(常期类为日, 被研码集, wb, 阶标左型:="周局", 阶标右型:="日局", 被研主题:="日类局局交叉分布情况", 基色底:=常色十橙)
    Call XLSOP统时全码_标析正程(常期类为日, 被研码集, wb, 阶标左型:="月局", 阶标右型:="日局", 被研主题:="日类局局交叉分布情况", 基色底:=常色十橙)
    Call XLSOP统时全码_标析正程(常期类为日, 被研码集, wb, 阶标左型:="月局", 阶标右型:="周局", 被研主题:="日类局局交叉分布情况", 基色底:=常色十橙)
'========================================================================================
'分析：均线重要性分析
'========================================================================================
    Dim WSSUM As Worksheet
    Dim WSJXX As Worksheet
    Dim 被研期类  As String
    Dim 基色底  As Long
    '------------------------------------------------------------------------------------
    '均重：月线
    '------------------------------------------------------------------------------------
    被研期类 = 常期类为月
    基色底 = 常色十靛
    Call PBASE格程工具_表操工表新增(WSSUM, "Jxs" & 被研期类, wb, 基色底:=基色底)
    Call PBASE格程工具_表操工表新增(WSJXX, "Jxx" & 被研期类, wb, 基色底:=基色底)
    Call XLSOP统时全码_线重正程(被研期类, 被研码集, WSJXX, WSSUM)
    '------------------------------------------------------------------------------------
    '均重：周线
    '------------------------------------------------------------------------------------
    被研期类 = 常期类为周
    基色底 = 常色主靛
    Call PBASE格程工具_表操工表新增(WSSUM, "Jxs" & 被研期类, wb, 基色底:=基色底)
    Call PBASE格程工具_表操工表新增(WSJXX, "Jxx" & 被研期类, wb, 基色底:=基色底)
    Call XLSOP统时全码_线重正程(被研期类, 被研码集, WSJXX, WSSUM)
    '------------------------------------------------------------------------------------
    '均重：日线
    '------------------------------------------------------------------------------------
    被研期类 = 常期类为日
    基色底 = 常色主碧
    Call PBASE格程工具_表操工表新增(WSSUM, "Jxs" & 被研期类, wb, 基色底:=基色底)
    Call PBASE格程工具_表操工表新增(WSJXX, "Jxx" & 被研期类, wb, 基色底:=基色底)
    Call XLSOP统时全码_线重正程(被研期类, 被研码集, WSJXX, WSSUM)
    '------------------------------------------------------------------------------------
    Set WSJXX = Nothing
    Set WSSUM = Nothing
'========================================================================================
'保存：外部存档
'========================================================================================
    Dim 工簿简称 As String
    Dim 工簿路径 As String
    
    工簿简称 = String(3, "J") & 被研市板 & "." & Format$(Now, "YYYYMMDDhhnn")
    工簿路径 = ThisWorkbook.Path & "\" & 工簿简称 & ".xlsx"
    '------------------------------------------------------------------------------------
    '进行保存
    '------------------------------------------------------------------------------------
    If wb.Name <> ThisWorkbook.Name Then
        MSG = MSG & vbCrLf & PBASE格程工具_表操保存外簿(wb, 工簿简称)
        MSG = MSG & vbCrLf
        'WB.Close
    End If
    '------------------------------------------------------------------------------------
    Set wb = Nothing
'========================================================================================
End Function
