'阶阶矩阵标标[AMMJC]：阶标按照代码进行分布
'阶阶矩阵标涨[AMMJJ]：阶阶阶化关系统计
'########################################################################################
'########################################################################################
'#################################  统时全码  阶阶矩阵  ##################################
'########################################################################################
'########################################################################################
'========================================================================================
'========================================================================================
'功能：标析
'========================================================================================
'========================================================================================
Function XLSOP统时全码_标析正程( _
          期类 As String _
        , 典被研代码 As Dictionary _
        , wb As Workbook _
        , 阶标左型 As String _
        , 阶标右型 As String _
        , Optional 被研主题 As String = "乾局" _
        , Optional ByVal 基色底 As Long = 常色主碧 _
        ) As Integer
'========================================================================================
'设置典集
'========================================================================================
    Dim 典阶标 As New Dictionary
    Dim 典数阶标 As Integer
    典数阶标 = XLSOP统时全码基程_设置典阶标(典阶标, 期类, 阶标左型:=阶标左型, 阶标右型:=阶标右型)
    '------------------------------------------------------------------------------------
    Dim 典阶涨 As New Dictionary
    Dim 典数阶涨 As Integer
    典数阶涨 = XLSOP统时全码基程_设置典阶涨(典阶涨, 期类)
'========================================================================================
'阶阶数组：初始赋值
'========================================================================================
    Dim X As Integer
    Dim Y As Integer
    Dim Z As Integer
    Dim i As Integer
    '------------------------------------------------------------------------------------
    '阶阶矩阵：初始坐标赋值
    '------------------------------------------------------------------------------------
    Dim AMMJJ As Variant
    ReDim AMMJJ(0 To 典数阶标 + 1, 0 To 典数阶标 + 1, 1 To 3) As Variant
    For Z = 1 To 3
        AMMJJ(0, 0, Z) = 期类
        For i = 1 To 典数阶标
            AMMJJ(i, 0, Z) = 典阶标.Keys(i - 1)
            AMMJJ(0, i, Z) = 典阶标.Keys(i - 1)
        Next
    Next
    '------------------------------------------------------------------------------------
    '阶涨矩阵：初始坐标赋值
    '------------------------------------------------------------------------------------
    Dim AMMJF As Variant
    ReDim AMMJF(0 To 典数阶标 + 1, 0 To 典数阶涨 + 1, 1 To 3) As Variant
    For Z = 1 To 3
        AMMJF(0, 0, Z) = 期类
        For X = 1 To 典数阶标
            AMMJF(X, 0, Z) = 典阶标.Keys(X - 1)
        Next
        For Y = 1 To 典数阶涨
            AMMJF(0, Y, Z) = 典阶涨.Items(Y - 1)
        Next
    Next
'========================================================================================
'生成数据
'========================================================================================
    Dim ANNJSL As Variant
    ReDim ANNJSL(1 To 典被研代码.Count, 1 To 位阶码矩列展始 - 1 + 典数阶标) As Variant
    Dim ANNJSR As Variant
    ReDim ANNJSR(1 To 典被研代码.Count, 1 To 位阶码矩列展始 - 1 + 典数阶标) As Variant
    '------------------------------------------------------------------------------------
    '生成数据
    '------------------------------------------------------------------------------------
    Dim 被研代码 As String
    Dim 被研代称 As String
    Dim 计数导入 As Integer
    For 计数导入 = 1 To 典被研代码.Count
        '--------------------------------------------------------------------------------
        被研代码 = 典被研代码.Keys(计数导入 - 1)
        被研代称 = 典被研代码.Items(计数导入 - 1)
        '--------------------------------------------------------------------------------
        '数据生成
        '--------------------------------------------------------------------------------
        ReDim ARRJSL(1 To 位阶码矩列展始 - 1 + 典数阶标) As Variant
        ReDim ARRJSR(1 To 位阶码矩列展始 - 1 + 典数阶标) As Variant
        Call XLSOP统时全码_标析引擎(ARRJSL, ARRJSR, AMMJJ, AMMJF, 典阶标, 典阶涨, 被研代码, 期类, 阶标左型:=阶标左型, 阶标右型:=阶标右型)
        '--------------------------------------------------------------------------------
        '数据输出：左
        '--------------------------------------------------------------------------------
        For i = 1 To 位阶码矩列展始 - 1 + 典数阶标
            ANNJSL(计数导入, i) = ARRJSL(i)
            ANNJSR(计数导入, i) = ARRJSL(i)
        Next
        ANNJSL(计数导入, 位阶码矩列代称) = 被研代称
        ANNJSL(计数导入, 位阶码矩列市板) = 阶标左型
        ANNJSR(计数导入, 位阶码矩列代称) = 被研代称
        ANNJSR(计数导入, 位阶码矩列市板) = 阶标右型
        '-----------------------------------------------------------------------------
        DoEvents
        Debug.Print "标析>>" & 期类 & ">>" & 计数导入, 被研代码, 被研代称
        '--------------------------------------------------------------------------------
    Next
'========================================================================================
'格式化：阶标分布
'========================================================================================
    '作用：分析该期类左坐标的分布情况
    Dim WSJSL As Worksheet
    Call PBASE格程工具_表操工表新增(WSJSL, "JS." & 期类 & 阶标左型, wb, 基色底:=常色主黑)
    Call UTL数据转换_集ARR2WS(ANNJSL, WSJSL)
    Call XLSOP统时全码_标析格程阶标分布(WSJSL, 典阶标)
    Set WSJSL = Nothing
    '------------------------------------------------------------------------------------
    '作用：分析该期类右坐标的分布情况
    Dim WSJSR As Worksheet
    Call PBASE格程工具_表操工表新增(WSJSR, "JS." & 期类 & 阶标右型, wb, 基色底:=常色主黑)
    Call UTL数据转换_集ARR2WS(ANNJSR, WSJSR)
    Call XLSOP统时全码_标析格程阶标分布(WSJSR, 典阶标)
    Set WSJSR = Nothing
'========================================================================================
'格式化：阶阶矩阵
'========================================================================================
    Dim WSJJ As Worksheet
    Call PBASE格程工具_表操工表新增(WSJJ, "JJ." & 期类 & 阶标左型 & 阶标右型, wb, 基色底)
    With WSJJ
        .Cells.Interior.ColorIndex = 1
        .Cells.Font.Size = 10
        .Columns(1).Font.Color = 基色底
        With .Cells(1, 1)
            .Value = 期类 & "期类：" & 阶标左型 & " * " & 阶标右型
            .Font.Size = 15
            .Font.Bold = True
        End With
    End With
    '------------------------------------------------------------------------------------
    '格式化：阶阶矩阵标标
    '------------------------------------------------------------------------------------
    Call XLSOP统时全码_标析格程标标矩阵(WSJJ, AMMJJ, 典阶标, 基行:=3)
    '------------------------------------------------------------------------------------
    '格式化：阶阶矩阵标涨
    '------------------------------------------------------------------------------------
    Call XLSOP统时全码_标析格程标涨矩阵(WSJJ, AMMJF, 典阶标, 典阶涨)
    '------------------------------------------------------------------------------------
    '格式化
    '------------------------------------------------------------------------------------
    ActiveWindow.Zoom = 80
    If InStr(阶标左型, "局") > 0 Then
        WSJJ.Columns.ColumnWidth = 4
        WSJJ.Columns(1).ColumnWidth = 6
        WSJJ.Columns(典数阶标 + 2).ColumnWidth = 10
    Else
        WSJJ.Columns.ColumnWidth = 4
        WSJJ.Columns.AutoFit
    End If
'========================================================================================
'返回
'========================================================================================
    Set 典阶标 = Nothing
    Set 典阶涨 = Nothing
    XLSOP统时全码_标析正程 = 计数导入
'========================================================================================
End Function







'========================================================================================
'========================================================================================
'格式化：阶标分布
'========================================================================================
'========================================================================================
Function XLSOP统时全码_标析格程阶标分布( _
          WSJC As Worksheet _
        , 典阶标 As Dictionary _
        , Optional ByVal 基色底 As Long = 常色主碧 _
        ) As Integer
'========================================================================================
'格式化
'========================================================================================
    Dim 典数阶标 As Integer
    典数阶标 = 典阶标.Count
    '------------------------------------------------------------------------------------
    '格式化：列
    '------------------------------------------------------------------------------------
    WSJC.Cells.Interior.ColorIndex = 1
    WSJC.Cells.Font.Size = 10
    WSJC.Columns(位阶码矩列代码).Font.ColorIndex = 1
    WSJC.Columns(位阶码矩列代称).Font.ColorIndex = 15
    WSJC.Columns(位阶码矩列市板).Font.ColorIndex = 1
    WSJC.Columns(位阶码矩列期类).Font.ColorIndex = 1
    WSJC.Columns(位阶码矩列累龄).Font.ColorIndex = 1
    WSJC.Columns(位阶码矩列代码).ColumnWidth = 0.2
    WSJC.Columns(位阶码矩列代称).ColumnWidth = 9
    WSJC.Columns(位阶码矩列市板).ColumnWidth = 6
    WSJC.Columns(位阶码矩列期类).ColumnWidth = 4
    WSJC.Columns(位阶码矩列累龄).ColumnWidth = 4
    WSJC.Columns(位阶码矩列始日).Hidden = True
    WSJC.Columns(位阶码矩列终日).Hidden = True
    '------------------------------------------------------------------------------------
    '格式化：标题
    '------------------------------------------------------------------------------------
    For i = 1 To 典数阶标
        WSJC.Cells(位阶码矩行标题, i + 位阶码矩列展始 - 1) = 典阶标.Keys(i - 1)
    Next
    WSJC.Cells(位阶码矩行标题, 位阶码矩行开始) = "代码"
    WSJC.Cells(位阶码矩行标题, 位阶码矩列代码) = "代称"
    WSJC.Cells(位阶码矩行标题, 位阶码矩列市板) = "阶标"
    WSJC.Cells(位阶码矩行标题, 位阶码矩列期类) = "期类"
    WSJC.Cells(位阶码矩行标题, 位阶码矩列累龄) = "累龄"
    WSJC.Cells(位阶码矩行标题, 位阶码矩列始日) = "始日"
    WSJC.Cells(位阶码矩行标题, 位阶码矩列终日) = "终日"
    WSJC.Cells(位阶码矩行标题, 位阶码矩列累龄) = "累龄"
    WSJC.Rows(1).Font.ColorIndex = 2
'========================================================================================
'输出矩阵：阶码矩阵
'========================================================================================
    Dim 累龄 As Integer
    Dim 色度 As Double
    Dim i As Integer
    Dim X As Integer
    Dim Y As Integer
    '------------------------------------------------------------------------------------
    X = 1
    For Y = 1 To 典数阶标
        With WSJC.Cells(X, 位阶码矩列展始).Offset(0, 典数阶标).Cells(1, Y)
            .Value = .Offset(0, -1 * 典数阶标)
        End With
    Next
    For X = PBASE格程工具_表参末行指定(WSJC, 1) To 位阶码矩行开始 Step -1
        累龄 = WSJC.Cells(X, 位阶码矩列累龄)
        If 累龄 = 0 Then
            WSJC.Rows(X).Delete
        Else
            For Y = 1 To 典数阶标
                With WSJC.Cells(X, 位阶码矩列展始).Cells(1, Y).Offset(0, 典数阶标)
                    .Value = Round(100 * .Offset(0, -1 * 典数阶标) / 累龄, 1)
                    If .Value > 30 Then
                        .Interior.Color = 常色六青
                        色度 = .Value / 100
                        .Interior.TintAndShade = 色度
                    ElseIf .Value > 10 Then
                        .Interior.Color = 常色主靛
                        色度 = .Value / 100
                        .Interior.TintAndShade = 色度
                    ElseIf .Value > 5 Then
                        .Interior.Color = 常色八43
                        色度 = .Value / 100
                        .Interior.TintAndShade = 色度
                    ElseIf .Value > 1 Then
                        .Interior.ColorIndex = 50
                        色度 = .Value / 100
                        .Interior.TintAndShade = 色度
                    ElseIf .Value > 0 Then
                        .Interior.ColorIndex = 51
                    Else
                        .Interior.ColorIndex = 1
                    End If
                    .Font.Color = .Interior.Color
                End With
            Next
        End If
    Next
    WSJC.Cells(1, 位阶码矩列展始).Resize(1, 典数阶标).Columns.ColumnWidth = 6
    WSJC.Cells(1, 位阶码矩列展始).Resize(1, 典数阶标).Columns.Hidden = True
    WSJC.Cells(1, 位阶码矩列展始).Offset(0, 典数阶标).Resize(1, 典数阶标).Columns.ColumnWidth = 2
'========================================================================================
'格式化：排序
'========================================================================================
    With WSJC
        .Sort.SortFields.Clear
        .Sort.SortFields.Add Key:=.Columns(位阶码矩列代码) _
            , SortOn:=xlSortOnValues, Order:=xlAscending _
            , DataOption:=xlSortNormal
        .Sort.SortFields.Add Key:=.Columns(位阶码矩列期类) _
            , SortOn:=xlSortOnValues, Order:=xlAscending, CustomOrder:="M,W,D" _
            , DataOption:=xlSortNormal
    End With
    With WSJC.Sort
        .SetRange WSJC.UsedRange
        .Header = xlYes
        .MatchCase = False
        .Orientation = xlTopToBottom
        .SortMethod = xlPinYin
        .Apply
    End With
'========================================================================================
'格式化：整体
'========================================================================================
    Call PBASE格程工具_表冻结锁定(WSJC, 缩放:=100)
'========================================================================================
End Function




'========================================================================================
'========================================================================================
'格式化：不同指标转换之间的矩阵
'========================================================================================
'========================================================================================
Function XLSOP统时全码_标析格程标标矩阵( _
          WSJJ As Worksheet _
        , AMMJJ As Variant _
        , 典阶标 As Dictionary _
        , Optional 基行 As Integer = 1 _
        , Optional 基列 As Integer = 1 _
        , Optional ByVal 基色底 As Long = 常色主黄 _
        ) As Integer
'========================================================================================
'参数
'========================================================================================
    Dim 典数阶标 As Integer
    典数阶标 = 典阶标.Count
    '------------------------------------------------------------------------------------
    Dim 维行  As Integer
    Dim 维列 As Integer
    维行 = 典数阶标
    维列 = 典数阶标
    '------------------------------------------------------------------------------------
    Dim 总值本行 As Long
    Dim 总值本列 As Long
    Dim 总值本矩 As Long
'########################################################################################
'########################################################################################
'主题：总数
'########################################################################################
'########################################################################################
    With WSJJ.Rows(基行).Borders(xlEdgeTop)
        .LineStyle = xlContinuous
        .Color = 基色底
        .Weight = xlThin
    End With
'========================================================================================
'输出矩阵: 全占比
'========================================================================================
        WSJJ.Cells(基行, 基列) = "全占比：按矩阵汇总"
        基行 = 基行 + 1
        '--------------------------------------------------------------------------------
        For X = 1 To 维行 + 2
            WSJJ.Cells(基行, 基列).Cells(X, 1) = AMMJJ(X - 1, 0, 位阶阶矩三维数和)
        Next
        For Y = 1 To 维列 + 2
            WSJJ.Cells(基行, 基列).Cells(1, Y) = AMMJJ(0, Y - 1, 位阶阶矩三维数和)
        Next
        '--------------------------------------------------------------------------------
        总值本矩 = AMMJJ(维行 + 1, 维列 + 1, 位阶阶矩三维数和)
        For X = 1 To 维行 + 1
            For Y = 1 To 维列 + 1
                If 总值本矩 > 0 Then
