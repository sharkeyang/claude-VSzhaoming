        For X = 1 To 维行 + 1
            For Y = 1 To 维列 + 1
                If 总值本矩 > 0 Then
                    WSJJ.Cells(基行, 基列).Cells(X + 1, Y + 1) = Round(AMMJF(X, Y, 位阶阶矩三维数和) / 总值本矩, 3) * 100
                End If
            Next
        Next
        For X = 1 To 维行
            For Y = 1 To 维列
                With WSJJ.Cells(基行, 基列).Cells(X + 1, Y + 1)
                    .Interior.Color = 常色八蓝
                    If .Value > 10 Then
                        .Interior.TintAndShade = 0.8
                    ElseIf .Value > 5 Then
                        .Interior.TintAndShade = 0.5
                    ElseIf .Value > 1 Then
                        .Interior.TintAndShade = 0.1
                    Else
                        .Interior.TintAndShade = -0.5
                    End If
                End With
            Next
        Next
        '--------------------------------------------------------------------------------
        '格式化
        '--------------------------------------------------------------------------------
        WSJJ.Cells(基行, 基列).Resize(维行 + 2, 维列 + 2).NumberFormatLocal = 全设格式of零位
        WSJJ.Cells(基行, 基列).Resize(维行 + 2, 维列 + 2).Font.ColorIndex = 2
        WSJJ.Cells(基行, 基列).Offset(1, 1).Resize(维行, 维列).Font.ColorIndex = 1
        WSJJ.Cells(基行, 基列).Offset(1, 1).Resize(维行, 维列).Borders.ColorIndex = 1
        基行 = 基行 + 维行 + 3
'########################################################################################
'########################################################################################
'主题：涨幅
'########################################################################################
'########################################################################################
    With WSJJ.Rows(基行).Borders(xlEdgeTop)
        .LineStyle = xlContinuous
        .Color = 基色底
        .Weight = xlThin
    End With
''========================================================================================
''输出矩阵: 涨幅矩阵
''========================================================================================
'        WSJJ.Cells(基行, 基列) = "涨幅矩阵（绝对数）"
'        基行 = 基行 + 1
'        '------------------------------------------------------------------------------------
'        '原样输出
'        '------------------------------------------------------------------------------------
'        For X = 1 To 维行 + 2
'        For Y = 1 To 维列 + 2
'            WSJJ.Cells(基行, 基列).Cells(X, Y) = AMMJF(X - 1, Y - 1, 位阶涨矩三维涨和)
'        Next
'        Next
'        '------------------------------------------------------------------------------------
'        'UTL展示幅度
'        '------------------------------------------------------------------------------------
'        总值本矩 = WSJJ.Cells(基行, 基列).Cells(维行 + 2, 维列 + 2)
'        For X = 1 To 维行
'            For Y = 1 To 维列
'                With WSJJ.Cells(基行, 基列).Cells(X + 1, Y + 1)
'                    If .Value > 0 Then
'                        .Value = CLng(.Value)
'                        .Interior.ColorIndex = 36
'                    ElseIf .Value < 0 Then
'                        .Value = CLng(.Value)
'                        .Interior.ColorIndex = 35
'                    Else
'                        .Interior.ColorIndex = 15
'                    End If
'                End With
'            Next
'        Next
'        WSJJ.Rows(基行).Font.ColorIndex = 2
'        WSJJ.Rows(基行).Rows(维行 + 2).Font.ColorIndex = 2
'        基行 = 基行 + 维行 + 3
'========================================================================================
'输出矩阵: 涨幅矩阵平均
'========================================================================================
        WSJJ.Cells(基行, 基列) = "涨幅平均矩阵"
        基行 = 基行 + 1
        '--------------------------------------------------------------------------------
        For X = 1 To 维行 + 2
            WSJJ.Cells(基行, 基列).Cells(X, 1) = AMMJF(X - 1, 0, 位阶阶矩三维数和)
        Next
        For Y = 1 To 维列 + 2
            WSJJ.Cells(基行, 基列).Cells(1, Y) = AMMJF(0, Y - 1, 位阶阶矩三维数和)
        Next
        '--------------------------------------------------------------------------------
        For X = 1 To 维行 + 1
        For Y = 1 To 维列 + 1
            With WSJJ.Cells(基行, 基列).Cells(X + 1, Y + 1)
                If AMMJF(X, Y, 位阶阶矩三维数和) > 0 Then
                    .Value = Round(AMMJF(X, Y, 位阶阶矩三维涨和) / AMMJF(X, Y, 位阶阶矩三维数和), 1)
                    If .Value >= 0 Then
                        If .Value > 2 Then
                            .Interior.Color = 常色八黄
                        ElseIf .Value > 1 Then
                            .Interior.Color = 常色五黄
                        ElseIf .Value > 0.5 Then
                            .Interior.Color = 常色三黄
                        Else
                            .Interior.Color = 常色一黄
                        End If
                    Else
                            .Interior.Color = 常色四青
                    End If
                Else
                            .Interior.Color = 常色二灰
                End If
            End With
        Next
        Next
        '--------------------------------------------------------------------------------
        '格式化
        '--------------------------------------------------------------------------------
        WSJJ.Cells(基行, 基列).Resize(维行 + 2, 维列 + 2).NumberFormatLocal = 全设格式of一位
        WSJJ.Cells(基行, 基列).Resize(维行 + 2, 维列 + 2).Font.ColorIndex = 1
        WSJJ.Cells(基行, 基列).Resize(维行 + 2, 1).Font.ColorIndex = 2
        WSJJ.Cells(基行, 基列).Resize(1, 维列 + 2).Font.ColorIndex = 2
        WSJJ.Cells(基行, 基列).Offset(1, 1).Resize(维行, 维列).Borders.ColorIndex = 1
        基行 = 基行 + 维行 + 5
'========================================================================================
'格式化
'========================================================================================
    WSJJ.Activate
    ActiveWindow.Zoom = 50
    WSJJ.Columns.ColumnWidth = 4
'    WSJJ.Columns.AutoFit
    WSJJ.Columns(1).ColumnWidth = 10
    WSJJ.Columns(维列 + 2).ColumnWidth = 10
