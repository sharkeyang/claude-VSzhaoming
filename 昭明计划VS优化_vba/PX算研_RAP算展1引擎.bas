'========================================================================================
'功能：算展格程包壳（通用生成 + 通用显示）
'========================================================================================
'========================================================================================
Function XL算展格程跨期( _
          ARRLLL As Variant _
        , WS As Worksheet _
        , Optional 被研期类 As String = 常期类为日 _
        , Optional 基色底 As Long = 常色研究 _
        , Optional 基列 As Integer = 1 _
        , Optional 基行 As Integer = 1 _
        , Optional ByRef 谕组 As Variant _
        ) As Integer
'========================================================================================
    Dim 列定位 As Integer
    列定位 = XL算展格程跨期_通用生成(ARRLLL, WS, 基色底:=基色底, 基列:=基列, 基行:=基行, 谕组:=谕组)
    Call XL算展格程跨期_通用显示(WS, 被研期类:=被研期类, 基列:=基列, 基行:=基行, 原始道基列:=列定位)
    XL算展格程跨期 = 列定位
End Function

'========================================================================================
'========================================================================================
'功能：算展格程——通用生成（写入全部11列，无周期判断）
'========================================================================================
'========================================================================================
Function XL算展格程跨期_通用生成( _
          ARRLLL As Variant _
        , WS As Worksheet _
        , Optional 基色底 As Long = 常色研究 _
        , Optional 基列 As Integer = 1 _
        , Optional 基行 As Integer = 1 _
        , Optional ByRef 谕组 As Variant _
        ) As Integer
'========================================================================================
'检查
'========================================================================================
    If VBA.IsEmpty(ARRLLL) = True Then
        Exit Function
    End If
'========================================================================================
'格式化：全局设置
'========================================================================================
            '============================================================================
            '全局设置
            '============================================================================
            WS.Tab.Color = 基色底
            With WS.Cells
                .ClearFormats
                .Interior.ColorIndex = 56
                .Font.Name = "宋体"
                .Font.Size = 10
            End With
            '============================================================================
            '调整与冻结
            '注意：此步骤要放在其他过程前面
            '============================================================================
            WS.Rows.Hidden = False
            WS.Columns.Hidden = False
            Call PBASE格程工具_表冻结锁定(WS, 基列:=基列)
'========================================================================================
'输出
'========================================================================================
    UTL宏工具_BEGIN
    '------------------------------------------------------------------------------------
    '生成神谕（如果已由数程传入则跳过）
    '------------------------------------------------------------------------------------
    If IsMissing(谕组) Then
        ReDim 谕组(LBound(ARRLLL, 1) To UBound(ARRLLL, 1), 1 To 位qt主宽) As Variant
        Call IQQQ跨码据擎_数程生成跨时神谕(谕组, ARRLLL, 基列:=1, 是否跨码:=False)
    End If
    '------------------------------------------------------------------------------------
    '写入全部11列（日龄、周龄、月龄、主期、主七、日键、周键、月键、日涨、周涨、月涨）
    '三组全写，无周期判断
    '------------------------------------------------------------------------------------
    Dim 基位日类 As Integer: 基位日类 = 0
    Dim 基位周类 As Integer: 基位周类 = 花宽单道
    Dim 基位月类 As Integer: 基位月类 = 花宽单道 * 2
    Dim 日类结日 As Date, 周类结日 As Date, 月类结日 As Date
    Dim X As Integer
    For X = LBound(谕组, 1) To UBound(谕组, 1)
        日类结日 = ARRLLL(X, 基位日类 + 位os结期)
        周类结日 = ARRLLL(X, 基位周类 + 位os结期)
        月类结日 = ARRLLL(X, 基位月类 + 位os结期)
        '龄族
        谕组(X, 位列算展of日龄) = ARRLLL(X, 基位日类 + 位os基累龄)
        谕组(X, 位列算展of周龄) = ARRLLL(X, 基位周类 + 位os基累龄)
        谕组(X, 位列算展of月龄) = ARRLLL(X, 基位月类 + 位os基累龄)
        '共享
        谕组(X, 位列算展of主期) = 日类结日
        谕组(X, 位列算展of主七) = Weekday(日类结日, vbMonday)
        '键族
        谕组(X, 位列算展of日键) = True
        谕组(X, 位列算展of周键) = (周类结日 = 日类结日)
        谕组(X, 位列算展of月键) = (月类结日 = 日类结日)
        '涨族
        谕组(X, 位列算展of日涨) = 谕组(X, 位谕of日波BSPR)
        谕组(X, 位列算展of周涨) = 谕组(X, 位谕of周波今涨幅)
        谕组(X, 位列算展of月涨) = 谕组(X, 位谕of月波今涨幅)
    Next
    '------------------------------------------------------------------------------------
    '输出：神谕
    '------------------------------------------------------------------------------------
    WS.Cells(基行, 基列).Resize(1, 位谕列终全部).EntireColumn.ClearContents
    Call UTL数据转换_集ARR2WS(谕组, WS, 始行:=基行 + 1, 始列:=基列)
    '格式化
    Dim 列定位 As Integer
    列定位 = IQQQ跨码展擎_按列神谕区域(WS, 基列:=基列)
    Call IQQQ跨码展擎_按行汇总(WS, 基列:=基列, 是否算展:=True)
    '------------------------------------------------------------------------------------
    '11列表头（通用生成只写标签，不控制显隐）
    '------------------------------------------------------------------------------------
    WS.Cells(1, 基列 + 位列算展of日龄 - 1) = "日龄"
    WS.Cells(1, 基列 + 位列算展of周龄 - 1) = "周龄"
    WS.Cells(1, 基列 + 位列算展of月龄 - 1) = "月龄"
    WS.Cells(1, 基列 + 位列算展of主期 - 1) = "期"
    WS.Cells(1, 基列 + 位列算展of主七 - 1) = "七"
    WS.Cells(1, 基列 + 位列算展of日键 - 1) = "日键"
    WS.Cells(1, 基列 + 位列算展of周键 - 1) = "周键"
    WS.Cells(1, 基列 + 位列算展of月键 - 1) = "月键"
    WS.Cells(1, 基列 + 位列算展of日涨 - 1) = "日涨"
    WS.Cells(1, 基列 + 位列算展of周涨 - 1) = "周涨"
    WS.Cells(1, 基列 + 位列算展of月涨 - 1) = "月涨"
'========================================================================================
'输出：原始数据
'========================================================================================
    Call UTL数据转换_集ARR2WS(ARRLLL, WS, 2, 列定位)
'========================================================================================
'格式化：原始数据 — 隐藏三周期道
'========================================================================================
    Dim 基列一期 As Integer, 基列二期 As Integer, 基列三期 As Integer
    基列一期 = 列定位
    基列二期 = 列定位 + 花宽单道 * 1
    基列三期 = 列定位 + 花宽单道 * 2
    WS.Cells(1, 基列一期).Resize(1, 花宽单道).EntireColumn.Hidden = True
    WS.Cells(1, 基列二期).Resize(1, 花宽单道).EntireColumn.Hidden = True
    WS.Cells(1, 基列三期).Resize(1, 花宽单道).EntireColumn.Hidden = True
    '------------------------------------------------------------------------------------
    '神谕族段显隐（与神谕结构相关，周期无关）
    '------------------------------------------------------------------------------------
    WS.Cells(1, 1).Cells(1, 位谕始of族仓).Resize(1, 位谕终of族仓 - 位谕始of族仓 + 1).EntireColumn.Hidden = True
    WS.Columns(位谕of仓周类).Hidden = False
    WS.Columns(位谕of仓日类).Hidden = False
    WS.Cells(1, 1).Cells(1, 位谕始of族日段).Resize(1, 位谕终of族日段 - 位谕始of族日段 + 1).EntireColumn.Hidden = True
    UTL宏工具_END
'========================================================================================
'返回
'========================================================================================
    XL算展格程跨期_通用生成 = 列定位
End Function



'========================================================================================
'========================================================================================
'功能：算展格程——通用显示（按周期控制行过滤 + 列显隐 + 重组）
'默认日类，可重复调用以切换视角
'========================================================================================
'========================================================================================
Sub XL算展格程跨期_通用显示( _
          WS As Worksheet _
        , Optional 被研期类 As String = 常期类为日 _
        , Optional 基列 As Integer = 1 _
        , Optional 基行 As Integer = 1 _
        , Optional 原始道基列 As Integer = 0 _
        )
'========================================================================================
'选择周期对应的列
'========================================================================================
    Dim 列键 As Integer   '键列，用于行过滤
    Dim 列龄 As Integer
    Dim 列涨 As Integer
    '------------------------------------------------------------------------------------
    If 被研期类 = 常期类为日 Then
        列龄 = 位列算展of日龄
        列键 = 位列算展of日键
        列涨 = 位列算展of日涨
    ElseIf 被研期类 = 常期类为周 Then
        列龄 = 位列算展of周龄
        列键 = 位列算展of周键
        列涨 = 位列算展of周涨
    ElseIf 被研期类 = 常期类为月 Then
        列龄 = 位列算展of月龄
        列键 = 位列算展of月键
        列涨 = 位列算展of月涨
    Else
        Exit Sub
    End If
    UTL宏工具_BEGIN
    '默认计算原始道基列（切换类调用时未传入则自动推算）
    If 原始道基列 = 0 Then 原始道基列 = 基列 + 位谕列终全部
'========================================================================================
'第一步：行过滤——隐藏非周期行
'========================================================================================
    Dim X As Integer
    For X = PBASE格程工具_表参末行指定(WS, 1) To 2 Step -1
        If WS.Cells(X, 基列 + 列键 - 1) <> True Then
            WS.Rows(X).Hidden = True
        Else
            WS.Rows(X).Hidden = False
        End If
    Next
'========================================================================================
'第二步：隐藏主区（位qt主宽 = 27列）
'========================================================================================
    '------------------------------------------------------------------------------------
    '格式化
    '------------------------------------------------------------------------------------
    With WS.Cells(1, 基列).Resize(1, 位qt主宽).EntireColumn
        .Font.ColorIndex = 2
        .Font.Size = 9
    End With
    WS.Cells(1, 基列).Resize(1, 位qt主宽).EntireColumn.Hidden = True
'========================================================================================
'第四步：格式化——列表头 + 列属性（按物理列位置设置）
'========================================================================================
    WS.Cells(1, 基列 + 位列算展of主期 - 1) = "主期"
    WS.Cells(1, 基列 + 位列算展of主七 - 1) = "主七"
    '------------------------------------------------------------------------------------
    '龄
    With WS.Columns(基列).Columns(列龄)
        .HorizontalAlignment = xlLeft
        .Font.ColorIndex = 15
        .ColumnWidth = 4
    End With
    '期
    With WS.Columns(基列).Columns(位列算展of主期)
        .HorizontalAlignment = xlLeft
        .Font.ColorIndex = 15
        .NumberFormatLocal = 全设格式of日期
        .ColumnWidth = 8
    End With
    '七
    With WS.Columns(基列).Columns(位列算展of主七)
        .Font.Color = 常色主黑
        .ColumnWidth = 1
    End With
    '涨
    With WS.Columns(基列).Columns(列涨)
        .NumberFormatLocal = "[红色]0_);[绿色](0)"
        .Font.Bold = True
        .HorizontalAlignment = xlLeft
        .ColumnWidth = 5
    End With
    '------------------------------------------------------------------------------------
    '神谕列：非日周期隐藏临数据
    '------------------------------------------------------------------------------------
    If 被研期类 <> 常期类为日 Then
        WS.Columns(基列).Columns(位谕of周波临涨幅).Hidden = True
        WS.Columns(基列).Columns(位谕of周波临高幅).Hidden = True
    End If
    WS.Columns(基列).Columns(位谕of日波BSPR).Hidden = False
'========================================================================================
'第三步：显示周期对应的4列（龄 期 七 涨）
'键列仅用于行过滤，不显示
'========================================================================================
    WS.Columns(基列).Columns(列龄).Hidden = False
    WS.Columns(基列).Columns(位列算展of主期).Hidden = False
    WS.Columns(基列).Columns(位列算展of主七).Hidden = False
    If 被研期类 = 常期类为周 Then
        WS.Columns(基列).Columns(列涨).Hidden = True
    Else
        WS.Columns(基列).Columns(列涨).Hidden = False
    End If
'========================================================================================
'第五步：重组——原始数据（日类灰绿 / 周类灰蓝）
'========================================================================================
    If 原始道基列 > 0 Then
        Dim 列定位 As Integer
        Dim 重输始列数组 As Variant
        Dim 重输指标数组 As Variant
        '重置列定位到原始数据道位置
        列定位 = 原始道基列
        '------------------------------------------------------------------------------------
        '日类基本信息 + 算法（灰绿底色）
        '------------------------------------------------------------------------------------
        Dim 日类始 As Integer
        日类始 = 列定位
        重输始列数组 = Array(原始道基列)
        重输指标数组 = Array( _
                    Array(位os基累龄, 5), Array(位os结期, 12) _
                    , , Array(位os算法名, 7) _
                    , , Array(位os算累持, 4), Array(位os算累赚, 7), Array(位os算今赚, 6), Array(位os算今手, 6) _
                    , , Array(位os结幅PR0, 6) _
                )
        列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
        WS.Cells(1, 日类始).Resize(1, 列定位 - 日类始).EntireColumn.Interior.Color = 常色灰绿
        WS.Cells(1, 日类始).Resize(1, 列定位 - 日类始).Font.ColorIndex = 1
        WS.Cells(1, 日类始) = "日类"
        WS.Cells(1, 日类始).Font.Bold = True
        '------------------------------------------------------------------------------------
        '周类基本信息 + 算法（灰蓝底色）
        '------------------------------------------------------------------------------------
        Dim 周类始 As Integer
        周类始 = 列定位
        重输始列数组 = Array(原始道基列 + 花宽单道)
        重输指标数组 = Array( _
                    Array(位os基累龄, 5), Array(位os结期, 12) _
                    , , Array(位os算法名, 7) _
                    , , Array(位os算累持, 4), Array(位os算累赚, 7), Array(位os算今赚, 6), Array(位os算今手, 6) _
                    , , Array(位os结幅PR0, 6) _
                )
        列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
        WS.Cells(1, 周类始).Resize(1, 列定位 - 周类始).EntireColumn.Interior.Color = 常色灰蓝
        WS.Cells(1, 周类始).Resize(1, 列定位 - 周类始).Font.ColorIndex = 1
        WS.Cells(1, 周类始) = "周类"
        WS.Cells(1, 周类始).Font.Bold = True
        Erase 重输指标数组
        Erase 重输始列数组
    End If
    UTL宏工具_END
'========================================================================================
End Sub



