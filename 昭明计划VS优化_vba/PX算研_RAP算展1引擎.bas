'功能：算法展示 LLL/LD/LW/LM
'========================================================================================
'========================================================================================
Function XL算展引擎正程( _
          被研代码 As String _
        , Optional 被研期类 As String = 常期类为月 _
        , Optional 被研算法 As String = "" _
        , Optional 是否外簿 As Boolean = True _
        , Optional 基色底 As Long = 常色研究 _
        ) As Integer
'========================================================================================
'工区
'========================================================================================
    '------------------------------------------------------------------------------------
    '设置：工簿
    '------------------------------------------------------------------------------------
    Dim wb As Workbook
    If 是否外簿 = False Then
        Set wb = ThisWorkbook
    Else
        Set wb = Workbooks.Add
    End If
'========================================================================================
'运行
'========================================================================================
    计数明细 = XL算展引擎子程跨期(wb, 被研代码, 被研期类, 被研算法, 基色底:=基色底)
'========================================================================================
'工区：外部存档
'========================================================================================
    Dim 工簿简称 As String
    工簿简称 = "算展." & 被研代码
    '------------------------------------------------------------------------------------
    '进行保存
    '------------------------------------------------------------------------------------
    If wb.Name <> ThisWorkbook.Name Then
        MSG = MSG & vbCrLf & PBASE格程工具_表操保存外簿(wb, 工簿简称)
        wb.Save
    End If
    Set wb = Nothing
'========================================================================================
'返回
'========================================================================================
    XL算展引擎正程 = 计数明细
End Function





'========================================================================================
'========================================================================================
'功能：算法展示 针对跨期【周+日】
'========================================================================================
'========================================================================================
Function XL算展引擎子程跨期( _
          wb As Workbook _
        , 被研代码 As String _
        , 被研期类 As String _
        , 被研算法 As String _
        , Optional 基色底 As Long = 常色研究 _
        ) As Integer
'========================================================================================
'设置：工表
'========================================================================================
    Dim 设定表名 As String
    设定表名 = "L" & 被研期类 & Right(被研代码, 6)
    Dim WSLLL As Worksheet
    Call PBASE格程工具_表操工表新增(WSLLL, 设定表名, wb:=wb, 基色底:=基色底)
'========================================================================================
'步骤一：明细准备
'增加复杂度：如果能读取CSV文件，就从CSV文件导入。否则从藏库进行导入
'========================================================================================
    Dim ARRLLL As Variant
    Dim 谕组 As Variant
    Dim 计数明细 As Integer
    计数明细 = XL算展数程跨期(ARRLLL, 被研代码, 谕组:=谕组, 被研算法:=被研算法)
    '------------------------------------------------------------------------------------
    '验证：排除空数组
    If 计数明细 < 1 Then GoTo 返点
'========================================================================================
'步骤二：格程（神谕已在数程中生成）
'========================================================================================
    Call XL算展格程跨期(ARRLLL, WSLLL, 被研期类:=被研期类, 基色底:=基色底, 谕组:=谕组)
    '------------------------------------------------------------------------------------
    '------------------------------------------------------------------------------------
    '待完成
    '对于偏线（入、a多_入、继、升继）以及各种【机阱】的正确性进行复盘，遇到与设计初衷相违背的进行标注
'========================================================================================
'步骤四：统算展
'========================================================================================
    Dim WSANA As Worksheet
    Call PBASE格程工具_表操工表新增(WSANA, "汇算展", wb:=wb, 基色底:=基色底)
    Call XL算展统程跨期(WSANA, ARRLLL, 被研期类, 算法类型:=常算法类型为跨期, WSIN:=WSLLL)
    Set WSANA = Nothing
'========================================================================================
返点:
'========================================================================================
    Erase ARRLLL
    Set WSLLL = Nothing
    '------------------------------------------------------------------------------------
    XL算展引擎子程跨期 = 计数明细
End Function




