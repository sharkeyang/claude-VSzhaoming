    '重组：索引
    '------------------------------------------------------------------------------------
    重输始列数组 = Array(基列)
    重输指标数组 = Array( _
            Array(位os基累龄, 5), Array(位os结期, 9) _
        , , Array(位os算法名, 10) _
        , , Array(位os算累持, 4), Array(位os算累赚, 7), Array(位os算今赚, 6), Array(位os算今手, 6), Array(位os算今仓, 3) _
        )
    列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
    Erase 重输指标数组
    Erase 重输始列数组
    '====================================================================================
    '区域格式化：计分区域
    '------------------------------------------------------------------------------------
    
'增加两个展示列
'一个是层的展示列 L0-LF
    '------------------------------------------------------------------------------------
    '重组：
    '------------------------------------------------------------------------------------
            '----------------------------------------------
            重输始列数组 = Array(基列)
            重输指标数组 = Array( _
                         Array(位os结幅PR0, 6), Array(位os结收, 6) _
                    )
            列定位 = UG区域格程重组(重输始列数组, 重输指标数组, WS, 列定位)
            Erase 重输指标数组
            Erase 重输始列数组
'========================================================================================
'返回
'========================================================================================
    XL算展格程单期 = 列定位
End Function
