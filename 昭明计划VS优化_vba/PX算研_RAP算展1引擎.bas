Function XL算展数程跨期( _
          ARRLLL As Variant _
        , 指定代码 As String _
        , Optional ByVal 指定结期上限 As Variant _
        , Optional ByVal 典腾实 As Variant _
        , Optional ByRef 谕组 As Variant _
