    工表统算展.Cells(1, 位统算展累赚均次) = "赚" & vbCrLf & "每次"
    工表统算展.Cells(1, 位统算展累涨合计) = "累涨" & vbCrLf & "全次" & vbCrLf & "合计"
    工表统算展.Cells(1, 位统算展累赚合计) = "累赚" & vbCrLf & "全次" & vbCrLf & "合计"
    工表统算展.Cells(1, 位统算展今赚最高) = "今赚" & vbCrLf & "最高" & vbCrLf & "合计"
    工表统算展.Cells(1, 位统算展算法胜率) = "算法" & vbCrLf & "胜率"
    工表统算展.Cells(1, 位统算展算法名称) = "算法" & vbCrLf & "名称"
    '------------------------------------------------------------------------------------
    '格式化：记录
    '------------------------------------------------------------------------------------
    Dim 统算展目行 As Integer
    统算展目行 = PBASE格程工具_表参末行指定(工表统算展, 1) + 1
    
    '基元.Offset(1, 0).Resize(1, 位统算展列数汇总).Copy 工表统算展.Cells(统算展目行, 1)
    For X = 1 To 位统算展列数汇总
        With 工表统算展.Cells(统算展目行, X)
            .Value = 基元.Offset(1, 0).Cells(1, X)
            .Interior.Color = 基元.Offset(1, 0).Cells(1, X).Interior.Color
        End With
    Next
    工表统算展.Rows(统算展目行).Font.Bold = False
    工表统算展.Columns(位统算展累涨合计).NumberFormatLocal = "0%"
    工表统算展.Columns(位统算展算法胜率).NumberFormatLocal = "0%"
