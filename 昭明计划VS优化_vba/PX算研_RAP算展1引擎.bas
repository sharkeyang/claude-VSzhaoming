Function XL算展格程单期( _
          ARRLA As Variant _
        , WS As Worksheet _
        , Optional 基色底 As Long = 常色研究 _
        , Optional 基列 As Integer = 1 _
        ) As Integer
'========================================================================================
'检查
'========================================================================================
    If VBA.IsEmpty(ARRLA) = True Then
        Exit Function
    End If
'========================================================================================
'输出
'========================================================================================
    Call UTL数据转换_集ARR2WS(ARRLA, WS, 2, 基列)
'========================================================================================
'格式化：全局设置
'========================================================================================
    WS.Tab.Color = 基色底
    '------------------------------------------------------------------------------------
    WS.Rows.Hidden = False
    WS.Columns.Hidden = False
    WS.Cells.ClearFormats
    WS.Cells.Font.Size = 10
    '------------------------------------------------------------------------------------
    WS.Cells.Interior.ColorIndex = 1
    '====================================================================================
    '调整与冻结
    '------------------------------------------------------------------------------------
    Call PBASE格程工具_表冻结锁定(WS, 1)
'========================================================================================
'格式化：特殊设置
'========================================================================================
    Dim 列定位 As Integer
    '====================================================================================
    '格式化：系统部分
    '------------------------------------------------------------------------------------
    列定位 = 基列
    列定位 = IQQQ跨码展擎_按列OS区域(WS, 列定位, 基色底:=基色底, 基色调:=0.2)
    '------------------------------------------------------------------------------------
    WS.Cells(1, 基列).Resize(1, 花宽单道).EntireColumn.Hidden = True
'========================================================================================
'格式化：重组
