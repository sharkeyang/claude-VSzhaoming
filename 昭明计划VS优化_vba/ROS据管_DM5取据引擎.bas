'========================================================================================
Function STBASE取据引擎_工具衍生外库路径(导入代码 As String, Optional 导入类别 As String = "") As String
        Dim 导入路径 As String
        If UBCID是中股票(导入代码) = True _
        Or UBCID是中股基(导入代码) = True _
        Or UBCID是中股指(导入代码) = True _
        Then
            导入路径 = 全设基夹中股 & "\" & 导入代码 & ".csv"
        ElseIf UBCID是港股票(导入代码) = True Or UBCID是港股指(导入代码) = True Then
            导入路径 = 全设基夹港股 & "\" & 导入代码 & ".csv"
        ElseIf UBCID是美股票(导入代码) = True Then
            导入路径 = 全设基夹美股 & "\" & "US." & 导入代码 & ".csv"
        ElseIf UBCID是中期(导入代码) = True Then
            导入路径 = 全设基夹中期 & "\" & 导入代码 & ".csv"
        Else
            导入路径 = ""
        End If
        STBASE取据引擎_工具衍生外库路径 = 导入路径
End Function
