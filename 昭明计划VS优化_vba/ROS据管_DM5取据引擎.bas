'========================================================================================
'功能：从外库AK取数据
'========================================================================================
Function STBASE取据引擎_工具取据由外库( _
          ByRef ARRSTOCK As Variant _
        , ByVal 提取代码 As String _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        ) As Integer
'========================================================================================
'验证原文件
'========================================================================================
    Dim 指定路径 As String
    指定路径 = STBASE取据引擎_工具衍生外库路径(提取代码)
    '------------------------------------------------------------------------------------
    If UTL判断文件存在(指定路径) = False Then
        STBASE取据引擎_工具取据由外库 = 0
        Exit Function
    End If
'========================================================================================
'第一次循环：过滤空记录  =================================================================
'========================================================================================
    Dim sLINE As String
    Dim aLINE As Variant
    Dim 读入计数 As Integer
    '------------------------------------------------------------------------------------
    '计算总行数
    '------------------------------------------------------------------------------------
    读入计数 = 0
    Dim FileNum As Integer
    FileNum = FreeFile()
    Open 指定路径 For Input As #FileNum
    Do While Not EOF(1)
        Line Input #FileNum, sLINE
        读入计数 = 读入计数 + 1
    Loop
    Close #FileNum
    If 读入计数 = 0 Then Exit Function
'========================================================================================
'第二次循环：读入数据到数组  =============================================================
'========================================================================================
    ReDim ARRALL(1 To 读入计数, 1 To 位列TS上限单期) As Variant
    '------------------------------------------------------------------------------------
    Dim 当日 As Date
    Dim 值期数 As Integer
    值期数 = 0
    读入计数 = 0
    FileNum = FreeFile()
    Open 指定路径 For Input As #FileNum
    Do While Not EOF(1)
        '--------------------------------------------------------------------------------
        Line Input #FileNum, sLINE
        读入计数 = 读入计数 + 1
        '--------------------------------------------------------------------------------
        If UTL数据转换_串2组4CSV(aLINE, sLINE) > 0 Then
                当日 = aLINE(位列TS结期)
                ARRALL(读入计数, 位列TS结期) = 当日
                ARRALL(读入计数, 位列TS结收) = aLINE(位列TS结收)
                ARRALL(读入计数, 位列TS结开) = aLINE(位列TS结开)
                ARRALL(读入计数, 位列TS结高) = aLINE(位列TS结高)
                ARRALL(读入计数, 位列TS结低) = aLINE(位列TS结低)
                If 指定结期下限 < 当日 And 当日 <= 指定结期上限 Then
                    值期数 = 值期数 + 1
                    ARRALL(读入计数, 位列TS结龄) = 1    '作为是否输出的标志
                Else
                    ARRALL(读入计数, 位列TS结龄) = 0
                End If
                Erase aLINE
        End If
        '--------------------------------------------------------------------------------
    Loop
    Close #FileNum
    If 值期数 = 0 Then Exit Function
'========================================================================================
'第二次读取原文件：获取内容  =============================================================
'========================================================================================
    '------------------------------------------------------------------------------------
    '转换为数组
    '------------------------------------------------------------------------------------
    ReDim ARRSTOCK(1 To 值期数, 1 To 位列TS上限单期) As Variant
    '------------------------------------------------------------------------------------
    '处理信息
    '------------------------------------------------------------------------------------
    Dim 值正序 As Integer
    Dim M As Integer
    值正序 = 0
    For M = LBound(ARRALL, 1) To UBound(ARRALL, 1)
        If ARRALL(M, 位列TS结龄) = 1 Then   '输出标志
                '---------------------------------------------------------------------
                值正序 = 值正序 + 1
                ARRSTOCK(值正序, 位列TS结龄) = 值正序
                '---------------------------------------------------------------------
                ARRSTOCK(值正序, 位列TS结期) = ARRALL(M, 位列TS结期)
                ARRSTOCK(值正序, 位列TS结收) = ARRALL(M, 位列TS结收)
                ARRSTOCK(值正序, 位列TS结开) = ARRALL(M, 位列TS结开)
                ARRSTOCK(值正序, 位列TS结高) = ARRALL(M, 位列TS结高)
                ARRSTOCK(值正序, 位列TS结低) = ARRALL(M, 位列TS结低)
                '---------------------------------------------------------------------
        End If
    Next M
    Erase ARRALL
'========================================================================================
'返回
'========================================================================================
    STBASE取据引擎_工具取据由外库 = 值期数
End Function



Function STBASE取据引擎_工具期类第几日( _
          ByVal 结期 As Date _
        , Optional ByVal 指定期类 As String = 常期类为周 _
        ) As Integer
    If 指定期类 = 常期类为月 Then
        STBASE取据引擎_工具期类第几日 = Day(结期)
    ElseIf 指定期类 = 常期类为周 Then
        STBASE取据引擎_工具期类第几日 = Weekday(结期, vbMonday)
    Else
        STBASE取据引擎_工具期类第几日 = 0
    End If
End Function
Function STBASE取据引擎_工具结算数据转换( _
          ByRef ARRCSV As Variant _
        , ByRef ARRDATA As Variant _
        , Optional ByVal 指定期类 As String = 常期类为周 _
        , Optional ByVal 是否去重 As Boolean = False _
        ) As Integer
'========================================================================================
'验明正身
'========================================================================================
    If VBA.IsEmpty(ARRCSV) = True Then Exit Function
    If 指定期类 <> 常期类为周 And 指定期类 <> 常期类为月 And 指定期类 <> 常期类为日 Then Exit Function
'========================================================================================
'声明变量
'========================================================================================
    Dim 临期 As Date, 临期期始 As Date
    Dim 结期 As Date, 结期期始 As Date
    Dim 结开 As Double, 结高 As Double, 结低 As Double, 结收 As Double
    Dim 计数合期 As Integer
    Dim X As Integer
'========================================================================================
'扩充数组
'========================================================================================
    Dim 组转 As Variant
    组转 = ARRCSV
    ReDim Preserve 组转(LBound(组转, 1) To UBound(组转, 1), 1 To 99) As Variant
    '------------------------------------------------------------------------------------
    Dim 基列转 As Integer
    基列转 = 位列TS上限单期
'========================================================================================
'转换
'========================================================================================
    '------------------------------------------------------------------------------------
    '首日赋值
    '------------------------------------------------------------------------------------
    X = LBound(组转, 1)
    结期 = 组转(X, 位列TS结期)
    结期期始 = 结期 - STBASE取据引擎_工具期类第几日(结期, 指定期类)
    结收 = 组转(X, 位列TS结收)
    结开 = 组转(X, 位列TS结开)
    结高 = 组转(X, 位列TS结高)
    结低 = 组转(X, 位列TS结低)
    计数合期 = 1
    '------------------------------------------------------------------------------------
    '循环
    '------------------------------------------------------------------------------------
    For X = LBound(组转, 1) To UBound(组转, 1)
            临期 = 组转(X, 位列TS结期)
            临期期始 = 临期 - STBASE取据引擎_工具期类第几日(临期, 指定期类)
            '辅助输出供参考
            组转(X, 基列转 + 位列TS上限单期 + 1) = STBASE取据引擎_工具期类第几日(临期, 指定期类)
            组转(X, 基列转 + 位列TS上限单期 + 2) = 临期期始
            
            If 临期期始 <> 结期期始 Then
                组转(X - 1, 基列转 + 位列TS结IS) = True      '标志上周最后一天
                组转(X - 1, 基列转 + 位列TS结龄) = 计数合期
                计数合期 = 计数合期 + 1
                '相同步骤
                组转(X - 1, 基列转 + 位列TS结期) = 结期
                组转(X - 1, 基列转 + 位列TS结收) = 结收
                组转(X - 1, 基列转 + 位列TS结开) = 结开
                组转(X - 1, 基列转 + 位列TS结高) = 结高
                组转(X - 1, 基列转 + 位列TS结低) = 结低
                结期 = 组转(X, 位列TS结期)
                结期期始 = 结期 - STBASE取据引擎_工具期类第几日(结期, 指定期类)
                结收 = 组转(X, 位列TS结收)
                '不同步骤
                结开 = 组转(X, 位列TS结开)
                结高 = 组转(X, 位列TS结高)
                结低 = 组转(X, 位列TS结低)
            ElseIf X > LBound(组转, 1) Then
                组转(X - 1, 基列转 + 位列TS结IS) = False
                组转(X - 1, 基列转 + 位列TS结龄) = 计数合期
                '相同步骤
                组转(X - 1, 基列转 + 位列TS结期) = 结期
                组转(X - 1, 基列转 + 位列TS结收) = 结收
                组转(X - 1, 基列转 + 位列TS结开) = 结开
                组转(X - 1, 基列转 + 位列TS结高) = 结高
                组转(X - 1, 基列转 + 位列TS结低) = 结低
                结期 = 组转(X, 位列TS结期)
                结期期始 = 结期 - STBASE取据引擎_工具期类第几日(结期, 指定期类)
                结收 = 组转(X, 位列TS结收)
                '不同步骤
                If 结高 < 组转(X, 位列TS结高) Then 结高 = 组转(X, 位列TS结高)
                If 结低 > 组转(X, 位列TS结低) Then 结低 = 组转(X, 位列TS结低)
            End If
    Next
    '------------------------------------------------------------------------------------
    '最后一日：强制输出，是否进行结算由外部程序控制
    '------------------------------------------------------------------------------------
    组转(X - 1, 基列转 + 位列TS结IS) = True
    组转(X - 1, 基列转 + 位列TS结龄) = 计数合期
    组转(X - 1, 基列转 + 位列TS结期) = 结期
    组转(X - 1, 基列转 + 位列TS结开) = 结开
    组转(X - 1, 基列转 + 位列TS结收) = 结收
    组转(X - 1, 基列转 + 位列TS结高) = 结高
    组转(X - 1, 基列转 + 位列TS结低) = 结低
'========================================================================================
'测试输出
'========================================================================================
'                    Dim WSX As Worksheet
'                    Call PBASE格程工具_表操工表新增(WSX, "K临")
'                    Call UTL数据转换_集ARR2WS(组转, WSX, 1, 1)
'                    WSX.Columns.AutoFit
'                    Stop
'========================================================================================
'提取已转换数据：保留所有日期
'========================================================================================
    ReDim ARRDATA(LBound(组转, 1) To UBound(组转, 1), 1 To 位列TS上限单期) As Variant
    Dim Y As Integer
    For X = LBound(组转, 1) To UBound(组转, 1)
        '存储：已转换周期的数据
        For Y = 1 To 位列TS上限单期
            ARRDATA(X, Y) = 组转(X, Y + 基列转)
        Next
'        '存储：原始日类数据
'        For Y = 1 To 位列TS上限结算 - 位列TS上限单期
'            ARRDATA(X, 位列TS上限单期 + Y) = 组转(X, Y)
'        Next
    Next
    Erase 组转
'========================================================================================
'提取已转换数据：只保留单条数据
'========================================================================================
If 是否去重 = True Then
    组转 = ARRDATA
    计数合期 = 组转(UBound(组转, 1), 位列TS结龄)
    ReDim ARRDATA(1 To 计数合期, 1 To 位列TS上限单期) As Variant
    '------------------------------------------------------------------------------------
    Dim 值结龄 As Integer
    For X = LBound(组转, 1) To UBound(组转, 1)
        If 组转(X, 位列TS结IS) = True Then
            值结龄 = 组转(X, 位列TS结龄)
            '存储：已转换周期的数据
            For Y = 1 To 位列TS上限单期
                ARRDATA(值结龄, Y) = 组转(X, Y)
            Next
        End If
    Next
    Erase 组转
End If
'========================================================================================
'返回
'========================================================================================
    STBASE取据引擎_工具结算数据转换 = 计数合期
End Function
