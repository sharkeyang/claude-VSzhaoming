Function STBASE取据引擎查时戳由藏库( _
          Optional CIDL As String = 常查询代码中股 _
        , Optional 指定结期上限 As Date = 常结期上限市场 _
        ) As Date
    '------------------------------------------------------------------------------------
    '链接藏库
    '------------------------------------------------------------------------------------
    Dim WS藏库 As Worksheet
    If STBASE外簿工具_藏库链接(WS藏库, 常期类为日) = False Then Exit Function
    '------------------------------------------------------------------------------------
    '查询信息
    '------------------------------------------------------------------------------------
    Dim 时戳 As Date
    Dim 当日 As Date
    Dim 值更源 As String
    For Y = PBASE格程工具_表参末列指定(WS藏库, 位行TT交日) To 位列TT头部 + 1 Step -1
        当日 = WS藏库.Cells(位行TT交日, Y).Value
        值更源 = WS藏库.Cells(位行TT更源, Y).Value
        If VBA.IsDate(当日) = True And 值更源 <> 常据源TR Then      '非腾实更新
            If 当日 <= 指定结期上限 Then
                时戳 = 当日
                Exit For
            End If
        End If
    Next
    '====================================================================================
    STBASE取据引擎查时戳由藏库 = 时戳
End Function

Function STBASE取据引擎查时戳由外库( _
          Optional CIDL As String = 常查询代码中股 _
        , Optional 指定结期上限 As Date = 常结期上限市场 _
        ) As Date
    '====================================================================================
    '验证原文件
    '====================================================================================
    Dim 指定路径 As String
    指定路径 = STBASE取据引擎_工具衍生外库路径(CIDL)
    If UTL判断文件存在(指定路径) = False Then
        STBASE取据引擎查时戳由外库 = 0
        Exit Function
    End If
    '====================================================================================
    '循环：读入数据到数组
    '====================================================================================
    Dim 时戳 As Date
    Dim 当日 As Date
    Dim aLINE As Variant
    Dim sLINE As String
    Dim FileNum As Integer
    FileNum = FreeFile()
    Open 指定路径 For Input As #FileNum
    Do While Not EOF(1)
        '--------------------------------------------------------------------------------
        Line Input #FileNum, sLINE
        If UTL数据转换_串2组4CSV(aLINE, sLINE) > 0 Then
            当日 = aLINE(位列TS结期)
            Erase aLINE
            If 当日 <= 指定结期上限 Then
                时戳 = 当日
            Else
                Exit Do
            End If
        End If
        '--------------------------------------------------------------------------------
    Loop
    Close #FileNum
    '====================================================================================
    STBASE取据引擎查时戳由外库 = 时戳
End Function

Function STBASE取据引擎查时戳由腾历( _
          Optional 期类 As String = 常期类为日 _
        , Optional CIDL As String = 常查询代码中股 _
        , Optional 指定结期上限 As Date = 常结期上限市场 _
        ) As Date
    '------------------------------------------------------------------------------------
    '查询信息
    '------------------------------------------------------------------------------------
    Dim nRESP As Integer
    Dim aRESP As Variant
    nRESP = UBHTTP腾历_查回组行(aRESP, CIDL, 期类)
    '------------------------------------------------------------------------------------
    '加工信息
    '------------------------------------------------------------------------------------
    Dim 时戳 As Date
    Dim sLINE As String
    Dim sdate As String
    Dim 当日 As Date
    Dim i As Integer
    If nRESP > 0 Then
        '--------------------------------------------------------------------------------
        '确定行情集合
        '--------------------------------------------------------------------------------
        For i = UBound(aRESP) To LBound(aRESP) Step -1
            sLINE = aRESP(i)
            If sLINE Like "###### *" Then
                sdate = Left$(sLINE, 6)
                当日 = DateSerial(Left$(sdate, 2), Mid$(sdate, 3, 2), Mid$(sdate, 5, 2))
                If 当日 <= 指定结期上限 Then
                    时戳 = 当日
                    Exit For
                End If
            End If
        Next i
        '--------------------------------------------------------------------------------
    End If
    STBASE取据引擎查时戳由腾历 = 时戳
    '------------------------------------------------------------------------------------
End Function

Function STBASE取据引擎查时戳由腾实(Optional CIDL As String = 常查询代码中股) As Date
    Dim nRESP As Integer
    Dim aRESP As Variant
    '------------------------------------------------------------------------------------
    '查询信息
    '------------------------------------------------------------------------------------
    nRESP = UBHTTP腾实_查回组(aRESP, CIDL)
    '------------------------------------------------------------------------------------
    '处理信息
    '------------------------------------------------------------------------------------
    Dim sdate As String
    Dim fdate As Date
    If nRESP > 0 Then
        sdate = aRESP(位序腾实时间)
        
        If sdate Like "##############" Then  'A股情况
            fdate = DateSerial(Left$(sdate, 4), Mid$(sdate, 5, 2), Mid$(sdate, 7, 2)) _
                  + TimeSerial(Mid$(sdate, 9, 2), Mid$(sdate, 11, 2), Mid$(sdate, 13, 2))
        ElseIf VBA.IsDate(sdate) Then   '港股情况
            fdate = DateValue(sdate)
        End If
        Erase aRESP
    Else
        fdate = 0
    End If
    '------------------------------------------------------------------------------------
    STBASE取据引擎查时戳由腾实 = fdate
End Function

