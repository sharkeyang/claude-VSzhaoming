' ============================================================
' 调用规则说明:
' ------------------------------------------------------------
' 1. 无市场参数（Market = ""）
'    → Python 负责：交易日判断 + 下载中股/中期 + 调 VBA 结算
'    → VBA 等待完成后直接退出，不重复结算
'    对应按钮: STBASE取据引擎PY下载调程_中股
'    等价命令: C:\ProgramData\anaconda3\python.exe "D:\@VSwork\VS_AkShare\Akshare_下载.py"
' ------------------------------------------------------------
' 2. 有市场参数（Market = "中期", "港股指 港股通", ...）
'    → Python 负责：仅下载指定市场
'    → VBA 负责：等待完成后调对应结算宏
'    对应按钮: 各单独下载 / 组合下载按钮
'    等价命令: C:\ProgramData\anaconda3\python.exe "D:\@VSwork\VS_AkShare\Akshare_下载.py" 港股指 港股通
' ------------------------------------------------------------
' 结算宏对应关系:
'   中股   → STBASE结算管理_全新结算调程花天
'   中期   → STBASE结算管理_全新结算调程花中期连
'   港股通 → STBASE结算管理_全新结算调程花港股通
'   港股指 → STBASE结算管理_全新结算调程花港股指
'   美股票 → STBASE结算管理_全新结算调程花美股票
'   密市   → 无结算
' ============================================================

' ============================================================
' Python 环境配置
' ============================================================
Private Const PYTHON_EXE As String = "C:\ProgramData\anaconda3\python.exe"
Private Const PYTHON_SCRIPT As String = "D:\@VSwork\VSzdata\zdata.py"


'########################################################################################
'########################################################################################
'###################################      数据引擎VS    #################################
'########################################################################################
'########################################################################################
'========================================================================================
'架构：两层取据
'========================================================================================
'上层：数据获取（Python → CSV）
'   STBASE取据引擎PY下载基程(Market) — 调用 AkShare 下载
'   Market="" → Python 全包（含结算）
'   Market="XX" → Python只下载，VBA接结算
'   12个按钮Sub，分发到不同市场/组合
'----------------------------------------------------------------------------------------
'下层：数据取据（CSV/藏库/腾讯）
'   取据由外库     CSV文件       主取据入口，读CSV→解析→返回数组
'   取据由藏库     藏库Worksheet 从本地藏库按行/按码提取
'   取据由腾历     腾讯历史      HTTP→解析JSON→返回数组
'   取据由腾实     腾讯实时      单条最新数据
'   取据由腾实批   腾讯实时      批量HTTP请求
'   取据由外库(期类) CSV→周/月    日线→周线/月线聚合
'========================================================================================
'核心功能
'========================================================================================
'1. 时戳查询（各源最大可用日期）
'   查时戳由藏库 / 查时戳由外库 / 查时戳由腾历 / 查时戳由腾实 / 查时戳由花册前结期
'2. 期类转换（日线→周线/月线聚合）
'   工具结算数据转换：按周/月合并日线，取首开/最高/最低/末收
'   工具期类第几日：周=星期几(1-7)，月=几号(1-31)
'3. 路径推导
'   工具衍生外库路径：根据代码类型（中股/港股/美股/中期）推断CSV路径
'========================================================================================
'调用链
'========================================================================================
'Python下载(AkShare) → CSV文件 → 取据由外库 → 结算数据转换(日/周/月) → 结算引擎
'                                          ↓
'                                     藏库/腾讯备用取据
'========================================================================================

' ============================================================
' 核心函数：调用 Python 下载数据，完成后按需触发结算
' Market = ""   → Python 全管（含结算），VBA 不插手
' Market = "XX" → Python 只下载，VBA 接手结算
' ============================================================
Private Sub STBASE取据引擎PY下载基程(Optional ByVal Market As String = "")
    Dim wsh As Object
    Set wsh = CreateObject("WScript.Shell")
    Dim command As String

    ' 构建命令行
    If Market = "" Then
        command = "powershell -Command """ & PYTHON_EXE & " """ & PYTHON_SCRIPT & """ """
    Else
        command = "powershell -Command """ & PYTHON_EXE & " """ & PYTHON_SCRIPT & """ " & Market & " "
    End If

    ' 同步等待 Python 执行完毕（True = 等待）
    wsh.Run command, vbNormalFocus, True

    ' 无市场参数：Python 已自行调结算，VBA 不再重复
    If Market = "" Then Exit Sub

    ' 有市场参数：VBA 按市场逐一触发对应结算宏
    Dim markets_arr() As String
    markets_arr = Split(Market)
    Dim M As Variant
    For Each M In markets_arr
        Select Case M
            Case "AK中股":
                Application.Run "STBASE结算管理_全新结算调程花天"
            Case "AK中期":
                Application.Run "STBASE结算管理_全新结算调程花中期连"
            Case "AK港股通", "AK港股":
                Application.Run "STBASE结算管理_全新结算调程花港股通"
            Case "AK港股指":
                Application.Run "STBASE结算管理_全新结算调程花港股指"
            Case "AK美股票", "AK美股":
                Application.Run "STBASE结算管理_全新结算调程花美股票"
            ' AK密市：无结算，跳过
        End Select
    Next M
End Sub

