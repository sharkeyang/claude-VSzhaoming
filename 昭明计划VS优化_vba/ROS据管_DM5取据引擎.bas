'========================================================================================
'功能：从藏库提取行情，按照代码所在列
'========================================================================================
'========================================================================================
Function STBASE取据引擎取据由藏库按行( _
          ByRef ARRSTOCK As Variant _
        , ByRef ARR藏库 As Variant _
        , ByVal 提取行号 As Integer _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        ) As Integer
    '====================================================================================
    '准备数据
    '====================================================================================
    ReDim ARRIS(LBound(ARR藏库, 2) To UBound(ARR藏库, 2)) As Variant
    '====================================================================================
    '加工信息
    '====================================================================================
    Dim 当期 As Date
    Dim 当串 As String
    Dim 值期数 As Integer
    值期数 = 0
    '------------------------------------------------------------------------------------
    Dim i As Integer
    For i = 位列TT头部 + 1 To UBound(ARR藏库, 2)
            当期 = ARR藏库(位行TT交日, i)
            当串 = ARR藏库(提取行号, i)
            If (InStr(当串, ",") > 0) And (指定结期下限 < 当期) And (当期 <= 指定结期上限) Then
                ARRIS(i) = True
                值期数 = 值期数 + 1
            Else
                ARRIS(i) = False
            End If
    Next
    If 值期数 = 0 Then Exit Function
    '====================================================================================
    '处理信息：转换为数组
    '====================================================================================
    '------------------------------------------------------------------------------------
    '转换为数组
    '------------------------------------------------------------------------------------
    ReDim ARRSTOCK(1 To 值期数, 1 To 位列TS上限单期) As Variant
    '------------------------------------------------------------------------------------
    '处理信息
    '------------------------------------------------------------------------------------
    Dim aLINE As Variant
    Dim 值正序 As Integer
    值正序 = 0
    For i = 位列TT头部 + 1 To UBound(ARRIS)
        当期 = ARR藏库(位行TT交日, i)
        当串 = ARR藏库(提取行号, i)
        If ARRIS(i) = True Then
            If UTL数据转换_串2组4CSV(aLINE, 当串) > 0 Then
                '---------------------------------------------------------------------
                值正序 = 值正序 + 1
                ARRSTOCK(值正序, 位列TS结龄) = 值正序
                '---------------------------------------------------------------------
                ARRSTOCK(值正序, 位列TS结期) = 当期
                ARRSTOCK(值正序, 位列TS结收) = aLINE(位列TS结收)
                ARRSTOCK(值正序, 位列TS结开) = 0 'aLINE(位列TS结开)
                ARRSTOCK(值正序, 位列TS结高) = aLINE(位列TS结高)
                ARRSTOCK(值正序, 位列TS结低) = aLINE(位列TS结低)
                Erase aLINE
                '---------------------------------------------------------------------
            End If
        End If
    Next
'========================================================================================
    STBASE取据引擎取据由藏库按行 = 值期数
End Function



'========================================================================================
'========================================================================================
'功能：从藏库提取行情，按照代码
'注意20220826：本质是从CSV文件提取，注意四价排列顺序
'========================================================================================
'========================================================================================
Function STBASE取据引擎取据由藏库按码( _
          ByRef ARRSTOCK As Variant _
        , ByRef ARR藏库 As Variant _
        , ByVal 提取代码 As String _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        ) As Integer
'========================================================================================
'提取数据
'========================================================================================
    Dim 提取行号 As Integer
    提取行号 = 1
    For X = LBound(ARR藏库, 1) To UBound(ARR藏库, 1)
        If ARR藏库(X, 位列TT代码) = 提取代码 Then
            提取行号 = X
            Exit For
        End If
    Next
    If 提取行号 = 1 Then Exit Function
'========================================================================================
'提取数据
'========================================================================================
    Dim 值期数 As String
    值期数 = STBASE取据引擎取据由藏库按行(ARRSTOCK, ARR藏库, 提取行号, 指定结期上限:=指定结期上限, 指定结期下限:=指定结期下限)
'========================================================================================
    STBASE取据引擎取据由藏库按码 = 值期数
End Function






'========================================================================================
'========================================================================================
'将日线数据转换为周线数据
'注意：如果最后一周未到周末，也要输出用于填写ARROS临时数据，但不用于结算，具体控制在【区间结算】【到点结算】【全点结算】。
'========================================================================================
'========================================================================================
Function STBASE取据引擎取据由外库( _
          ByRef ARRCSV As Variant _
        , ByVal 提取代码 As String _
        , ByVal 指定期类 As String _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        ) As Integer
'========================================================================================
'导入数据
'========================================================================================
    Dim ARRCSVD As Variant
    Dim 计数行情 As Integer
    计数行情 = STBASE取据引擎_工具取据由外库(ARRCSVD, 提取代码, 指定结期上限:=指定结期上限, 指定结期下限:=指定结期下限)
    If 计数行情 < 1 Then Exit Function
    '------------------------------------------------------------------------------------
    '转换周期
    '------------------------------------------------------------------------------------
    If 指定期类 = 常期类为日 Or 指定期类 = 常期类为周 Or 指定期类 = 常期类为月 Then
        Dim ARRDATA As Variant
        计数行情 = STBASE取据引擎_工具结算数据转换(ARRCSVD, ARRDATA, 指定期类, 是否去重:=True)
        ARRCSV = ARRDATA
        Erase ARRDATA
    End If
'========================================================================================
'返回
'========================================================================================
    STBASE取据引擎取据由外库 = 计数行情
End Function



'========================================================================================
'========================================================================================
'查询行情：腾讯历史 回文引号内容 转换为组数
'========================================================================================
'========================================================================================
Function STBASE取据引擎取据由腾历( _
          ByRef ARRSTOCK As Variant _
        , ByVal 提取代码 As String _
        , Optional ByVal 指定期类 As String = 常期类为日 _
        , Optional ByVal 指定结期上限 As Date = 常结期上限市场 _
        , Optional ByVal 指定结期下限 As Date = 常结期下限市场 _
        ) As Integer
    '====================================================================================
    '查询信息
    '====================================================================================
    Dim aRESP As Variant
    Dim nRESP As Integer
    nRESP = UBHTTP腾历_查回组行(aRESP, 提取代码, 指定期类)
    If nRESP < 1 Then Exit Function
    '------------------------------------------------------------------------------------
    '获取数量
    '------------------------------------------------------------------------------------
    Dim sLINE As String
    Dim aLINE As Variant
    ReDim ARRALL(1 To nRESP, 1 To 位列TS上限单期) As Variant
    Dim 当日 As Date
    Dim 值期数 As Integer
    值期数 = 0
    Dim 读入计数 As Integer
    读入计数 = 0
    Dim M As Integer
    For M = LBound(aRESP) To UBound(aRESP)
        sLINE = aRESP(M)
        读入计数 = 读入计数 + 1
        If UTL数据转换_串2组4腾历(aLINE, sLINE) > 0 Then
                当日 = aLINE(位列TS结期)
                ARRALL(读入计数, 位列TS结期) = 当日
                ARRALL(读入计数, 位列TS结收) = aLINE(位列TS结收)
                ARRALL(读入计数, 位列TS结开) = aLINE(位列TS结开)
                ARRALL(读入计数, 位列TS结高) = aLINE(位列TS结高)
                ARRALL(读入计数, 位列TS结低) = aLINE(位列TS结低)
                If 指定结期下限 < 当日 And 当日 <= 指定结期上限 Then
                    值期数 = 值期数 + 1
                    ARRALL(读入计数, 位列TS结龄) = 1    '作为是否输出的标志
                Else
                    ARRALL(读入计数, 位列TS结龄) = 0
                End If
                Erase aLINE
        End If
    Next M
    Erase aRESP
    '====================================================================================
    '处理信息：转换为数组
    '====================================================================================
    '------------------------------------------------------------------------------------
    '转换为数组
    '------------------------------------------------------------------------------------
    ReDim ARRSTOCK(1 To 值期数, 1 To 位列TS上限单期) As Variant
    '------------------------------------------------------------------------------------
    '处理信息
    '------------------------------------------------------------------------------------
    Dim 值正序 As Integer
    Dim M As Integer
    值正序 = 0
    For M = LBound(ARRALL, 1) To UBound(ARRALL, 1)
        If ARRALL(M, 位列TS结龄) = 1 Then   '输出标志
                '---------------------------------------------------------------------
                值正序 = 值正序 + 1
                ARRSTOCK(值正序, 位列TS结龄) = 值正序
                '---------------------------------------------------------------------
                ARRSTOCK(值正序, 位列TS结期) = ARRALL(M, 位列TS结期)
                ARRSTOCK(值正序, 位列TS结收) = ARRALL(M, 位列TS结收)
                ARRSTOCK(值正序, 位列TS结开) = ARRALL(M, 位列TS结开)
                ARRSTOCK(值正序, 位列TS结高) = ARRALL(M, 位列TS结高)
                ARRSTOCK(值正序, 位列TS结低) = ARRALL(M, 位列TS结低)
                '---------------------------------------------------------------------
        End If
    Next M
    Erase ARRALL
    '====================================================================================
    STBASE取据引擎取据由腾历 = 值期数
End Function



Function STBASE取据引擎取据由腾实( _
          ByRef ARRSTOCK As Variant _
        , ByVal 提取代码 As String _
        ) As Integer
    '------------------------------------------------------------------------------------
    '转换为数组
    '------------------------------------------------------------------------------------
    ReDim ARRSTOCK(1 To 1, 1 To 位列TS上限单期) As Variant
    '------------------------------------------------------------------------------------
    '查询信息
    '------------------------------------------------------------------------------------
    Dim aRESP As Variant
    If UBHTTP腾实_查回组(aRESP, 提取代码) > 0 Then
                Dim 值正序 As Integer
                值正序 = 1
                ARRSTOCK(值正序, 位列TS结龄) = 值正序
                '---------------------------------------------------------------------
                Dim sdate As String
                sdate = aRESP(位序腾实时间)
                If sdate Like "##############" Then  'A股情况
                    ARRSTOCK(值正序, 位列TS结期) = DateSerial(Left$(sdate, 4), Mid$(sdate, 5, 2), Mid$(sdate, 7, 2))
                End If
                '---------------------------------------------------------------------
                ARRSTOCK(值正序, 位列TS结收) = aRESP(位序腾实今收)
                ARRSTOCK(值正序, 位列TS结开) = aRESP(位序腾实今开)
                ARRSTOCK(值正序, 位列TS结高) = aRESP(位序腾实今高)
                ARRSTOCK(值正序, 位列TS结低) = aRESP(位序腾实今低)
                Erase aRESP
    End If
    '------------------------------------------------------------------------------------
    STBASE取据引擎取据由腾实 = 1
End Function

'批量取腾实数据，返回 Dictionary(代码 → ARRCSV数组)
'复用 UBHTTP腾实_查回典批量，一次 HTTP 查常HTTP批大小个代码
Function STBASE取据引擎取据由腾实批(ByVal 代码串 As String) As Dictionary
    Dim 查回典 As Dictionary
    Set 查回典 = UBHTTP腾实_查回典批量(代码串)

    Dim 结果典 As New Dictionary
    Dim vKey As Variant, 段组 As Variant, sdate As String
    Dim ARRCSV() As Variant

    For Each vKey In 查回典.Keys
        段组 = 查回典(vKey)
        ReDim ARRCSV(1 To 1, 1 To 位列TS上限单期) As Variant
        ARRCSV(1, 位列TS结龄) = 1
        sdate = 段组(位序腾实时间)
        If sdate Like "##############" Then
            ARRCSV(1, 位列TS结期) = DateSerial(Left$(sdate, 4), Mid$(sdate, 5, 2), Mid$(sdate, 7, 2))
        End If
        ARRCSV(1, 位列TS结收) = 段组(位序腾实今收)
        ARRCSV(1, 位列TS结开) = 段组(位序腾实今开)
        ARRCSV(1, 位列TS结高) = 段组(位序腾实今高)
        ARRCSV(1, 位列TS结低) = 段组(位序腾实今低)
        结果典.Add vKey, ARRCSV
    Next
    Set STBASE取据引擎取据由腾实批 = 结果典
End Function
