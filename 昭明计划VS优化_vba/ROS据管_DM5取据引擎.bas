Function STBASE取据引擎查时戳由花册前结期( _
          WS As Worksheet _
        , Optional 基列 As Integer = 花列甲道 _
        , Optional CIDL As String = 常查询代码中股 _
        ) As Date
    '------------------------------------------------------------------------------------
    '获取前次结算日
    '------------------------------------------------------------------------------------
    Dim 提取列元 As Range
    Set 提取列元 = WS.Columns(基列).Columns(位os代码).Find(What:=CIDL)
