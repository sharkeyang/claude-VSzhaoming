'基程：族行业益盟
'#################################################################################################################################
'#################################################################################################################################
Function 现市基程_族行业益盟( _
          MS As Worksheet _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 始行 As Integer = 3 _
        , Optional 始列 As Integer = 3 _
        , Optional 天组 As Variant _
        , Optional 天典 As Dictionary _
        ) As Boolean
    '=============================================================================================================================
    '页面格式设置
    '=============================================================================================================================
    MS.Cells.Font.Size = 10
    MS.Cells.Font.Color = 常色三灰
    MS.Columns.ColumnWidth = 2
    '-----------------------------------------------------------------------------------------------------------------------------
    '行格式
    MS.Cells(始行 + 1, 始行 + 1) = "芥蓝"
    MS.Rows(始行).Font.Bold = True
    MS.Rows(始行).HorizontalAlignment = xlLeft
    With MS.Rows(始行 + 1)
        .RowHeight = 40
        .VerticalAlignment = xlTop
        .WrapText = True
        .Orientation = 0
    End With
    MS.Rows(始行 + 1).Font.Bold = True
    '-----------------------------------------------------------------------------------------------------------------------------
    '列格式
    MS.Columns(始行 + 1).HorizontalAlignment = xlRight
    MS.Columns(始行 + 1).Font.Bold = True
    MS.Columns(始行 + 1).ColumnWidth = 12
    MS.Columns(始行 + 2).ColumnWidth = 6
    MS.Columns(始行 + 3).ColumnWidth = 5
    '=============================================================================================================================
    '分程调用列表：族行业益盟
    '=============================================================================================================================
    Dim 当列 As Integer
    当列 = 始行 + 5
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_金融族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_电子制造族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_文化族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_互联网族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_周期族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_电气制造族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_机械制造族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_汽车族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_运输族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_基建族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_农业族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_化工族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_医药族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_消费族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    当列 = 现市分程_族行业益盟_公共族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '-----------------------------------------------------------------------------------------------------------------------------
    '当列 = 现市分程_族行业益盟_略_族(MS, 始行, 当列, 是否排序, 天组:=天组, 天典:=天典) + 1
    '=============================================================================================================================
    '页面格式设置
    '=============================================================================================================================
    If 是否排序 = xlAscending Or 是否排序 = xlDescending Then
        With MS.Cells(始行 + 1, 始行 + 1)
            .Resize(.Offset(65536, 0).End(xlUp).Row, 3).Sort _
            key1:=.Offset(0, 1), order1:=是否排序, Header:=xlYes
        End With
    End If
    '-----------------------------------------------------------------------------------------------------------------------------
    MS.Activate
    Call PBASE格程工具_表冻结锁定(MS, 始行 + 1, 始行 + 3)
    '=============================================================================================================================
End Function
'#################################################################################################################################
'#################################################################################################################################
'#################################################################################################################################




