'========================================================================================
'========================================================================================
'功能：将字典转变为数组
'========================================================================================
'========================================================================================
Function UTL数据转换_集典码2组码( _
          组码 As Variant _
        , 典码 As Dictionary _
        , Optional 组宽 As Integer = 花宽主道 _
        ) As Integer
    '------------------------------------------------------------------------------------
    If 典码 Is Nothing Then Exit Function
    If 典码.Count = 0 Then Exit Function
    '---------------------------------------
    ReDim 组码(1 To 典码.Count, 1 To 组宽) As Variant
    Dim X As Integer
    For X = 1 To 典码.Count
        组码(X, 1) = 典码.Keys(X - 1)
    Next
    '------------------------------------------------------------------------------------
    UTL数据转换_集典码2组码 = 典码.Count
End Function
'========================================================================================
'========================================================================================
'功能：将数组转变为字典
'========================================================================================
'========================================================================================
Function UTL数据转换_集组码2典码位( _
          典码位 As Dictionary _
        , 组码 As Variant _
        ) As Integer
    '------------------------------------------------------------------------------------
    If VBA.IsMissing(组码) = True Then Exit Function
    If VBA.IsEmpty(组码) = True Then Exit Function
    '------------------------------------------------------------------------------------
    Dim 典码位组码 As New Dictionary
    Dim CIDL As String
    Dim X As Integer
    For X = LBound(组码, 1) To UBound(组码, 1)
        CIDL = 组码(X, 1)
        If UBCID是代码(CIDL) = True And 典码位组码.Exists(CIDL) = False Then
            典码位组码.Add Item:=X, Key:=CIDL
        End If
    Next
    Set 典码位 = 典码位组码
    Set 典码位组码 = Nothing
    '------------------------------------------------------------------------------------
    UTL数据转换_集组码2典码位 = 典码位.Count
End Function
'========================================================================================
'========================================================================================
'功能：根据典码中的代码，链接到组码中位置，输出到典码位
'========================================================================================
'========================================================================================
Function UTL数据转换_集典码2典码位( _
          典码位 As Dictionary _
        , 组码 As Variant _
        , 典码 As Dictionary _
        ) As Integer
    '------------------------------------------------------------------------------------
    If VBA.IsMissing(组码) = True Then Exit Function
    If VBA.IsEmpty(组码) = True Then Exit Function
    '------------------------------------------------------------------------------------
    For X = LBound(组码, 1) To UBound(组码, 1)
        CIDL = 组码(X, 位qt代码)
        If UBCID是代码(CIDL) = True Then
        If 典码.Exists(CIDL) = True Then
            典码位.Add Key:=CIDL, Item:=X
        End If
        End If
    Next
    '------------------------------------------------------------------------------------
    UTL数据转换_集典码2典码位 = 典码位.Count
End Function
'========================================================================================
'========================================================================================
'功能：将WS所有首列CIDL转变为字典
'========================================================================================
'========================================================================================
Function UTL数据转换_集WS2典码( _
          典码 As Dictionary _
        , ws As Worksheet _
        , Optional 始行 As Integer = 2 _
        , Optional 始列 As Integer = 1 _
        , Optional 总行 As Integer = 0 _
        , Optional 总列 As Integer = 花宽全道 _
        ) As Integer
    '------------------------------------------------------------------------------------
    If 始行 <= 0 Then Exit Function
    If 总行 = 0 Then
        总行 = PBASE格程工具_表参末行指定(ws, 始列) - 始行 + 1
    End If
    If 总行 > 0 Then
        Dim ARR As Variant
        ARR = ws.Cells(始行, 始列).Resize(总行, 总列)
        Call UTL数据转换_集组码2典码位(典码, ARR)
        Erase ARR
    End If
    '------------------------------------------------------------------------------------
    UTL数据转换_集WS2典码 = 典码.Count
End Function
Function UTL数据转换_集WS名2典码( _
          典码 As Dictionary _
        , WS名 As String _
        , Optional wb As Workbook _
        , Optional 始行 As Integer = 2 _
        , Optional 始列 As Integer = 1 _
        , Optional 总行 As Integer = 0 _
        , Optional 总列 As Integer = 花宽全道 _
        ) As Integer
    '------------------------------------------------------------------------------------
    If wb Is Nothing Then Set wb = ThisWorkbook
    If UTL判断工表存在(WS名, wb) = True Then
        Call UTL数据转换_集WS2典码(典码, wb.Sheets(WS名))
    End If
    '------------------------------------------------------------------------------------
    UTL数据转换_集WS名2典码 = 典码.Count
End Function



'========================================================================================
'========================================================================================
'二维数组输出
'========================================================================================
'========================================================================================
Function UTL数据转换_集ARR2WS( _
          ByRef ARR As Variant _
        , ByRef ws As Worksheet _
        , Optional ByVal 始行 As Integer = 2 _
        , Optional ByVal 始列 As Integer = 1 _
        ) As Boolean
    '------------------------------------------------------------------------------------
    If VBA.IsEmpty(ARR) = True Then Exit Function
    'Debug.Print LBound(ARR, 1); UBound(ARR, 1); LBound(ARR, 2); UBound(ARR, 2)
    ws.Cells(始行, 始列).Resize(UBound(ARR, 1) - LBound(ARR, 1) + 1, UBound(ARR, 2) - LBound(ARR, 2) + 1) = ARR
    '------------------------------------------------------------------------------------
End Function
Function UTL数据转换_集WS2ARR( _
          ByRef ARR As Variant _
        , ByRef ws As Worksheet _
        , Optional ByVal 始行 As Integer = 2 _
        , Optional ByVal 始列 As Integer = 1 _
        , Optional ByVal 总行 As Integer = 0 _
        , Optional ByVal 总列 As Integer = 花宽全道 _
        ) As Integer
    '------------------------------------------------------------------------------------
    If 始行 <= 0 Then Exit Function
    If 总行 = 0 Then
        总行 = PBASE格程工具_表参末行指定(ws, 始列) - 始行 + 1
    End If
    If 总行 > 0 Then
        ARR = ws.Cells(始行, 始列).Resize(总行, 总列)
    End If
    '------------------------------------------------------------------------------------
    UTL数据转换_集WS2ARR = 总行
End Function
