'========================================================================================
'========================================================================================
'OS按码墨汁：数程三道
'功能：根据代码列表，合并各期OS信息。
'========================================================================================
'========================================================================================
Function STBASE罗盘数程_OS按码墨汁数程三道( _
          ARROHHH As Variant _
        , ARRHD As Variant _
        , ARRHW As Variant _
        ) As Integer
'========================================================================================
'读入HX文件
'========================================================================================
    '------------------------------------------------------------------------------------
    '验证：排除空数组
    '------------------------------------------------------------------------------------
    If VBA.IsEmpty(ARROHHH) _
    Or VBA.IsEmpty(ARRHD) _
    Or VBA.IsEmpty(ARRHW) _
    Then
        STBASE罗盘数程_OS按码墨汁数程三道 = 0
        Exit Function
    End If
'========================================================================================
'合并
'========================================================================================
    ReDim Preserve ARROHHH(LBound(ARROHHH, 1) To UBound(ARROHHH, 1), 1 To 位qt主宽) As Variant
    '------------------------------------------------------------------------------------
    Call STBASE罗盘数程_OS按码墨汁数程基程(ARROHHH, ARRHD)
    Call STBASE罗盘数程_OS按码墨汁数程基程(ARROHHH, ARRHW)
'========================================================================================
'返回
'========================================================================================
    STBASE罗盘数程_OS按码墨汁数程三道 = UBound(ARROHHH, 1) - LBound(ARROHHH, 1) + 1
End Function



'========================================================================================
'========================================================================================
'OS按码墨汁：合并基程
'========================================================================================
'========================================================================================
Function STBASE罗盘数程_OS按码墨汁数程基程( _
          ARROHHH As Variant _
        , ARRHX As Variant _
        , Optional 主列代码 As Integer = 1 _
        ) As Integer
'========================================================================================
'进行合并验证，排除空数组
'========================================================================================
    If VBA.IsEmpty(ARROHHH) _
    Or VBA.IsEmpty(ARRHX) _
    Then
        Exit Function
    End If
'========================================================================================
'扩展数组
'========================================================================================
    Dim 维二左值 As Integer
    维二左值 = UBound(ARROHHH, 2) - LBound(ARROHHH, 2) + 1
    Dim 维二右值 As Integer
    维二右值 = UBound(ARRHX, 2) - LBound(ARRHX, 2) + 1
    Dim 维二合值 As Integer
    维二合值 = 维二左值 + 维二右值
    '------------------------------------------------------------------------------------
    ReDim Preserve ARROHHH(LBound(ARROHHH, 1) To UBound(ARROHHH, 1), 1 To 维二合值) As Variant
'========================================================================================
'读取信息
'========================================================================================
    Dim 集合记录 As New Dictionary
    Dim CIDL As String
    '------------------------------------------------------------------------------------
    '将代码信息导入集合
    '------------------------------------------------------------------------------------
    Dim X As Integer
    For X = LBound(ARRHX, 1) To UBound(ARRHX, 1)
        CIDL = ARRHX(X, 位os代码)
        集合记录.Add Item:=X, Key:=CIDL
    Next X
'========================================================================================
'遍历合并
'========================================================================================
    Dim 行号定位 As Integer
    行号定位 = 1
    '------------------------------------------------------------------------------------
    For X = LBound(ARROHHH, 1) To UBound(ARROHHH, 1)
        '--------------------------------------------------------------------------------
        '获取主键
        '--------------------------------------------------------------------------------
        CIDL = ARROHHH(X, 主列代码)
        '--------------------------------------------------------------------------------
        '合并右信息：精准方式
        '--------------------------------------------------------------------------------
        If 集合记录.Exists(CIDL) Then
            行号定位 = 集合记录(CIDL)
            For Y = 1 To 维二右值
                ARROHHH(X, 维二左值 + Y) = ARRHX(行号定位, Y)
            Next Y
        End If
        '--------------------------------------------------------------------------------
        'Debug.Print "墨汁OS>>> "  & X & "__" & CIDL
        '--------------------------------------------------------------------------------
    Next X
    '------------------------------------------------------------------------------------
    集合记录.RemoveAll
    Set 集合记录 = Nothing
'========================================================================================
'返回
'========================================================================================
    STBASE罗盘数程_OS按码墨汁数程基程 = UBound(ARROHHH, 1) - LBound(ARROHHH, 1) + 1
'========================================================================================
End Function
