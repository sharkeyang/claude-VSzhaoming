        If UBound(aLINE) < 位列TS结收 Then Exit Function
        '--------------------------------------------------------------------------------
        ReDim ARRLINE(位列TS下限 To 位列TS上限单期) As Variant
        ARRLINE(位列TS结高) = aLINE(位列TS结高)
        ARRLINE(位列TS结低) = aLINE(位列TS结低)
        ARRLINE(位列TS结收) = aLINE(位列TS结收)
        UTL数据转换_组转串4CSV = Join(ARRLINE, ",")
        Erase ARRLINE
        '--------------------------------------------------------------------------------
End Function

