Attribute VB_Name = "WMR现市_F2美股"
'========================================================================================
'========================================================================================
'调用：美股
'========================================================================================
'========================================================================================
Function 现市基程_市场美国( _
          MS As Worksheet _
        , Optional 是否排序 As XlSortOrder = xlDescending _
        , Optional 始行 As Integer = 3 _
        , Optional 始列 As Integer = 1 _
        ) As Boolean
'========================================================================================
'页面格式设置
'========================================================================================
    MS.Cells.Font.Size = 10
    MS.Columns.ColumnWidth = 2
    '------------------------------------------------------------------------------------
    MS.Cells(始行, 始行 + 1) = "芥蓝"
    MS.Columns(始行 + 1).ColumnWidth = 13
    MS.Columns(始行 + 2).ColumnWidth = 6
    MS.Columns(始行 + 3).ColumnWidth = 5
    MS.Columns(始行 + 3).Hidden = True
    '------------------------------------------------------------------------------------
    始列 = 始行 + 5
'========================================================================================
'按分类：跨市场品类
'========================================================================================
    Call 现市特程_US_行业(MS, 始行, 始列, True)
'========================================================================================
'ETF类
'========================================================================================
    始列 = 现市分程US_ETF类群(MS, PBASE格程工具_表参末行指定(MS, 始列) + 5, 始列)
'========================================================================================
'分类展示
'========================================================================================
    '始列 = 现市分程US_道琼斯板块(MS, 始行, 始列 + 3, 是否排序)
    '------------------------------------------------------------------------------------
    始列 = 现市分程US_成分_中概股系列(MS, 始行, 始列 + 2, 是否排序)
    '------------------------------------------------------------------------------------
    始列 = 现市分程US_成分_美行业板块(MS, 始行, 始列 + 1, 是否排序)
'========================================================================================
'页面格式设置
'========================================================================================
    With MS.Rows(始行)
        .Font.Bold = True
        .HorizontalAlignment = xlLeft
        .Borders(xlEdgeBottom).Weight = xlThin
    End With
    '------------------------------------------------------------------------------------
    MS.Activate
    Call PBASE格程工具_表冻结锁定(MS, 始行)
'========================================================================================
End Function






