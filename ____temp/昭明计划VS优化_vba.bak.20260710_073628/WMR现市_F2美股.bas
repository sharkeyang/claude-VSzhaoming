    目行 = 查程同市码组(码市, 码指, 码组, MS, 目行, 目列, 是否排序, 是否返列:=False)
    Erase 码组
'========================================================================================
    现市分程US_ETF类群 = 目列 + 4
    '------------------------------------------------------------------------------------
    MS.Columns(始列).Columns(位简式名称).ColumnWidth = 50
    MS.Columns(始列).Columns(位简式名称).HorizontalAlignment = xlRight
    MS.Columns(始列).Columns(位简式涨幅).ColumnWidth = 6
End Function





